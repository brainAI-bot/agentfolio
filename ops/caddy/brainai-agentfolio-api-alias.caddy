# Include inside the brainai.bot server block.
# Routes brainai.bot/agentfolio/api/* to the AgentFolio API while removing
# browser/session credentials before the request reaches the upstream backend.
handle /agentfolio/api/* {
    uri strip_prefix /agentfolio
    reverse_proxy localhost:3333 {
        header_up -Authorization
        header_up -Cookie
        header_up X-AgentFolio-Alias-Proxy brainai.agentfolio-api
    }
}
