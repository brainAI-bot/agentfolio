// ============ FEATURE: Real-time Solana Chain Sync ============
// Periodically checks the SATP identity registry program for new registrations
const IDENTITY_REGISTRY_PROGRAM = 'BY4jzmnrui1K5gZ5z5xRQkVfEEMXYHYugtH1Ua867eyr';
const CHAIN_SYNC_INTERVAL = 5 * 60 * 1000; // 5 minutes

async function syncChainIdentities() {
  try {
    const { Connection, PublicKey } = require('@solana/web3.js');
    const rpcUrl = process.env.SOLANA_RPC || 'https://api.mainnet-beta.solana.com';
    const connection = new Connection(rpcUrl, 'confirmed');
    const programPk = new PublicKey(IDENTITY_REGISTRY_PROGRAM);
    
    const accounts = await connection.getProgramAccounts(programPk, {
      dataSlice: { offset: 0, length: 0 }, // just get pubkeys first
    });
    
    logger.info(`[ChainSync] Found ${accounts.length} on-chain identity accounts`);
    
    // For each account, fetch data and check if we have a matching profile
    for (const { pubkey, account } of accounts) {
      try {
        const fullAccount = await connection.getAccountInfo(pubkey);
        if (!fullAccount || !fullAccount.data || fullAccount.data.length < 40) continue;
        
        // Extract owner wallet from account data (first 32 bytes after 8-byte discriminator)
        const ownerBytes = fullAccount.data.slice(8, 40);
        const ownerPk = new PublicKey(ownerBytes);
        const ownerAddress = ownerPk.toBase58();
        
        // Check if profile exists for this wallet
        const existing = loadProfileByWallet(ownerAddress);
        if (existing) {
          // Update SATP verification status if not already set
          if (!existing.verificationData) existing.verificationData = {};
          if (!existing.verificationData.satp || !existing.verificationData.satp.verified) {
            existing.verificationData.satp = {
              did: `did:satp:sol:${ownerAddress}`,
              verified: true,
              onChainAccount: pubkey.toBase58(),
              syncedAt: new Date().toISOString()
            };
            existing.updatedAt = new Date().toISOString();
            dbSaveProfileFn(existing);
            logger.info(`[ChainSync] Updated SATP verification for ${existing.id} (${ownerAddress})`);
          }
        }
      } catch (e) {
        // Skip individual account errors
      }
    }
  } catch (err) {
    logger.warn(`[ChainSync] Sync error: ${err.message}`);
  }
}

// Run on startup (delayed 60s) and every 5 minutes
setTimeout(syncChainIdentities, 60 * 1000);
setInterval(syncChainIdentities, CHAIN_SYNC_INTERVAL);

const DATA_DIR = __dirname + '/../data/profiles';

// Helper: Add activity and broadcast via WebSocket
function addActivityAndBroadcast(profileId, type, data, dataDir) {
  const activity = addActivity(profileId, type, data, dataDir);
  if (activity) {
    broadcastActivity({
      profileId,
      type,
      data,
      timestamp: activity.timestamp || Date.now()
    });
  }
  return activity;
}

// Profile creation
function createProfile(data, dataDir) {
  if (!data.name || !data.handle) {
    return { error: 'Name and handle are required' };
  }
  
  // SECURITY: Sanitize all user inputs before storage
  const sanitized = sanitizeProfileData(data);
  const safeName = sanitized.name || data.name.replace(/[^a-zA-Z0-9\s\-_]/g, '').slice(0, 100);
  
  const id = 'agent_' + safeName.toLowerCase().replace(/[^a-z0-9]/g, '');
  const filePath = path.join(dataDir, `${id}.json`);
  
  // Check DB first (primary), fall back to filesystem
  if (loadProfile(id) || fs.existsSync(filePath)) {
    return { error: 'Profile already exists with this name' };
  }
  
  // Check for suspicious XSS patterns in input
  if (hasSuspiciousPatterns(data.name) || hasSuspiciousPatterns(data.bio)) {
    logger.warn('Suspicious input detected in profile creation', { profileId: id, category: 'security' });
  }
  
  const profile = {
    id,
    name: safeName,
    handle: sanitized.handle || data.handle,
    bio: sanitized.bio !== undefined ? sanitized.bio : (data.bio || ''),
    avatar: sanitized.avatar !== undefined ? sanitized.avatar : (sanitizeUrl(data.avatar) || null),
    links: {
      moltbook: sanitized.links?.moltbook || data.moltbook || null,
      x: sanitized.links?.x || data.x || null,
      github: sanitized.links?.github || data.github || null,
      website: sanitized.links?.website || sanitizeUrl(data.website) || null,
      agentmail: sanitized.links?.agentmail || data.agentmail || null
    },
    wallets: {
      hyperliquid: sanitized.wallets?.hyperliquid || data.hyperliquid || null,
      solana: sanitized.wallets?.solana || data.solana || null,
      ethereum: sanitized.wallets?.ethereum || data.ethereum || null
    },
    skills: sanitized.skills || (data.skills || []).map(s => ({
      name: sanitizeText(s.name || s, { maxLength: 100, allowNewlines: false }),
      category: s.category || 'Other',
      verified: false,
      proofs: []
    })),
    portfolio: [],
    verification: {
      tier: 'unverified',
      score: 0,
      lastVerified: null
    },
    createdAt: new Date().toISOString()
  };
  
  // Save to SQLite database (primary storage)
  dbSaveProfileFn(profile);
  logger.info('Profile created', { profileId: profile.id, name: profile.name, storage: 'sqlite' });
  
  // Write JSON backup
  try {
    fs.writeFileSync(filePath, JSON.stringify(profile, null, 2));
  } catch (e) {
    logger.warn('Failed to write JSON backup', { profileId: profile.id, error: e.message });
  }
  
  // Log activity
  addActivityAndBroadcast(profile.id, ACTIVITY_TYPES.PROFILE_CREATED, {}, dataDir);
  
  // Auto-announce new registration on X
  if (isAnnouncementsEnabled()) {
    announceNewAgent(profile).catch(e => logger.error('X announce failed', { profileId: profile.id, error: e.message }));
  }
  
  // Trigger webhooks for new registration
  triggerWebhooks(WEBHOOK_EVENTS.AGENT_REGISTERED, {
    agentId: profile.id,
    name: profile.name,
    handle: profile.handle,
    bio: profile.bio,
    skills: profile.skills.map(s => s.name),
    profileUrl: `https://agentfolio.bot/profile/${profile.id}`
  }).catch(e => logger.error('Webhook trigger failed', { event: 'AGENT_REGISTERED', profileId: profile.id, error: e.message }));
  
  // Check and unlock achievements for new profile
  try {
    const newAchievements = checkAchievements(profile.id, profile);
    if (newAchievements.length > 0) {
      logger.info('Achievements unlocked', { profileId: profile.id, count: newAchievements.length, achievements: newAchievements.map(a => a.name) });
    }
  } catch (e) {
    logger.error('Achievement check failed', { profileId: profile.id, error: e.message });
  }
  
  // Send welcome onboarding email (async, don't block registration)
  sendWelcomeEmail(profile).catch(e => {
    logger.warn('Welcome email failed', { profileId: profile.id, error: e.message });
  });
  
  return profile;
}

const COMMON_STYLES = `
  <link rel="stylesheet" href="/public/css/main.css">
  <style>
    :root {
      --bg-secondary: #0f0f12;
      --bg-tertiary: #1c1c20;
    }
  </style>
`;

const THEME_SCRIPT = `
  <script>
    function toggleTheme() {
      const html = document.documentElement;
      const current = html.getAttribute('data-theme');
      const next = current === 'light' ? 'dark' : 'light';
      html.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      updateToggleIcon();
    }
    
    function updateToggleIcon() {
      const btn = document.querySelector('.theme-toggle');
      if (btn) {
        const theme = document.documentElement.getAttribute('data-theme');
        btn.textContent = theme === 'light' ? '☀️' : '🌙';
      }
    }
    
    // Apply saved theme on load
    (function() {
      const saved = localStorage.getItem('theme');
      if (saved) {
        document.documentElement.setAttribute('data-theme', saved);
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', updateToggleIcon);
      } else {
        updateToggleIcon();
      }
    })();
  </script>
`;

// Nav with theme toggle
