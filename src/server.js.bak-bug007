    <a href="/marketplace/post">Post a Job</a>
    <span style="color:#71717a;font-size:11px;text-transform:uppercase;letter-spacing:1px;margin-top:12px;">Resources</span>
    <a href="/getting-started">Getting Started</a>
    <a href="/integrations">Integrations</a>
