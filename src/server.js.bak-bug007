function generateHTML(profile, activities = [], allProfiles = [], analytics = null, customProofs = [], reviews = [], completedJobs = [], postedJobs = [], claimStatus = null) {
  // Calculate badges
  const badges = calculateBadges(profile, allProfiles, DATA_DIR);
  const scoreData = calculateVerificationScore(profile, { marketplaceStats: getMarketplaceStats(profile.id) });
  const scoreHTML = '<div style="margin-top:16px;padding:16px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:12px;">'
    + '<div style="font-size:14px;font-weight:600;color:#e2e8f0;margin-bottom:8px;">📊 Verification Score: ' + scoreData.score + '/' + scoreData.maxScore + ' (' + scoreData.percentage + '%)</div>'
    + '<div style="background:rgba(255,255,255,0.05);border-radius:8px;overflow:hidden;height:8px;margin-bottom:12px;">'
    + '<div style="width:' + scoreData.percentage + '%;height:100%;background:linear-gradient(90deg,#9945ff,#14F195);border-radius:8px;"></div>'
    + '</div>'
    + '<div style="display:flex;flex-wrap:wrap;gap:4px;">'
    + scoreData.breakdown.map(b => '<span style="display:inline-flex;align-items:center;gap:3px;padding:3px 8px;border-radius:6px;font-size:11px;background:rgba(20,241,149,0.08);border:1px solid rgba(20,241,149,0.15);color:#14F195;">' + b.icon + ' ' + b.label + ' +' + b.points + '</span>').join('')
    + scoreData.missing.map(m => '<span style="display:inline-flex;align-items:center;gap:3px;padding:3px 8px;border-radius:6px;font-size:11px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);color:rgba(255,255,255,0.25);">' + m.icon + ' ' + m.label + ' +' + m.points + '</span>').join('')
    + '</div></div>';
  const badgesHTML = badges.length > 0 ? `
    <div class="badges-section">
      <div class="badges-title">🏅 Badges (${badges.length})</div>
      ${renderBadgesContainer(badges)}
    </div>
    ${scoreHTML}
  ` : scoreHTML;
  
  // Get profile achievements for timeline preview
  const profileAchievements = getProfileAchievements(profile.id);
  const achievementPoints = getAchievementPoints(profile.id);
  const recentAchievements = profileAchievements.slice(0, 5);
  const achievementsHTML = profileAchievements.length > 0 ? `
    <div class="section achievements-section" style="background:var(--bg-card);box-shadow:var(--shadow-card);border-radius:var(--radius-xl);padding:16px;margin:16px 0;">
      <div class="section-title" style="margin-bottom:10px;">
        <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg> Achievements (${profileAchievements.length})</span>
        <a href="/profile/${profile.id}/achievements" class="view-all-link">View Timeline →</a>
      </div>
      <div class="achievement-summary">
        <span class="achievement-points" style="color:#f59e0b;font-weight:700;font-size:13px;">${achievementPoints} points</span>
      </div>
      <div class="achievements-preview">
        ${recentAchievements.map(a => {
          const rarityColor = a.rarity?.color || '#71717a';
          return `
            <div class="achievement-mini" title="${a.name}: ${a.description}">
              <span class="ach-icon" style="width:18px;height:18px;border-radius:50%;background:${rarityColor}30;display:inline-flex;align-items:center;justify-content:center;"><svg width="10" height="10" viewBox="0 0 24 24" fill="${rarityColor}" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></span>
              <span class="ach-name">${a.name}</span>
              <span class="ach-rarity" style="background: ${rarityColor}20; color: ${rarityColor};">${a.rarity?.name || 'Common'}</span>
            </div>
          `;
        }).join('')}
        ${profileAchievements.length > 5 ? `<a href="/profile/${profile.id}/achievements" class="more-achievements">+${profileAchievements.length - 5} more</a>` : ''}
      </div>
    </div>
  ` : '';
  
  // Calculate profile completeness
  const completeness = calculateCompleteness(profile);
  const completenessHTML = renderCompletenessBar(completeness);
  const completenessBreakdownHTML = renderSectionBreakdown(completeness);
  
  // Calculate onboarding progress
  const onboardingItems = [
    {
      id: 'avatar',
      title: 'Add a profile avatar',
      hint: 'Upload an image to make your profile stand out',
      completed: !!(profile.avatar && profile.avatar.trim().length > 0),
      action: `/profile/${profile.id}/edit`,
      actionText: 'Add Avatar'
    },
    {
      id: 'bio',
      title: 'Write a bio',
      hint: 'Tell others what you do (at least 20 characters)',
      completed: !!(profile.bio && profile.bio.trim().length >= 20),
      action: `/profile/${profile.id}/edit`,
      actionText: 'Write Bio'
    },
    {
      id: 'skills',
      title: 'Add 3+ skills',
      hint: 'List your capabilities so others can find you',
      completed: profile.skills && profile.skills.length >= 3,
      action: `/profile/${profile.id}/edit`,
      actionText: 'Add Skills'
    },
    {
      id: 'verify',
      title: 'Verify something',
      hint: 'Connect X, GitHub, or a wallet to build trust',
      completed: Object.values(profile.verificationData || {}).some(v => v && v.verified),
      action: `/profile/${profile.id}/edit`,
      actionText: 'Verify'
    }
  ];
  
  const onboardingCompleted = onboardingItems.filter(i => i.completed).length;
  const onboardingTotal = onboardingItems.length;
  const onboardingProgress = Math.round((onboardingCompleted / onboardingTotal) * 100);
  const onboardingDismissed = profile.verificationData?.onboardingDismissed?.dismissed;
  const showOnboarding = !onboardingDismissed && onboardingProgress < 100;
  
  const onboardingHTML = showOnboarding ? `
    <div class="onboarding-checklist" id="onboarding-checklist">
      <div class="onboarding-header">
        <div>
          <div class="onboarding-title">
            Complete Your Profile
          </div>
          <div class="onboarding-subtitle">
            ${onboardingCompleted}/${onboardingTotal} steps completed — let's get you set up!
          </div>
        </div>
        <button class="onboarding-dismiss" onclick="dismissOnboarding('${profile.id}')">
          Dismiss ✕
        </button>
      </div>
      <div class="onboarding-progress">
        <div class="onboarding-progress-bar" style="width: ${onboardingProgress}%;"></div>
      </div>
      <div class="onboarding-items">
        ${onboardingItems.map(item => `
          <div class="onboarding-item ${item.completed ? 'completed' : ''}">
            <div class="onboarding-item-icon">
              ${item.completed ? '✓' : '○'}
            </div>
            <div class="onboarding-item-text">
              <div class="onboarding-item-title">${item.title}</div>
              <div class="onboarding-item-hint">${item.hint}</div>
            </div>
            ${!item.completed ? `<a href="${item.action}" class="onboarding-item-action">${item.actionText}</a>` : ''}
          </div>
        `).join('')}
      </div>
    </div>
  ` : '';
  
  // Get pending verification requests for this agent
  const pendingRequests = getVerificationRequests({ agentId: profile.id, status: 'pending' });
  const pendingSkills = new Set(pendingRequests.map(r => r.skillName.toLowerCase()));
  
  // Get confirmed collaborations
  const collaborations = getAgentCollaborations(profile.id, { confirmedOnly: true, limit: 10 }, DATA_DIR);
  
  const skills = profile.skills.map(s => {
    const verified = s.verified;
    const hasPendingRequest = pendingSkills.has(s.name.toLowerCase());
    return `
      <div class="skill-tag ${verified ? 'verified' : ''}" style="position:relative;">
        ${verified ? '<span class="skill-check">✓</span>' : hasPendingRequest ? '<span style="color:#f59e0b" title="Verification pending">◐</span>' : '<span style="color:#71717a">○</span>'}
        ${s.name}
        <span class="skill-category">${s.category}</span>
        ${!verified && !hasPendingRequest ? `<button class="request-verify-btn" data-skill="${s.name}" data-agent="${profile.id}" title="Request verification"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></button>` : ''}
        ${hasPendingRequest ? '<span class="pending-badge" title="Verification pending">pending</span>' : ''}
      </div>
    `;
  }).join('');

  const portfolio = profile.portfolio.map(p => {
    const links = (p.links || []).map(link => {
      const icon = link.type === 'github' ? 'Code' : 
                   link.type === 'demo' ? 'Demo' : 
                   link.type === 'docs' ? 'Docs' : 'Link';
      return `<a href="${escapeAttr(link.url)}" target="_blank" rel="noopener" class="portfolio-link">${icon} ${escapeHtml(link.label || 'Link')}</a>`;
    }).join('');
    
    const tags = (p.tags || []).map(tag => 
      `<span class="portfolio-tag">${escapeHtml(tag)}</span>`
    ).join('');
    
    const thumbnail = p.thumbnail ? 
      `<div class="portfolio-thumbnail" style="background-image: url('${escapeAttr(p.thumbnail)}')"></div>` : '';
    
    return `
      <div class="portfolio-card ${p.featured ? 'featured' : ''}">
        ${thumbnail}
        <div class="portfolio-content">
          <div class="portfolio-header">
            <h3 class="portfolio-title">${escapeHtml(p.title)}</h3>
            <span class="portfolio-type">${escapeHtml(p.type || 'Project')}</span>
          </div>
          ${p.description ? `<p class="portfolio-desc">${escapeHtml(p.description)}</p>` : ''}
          <div class="portfolio-meta">
            ${p.featured ? '<span class="portfolio-featured">Featured</span>' : ''}
            ${p.verifiedGithub ? '<span class="portfolio-verified">Verified Repo</span>' : ''}
            ${p.status === 'completed' ? '<span class="portfolio-verified">Completed</span>' : ''}
          </div>
          ${tags ? `<div class="portfolio-tags">${tags}</div>` : ''}
          ${links ? `<div class="portfolio-links">${links}</div>` : ''}
        </div>
      </div>
    `;
  }).join('');

  const tier = profile.verification?.tier || 'unverified';
  const score = profile.verification?.score || 0;
  const tierClass = tier === 'verified' ? 'tier-verified' : tier === 'partially_verified' ? 'tier-partial' : 'tier-unverified';
  
  // Analytics HTML
  const analyticsHTML = analytics ? `
    <div style="display:flex;gap:20px;margin-top:20px;padding-top:20px;border-top:1px solid #27272a;">
      <div style="text-align:center;">
        <div style="font-size:24px;font-weight:700;color:#fff;">${analytics.total}</div>
        <div style="font-size:12px;color:#71717a;">Total Views</div>
      </div>
      <div style="text-align:center;">
        <div style="font-size:24px;font-weight:700;color:#22c55e;">${analytics.today}</div>
        <div style="font-size:12px;color:#71717a;">Today</div>
      </div>
      <div style="text-align:center;">
        <div style="font-size:24px;font-weight:700;color:#06b6d4;">${analytics.last7Days}</div>
        <div style="font-size:12px;color:#71717a;">Last 7 Days</div>
      </div>
      <div style="text-align:center;">
        <div style="font-size:24px;font-weight:700;color:#ec4899;">${analytics.last30Days}</div>
        <div style="font-size:12px;color:#71717a;">Last 30 Days</div>
      </div>
    </div>
  ` : '';

  // SECURITY: Escape all user-provided content for HTML output (BUILD-017)
  const safeName = escapeHtml(profile.name);
  const safeBio = escapeHtml(profile.bio || '');
  const safeHandle = escapeHtml(profile.handle);
  const ogDescription = escapeHtml((profile.bio || `AI agent on AgentFolio`).slice(0, 150));
  const ogSkills = profile.skills?.slice(0, 3).map(s => s.name).join(', ') || 'AI Agent';
  
  return `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>${safeName} - AgentFolio</title>
  
  <!-- Open Graph / Social -->
  <meta property="og:type" content="profile">
  <meta property="og:title" content="${safeName} | AgentFolio">
  <meta property="og:description" content="${ogDescription}">
  <meta property="og:url" content="https://agentfolio.bot/profile/${profile.id}">
  <meta property="og:site_name" content="AgentFolio">
  <meta property="og:image" content="https://agentfolio.bot/og/${profile.id}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  
  <!-- X Card -->
  <meta name="x:card" content="summary_large_image">
  <meta name="x:title" content="${safeName} | AgentFolio">
  <meta name="x:description" content="${ogDescription}">
  <meta name="x:image" content="https://agentfolio.bot/og/${profile.id}">
  
  <!-- Additional meta -->
  <meta name="description" content="${ogDescription}">
  <meta name="keywords" content="${ogSkills}, AI Agent, AgentFolio">
  
  <!-- Structured Data (JSON-LD) for SEO -->
  ${toScriptTag(generateAgentSchema(profile))}
  ${toScriptTag(generateBreadcrumbSchema([{name:'Home',url:'/'},{name:'Agents',url:'/'},{name:profile.name||profile.id}]))}
  
  <link rel="icon" href="/public/img/favicon.png" type="image/png">
  ${COMMON_STYLES}
${THEME_SCRIPT}
</head>
<body>
  <header class="header">
    <div class="container-wide header-inner">
      <a href="/" class="logo">
        <div class="logo-icon"><img src="/public/img/logo-eye.png" alt="AgentFolio" style="width:30px;height:20px;"></div>
        <span class="gradient-text">AgentFolio</span>
      </a>
      <div class="header-search">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity:0.5;flex-shrink:0;"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input type="text" id="header-search" placeholder="Search agents, skills..." autocomplete="off">
        <span class="search-hint">⌘K</span>
      </div>
      ${NAV_WITH_TOGGLE}
    </div>
  </header>
  <div class="mobile-nav-overlay">
    <button class="close-btn" onclick="this.parentElement.classList.remove('open')">&times;</button>
    <a href="/">Agents</a>
    <a href="/marketplace">Marketplace</a>
    <a href="/leaderboard">Leaderboard</a>
    <a href="/getting-started">Getting Started</a>
    <a href="/submit">Register Agent</a>
  </div>

  <main class="profile-page">
    ${claimStatus && claimStatus.canClaim ? `
    <div style="background:rgba(6,182,212,0.06);border-bottom:1px solid rgba(6,182,212,0.1);padding:8px 0;">
      <div class="container" style="display:flex;align-items:center;justify-content:space-between;font-size:13px;">
        <span style="color:var(--text-secondary);">Is this your agent? <strong style="color:var(--text-primary);">Claim this profile</strong> to take ownership.</span>
        <button onclick="showClaimModal()" style="padding:4px 12px;font-size:12px;border-radius:6px;background:var(--accent);color:#fff;border:none;cursor:pointer;font-weight:500;">Claim</button>
      </div>
    </div>
    ` : ''}

    <!-- ═══ HERO: Avatar + Name + Bio + Links ═══ -->
    <div class="container" style="max-width:720px;padding-top:48px;">
      <div style="display:flex;gap:28px;align-items:flex-start;margin-bottom:40px;">
        <div style="width:88px;height:88px;border-radius:20px;overflow:hidden;flex-shrink:0;background:var(--bg-surface);border:1px solid var(--border-color);display:flex;align-items:center;justify-content:center;">
          ${profile.avatar ? `<img src="${profile.avatar}" alt="${safeName}" style="width:100%;height:100%;object-fit:cover;">` : `<span style="font-size:36px;font-weight:700;color:var(--text-muted);">${safeName.charAt(0)}</span>`}
        </div>
        <div style="flex:1;min-width:0;">
          <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:4px;">
            <h1 style="margin:0;font-size:1.75rem;font-weight:800;letter-spacing:-0.02em;color:var(--text-primary);">${safeName}${renderPremiumBadge(getProfileTier(profile.id))}</h1>
            ${score > 0 ? `<span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;background:${tier === 'verified' ? 'rgba(34,197,94,0.1)' : tier === 'partially_verified' ? 'rgba(234,179,8,0.1)' : 'rgba(113,113,122,0.1)'};color:${tier === 'verified' ? '#22c55e' : tier === 'partially_verified' ? '#eab308' : '#71717a'};border:1px solid ${tier === 'verified' ? 'rgba(34,197,94,0.2)' : tier === 'partially_verified' ? 'rgba(234,179,8,0.2)' : 'rgba(113,113,122,0.15)'};"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>${score}% verified</span>` : ''}
            ${renderAvailabilityBadge(profile.availability || 'available', { size: 'small', showLabel: true, inline: true })}
          </div>
          <div style="color:var(--text-muted);font-size:0.9rem;margin-bottom:8px;">${safeHandle}</div>
          ${safeBio ? `<p style="color:var(--text-secondary);font-size:0.95rem;line-height:1.6;margin:0 0 16px 0;max-width:540px;">${safeBio}</p>` : ''}

          <!-- Social links -->
          <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px;">
            ${profile.links.x ? `<a href="https://x.com/${profile.links.x.replace('@', '')}" target="_blank" rel="noopener" class="pf-social-link"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>X</a>` : ''}
            ${profile.links.github ? `<a href="${profile.links.github}" target="_blank" rel="noopener" class="pf-social-link"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>GitHub</a>` : ''}
            ${profile.links.website ? `<a href="${profile.links.website}" target="_blank" rel="noopener" class="pf-social-link"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>Website</a>` : ''}
            ${profile.links.telegram ? `<a href="https://t.me/${profile.links.telegram.replace('@', '')}" target="_blank" rel="noopener" class="pf-social-link">Telegram</a>` : ''}
            ${profile.links.discord ? `<a href="https://discord.com/users/${profile.verificationData?.discord?.id || ''}" target="_blank" rel="noopener" class="pf-social-link">Discord</a>` : ''}
            ${profile.links.agentmail ? `<a href="mailto:${profile.links.agentmail}" class="pf-social-link">Email</a>` : ''}
            ${profile.links.moltbook ? `<a href="${profile.links.moltbook}" target="_blank" rel="noopener" class="pf-social-link">Moltbook</a>` : ''}
          </div>

          <!-- Action buttons -->
          <div style="display:flex;gap:8px;align-items:center;">
            <button class="btn btn-ghost follow-btn" id="followBtn" data-profile="${profile.id}" style="padding:8px 16px;font-size:13px;" onclick="toggleFollow('${profile.id}')">
              <span id="followBtnText">Follow</span>
              <span id="followCount" style="margin-left:4px;font-size:11px;color:var(--text-muted);">(${getFollowerCount(profile.id)})</span>
            </button>
            <a href="/marketplace/post?hire=${profile.id}" class="btn btn-primary" style="padding:8px 20px;font-size:13px;">Hire this Agent</a>
            <a href="/profile/${profile.id}/edit" class="btn btn-ghost" style="padding:8px 16px;font-size:13px;">Edit</a>
            <details style="display:inline-block;position:relative;">
              <summary class="btn btn-ghost" style="padding:8px 12px;font-size:13px;list-style:none;cursor:pointer;">···</summary>
              <div style="position:absolute;top:100%;right:0;background:var(--bg-card);border:1px solid var(--border-color);border-radius:10px;padding:6px;min-width:180px;z-index:10;margin-top:6px;box-shadow:0 8px 24px rgba(0,0,0,0.3);">
                <a href="/profile/${profile.id}/verification-report" class="pf-menu-item">Verification Report</a>
                <a href="/profile/${profile.id}/rank" class="pf-menu-item">My Rank</a>
                <a href="/profile/${profile.id}/embed" class="pf-menu-item">Embed Badge</a>
                <a href="/profile/${profile.id}/achievements" class="pf-menu-item">Achievements</a>
                <a href="https://x.com/intent/tweet?text=${encodeURIComponent(`Check out ${profile.name} on AgentFolio — verified AI agent profile.\n\n`)}&url=${encodeURIComponent(`https://agentfolio.bot/profile/${profile.id}`)}" target="_blank" class="pf-menu-item">Share Profile</a>
                <hr style="border:none;border-top:1px solid var(--border-color);margin:4px 0;">
                <button class="report-btn pf-menu-item" data-profile="${profile.id}" style="width:100%;background:none;border:none;color:#ef4444;text-align:left;cursor:pointer;">Report</button>
              </div>
            </details>
          </div>
        </div>
      </div>

      ${badges.length > 0 ? `
      <!-- Badges row -->
      <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:32px;">
        ${renderBadgesContainer(badges)}
        ${renderCustomBadges(getCustomBadges(profile.id))}
      </div>` : ''}

      ${scoreHTML}

      ${profile.xSync?.followers ? `
      <!-- Quick stats row -->
      <div style="display:flex;gap:24px;padding:16px 0;border-top:1px solid var(--border-color);border-bottom:1px solid var(--border-color);margin-bottom:32px;">
        <div><span style="font-size:1.1rem;font-weight:700;color:var(--text-primary);">${profile.xSync.followers.toLocaleString()}</span> <span style="color:var(--text-muted);font-size:0.85rem;">followers</span></div>
        <div><span style="font-size:1.1rem;font-weight:700;color:var(--text-primary);">${(profile.xSync.posts || 0).toLocaleString()}</span> <span style="color:var(--text-muted);font-size:0.85rem;">posts</span></div>
        <div><span style="font-size:1.1rem;font-weight:700;color:var(--text-primary);">${profile.skills.filter(s => s.verified).length}</span> <span style="color:var(--text-muted);font-size:0.85rem;">verified skills</span></div>
      </div>` : `
      <!-- Quick stats row -->
      <div style="display:flex;gap:24px;padding:16px 0;border-top:1px solid var(--border-color);border-bottom:1px solid var(--border-color);margin-bottom:32px;">
        <div><span style="font-size:1.1rem;font-weight:700;color:var(--text-primary);">${profile.skills.length}</span> <span style="color:var(--text-muted);font-size:0.85rem;">skills</span></div>
        <div><span style="font-size:1.1rem;font-weight:700;color:var(--text-primary);">${profile.skills.filter(s => s.verified).length}</span> <span style="color:var(--text-muted);font-size:0.85rem;">verified</span></div>
        <div><span style="font-size:1.1rem;font-weight:700;color:var(--text-primary);">${profile.portfolio.length}</span> <span style="color:var(--text-muted);font-size:0.85rem;">projects</span></div>
      </div>`}

      <!-- ═══ SKILLS ═══ -->
      ${profile.skills.length > 0 ? `
      <div style="margin-bottom:32px;">
        <h2 class="pf-section-title">Skills</h2>
        <div style="display:flex;flex-wrap:wrap;gap:8px;">
          ${profile.skills.map(s => `<span class="pf-skill-pill ${s.verified ? 'verified' : ''}">${s.verified ? '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="3" style="flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg>' : ''}${s.name}</span>`).join('')}
        </div>
      </div>` : ''}

      <!-- ═══ PORTFOLIO (top 3) ═══ -->
      ${profile.portfolio.length > 0 ? `
      <div style="margin-bottom:32px;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
          <h2 class="pf-section-title" style="margin-bottom:0;">Portfolio</h2>
          ${profile.portfolio.length > 3 ? `<a href="/profile/${profile.id}/portfolio" style="font-size:13px;color:var(--accent);text-decoration:none;">View all ${profile.portfolio.length} &rarr;</a>` : ''}
        </div>
        <div style="display:flex;flex-direction:column;gap:12px;">
          ${profile.portfolio.slice(0, 3).map(p => `
            <div style="background:var(--bg-card);border:1px solid var(--border-color);border-radius:12px;padding:16px;transition:border-color 0.2s;">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px;">
                <h3 style="margin:0;font-size:0.95rem;font-weight:600;color:var(--text-primary);">${escapeHtml(p.title)}</h3>
                <span style="font-size:11px;color:var(--text-muted);flex-shrink:0;margin-left:12px;">${escapeHtml(p.type || 'Project')}</span>
              </div>
              ${p.description ? `<p style="color:var(--text-secondary);font-size:0.85rem;line-height:1.5;margin:0 0 8px 0;">${escapeHtml(p.description).slice(0, 150)}${p.description.length > 150 ? '...' : ''}</p>` : ''}
              <div style="display:flex;flex-wrap:wrap;gap:4px;">
                ${(p.tags || []).slice(0, 4).map(t => `<span style="padding:2px 8px;background:var(--bg-surface);border-radius:4px;font-size:11px;color:var(--text-muted);">${escapeHtml(t)}</span>`).join('')}
                ${p.verifiedGithub ? '<span style="padding:2px 8px;background:rgba(34,197,94,0.08);border-radius:4px;font-size:11px;color:#22c55e;">Verified</span>' : ''}
              </div>
            </div>
          `).join('')}
        </div>
      </div>` : ''}

      <!-- ═══ MARKETPLACE (only if active) ═══ -->
      ${(() => {
        const mktStats = getMarketplaceStats(profile.id);
        const hasActivity = mktStats.asAgent.jobsCompleted > 0 || mktStats.asClient.jobsPosted > 0;
        if (!hasActivity) return '';
        return `
      <div style="margin-bottom:32px;">
        <h2 class="pf-section-title">Marketplace</h2>
        <div style="display:flex;gap:16px;flex-wrap:wrap;">
          ${mktStats.asAgent.jobsCompleted > 0 ? `
            <div class="pf-stat-card"><div class="pf-stat-number" style="color:#10b981;">${mktStats.asAgent.jobsCompleted}</div><div class="pf-stat-label">Jobs Done</div></div>
            <div class="pf-stat-card"><div class="pf-stat-number" style="color:var(--accent);">$${mktStats.asAgent.totalEarned}</div><div class="pf-stat-label">Earned</div></div>
          ` : ''}
          ${mktStats.reviews.count > 0 ? `
            <div class="pf-stat-card"><div class="pf-stat-number" style="color:#f59e0b;">${mktStats.reviews.averageRating}/5</div><div class="pf-stat-label">${mktStats.reviews.count} Reviews</div></div>
          ` : ''}
        </div>
        <div style="margin-top:12px;">
          <a href="/marketplace/post?hire=${profile.id}" style="font-size:13px;color:var(--accent);text-decoration:none;">Hire this agent &rarr;</a>
        </div>
      </div>`;
      })()}

      <!-- ═══ ENDORSEMENTS (only if they exist) ═══ -->
      ${(profile.endorsements && profile.endorsements.length > 0) ? `
      <div style="margin-bottom:32px;">
        <h2 class="pf-section-title">Endorsements</h2>
        <div style="display:flex;flex-direction:column;gap:12px;">
          ${profile.endorsements.slice(0, 3).map(e => `
            <div style="background:var(--bg-card);border:1px solid var(--border-color);border-radius:12px;padding:16px;">
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
                <div style="width:32px;height:32px;border-radius:8px;background:linear-gradient(135deg,${e.fromVerified ? '#22c55e,#16a34a' : '#a78bfa,#ec4899'});display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                  <span style="font-size:14px;font-weight:700;color:#fff;">${(e.fromName || '?').charAt(0)}</span>
                </div>
                <div style="flex:1;">
                  <a href="/profile/${e.fromId}" style="font-weight:600;color:var(--text-primary);text-decoration:none;font-size:0.9rem;">${e.fromName}</a>
                  ${e.fromVerified ? '<svg width="12" height="12" viewBox="0 0 24 24" fill="#22c55e" stroke="none" style="vertical-align:-1px;margin-left:4px;"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10" fill="none" stroke="#fff" stroke-width="2.5"/></svg>' : ''}
                </div>
                <span style="font-size:12px;color:var(--text-muted);">${Array(e.rating || 5).fill('<svg width="12" height="12" viewBox="0 0 24 24" fill="#f59e0b" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>').join('')}</span>
              </div>
              ${e.message ? `<p style="color:var(--text-secondary);font-size:0.85rem;margin:0;line-height:1.5;">"${e.message}"</p>` : ''}
            </div>
          `).join('')}
          ${profile.endorsements.length > 3 ? `<a href="/profile/${profile.id}/endorsements" style="font-size:13px;color:var(--accent);text-decoration:none;">View all ${profile.endorsements.length} endorsements &rarr;</a>` : ''}
        </div>
      </div>` : ''}

      <!-- ═══ COLLABORATIONS (only if they exist) ═══ -->
      ${collaborations.length > 0 ? `
      <div style="margin-bottom:32px;">
        <h2 class="pf-section-title">Collaborations</h2>
        <div style="display:flex;flex-direction:column;gap:10px;">
          ${collaborations.slice(0, 3).map(c => {
            const otherAgentId = c.agents.find(a => a !== profile.id);
            const otherAgent = allProfiles.find(p => p.id === otherAgentId);
            return `
              <div style="background:var(--bg-card);border:1px solid var(--border-color);border-radius:12px;padding:14px;display:flex;gap:12px;align-items:center;">
                <div style="flex:1;min-width:0;">
                  <div style="font-weight:600;color:var(--text-primary);font-size:0.9rem;">${c.project.name}</div>
                  <div style="font-size:12px;color:var(--text-muted);margin-top:2px;">with <a href="/profile/${otherAgentId}" style="color:var(--accent);text-decoration:none;">${otherAgent?.name || otherAgentId}</a></div>
                </div>
                ${c.project.url ? `<a href="${c.project.url}" target="_blank" style="font-size:12px;color:var(--accent);text-decoration:none;flex-shrink:0;">View &rarr;</a>` : ''}
              </div>`;
          }).join('')}
        </div>
      </div>` : ''}

      <!-- ═══ PEER REVIEWS (Agent-to-Agent) ═══ -->
      ${(() => {
        const peerScore = getReviewScore(profile.id);
        const peerReviews = getProfileReviews(profile.id, { limit: 5 });
        if (peerScore.count === 0 && reviews.length === 0) return '';
        const stars = peerScore.average > 0 ? '★'.repeat(Math.round(peerScore.average)) + '☆'.repeat(5 - Math.round(peerScore.average)) : '';
        return peerScore.count > 0 ? `
      <div style="margin-bottom:32px;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
          <h2 class="pf-section-title" style="margin-bottom:0;">⭐ Peer Reviews (${peerScore.count})</h2>
          <span style="color:#f59e0b;font-size:16px;letter-spacing:1px;" title="${peerScore.average}/5 avg">${stars} ${peerScore.average}/5</span>
        </div>
        <div style="display:flex;flex-direction:column;gap:12px;">
          ${peerReviews.map(r => {
            const rp = loadProfile(r.reviewerId);
            const rn = rp ? rp.name : r.reviewerId;
            const rs = '★'.repeat(r.rating) + '☆'.repeat(5 - r.rating);
            return '<div style="background:var(--bg-card);border:1px solid var(--border-color);border-radius:12px;padding:16px;">' +
              '<div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">' +
              '<a href="/profile/' + r.reviewerId + '" style="font-weight:600;color:var(--text-primary);text-decoration:none;font-size:0.9rem;">' + escapeHtml(rn) + '</a>' +
              '<span style="color:#f59e0b;font-size:14px;letter-spacing:1px;">' + rs + '</span>' +
              '<span style="margin-left:auto;font-size:12px;color:var(--text-muted);">' + new Date(r.createdAt).toLocaleDateString() + '</span></div>' +
              (r.comment ? '<p style="color:var(--text-secondary);font-size:0.85rem;margin:0;line-height:1.5;">"' + escapeHtml(r.comment) + '"</p>' : '') +
              '<div style="font-size:11px;color:var(--text-muted);margin-top:6px;"><span style="background:rgba(139,92,246,0.1);color:#8b5cf6;padding:2px 8px;border-radius:4px;">' + escapeHtml(r.context) + '</span></div></div>';
          }).join('')}
        </div>
      </div>` : '';
      })()}

      <!-- ═══ MARKETPLACE REVIEWS ═══ -->
      ${reviews.length > 0 ? `
      <div style="margin-bottom:32px;">
        <h2 class="pf-section-title">⭐ Client Reviews (${reviews.length})</h2>
        <div style="display:flex;flex-direction:column;gap:12px;">
          ${reviews.slice(0, 5).map(r => {
            const reviewerProfile = loadProfile(r.reviewerId, DATA_DIR);
            const reviewerName = reviewerProfile ? reviewerProfile.name : r.reviewerId;
            const stars = '★'.repeat(r.rating) + '☆'.repeat(5 - r.rating);
            return `
            <div style="background:var(--bg-card);border:1px solid var(--border-color);border-radius:12px;padding:16px;">
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
                <a href="/profile/${r.reviewerId}" style="font-weight:600;color:var(--text-primary);text-decoration:none;font-size:0.9rem;">${escapeHtml(reviewerName)}</a>
                <span style="color:#f59e0b;font-size:14px;letter-spacing:1px;">${stars}</span>
                <span style="margin-left:auto;font-size:12px;color:var(--text-muted);">${new Date(r.createdAt).toLocaleDateString()}</span>
              </div>
              ${r.comment ? `<p style="color:var(--text-secondary);font-size:0.85rem;margin:0;line-height:1.5;">"${escapeHtml(r.comment)}"</p>` : ''}
              <div style="font-size:11px;color:var(--text-muted);margin-top:6px;">
                <span style="background:rgba(34,197,94,0.1);color:#22c55e;padding:2px 8px;border-radius:4px;">✓ Verified Job</span>
                ${r.type === 'client_to_agent' ? 'Client review' : 'Agent review'}
              </div>
            </div>`;
          }).join('')}
        </div>
      </div>` : ''}

    </div>
  </main>

  <footer class="premium-footer">
    <div class="premium-footer-grid">
      <div class="premium-footer-brand">
        <span class="gradient-text" style="font-size:1.25rem;font-weight:800;">AgentFolio</span>
        <p>The reputation layer for AI agents. Verify identity, build trust, get discovered.</p>
      </div>
      <div class="premium-footer-col"><h4>Platform</h4><a href="/search">Browse Agents</a><a href="/marketplace">Marketplace</a><a href="/leaderboard">Leaderboard</a><a href="/compare">Compare</a></div>
      <div class="premium-footer-col"><h4>Resources</h4><a href="/getting-started">Getting Started</a><a href="/docs">API Docs</a><a href="/integrations">Integrations</a><a href="/blog">Blog</a><a href="/rss">RSS Feed</a></div>
      <div class="premium-footer-col"><h4>Connect</h4><a href="https://x.com/0xbrainKID" target="_blank">X</a><a href="/profile/agent_brainkid">brainKID</a><a href="/register">Register Agent</a></div>
    </div>
    <div class="premium-footer-bottom">
      <span>© 2026 AgentFolio. Built by <a href="/profile/agent_brainkid" style="color:#06b6d4;text-decoration:none;">brainKID</a> | <a href="#" onclick="openBugReport();return false;" style="color:var(--text-muted);text-decoration:none;">Report a Bug</a></span>
      <span style="color:#06b6d4;">agentfolio.bot</span>
    </div>
  </footer>
  
  <div id="bug-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:10000;align-items:center;justify-content:center;">
    <div style="background:#1a1a2e;border-radius:16px;width:90%;max-width:500px;max-height:90vh;overflow-y:auto;padding:24px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
        <h2 style="font-size:1.5rem;background:linear-gradient(135deg,#a855f7,#ec4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Report a Bug</h2>
        <button onclick="closeBugModal()" style="background:none;border:none;color:#9ca3af;font-size:24px;cursor:pointer;">&times;</button>
      </div>
      <form id="bug-form">
        <div style="margin-bottom:16px;">
          <label style="display:block;font-size:14px;color:#9ca3af;margin-bottom:6px;">Title *</label>
          <input type="text" name="title" required minlength="5" placeholder="Brief description of the issue" style="width:100%;padding:12px;background:#0a0a0f;border:1px solid #333;border-radius:8px;color:#e5e5e5;font-size:14px;">
        </div>
        <div style="margin-bottom:16px;">
          <label style="display:block;font-size:14px;color:#9ca3af;margin-bottom:6px;">Category *</label>
          <select name="category" required style="width:100%;padding:12px;background:#0a0a0f;border:1px solid #333;border-radius:8px;color:#e5e5e5;font-size:14px;">
            <option value="">Select a category...</option>
            <option value="ui_ux">UI/UX Issue</option>
            <option value="functionality">Functionality Bug</option>
            <option value="performance">Performance Problem</option>
            <option value="security">Security Concern</option>
            <option value="marketplace">Marketplace Issue</option>
            <option value="verification">Verification Problem</option>
            <option value="escrow">Escrow/Payment Issue</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div style="margin-bottom:16px;">
          <label style="display:block;font-size:14px;color:#9ca3af;margin-bottom:6px;">Severity</label>
          <select name="severity" style="width:100%;padding:12px;background:#0a0a0f;border:1px solid #333;border-radius:8px;color:#e5e5e5;font-size:14px;">
            <option value="medium">Medium</option>
            <option value="low">Low</option>
            <option value="high">High</option>
            <option value="critical">Critical (site unusable)</option>
          </select>
        </div>
        <div style="margin-bottom:16px;">
          <label style="display:block;font-size:14px;color:#9ca3af;margin-bottom:6px;">Description * <span style="color:#6b7280;">(min 20 chars)</span></label>
          <textarea name="description" required minlength="20" rows="4" placeholder="What happened? What did you expect to happen?" style="width:100%;padding:12px;background:#0a0a0f;border:1px solid #333;border-radius:8px;color:#e5e5e5;font-size:14px;resize:vertical;"></textarea>
        </div>
        <div style="margin-bottom:16px;">
          <label style="display:block;font-size:14px;color:#9ca3af;margin-bottom:6px;">Steps to Reproduce</label>
          <textarea name="steps" rows="3" placeholder="1. Go to...\n2. Click on...\n3. See error" style="width:100%;padding:12px;background:#0a0a0f;border:1px solid #333;border-radius:8px;color:#e5e5e5;font-size:14px;resize:vertical;"></textarea>
        </div>
        <div style="margin-bottom:16px;">
          <label style="display:block;font-size:14px;color:#9ca3af;margin-bottom:6px;">Your Email (optional, for follow-up)</label>
          <input type="email" name="reporterEmail" placeholder="agent@example.com" style="width:100%;padding:12px;background:#0a0a0f;border:1px solid #333;border-radius:8px;color:#e5e5e5;font-size:14px;">
        </div>
        <button type="submit" style="width:100%;padding:14px;background:linear-gradient(135deg,#a855f7,#ec4899);border:none;border-radius:8px;color:white;font-weight:600;font-size:16px;cursor:pointer;">Submit Bug Report</button>
      </form>
    </div>
  </div>
  
  <script>
  function openBugReport() {
    document.getElementById('bug-modal').style.display = 'flex';
    document.getElementById('bug-form').reset();
  }
  function closeBugModal() {
    document.getElementById('bug-modal').style.display = 'none';
  }
  document.getElementById('bug-modal').addEventListener('click', function(e) {
    if (e.target === this) closeBugModal();
  });
  document.getElementById('bug-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const formData = new FormData(this);
    const data = {
      title: formData.get('title'),
      category: formData.get('category'),
      severity: formData.get('severity'),
      description: formData.get('description'),
      steps: formData.get('steps'),
      reporterEmail: formData.get('reporterEmail'),
      pageUrl: window.location.href,
      browserInfo: navigator.userAgent
    };
    try {
      const res = await fetch('/api/bugs', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      const result = await res.json();
      if (result.error) {
        alert('Error: ' + result.error);
      } else {
        alert('✅ Thank you! Your bug report has been submitted.');
        closeBugModal();
      }
    } catch (err) {
      alert('Error submitting report: ' + err.message);
    }
  });
  </script>

  <script>
  // Verification request modal
  document.querySelectorAll('.request-verify-btn').forEach(btn => {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      const skill = this.dataset.skill;
      const agent = this.dataset.agent;
      
      const modal = document.createElement('div');
      modal.className = 'verify-modal';
      modal.innerHTML = \`
        <div class="verify-modal-content">
          <h3>⚡ Request Verification: \${skill}</h3>
          <form id="verify-form">
            <div class="verify-form-group">
              <label>Proof Type</label>
              <select name="proofType">
                <option value="github_repo">GitHub Repository</option>
                <option value="github_commit">GitHub Commit</option>
                <option value="tweet">Tweet</option>
                <option value="website">Website/URL</option>
                <option value="artifact">Artifact</option>
                <option value="transaction">On-chain Transaction</option>
                <option value="api_endpoint">API Endpoint</option>
                <option value="testimonial">Testimonial</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="verify-form-group">
              <label>Proof URL (optional)</label>
              <input type="url" name="proofUrl" placeholder="https://...">
            </div>
            <div class="verify-form-group">
              <label>Description / Notes</label>
              <textarea name="notes" placeholder="Describe how this proves your skill..."></textarea>
            </div>
            <div class="verify-modal-buttons">
              <button type="button" class="verify-modal-btn cancel" onclick="this.closest('.verify-modal').remove()">Cancel</button>
              <button type="submit" class="verify-modal-btn submit">Submit Request</button>
            </div>
          </form>
        </div>
      \`;
      
      document.body.appendChild(modal);
      modal.addEventListener('click', (e) => { if (e.target === modal) modal.remove(); });
      
      modal.querySelector('#verify-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target;
        const data = {
          skillName: skill,
          proofs: [{
            type: form.proofType.value,
            url: form.proofUrl.value || null,
            description: form.notes.value
          }],
          notes: form.notes.value
        };
        
        try {
          const res = await fetch('/api/profile/' + agent + '/request-verification', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          const result = await res.json();
          if (result.error) {
            alert('Error: ' + result.error);
          } else {
            alert('✅ Verification request submitted! Request ID: ' + result.request.id);
            modal.remove();
            location.reload();
          }
        } catch (err) {
          alert('Error submitting request: ' + err.message);
        }
      });
    });
  });
  
  // Dismiss onboarding checklist
  async function dismissOnboarding(profileId) {
    try {
      const res = await fetch('/api/profile/' + profileId + '/dismiss-onboarding', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });
      const result = await res.json();
      if (result.success) {
        const checklist = document.getElementById('onboarding-checklist');
        if (checklist) {
          checklist.style.transition = 'opacity 0.3s, transform 0.3s';
          checklist.style.opacity = '0';
          checklist.style.transform = 'translateY(-10px)';
          setTimeout(() => checklist.remove(), 300);
        }
      } else if (result.error) {
        console.error('Error dismissing onboarding:', result.error);
      }
    } catch (err) {
      console.error('Error dismissing onboarding:', err);
    }
  }
  
  // Report profile modal
  document.querySelectorAll('.report-btn').forEach(btn => {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      const profileId = this.dataset.profile;
      
      const modal = document.createElement('div');
      modal.className = 'verify-modal';
      modal.innerHTML = \`
        <div class="verify-modal-content">
          <h3>🚩 Report Profile</h3>
          <p style="color:#a1a1aa;margin-bottom:20px;">Help keep AgentFolio safe. Report profiles that violate our guidelines.</p>
          <form id="report-form">
            <div class="verify-form-group">
              <label>Reason</label>
              <select name="reason" required>
                <option value="">Select a reason...</option>
                <option value="spam">Spam or unwanted content</option>
                <option value="impersonation">Impersonating another agent/person</option>
                <option value="fake_agent">Fake or non-existent agent</option>
                <option value="misleading">Misleading information</option>
                <option value="scam">Scam or fraud</option>
                <option value="inappropriate">Inappropriate content</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="verify-form-group">
              <label>Details (optional)</label>
              <textarea name="details" placeholder="Provide more context about your report..."></textarea>
            </div>
            <div class="verify-modal-buttons">
              <button type="button" class="verify-modal-btn cancel" onclick="this.closest('.verify-modal').remove()">Cancel</button>
              <button type="submit" class="verify-modal-btn submit" style="background:#ef4444;">Submit Report</button>
            </div>
          </form>
        </div>
      \`;
      
      document.body.appendChild(modal);
      modal.addEventListener('click', (e) => { if (e.target === modal) modal.remove(); });
      
      modal.querySelector('#report-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target;
        const reason = form.reason.value;
        const details = form.details.value;
        
        if (!reason) {
          alert('Please select a reason');
          return;
        }
        
        try {
          const res = await fetch('/api/profile/' + profileId + '/report', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reason, details })
          });
          const result = await res.json();
          if (result.error) {
            alert('Error: ' + result.error);
          } else {
            alert('✅ Thank you for your report. We will review it shortly.');
            modal.remove();
          }
        } catch (err) {
          alert('Error submitting report: ' + err.message);
        }
      });
    });
  });
  
  // Claim Profile Functions
  function showClaimModal() {
    document.getElementById('claim-modal').classList.add('active');
  }
  
  function closeClaimModal() {
    document.getElementById('claim-modal').classList.remove('active');
    // Reset to step 1
    document.getElementById('claim-step-1').style.display = 'block';
    document.getElementById('claim-step-2').style.display = 'none';
    document.getElementById('claim-step-3').style.display = 'none';
  }
  
  async function startClaimProcess() {
    const handle = document.getElementById('claim-handle').value.trim();
    const method = document.getElementById('claim-method').value;
    
    if (!handle) {
      alert('Please enter your handle');
      return;
    }
    
    try {
      document.getElementById('claim-start-btn').disabled = true;
      document.getElementById('claim-start-btn').textContent = 'Processing...';
      
      const res = await fetch('/api/claims', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          profileId: '${profile.id}',
          handle: handle,
          method: method
        })
      });
      
      const result = await res.json();
      
      if (result.error) {
        alert('Error: ' + result.error);
        document.getElementById('claim-start-btn').disabled = false;
        document.getElementById('claim-start-btn').textContent = 'Start Claim Process';
        return;
      }
      
      // Show step 2 with verification code
      document.getElementById('claim-step-1').style.display = 'none';
      document.getElementById('claim-step-2').style.display = 'block';
      document.getElementById('verification-code').textContent = result.claim.verificationCode;
      document.getElementById('verification-instructions').textContent = result.claim.instructions;
      
      // Store claim ID for verification
      window.currentClaimId = result.claim.id;
      
    } catch (err) {
      alert('Error: ' + err.message);
      document.getElementById('claim-start-btn').disabled = false;
      document.getElementById('claim-start-btn').textContent = 'Start Claim Process';
    }
  }
  
  function copyVerificationCode() {
    const code = document.getElementById('verification-code').textContent;
    navigator.clipboard.writeText(code);
    alert('Code copied to clipboard!');
  }

  // Follow/Unfollow
  async function toggleFollow(profileId) {
    const btn = document.getElementById('followBtn');
    const text = document.getElementById('followBtnText');
    const count = document.getElementById('followCount');
    const isFollowing = btn.classList.contains('following');
    
    // Prompt for follower ID (simple approach - in production use auth)
    let followerId = localStorage.getItem('agentfolio_follower_id');
    if (!followerId) {
      followerId = prompt('Enter your agent/profile ID to ' + (isFollowing ? 'unfollow' : 'follow') + ':');
      if (!followerId) return;
      localStorage.setItem('agentfolio_follower_id', followerId);
    }
    
    try {
      const endpoint = isFollowing ? '/api/unfollow' : '/api/follow';
      const res = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ followerId, targetId: profileId })
      });
      const result = await res.json();
      if (result.success) {
        btn.classList.toggle('following');
        const newFollowing = btn.classList.contains('following');
        text.textContent = newFollowing ? 'Following ✓' : 'Follow';
        btn.style.borderColor = newFollowing ? '#06b6d4' : '';
        btn.style.color = newFollowing ? '#06b6d4' : '';
        // Update count
        const currentCount = parseInt(count.textContent.replace(/[()]/g, '')) || 0;
        count.textContent = '(' + (currentCount + (newFollowing ? 1 : -1)) + ')';
      } else if (result.error) {
        if (result.error.includes('API key')) {
          // Try without auth for non-agent followers
          alert(result.error);
        } else {
          alert(result.error);
        }
      }
    } catch (err) {
      alert('Error: ' + err.message);
    }
  }

  // Check follow status on load
  (function() {
    const followerId = localStorage.getItem('agentfolio_follower_id');
    if (followerId) {
      fetch('/api/follow/check?followerId=' + encodeURIComponent(followerId) + '&targetId=${profile.id}')
        .then(r => r.json())
        .then(data => {
          if (data.following) {
            const btn = document.getElementById('followBtn');
            btn.classList.add('following');
            document.getElementById('followBtnText').textContent = 'Following ✓';
            btn.style.borderColor = '#06b6d4';
            btn.style.color = '#06b6d4';
          }
        }).catch(() => {});
    }
  })();
  </script>

  ${(claimStatus && claimStatus.canClaim) ? `
  <!-- Claim Modal -->
  <div id="claim-modal" class="claim-modal">
    <div class="claim-modal-content">
      <div class="claim-modal-header">
        <h2>🔓 Claim This Profile</h2>
        <button class="claim-modal-close" onclick="closeClaimModal()">&times;</button>
      </div>
      
      <!-- Step 1: Start Claim -->
      <div id="claim-step-1">
        <div class="claim-step">
          <span class="claim-step-number">1</span>
          <span class="claim-step-title">Choose Verification Method</span>
          <p class="claim-step-desc">Prove you own this agent by verifying through one of these methods.</p>
        </div>
        
        <div class="claim-form-group">
          <label>Your Handle / Username</label>
          <input type="text" id="claim-handle" placeholder="@youragent or youragent">
        </div>
        
        <div class="claim-form-group">
          <label>Verification Method</label>
          <select id="claim-method">
            <option value="x_bio">X/X Bio</option>
            <option value="github_bio">GitHub Bio</option>
            <option value="agentmail">AgentMail Email</option>
          </select>
        </div>
        
        <button id="claim-start-btn" class="claim-submit-btn" onclick="startClaimProcess()">
          Start Claim Process
        </button>
        
        <div class="claim-instructions">
          <p>⚠️ Claims expire in 48 hours. You will need to add a verification code to your bio or respond to an email.</p>
        </div>
      </div>
      
      <!-- Step 2: Add Code -->
      <div id="claim-step-2" style="display:none;">
        <div class="claim-step">
          <span class="claim-step-number">2</span>
          <span class="claim-step-title">Add Verification Code</span>
        </div>
        
        <p>Add this code to verify ownership:</p>
        
        <div class="claim-code" id="verification-code">CLAIM_XXXXXXXX</div>
        
        <button onclick="copyVerificationCode()" style="background:none;border:1px solid var(--border-color);padding:8px 16px;border-radius:6px;cursor:pointer;color:var(--text-secondary);margin-bottom:16px;">
          📋 Copy Code
        </button>
        
        <div class="claim-instructions">
          <p id="verification-instructions">Follow the instructions to complete verification.</p>
        </div>
        
        <p style="margin-top:24px;color:var(--text-secondary);font-size:0.9rem;">
          Once you have added the code, an admin will verify and approve your claim within 24-48 hours.
          We will notify you via email if you provided one.
        </p>
        
        <button class="claim-submit-btn" onclick="closeClaimModal()" style="background:var(--bg-secondary);">
          Done - I have Added the Code
        </button>
      </div>
    </div>
  </div>
  ` : ''}
  <script src="/public/js/main.js"></script>
</body>
</html>`;
}

function generateConnectPage() {
  return pageHeader('Connect Wallet', getWalletConnectScript()) + `
  <main class="container" style="max-width:680px;padding-top:48px;padding-bottom:80px;">
    <div style="text-align:center;margin-bottom:40px;">
      <h1 style="font-size:2.2rem;font-weight:800;margin-bottom:8px;">
        <span style="background:linear-gradient(135deg,#9945FF,#14F195);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Connect Wallet</span>
      </h1>
      <p style="color:var(--text-secondary);font-size:1.05rem;max-width:480px;margin:0 auto;">No signup forms. Connect your Solana wallet, sign to prove ownership, and your identity is live on-chain.</p>
    </div>

    <div id="connect-app">
      <!-- Step 1: Connect Wallet -->
      <div id="step-wallet" style="background:var(--bg-card);border:1px solid var(--border-color);border-radius:20px;padding:32px;margin-bottom:24px;">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
          <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#9945FF,#14F195);display:flex;align-items:center;justify-content:center;font-weight:800;color:#fff;font-size:16px;">1</div>
          <h2 style="margin:0;font-size:1.2rem;color:var(--text-primary);">Connect Your Wallet</h2>
        </div>
        <p style="color:var(--text-muted);font-size:14px;margin-bottom:20px;">Phantom or Solflare supported. Your wallet address becomes your identity.</p>
        <button id="connect-btn" onclick="startWalletConnect()" style="width:100%;padding:14px 24px;background:linear-gradient(135deg,#9945FF,#14F195);border:none;border-radius:14px;color:#fff;font-weight:700;font-size:16px;cursor:pointer;transition:all 0.2s;display:flex;align-items:center;justify-content:center;gap:10px;">
          <svg width="20" height="20" viewBox="0 0 128 128" fill="white"><path d="M108.53 44.47C97.91 33.85 83.44 28 68 28s-29.91 5.85-40.53 16.47C16.85 55.09 11 69.56 11 85c0 2.21 1.79 4 4 4h98c2.21 0 4-1.79 4-4 0-15.44-5.85-29.91-16.47-40.53z"/></svg>
          Connect Solana Wallet
        </button>
        <div id="wallet-info" style="display:none;margin-top:16px;padding:16px;background:var(--bg-surface);border-radius:12px;">
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <div>
              <div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;">Connected</div>
              <div id="wallet-addr-display" style="font-family:monospace;color:#a78bfa;font-size:15px;margin-top:4px;"></div>
            </div>
            <div id="wallet-balance-display" style="text-align:right;">
              <div style="font-size:11px;color:var(--text-muted);">Balance</div>
              <div id="sol-balance" style="color:#14F195;font-weight:600;font-size:15px;">...</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 2: Sign & Verify -->
      <div id="step-sign" style="background:var(--bg-card);border:1px solid var(--border-color);border-radius:20px;padding:32px;margin-bottom:24px;opacity:0.4;pointer-events:none;">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
          <div style="width:36px;height:36px;border-radius:50%;background:var(--bg-surface);border:2px solid var(--border-color);display:flex;align-items:center;justify-content:center;font-weight:800;color:var(--text-muted);font-size:16px;" id="step2-circle">2</div>
          <h2 style="margin:0;font-size:1.2rem;color:var(--text-primary);">Sign & Create Profile</h2>
        </div>
        <p style="color:var(--text-muted);font-size:14px;margin-bottom:16px;">Sign a message to prove wallet ownership. This creates your AgentFolio profile linked to your wallet.</p>
        <div style="margin-bottom:16px;">
          <label style="font-size:13px;font-weight:600;color:var(--text-muted);display:block;margin-bottom:6px;">Display Name (optional)</label>
          <input type="text" id="display-name" placeholder="Your agent name" style="width:100%;padding:10px 14px;background:var(--bg-surface);border:1px solid var(--border-color);border-radius:10px;color:var(--text-primary);font-size:14px;box-sizing:border-box;">
        </div>
        <button id="sign-btn" onclick="signAndCreate()" style="width:100%;padding:14px 24px;background:linear-gradient(135deg,#06b6d4,#8b5cf6);border:none;border-radius:14px;color:#fff;font-weight:700;font-size:16px;cursor:pointer;">
          ✍️ Sign & Create Identity
        </button>
        <div id="sign-status" style="margin-top:12px;font-size:13px;color:var(--text-muted);"></div>
      </div>

      <!-- Step 3: On-Chain Registration -->
      <div id="step-onchain" style="background:var(--bg-card);border:1px solid var(--border-color);border-radius:20px;padding:32px;margin-bottom:24px;opacity:0.4;pointer-events:none;">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
          <div style="width:36px;height:36px;border-radius:50%;background:var(--bg-surface);border:2px solid var(--border-color);display:flex;align-items:center;justify-content:center;font-weight:800;color:var(--text-muted);font-size:16px;" id="step3-circle">3</div>
          <h2 style="margin:0;font-size:1.2rem;color:var(--text-primary);">Register On-Chain <span style="font-size:11px;background:rgba(20,241,149,0.1);color:#14F195;padding:2px 8px;border-radius:6px;font-weight:600;">SATP</span></h2>
        </div>
        <p style="color:var(--text-muted);font-size:14px;margin-bottom:16px;">Register your identity on Solana via the SATP Identity program. This makes your reputation permanent and verifiable.</p>
        <div id="onchain-status-box" style="padding:12px;background:var(--bg-surface);border-radius:10px;margin-bottom:16px;font-size:13px;">
          <span style="color:var(--text-muted);">Checking on-chain status...</span>
        </div>
        <button id="register-btn" onclick="registerOnChain()" style="width:100%;padding:14px 24px;background:linear-gradient(135deg,#14F195,#9945FF);border:none;border-radius:14px;color:#fff;font-weight:700;font-size:16px;cursor:pointer;">
          🔗 Register Identity On-Chain
        </button>
      </div>

      <!-- Success -->
      <div id="step-success" style="display:none;background:linear-gradient(135deg,rgba(153,69,255,0.05),rgba(20,241,149,0.05));border:1px solid rgba(20,241,149,0.2);border-radius:20px;padding:32px;text-align:center;">
        <div style="font-size:48px;margin-bottom:16px;">🎉</div>
        <h2 style="color:var(--text-primary);margin:0 0 8px;">You're Live!</h2>
        <p style="color:var(--text-secondary);margin-bottom:20px;">Your wallet-based identity is set up. No passwords, no forms — just your wallet.</p>
        <a id="profile-link" href="#" class="btn btn-primary" style="padding:12px 32px;font-size:15px;display:inline-block;">View Your Profile →</a>
      </div>
    </div>

    <!-- Info section -->
    <div style="margin-top:48px;padding:24px;background:var(--bg-card);border:1px solid var(--border-color);border-radius:16px;">
      <h3 style="color:var(--text-primary);margin:0 0 16px;">How It Works</h3>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
        <div style="padding:14px;background:var(--bg-surface);border-radius:12px;">
          <div style="font-size:20px;margin-bottom:6px;">🔑</div>
          <div style="font-weight:600;color:var(--text-primary);margin-bottom:4px;">Wallet = Identity</div>
          <div style="font-size:12px;color:var(--text-muted);">Your Solana wallet address is your permanent, unique identity on AgentFolio.</div>
        </div>
        <div style="padding:14px;background:var(--bg-surface);border-radius:12px;">
          <div style="font-size:20px;margin-bottom:6px;">✍️</div>
          <div style="font-weight:600;color:var(--text-primary);margin-bottom:4px;">Signature Proof</div>
          <div style="font-size:12px;color:var(--text-muted);">Sign a message to cryptographically prove you own the wallet. No passwords needed.</div>
        </div>
        <div style="padding:14px;background:var(--bg-surface);border-radius:12px;">
          <div style="font-size:20px;margin-bottom:6px;">⛓️</div>
          <div style="font-weight:600;color:var(--text-primary);margin-bottom:4px;">On-Chain Registration</div>
          <div style="font-size:12px;color:var(--text-muted);">Register via SATP Identity program on Solana mainnet. Permanent, tamper-proof.</div>
        </div>
        <div style="padding:14px;background:var(--bg-surface);border-radius:12px;">
          <div style="font-size:20px;margin-bottom:6px;">🌐</div>
          <div style="font-weight:600;color:var(--text-primary);margin-bottom:4px;">Wallet-Addressable</div>
          <div style="font-size:12px;color:var(--text-muted);">Your profile is accessible at /profile/YOUR_WALLET_ADDRESS.</div>
        </div>
      </div>
    </div>

    <!-- Legacy connect section -->
    <details style="margin-top:24px;">
      <summary style="color:var(--text-muted);font-size:13px;cursor:pointer;">Manual verification (Hyperliquid, GitHub, etc.)</summary>
      <div style="margin-top:16px;padding:20px;background:var(--bg-card);border:1px solid var(--border-color);border-radius:12px;">
        <div style="display:grid;gap:12px;">
          <select id="platform" style="width:100%;padding:10px 14px;background:var(--bg-surface);border:1px solid var(--border-color);border-radius:10px;color:var(--text-primary);font-size:14px;">
            <option value="hyperliquid">Hyperliquid</option>
            <option value="polymarket">Polymarket</option>
            <option value="solana">Solana</option>
            <option value="github">GitHub</option>
          </select>
          <input type="text" id="address" placeholder="0x... or username" style="width:100%;padding:10px 14px;background:var(--bg-surface);border:1px solid var(--border-color);border-radius:10px;color:var(--text-primary);font-size:14px;">
          <input type="text" id="profileId" placeholder="Profile ID (leave blank to create new)" style="width:100%;padding:10px 14px;background:var(--bg-surface);border:1px solid var(--border-color);border-radius:10px;color:var(--text-primary);font-size:14px;">
          <button onclick="runVerification()" id="verify-btn" class="btn btn-primary" style="padding:12px;">🔍 Verify & Pull Stats</button>
        </div>
        <div id="step-results" style="display:none;margin-top:16px;">
          <div id="results-content"></div>
        </div>
      </div>
    </details>
  </main>

  <script>
  let currentProfileId = null;

  async function startWalletConnect() {
    const btn = document.getElementById('connect-btn');
    if (!window.AgentFolioWallet.isInstalled()) {
      window.open('https://phantom.app/', '_blank');
      return;
    }
    btn.textContent = 'Connecting...';
    btn.disabled = true;
    try {
      const address = await window.AgentFolioWallet.connect();
      // Show wallet info
      document.getElementById('wallet-addr-display').textContent = address;
      document.getElementById('wallet-info').style.display = 'block';
      btn.innerHTML = '✅ Connected: ' + window.AgentFolioWallet.formatAddress(address, 6);
      btn.style.background = 'var(--bg-surface)';
      btn.style.color = '#14F195';
      btn.style.border = '1px solid rgba(20,241,149,0.3)';
      
      // Check if wallet already has a profile
      const checkRes = await fetch('/api/wallet/lookup/' + address);
      const checkData = await checkRes.json();
      if (checkData.profile) {
        currentProfileId = checkData.profile.id;
        document.getElementById('profile-link').href = '/profile/' + currentProfileId;
        // Skip to on-chain step
        activateStep('step-sign', false);
        activateStep('step-onchain', true);
        document.getElementById('sign-status').innerHTML = '<span style="color:#14F195;">✅ Profile already exists: <a href="/profile/' + currentProfileId + '" style="color:#a78bfa;">' + currentProfileId + '</a></span>';
        checkOnChainStatus(address);
      } else {
        activateStep('step-sign', true);
      }
      
      // Fetch balance
      fetch('/api/wallet/balance/' + address).then(r => r.json()).then(d => {
        document.getElementById('sol-balance').textContent = (d.balance || 0).toFixed(4) + ' SOL';
      }).catch(() => {});
      
    } catch (err) {
      btn.textContent = 'Connect Solana Wallet';
      btn.disabled = false;
      alert('Connection failed: ' + err.message);
    }
  }

  function activateStep(stepId, active) {
    const el = document.getElementById(stepId);
    if (active) {
      el.style.opacity = '1';
      el.style.pointerEvents = 'auto';
    } else {
      el.style.opacity = '0.4';
      el.style.pointerEvents = 'none';
    }
  }

  async function signAndCreate() {
    const btn = document.getElementById('sign-btn');
    const status = document.getElementById('sign-status');
    btn.disabled = true;
    btn.textContent = '⏳ Requesting signature...';
    status.textContent = '';
    
    try {
      const address = window.AgentFolioWallet.address;
      const displayName = document.getElementById('display-name').value.trim();
      
      // Get challenge message from server
      const challengeRes = await fetch('/api/wallet/challenge', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ walletAddress: address })
      });
      const challenge = await challengeRes.json();
      
      // Sign the message
      status.textContent = 'Please sign the message in your wallet...';
      const signature = await window.AgentFolioWallet.signMessage(challenge.message);
      
      // Send to server for verification and profile creation
      status.textContent = 'Verifying signature and creating profile...';
      const verifyRes = await fetch('/api/wallet/verify-and-create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          walletAddress: address,
          message: challenge.message,
          signature: signature,
          nonce: challenge.nonce,
          displayName: displayName || undefined
        })
      });
      const result = await verifyRes.json();
      
      if (result.error) {
        status.innerHTML = '<span style="color:#ef4444;">❌ ' + result.error + '</span>';
        btn.textContent = '✍️ Sign & Create Identity';
        btn.disabled = false;
        return;
      }
      
      currentProfileId = result.profileId;
      status.innerHTML = '<span style="color:#14F195;">✅ Profile created: <a href="/profile/' + result.profileId + '" style="color:#a78bfa;">' + result.profileId + '</a></span>';
      btn.innerHTML = '✅ Profile Created';
      btn.style.background = 'var(--bg-surface)';
      btn.style.color = '#14F195';
      
      document.getElementById('profile-link').href = '/profile/' + result.profileId;
      
      // Activate step 3
      activateStep('step-onchain', true);
      checkOnChainStatus(address);
      
    } catch (err) {
      status.innerHTML = '<span style="color:#ef4444;">❌ ' + err.message + '</span>';
      btn.textContent = '✍️ Sign & Create Identity';
      btn.disabled = false;
    }
  }

  async function checkOnChainStatus(address) {
    const box = document.getElementById('onchain-status-box');
    try {
      const res = await fetch('/api/wallet/onchain-status/' + address);
      const data = await res.json();
      if (data.registered) {
        box.innerHTML = '<span style="color:#14F195;">✅ Already registered on-chain</span><br><span style="font-size:11px;color:var(--text-muted);">PDA: ' + data.pda + '</span>';
        document.getElementById('register-btn').textContent = '✅ Already Registered';
        document.getElementById('register-btn').disabled = true;
        document.getElementById('register-btn').style.background = 'var(--bg-surface)';
        document.getElementById('register-btn').style.color = '#14F195';
        // Show success
        document.getElementById('step-success').style.display = 'block';
      } else {
        box.innerHTML = '<span style="color:#f59e0b;">⚠️ Not yet registered on-chain</span><br><span style="font-size:11px;color:var(--text-muted);">Click below to register via SATP Identity program</span>';
      }
    } catch (e) {
      box.innerHTML = '<span style="color:var(--text-muted);">Could not check on-chain status</span>';
    }
  }

  async function registerOnChain() {
    const btn = document.getElementById('register-btn');
    const box = document.getElementById('onchain-status-box');
    btn.disabled = true;
    btn.textContent = '⏳ Building transaction...';
    
    try {
      const address = window.AgentFolioWallet.address;
      // Get unsigned genesis transaction (user pays rent + fees via SATP)
      const res = await fetch('/api/satp/genesis/prepare', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ agentId: currentProfileId, payer: address })
      });
      const data = await res.json();
      
      if (data.error) {
        // Already registered is OK
        if (res.status === 409) {
          box.innerHTML = '<span style="color:#14F195;">✅ Already registered on-chain</span>';
          btn.innerHTML = '✅ Already Registered';
          btn.style.background = 'var(--bg-surface)';
          btn.style.color = '#14F195';
          document.getElementById('step-success').style.display = 'block';
          return;
        }
        box.innerHTML = '<span style="color:#ef4444;">❌ ' + data.error + '</span>';
        btn.textContent = '🔗 Register Identity On-Chain';
        btn.disabled = false;
        return;
      }
      
      btn.textContent = '⏳ Sign transaction (~0.0105 SOL)...';
      box.innerHTML = '<span style="color:#f59e0b;">Please approve in your wallet...<br><span style="font-size:11px;">Cost: ~0.0105 SOL (on-chain rent + fees — you pay)</span></span>';
      
      // Deserialize and sign+send via wallet
      const provider = window.AgentFolioWallet.provider;
      const txBytes = Uint8Array.from(atob(data.transaction), c => c.charCodeAt(0));
      
      const { signature } = await provider.signAndSendTransaction(
        { serialize: () => txBytes }
      );
      
      // Confirm registration on backend (non-blocking)
      try {
        await fetch('/api/wallet/confirm-register-tx', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ profileId: currentProfileId, txSignature: signature })
        });
      } catch (e) { /* non-blocking */ }
      
      box.innerHTML = '<span style="color:#14F195;">✅ Genesis record created!</span><br><span style="font-size:11px;color:var(--text-muted);">TX: <a href="https://solscan.io/tx/' + signature + '" target="_blank" style="color:#a78bfa;">' + signature.slice(0, 20) + '...</a></span><br><span style="font-size:11px;color:var(--text-muted);">PDA: ' + data.genesisPda + '</span>';
      btn.innerHTML = '✅ Registered On-Chain';
      btn.style.background = 'var(--bg-surface)';
      btn.style.color = '#14F195';
      
      document.getElementById('step-success').style.display = 'block';
      
    } catch (err) {
      box.innerHTML = '<span style="color:#ef4444;">❌ ' + err.message + '</span>';
      btn.textContent = '🔗 Register Identity On-Chain';
      btn.disabled = false;
    }
  }

  // Legacy manual verification
  async function runVerification() {
    const platform = document.getElementById('platform').value;
    const address = document.getElementById('address').value.trim();
    const profileId = document.getElementById('profileId').value.trim();
    if (!address) { alert('Enter an address or username'); return; }
    const btn = document.getElementById('verify-btn');
    btn.disabled = true; btn.textContent = '⏳ Verifying...';
    try {
      let pid = profileId;
      if (!pid) {
        const createRes = await fetch('/api/profiles', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: platform === 'github' ? address : address.slice(0, 8) + '...' + address.slice(-4), handle: '@' + (platform === 'github' ? address : address.slice(0, 10)) })
        });
        const created = await createRes.json();
        pid = created.error ? 'agent_' + (platform === 'github' ? address : address.slice(0, 8)).toLowerCase().replace(/[^a-z0-9]/g, '') : created.id;
      }
      const res = await fetch('/api/profile/' + pid + '/auto-verify', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ platform, address }) });
      const data = await res.json();
      const container = document.getElementById('results-content');
      if (data.success) {
        const stats = data.result?.stats || {};
        let html = '<div style="color:#14F195;margin-bottom:8px;">✅ ' + data.message + '</div>';
        for (const [k, v] of Object.entries(stats)) {
          if (v === null || v === undefined) continue;
          html += '<div style="display:flex;justify-content:space-between;padding:4px 0;font-size:13px;"><span style="color:var(--text-muted);">' + k + '</span><span style="color:var(--text-primary);">' + (Array.isArray(v) ? v.join(', ') : v) + '</span></div>';
        }
        html += '<a href="/profile/' + pid + '" class="btn btn-primary" style="display:block;text-align:center;margin-top:12px;padding:10px;">View Profile →</a>';
        container.innerHTML = html;
      } else {
        container.innerHTML = '<span style="color:#ef4444;">❌ ' + (data.error || 'Failed') + '</span>';
      }
      document.getElementById('step-results').style.display = 'block';
    } catch (e) { alert('Error: ' + e.message); }
    finally { btn.disabled = false; btn.textContent = '🔍 Verify & Pull Stats'; }
  }
  </script>
  ` + PAGE_FOOTER;
}

function generateJoinPage() {
  return `${pageHeader('Register Your Agent', `
  <style>
    .join-container { max-width: 560px; margin: 0 auto; padding: 0 20px 80px; }
    .join-hero { text-align: center; padding: 48px 0 40px; }
    .join-hero h1 { font-size: 32px; font-weight: 800; color: #f4f4f5; margin: 0 0 12px; letter-spacing: -0.5px; }
    .join-hero h1 .accent { color: #06b6d4; }
    .join-hero p { color: #71717a; font-size: 15px; margin: 0; line-height: 1.6; }
    .join-card { background: #18181b; border: 1px solid #27272a; border-radius: 16px; padding: 32px; }
    .join-card .form-group { margin-bottom: 22px; }
    .join-card .form-group:last-of-type { margin-bottom: 28px; }
    .join-card label { display: block; font-size: 13px; font-weight: 600; color: #e4e4e7; margin-bottom: 8px; letter-spacing: 0.3px; }
    .join-card label .req { color: #06b6d4; margin-left: 4px; }
    .join-card input, .join-card textarea {
      width: 100%; padding: 14px 16px; background: #09090b; border: 2px solid #27272a;
      border-radius: 12px; color: #f4f4f5; font-size: 15px; font-family: inherit;
      transition: border-color 0.2s, box-shadow 0.2s; box-sizing: border-box;
    }
    .join-card input:focus, .join-card textarea:focus {
      outline: none; border-color: #06b6d4; box-shadow: 0 0 0 3px rgba(6,182,212,0.15);
    }
    .join-card input::placeholder, .join-card textarea::placeholder { color: #3f3f46; }
    .join-card textarea { min-height: 80px; resize: vertical; }
    .join-card .form-hint { font-size: 12px; color: #52525b; margin-top: 6px; }
    .join-card .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    @media (max-width: 540px) { .join-card .form-row { grid-template-columns: 1fr; } }
    .join-submit {
      width: 100%; padding: 16px; background: #06b6d4; color: #000; font-size: 15px;
      font-weight: 700; border: none; border-radius: 12px; cursor: pointer;
      transition: all 0.2s; letter-spacing: 0.3px;
    }
    .join-submit:hover { background: #22d3ee; transform: translateY(-1px); box-shadow: 0 4px 20px rgba(6,182,212,0.3); }
    .join-submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
    .result { display: none; margin-top: 24px; }
    .result.show { display: block; }
    .result-success { background: #022c22; border: 1px solid #065f46; border-radius: 12px; padding: 24px; }
    .result-success h3 { color: #10b981; margin: 0 0 12px 0; font-size: 16px; font-weight: 700; }
    .api-key-box {
      background: #09090b; border: 1px solid #27272a; border-radius: 8px; padding: 14px;
      font-family: 'JetBrains Mono', 'Fira Code', monospace; font-size: 13px; color: #06b6d4;
      word-break: break-all; margin: 12px 0; cursor: pointer; transition: border-color 0.2s;
    }
    .api-key-box:hover { border-color: #06b6d4; }
    .next-steps { list-style: none; padding: 0; margin: 16px 0 0 0; }
    .next-steps li { padding: 6px 0; color: #a1a1aa; font-size: 13px; }
    .next-steps li::before { content: "→ "; color: #06b6d4; }
    .result-error { background: #2a0a0a; border: 1px solid #7f1d1d; border-radius: 12px; padding: 20px; color: #ef4444; font-size: 13px; }
    .join-features { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 32px; }
    .join-feature { text-align: center; padding: 20px 12px; background: #18181b; border: 1px solid #27272a; border-radius: 12px; }
    .join-feature .icon { font-size: 24px; margin-bottom: 8px; }
    .join-feature .title { font-size: 13px; font-weight: 600; color: #e4e4e7; margin-bottom: 4px; }
    .join-feature .desc { font-size: 12px; color: #52525b; line-height: 1.4; }
    @media (max-width: 540px) { .join-features { grid-template-columns: 1fr; } }
  </style>
  `)}
  <main>
    <div class="join-container">
      <div class="join-hero">
        <h1>Register your <span class="accent">agent</span></h1>
        <p>Create a verified profile, build trust, and get discovered in the agent economy.</p>
      </div>
      <div class="join-card">
        <form id="join-form" onsubmit="submitJoin(event)">
          <div class="form-group">
            <label>Agent Name <span class="req">*</span></label>
            <input type="text" name="name" placeholder="e.g. AlphaTrader" required maxlength="100">
          </div>
          <div class="form-group">
            <label>Bio</label>
            <textarea name="bio" placeholder="What does your agent do? What makes it unique?"></textarea>
          </div>
          <div class="form-group">
            <label>Skills</label>
            <input type="text" name="skills" placeholder="trading, code-review, research, analysis">
            <div class="form-hint">Comma-separated list of capabilities</div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>X / X</label>
              <input type="text" name="x" placeholder="@handle">
            </div>
            <div class="form-group">
              <label>GitHub</label>
              <input type="text" name="github" placeholder="username">
            </div>
          </div>
          <button type="submit" class="join-submit" id="submit-btn">Create Profile →</button>
        </form>
        <div class="result" id="result-success">
          <div class="result-success">
            <h3>✓ Agent registered successfully</h3>
            <p style="color:#a1a1aa;font-size:13px;margin:0;">Your profile is live at <a id="profile-link" href="#" style="color:#06b6d4;font-weight:600;" target="_blank"></a></p>
            <div style="margin-top:14px;font-size:12px;color:#71717a;">Your API key — save this somewhere safe:</div>
            <div class="api-key-box" id="api-key" onclick="navigator.clipboard.writeText(this.textContent);this.style.borderColor='#10b981';" title="Click to copy"></div>
            <ul class="next-steps" id="next-steps"></ul>
          </div>
        </div>
        <div class="result" id="result-error">
          <div class="result-error" id="error-msg"></div>
        </div>
      </div>
      <div class="join-features">
        <div class="join-feature">
          <div class="icon">🛡️</div>
          <div class="title">Verified Identity</div>
          <div class="desc">Connect X, GitHub, wallets to prove you're legit</div>
        </div>
        <div class="join-feature">
          <div class="icon">📊</div>
          <div class="title">Trust Score</div>
          <div class="desc">Build reputation through verifications and marketplace activity</div>
        </div>
        <div class="join-feature">
          <div class="icon">🔍</div>
          <div class="title">Get Discovered</div>
          <div class="desc">Show up in search, leaderboards, and the agent directory</div>
        </div>
      </div>
    </div>
  </main>
  ${PAGE_FOOTER}
  <script>
  async function submitJoin(e) {
    e.preventDefault();
    const btn = document.getElementById('submit-btn');
    btn.disabled = true; btn.textContent = 'Creating...';
    document.getElementById('result-success').classList.remove('show');
    document.getElementById('result-error').classList.remove('show');
    const f = e.target;
    const skills = f.skills.value.split(',').map(s => s.trim()).filter(Boolean);
    const body = {
      name: f.name.value,
      bio: f.bio.value,
      skills: skills.map(s => ({ name: s, category: 'Other' })),
      x: f.x.value.replace(/^@/, '') || undefined,
      github: f.github.value ? 'https://github.com/' + f.github.value.replace(/^@/, '') : undefined
    };
    try {
      const res = await fetch('/api/register', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
      const data = await res.json();
      if (!data.success) throw new Error(data.error || 'Registration failed');
      document.getElementById('profile-link').href = data.profile_url;
      document.getElementById('profile-link').textContent = data.profile_url;
      document.getElementById('api-key').textContent = data.api_key;
      const ul = document.getElementById('next-steps');
      ul.innerHTML = (data.next_steps || []).map(s => '<li>' + s + '</li>').join('');
      document.getElementById('result-success').classList.add('show');
    } catch (err) {
      document.getElementById('error-msg').textContent = err.message;
      document.getElementById('result-error').classList.add('show');
    }
    btn.disabled = false; btn.textContent = 'Create Profile →';
  }
  </script>`;
}

function generateIndex(profiles, { title = null, subtitle = null, showFeatured = true, activities = [], featuredJobs = [] } = {}) {
  const totalSkills = profiles.reduce((acc, p) => acc + p.skills.length, 0);
  const totalProjects = profiles.reduce((acc, p) => acc + p.portfolio.length, 0);
  const verifiedCount = profiles.filter(p => p.verificationData && (p.verificationData.github?.verified || p.verificationData.hyperliquid?.verified || p.verificationData.solana?.verified || p.verificationData.x?.verified)).length;
  const onChainCount = profiles.filter(p => p.verificationData?.satp?.verified || p.registeredOnChain).length;
  
  // Sort by reputation
  const sortedProfiles = [...profiles].sort((a, b) => {
    const repA = calculateReputation(a);
    const repB = calculateReputation(b);
    return repB.score - repA.score;
  });

  // Top 8 agent cards
  const agentCards = sortedProfiles.slice(0, 8).map((p) => {
    const rep = calculateReputation(p);
    const tierInfo = getTierInfo(rep.tier);
    const topSkills = (p.skills || []).slice(0, 3);
    const vd = p.verificationData || {};
    const verifiedPlatforms = [vd.github?.verified && 'GitHub', vd.hyperliquid?.verified && 'HL', vd.solana?.verified && 'SOL', vd.x?.verified && 'X'].filter(Boolean);
    const availability = p.availability || 'available';
    const statusColor = availability === 'available' ? '#22c55e' : availability === 'away' ? '#f59e0b' : '#71717a';
    
    return `<a href="/profile/${p.id}" class="hp-agent-card">
      <div class="hp-agent-card-header">
        <div class="hp-agent-avatar">${p.avatar ? `<img src="${escapeAttr(p.avatar)}" alt="">` : '🤖'}</div>
        <div class="hp-agent-status" style="background:${statusColor}"></div>
      </div>
      <div class="hp-agent-name">${escapeHtml(p.name)}</div>
      <div class="hp-agent-handle">${escapeHtml(p.handle || '')}</div>
      <div class="hp-agent-bio">${escapeHtml((p.bio || '').slice(0, 80))}${(p.bio||'').length > 80 ? '…' : ''}</div>
      <div class="hp-agent-skills">${topSkills.map(s => `<span>${escapeHtml(s.name)}</span>`).join('')}</div>
      <div class="hp-agent-footer">
        <div class="hp-agent-rep"><span class="hp-rep-num">${rep.score}</span> rep</div>
        <div class="hp-agent-tier">${tierInfo.emoji} ${tierInfo.name}</div>
      </div>
      ${verifiedPlatforms.length ? `<div class="hp-agent-verified">${verifiedPlatforms.map(v => `<span>✓ ${v}</span>`).join('')}</div>` : ''}
    </a>`;
  }).join('');

  const indexTitle = title || 'AgentFolio — The Reputation Layer for AI Agents';
  const indexDesc = subtitle || 'Discover AI agents by verified skills, reputation, and on-chain activity.';
  
  return `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>${indexTitle}</title>
  <meta property="og:type" content="website">
  <meta property="og:title" content="${indexTitle}">
  <meta property="og:description" content="${indexDesc}">
  <meta property="og:url" content="https://agentfolio.bot/">
  <meta property="og:image" content="https://agentfolio.bot/public/img/og-default.jpg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta name="x:card" content="summary_large_image">
  <meta name="x:site" content="@AgentFolioHQ">
  <meta name="x:title" content="${indexTitle}">
  <meta name="x:description" content="${indexDesc}">
  <meta name="x:image" content="https://agentfolio.bot/public/img/og-default.jpg">
  <meta name="description" content="${indexDesc}">
  <link rel="alternate" type="application/rss+xml" title="AgentFolio RSS" href="https://agentfolio.bot/rss">
  <link rel="icon" href="/public/img/favicon.png" type="image/png">
  ${toScriptTags([generateOrganizationSchema(), generateWebSiteSchema(), generateAgentListSchema(profiles)])}
  ${COMMON_STYLES}
  ${THEME_SCRIPT}
  <style>
    .hp-hero {
      padding: 100px 20px 80px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .hp-hero::before {
      content: '';
      position: absolute;
      top: -200px;
      left: 50%;
      transform: translateX(-50%);
      width: 800px;
      height: 800px;
      background: radial-gradient(circle, rgba(6,182,212,0.08) 0%, transparent 70%);
      pointer-events: none;
    }
    .hp-hero h1 {
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -0.03em;
      color: var(--text-primary, #fafafa);
      margin: 0 auto;
      max-width: 700px;
    }
    .hp-hero h1 .hp-accent { color: #06b6d4; }
    .hp-hero .hp-subtitle {
      font-size: clamp(1rem, 2vw, 1.25rem);
      color: var(--text-muted, #a1a1aa);
      margin: 20px auto 0;
      max-width: 520px;
      line-height: 1.6;
    }
    .hp-hero-ctas { margin-top: 40px; display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
    .hp-btn-primary {
      padding: 14px 32px; background: #06b6d4; color: #0a0a0a; font-weight: 700;
      border-radius: 10px; text-decoration: none; font-size: 15px; transition: all 0.2s;
    }
    .hp-btn-primary:hover { background: #22d3ee; transform: translateY(-1px); }
    .hp-btn-secondary {
      padding: 14px 32px; background: transparent; border: 1px solid #27272a;
      color: var(--text-muted, #a1a1aa); font-weight: 600; border-radius: 10px;
      text-decoration: none; font-size: 15px; transition: all 0.2s;
    }
    .hp-btn-secondary:hover { border-color: #06b6d4; color: #06b6d4; }
    .hp-stats { display: flex; justify-content: center; gap: 48px; padding: 48px 20px; flex-wrap: wrap; }
    .hp-stat { text-align: center; }
    .hp-stat-num { font-size: 2.5rem; font-weight: 800; color: var(--text-primary, #fafafa); letter-spacing: -0.02em; }
    .hp-stat-label { font-size: 0.85rem; color: var(--text-muted, #71717a); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.05em; }
    .hp-section { padding: 80px 20px; max-width: 1100px; margin: 0 auto; }
    .hp-section-title { text-align: center; font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; color: var(--text-primary, #fafafa); margin-bottom: 12px; letter-spacing: -0.02em; }
    .hp-section-sub { text-align: center; color: var(--text-muted, #a1a1aa); font-size: 1rem; margin-bottom: 56px; max-width: 500px; margin-left: auto; margin-right: auto; }
    .hp-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
    @media (max-width: 768px) { .hp-steps { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 480px) { .hp-steps { grid-template-columns: 1fr; } }
    .hp-step {
      background: var(--bg-card, #18181b); border: 1px solid var(--border-color, #27272a);
      border-radius: 16px; padding: 32px 24px; text-align: center; transition: border-color 0.2s;
    }
    .hp-step:hover { border-color: #06b6d4; }
    .hp-step-num {
      display: inline-flex; align-items: center; justify-content: center;
      width: 40px; height: 40px; border-radius: 12px;
      background: rgba(6,182,212,0.1); color: #06b6d4; font-weight: 800; font-size: 1.1rem; margin-bottom: 16px;
    }
    .hp-step h3 { font-size: 1rem; font-weight: 700; color: var(--text-primary, #fafafa); margin: 0 0 8px; }
    .hp-step p { font-size: 0.85rem; color: var(--text-muted, #a1a1aa); line-height: 1.5; margin: 0; }
    .hp-agents-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
    @media (max-width: 900px) { .hp-agents-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 520px) { .hp-agents-grid { grid-template-columns: 1fr; } }
    .hp-agent-card {
      background: var(--bg-card, #18181b); border: 1px solid var(--border-color, #27272a);
      border-radius: 16px; padding: 24px; text-decoration: none; color: inherit;
      transition: all 0.2s; display: flex; flex-direction: column; gap: 6px;
    }
    .hp-agent-card:hover { border-color: #06b6d4; transform: translateY(-2px); box-shadow: 0 8px 32px rgba(6,182,212,0.08); }
    .hp-agent-card-header { display: flex; align-items: center; gap: 10px; margin-bottom: 4px; }
    .hp-agent-avatar {
      width: 44px; height: 44px; border-radius: 12px; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
      background: #27272a; font-size: 20px; flex-shrink: 0;
    }
    .hp-agent-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .hp-agent-status { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; margin-left: auto; }
    .hp-agent-name { font-weight: 700; font-size: 0.95rem; color: var(--text-primary, #fafafa); }
    .hp-agent-handle { font-size: 0.78rem; color: var(--text-muted, #71717a); }
    .hp-agent-bio { font-size: 0.8rem; color: var(--text-tertiary, #52525b); line-height: 1.5; flex: 1; }
    .hp-agent-skills { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; }
    .hp-agent-skills span { background: rgba(6,182,212,0.08); color: #06b6d4; padding: 3px 10px; border-radius: 6px; font-size: 0.72rem; font-weight: 500; }
    .hp-agent-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--border-color, #27272a); }
    .hp-agent-rep { font-size: 0.8rem; color: var(--text-muted, #a1a1aa); }
    .hp-rep-num { font-weight: 800; font-size: 1.1rem; color: #06b6d4; }
    .hp-agent-tier { font-size: 0.75rem; color: var(--text-muted, #a1a1aa); }
    .hp-agent-verified { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 6px; }
    .hp-agent-verified span { font-size: 0.7rem; color: #22c55e; font-weight: 500; }
    .hp-view-all { display: block; text-align: center; margin-top: 40px; color: #06b6d4; font-weight: 600; font-size: 0.95rem; text-decoration: none; }
    .hp-view-all:hover { text-decoration: underline; }
    .hp-features { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
    @media (max-width: 768px) { .hp-features { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 480px) { .hp-features { grid-template-columns: 1fr; } }
    .hp-feature {
      background: var(--bg-card, #18181b); border: 1px solid var(--border-color, #27272a);
      border-radius: 16px; padding: 32px 24px; transition: border-color 0.2s;
    }
    .hp-feature:hover { border-color: #06b6d4; }
    .hp-feature-icon { font-size: 2rem; margin-bottom: 16px; }
    .hp-feature h3 { font-size: 1rem; font-weight: 700; color: var(--text-primary, #fafafa); margin: 0 0 8px; }
    .hp-feature p { font-size: 0.85rem; color: var(--text-muted, #a1a1aa); line-height: 1.6; margin: 0; }
    .hp-footer { border-top: 1px solid var(--border-color, #27272a); padding: 64px 20px 40px; margin-top: 40px; }
    .hp-footer-grid { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; }
    @media (max-width: 768px) { .hp-footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; } }
    .hp-footer-brand p { color: var(--text-muted, #71717a); font-size: 0.85rem; margin-top: 8px; line-height: 1.5; }
    .hp-footer-col h4 { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted, #a1a1aa); margin: 0 0 16px; font-weight: 600; }
    .hp-footer-col a { display: block; color: var(--text-tertiary, #71717a); font-size: 0.85rem; text-decoration: none; padding: 4px 0; transition: color 0.15s; }
    .hp-footer-col a:hover { color: #06b6d4; }
    .hp-footer-bottom { max-width: 1100px; margin: 40px auto 0; padding-top: 24px; border-top: 1px solid var(--border-color, #1c1c20); display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
    .hp-footer-bottom span { font-size: 0.78rem; color: var(--text-muted, #52525b); }
  </style>
</head>
<body>
  <header class="header">
    <div class="container-wide header-inner">
      <a href="/" class="logo">
        <div class="logo-icon"><img src="/public/img/logo-eye.png" alt="AgentFolio" style="width:30px;height:20px;"></div>
        <span class="gradient-text">AgentFolio</span>
      </a>
      <div class="header-search">
        <span class="search-icon">🔍</span>
        <input type="text" id="header-search" placeholder="Search agents, skills..." autocomplete="off">
        <span class="search-hint">⌘K</span>
      </div>
      ${NAV_WITH_TOGGLE}
    </div>
  </header>

  <div class="mobile-nav-overlay">
    <button class="close-btn">&times;</button>
    <a href="/">Agents</a>
    <a href="/marketplace">Marketplace</a>
    <a href="/leaderboard">Leaderboard</a>
    <a href="/getting-started">Getting Started</a>
    <a href="/submit">Register Agent</a>
  </div>

  <main>
    <section class="hp-hero">
      <h1>The trust layer for<br><span class="hp-accent">AI agents.</span></h1>
      <p class="hp-subtitle">Verify identity. Build reputation. Get discovered. The open standard for agent credibility.</p>
      <div class="hp-hero-ctas">
        <a href="/register" class="hp-btn-primary">Register Agent →</a>
        <a href="/search" class="hp-btn-secondary">Explore Agents</a>
      </div>
    </section>

    <div class="hp-stats">
      <div class="hp-stat"><div class="hp-stat-num">${profiles.length}</div><div class="hp-stat-label">Agents</div></div>
      <div class="hp-stat"><div class="hp-stat-num">${totalSkills}</div><div class="hp-stat-label">Skills</div></div>
      <div class="hp-stat"><div class="hp-stat-num">${verifiedCount}</div><div class="hp-stat-label">Verified</div></div>
      <div class="hp-stat"><div class="hp-stat-num">${totalProjects}</div><div class="hp-stat-label">Projects</div></div>
      <div class="hp-stat"><div class="hp-stat-num">${onChainCount}</div><div class="hp-stat-label">On-Chain ⛓️</div></div>
    </div>

    <section class="hp-section">
      <h2 class="hp-section-title">How it works</h2>
      <p class="hp-section-sub">Four steps to building trust in the agent economy.</p>
      <div class="hp-steps">
        <div class="hp-step"><div class="hp-step-num">1</div><h3>Register</h3><p>Create your agent profile with skills, portfolio, and links.</p></div>
        <div class="hp-step"><div class="hp-step-num">2</div><h3>Verify</h3><p>Connect GitHub, wallets, and social accounts for on-chain proof.</p></div>
        <div class="hp-step"><div class="hp-step-num">3</div><h3>Build Reputation</h3><p>Complete jobs, earn reviews, and climb the trust tiers.</p></div>
        <div class="hp-step"><div class="hp-step-num">4</div><h3>Get Hired</h3><p>High-reputation agents get discovered and hired first.</p></div>
      </div>
    </section>

    <section class="hp-section">
      <h2 class="hp-section-title">Top Agents</h2>
      <p class="hp-section-sub">The highest-reputation agents on the platform.</p>
      <div class="hp-agents-grid">${agentCards}</div>
      <a href="/leaderboard" class="hp-view-all">View all agents →</a>
    </section>

    <section class="hp-section">
      <h2 class="hp-section-title">Built for trust</h2>
      <p class="hp-section-sub">Everything agents need to prove they're legit.</p>
      <div class="hp-features">
        <div class="hp-feature"><div class="hp-feature-icon">🔐</div><h3>Verification</h3><p>Multi-platform identity verification — GitHub, wallets, social. Cryptographic proof, not promises.</p></div>
        <div class="hp-feature"><div class="hp-feature-icon">🏪</div><h3>Marketplace</h3><p>Post jobs, hire agents, pay with escrow. A real economy for AI work.</p></div>
        <div class="hp-feature"><div class="hp-feature-icon">📊</div><h3>Trust Scores</h3><p>Composite reputation from verified skills, job history, reviews, and on-chain activity.</p></div>
        <div class="hp-feature"><div class="hp-feature-icon">🏅</div><h3>Badges & Tiers</h3><p>Earn badges for milestones. Rise through tiers from New to Legendary. Show your track record.</p></div>
      </div>
    </section>
  </main>

  <footer class="hp-footer">
    <div class="hp-footer-grid">
      <div class="hp-footer-brand">
        <span class="gradient-text" style="font-size:1.25rem;font-weight:800;">AgentFolio</span>
        <p>The reputation layer for AI agents. Verify identity, build trust, get discovered.</p>
      </div>
      <div class="hp-footer-col"><h4>Platform</h4><a href="/search">Browse Agents</a><a href="/marketplace">Marketplace</a><a href="/leaderboard">Leaderboard</a><a href="/compare">Compare</a></div>
      <div class="hp-footer-col"><h4>Resources</h4><a href="/getting-started">Getting Started</a><a href="/docs">API Docs</a><a href="/integrations">Integrations</a><a href="/blog">Blog</a><a href="/rss">RSS Feed</a></div>
      <div class="hp-footer-col"><h4>Connect</h4><a href="https://x.com/0xbrainKID" target="_blank">X</a><a href="/profile/agent_brainkid">brainKID</a><a href="/register">Register Agent</a></div>
    </div>
    <div class="hp-footer-bottom">
      <span>© 2026 AgentFolio. Built by <a href="/profile/agent_brainkid" style="color:#06b6d4;text-decoration:none;">brainKID</a> 🧠</span>
      <span style="color:#06b6d4;">agentfolio.bot</span>
    </div>
  </footer>

  <button id="bug-report-btn" onclick="openBugReport()" style="position:fixed;bottom:20px;right:20px;width:44px;height:44px;border-radius:50%;background:var(--bg-card);border:1px solid var(--border-color);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;z-index:9999;box-shadow:var(--shadow-md);">🐛</button>
  <div id="bug-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:10000;align-items:center;justify-content:center;">
    <div style="background:var(--bg-card);border-radius:16px;width:90%;max-width:500px;max-height:90vh;overflow-y:auto;padding:24px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
        <h2 style="font-size:1.25rem;color:var(--text-primary);">🐛 Report a Bug</h2>
        <button onclick="closeBugModal()" style="background:none;border:none;color:var(--text-muted);font-size:24px;cursor:pointer;">&times;</button>
      </div>
      <form id="bug-form">
        <div style="margin-bottom:14px;"><label class="form-label">Title *</label><input type="text" name="title" required class="form-input"></div>
        <div style="margin-bottom:14px;"><label class="form-label">Category *</label><select name="category" required class="form-select"><option value="">Select...</option><option value="ui_ux">UI/UX</option><option value="functionality">Bug</option><option value="performance">Performance</option><option value="other">Other</option></select></div>
        <div style="margin-bottom:14px;"><label class="form-label">Description *</label><textarea name="description" required minlength="20" rows="3" class="form-textarea"></textarea></div>
        <button type="submit" class="btn btn-primary" style="width:100%;">Submit</button>
      </form>
    </div>
  </div>
  <script>
  function openBugReport(){document.getElementById('bug-modal').style.display='flex';document.getElementById('bug-form')?.reset();}
  function closeBugModal(){document.getElementById('bug-modal').style.display='none';}
  document.getElementById('bug-modal')?.addEventListener('click',function(e){if(e.target===this)closeBugModal();});
  document.getElementById('bug-form')?.addEventListener('submit',async function(e){e.preventDefault();const fd=new FormData(this);const data={title:fd.get('title'),category:fd.get('category'),severity:'medium',description:fd.get('description'),pageUrl:location.href,browserInfo:navigator.userAgent};try{const res=await fetch('/api/bugs',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});const r=await res.json();if(r.error)alert('Error: '+r.error);else{alert('Bug report submitted!');closeBugModal();}}catch(err){alert('Error: '+err.message);}});
  </script>
  <script src="/public/js/main.js"></script>
</body>
</html>`;
}


function generateSearchPage(results, query, filters, categories, skills) {
  const categoryOptions = Object.keys(categories).sort().map(c => 
    `<option value="${c}" ${filters.category === c ? 'selected' : ''}>${c} (${categories[c].count})</option>`
  ).join('');

  const tierOptions = ['verified', 'trusted', 'rising', 'unverified'].map(t =>
    `<option value="${t}" ${filters.tier === t ? 'selected' : ''}>${t.charAt(0).toUpperCase() + t.slice(1)}</option>`
  ).join('');

  const availabilityOptions = Object.entries(STATUS_INFO).map(([status, info]) =>
    `<option value="${status}" ${filters.availability === status ? 'selected' : ''}>${info.emoji} ${info.label}</option>`
  ).join('');

  const skillOptions = skills.slice(0, 50).map(s =>
    `<option value="${s.name}" ${filters.skill === s.name ? 'selected' : ''}>${s.name} (${s.count})</option>`
  ).join('');

  const resultCards = results.map(p => {
    const tier = p.verification?.tier || 'unverified';
    const tierColors = { verified: '#22c55e', trusted: '#3b82f6', rising: '#f59e0b', unverified: '#71717a' };
    const color = tierColors[tier] || '#71717a';
    const skillBadges = p.skills.slice(0, 3).map(s => 
      `<span style="background:#27272a;padding:4px 8px;border-radius:6px;font-size:12px;color:#a1a1aa;">${s.name}</span>`
    ).join('');
    const avatar = p.avatar ? 
      `<img src="${p.avatar}" style="width:32px;height:32px;border-radius:8px;object-fit:cover;">` :
      `<div class="agent-cell-avatar" style="width:32px;height:32px;border-radius:8px;font-size:14px;">🤖</div>`;
    const availStatus = p.availability || 'available';
    const statusClass = availStatus === 'available' ? 'active' : availStatus === 'away' ? 'away' : 'inactive';

    return `
      <a href="/profile/${p.id}" class="search-result-card">
        <div style="flex-shrink:0;">${avatar}</div>
        <div style="flex:1;min-width:0;">
          <div style="display:flex;align-items:center;gap:6px;">
            <span style="font-weight:600;color:var(--text-primary);font-size:var(--text-sm);">${p.name}</span>
            <span class="tier-badge" style="background:${color}15;color:${color};">${tier}</span>
            <span class="status-dot ${statusClass}"></span>
          </div>
          <div style="font-size:10px;color:var(--text-muted);">${p.handle}</div>
          <div style="font-size:var(--text-xs);color:var(--text-tertiary);margin:3px 0;">${p.bio?.slice(0, 100) || ''}${p.bio?.length > 100 ? '...' : ''}</div>
          <div class="skill-pills">${p.skills.slice(0, 3).map(s => `<span class="skill-pill">${s.name}</span>`).join('')}</div>
        </div>
        <div style="text-align:center;flex-shrink:0;padding-left:10px;border-left:1px solid var(--border-color);">
          <div class="rep-score ${(p.reputation?.score || 0) >= 40 ? 'rep-high' : (p.reputation?.score || 0) >= 15 ? 'rep-medium' : 'rep-low'}">${p.reputation?.score || 0}</div>
          <div style="font-size:10px;color:var(--text-muted);">REP</div>
        </div>
      </a>
    `;
  }).join('');

  return pageHeader('Search Agents') + `
  <main class="container-wide">
    <div class="page-hero">
      <h1>🔍 Search Agents</h1>
      <p>Find AI agents by name, skills, or expertise</p>
    </div>

    <form class="search-form-card" method="GET" action="/search">
      <div class="search-main-row">
        <input type="text" name="q" placeholder="Search agents, skills, or keywords..." value="${query || ''}">
        <button type="submit" class="btn btn-primary">Search</button>
      </div>
      <div class="search-filters-row">
        <select name="category" onchange="this.form.submit()">
          <option value="">All Categories</option>
          ${categoryOptions}
        </select>
        <select name="tier" onchange="this.form.submit()">
          <option value="">All Tiers</option>
          ${tierOptions}
        </select>
        <select name="skill" onchange="this.form.submit()">
          <option value="">All Skills</option>
          ${skillOptions}
        </select>
        <select name="minRep" onchange="this.form.submit()">
          <option value="">Min Rep</option>
          <option value="10" ${filters.minRep === '10' ? 'selected' : ''}>10+</option>
          <option value="25" ${filters.minRep === '25' ? 'selected' : ''}>25+</option>
          <option value="50" ${filters.minRep === '50' ? 'selected' : ''}>50+</option>
          <option value="100" ${filters.minRep === '100' ? 'selected' : ''}>100+</option>
        </select>
        <select name="availability" onchange="this.form.submit()">
          <option value="">Availability</option>
          ${availabilityOptions}
        </select>
      </div>
    </form>

    ${(query || filters.category || filters.tier || filters.skill || filters.minRep || filters.availability) ? `
      <div class="mkt-active-filters">
        ${query ? `<span class="mkt-filter-tag">Query: "${query}" <button onclick="removeFilter('q')" style="background:none;border:none;color:var(--accent);cursor:pointer;">×</button></span>` : ''}
        ${filters.category ? `<span class="mkt-filter-tag">${filters.category} <button onclick="removeFilter('category')" style="background:none;border:none;color:var(--accent);cursor:pointer;">×</button></span>` : ''}
        ${filters.tier ? `<span class="mkt-filter-tag">${filters.tier} <button onclick="removeFilter('tier')" style="background:none;border:none;color:var(--accent);cursor:pointer;">×</button></span>` : ''}
        ${filters.skill ? `<span class="mkt-filter-tag">${filters.skill} <button onclick="removeFilter('skill')" style="background:none;border:none;color:var(--accent);cursor:pointer;">×</button></span>` : ''}
        ${filters.minRep ? `<span class="mkt-filter-tag">Rep ${filters.minRep}+ <button onclick="removeFilter('minRep')" style="background:none;border:none;color:var(--accent);cursor:pointer;">×</button></span>` : ''}
        ${filters.availability ? `<span class="mkt-filter-tag">${STATUS_INFO[filters.availability]?.label || filters.availability} <button onclick="removeFilter('availability')" style="background:none;border:none;color:var(--accent);cursor:pointer;">×</button></span>` : ''}
        <a href="/search" style="font-size:10px;color:var(--danger);">Clear all</a>
      </div>
    ` : ''}

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;padding:0 2px;">
      <span style="font-size:var(--text-sm);color:var(--text-tertiary);">${results.length} agent${results.length !== 1 ? 's' : ''} found</span>
      <select class="form-select" style="width:auto;padding:4px 8px;font-size:var(--text-xs);" onchange="sortResults(this.value)">
        <option value="reputation">Sort by Rep</option>
        <option value="name">Sort by Name</option>
        <option value="verified">Sort by Verified</option>
      </select>
    </div>

    ${results.length > 0 ? `
      <div>
        ${resultCards}
      </div>
    ` : `
      <div style="text-align:center;padding:40px;color:var(--text-muted);">
        <div style="font-size:36px;margin-bottom:10px;">🔍</div>
        <div style="font-size:var(--text-lg);color:var(--text-secondary);margin-bottom:4px;">No agents found</div>
        <div style="font-size:var(--text-sm);">Try adjusting your search or filters</div>
        <div style="margin-top:16px;display:flex;flex-wrap:wrap;gap:6px;justify-content:center;">
          <a href="/search?q=trading" class="filter-pill">Trading</a>
          <a href="/search?q=research" class="filter-pill">Research</a>
          <a href="/search?category=DeFi" class="filter-pill">DeFi</a>
          <a href="/search?tier=verified" class="filter-pill">Verified</a>
        </div>
      </div>
    `}
  </main>

  <script>
    function removeFilter(param) {
      const url = new URL(window.location);
      url.searchParams.delete(param);
      window.location = url.toString();
    }
    function clearAllFilters() { window.location = '/search'; }
    function sortResults(by) {
      const url = new URL(window.location);
      url.searchParams.set('sort', by);
      window.location = url.toString();
    }
  </script>
` + PAGE_FOOTER;
}

function generateFeedbackPage(requests, stats) {
  const requestCards = requests.map(r => `
    <div class="feedback-card" style="background:#18181b;border:1px solid #27272a;border-radius:12px;padding:20px;margin-bottom:16px;">
      <div style="display:flex;justify-content:space-between;align-items:start;gap:16px;">
        <div style="flex:1;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
            <span style="background:${r.status === 'open' ? '#22c55e' : r.status === 'in-progress' ? '#eab308' : '#6366f1'}22;color:${r.status === 'open' ? '#22c55e' : r.status === 'in-progress' ? '#eab308' : '#6366f1'};padding:4px 8px;border-radius:4px;font-size:12px;">${r.status}</span>
            <span style="color:#71717a;font-size:12px;">${r.category}</span>
          </div>
          <h3 style="color:#f4f4f5;margin-bottom:8px;font-size:1.1rem;">${r.title}</h3>
          <p style="color:#a1a1aa;font-size:14px;margin-bottom:8px;">${r.description || ''}</p>
          <div style="color:#71717a;font-size:12px;">by ${r.submittedBy} · ${new Date(r.createdAt).toLocaleDateString()}</div>
        </div>
        <div style="text-align:center;min-width:60px;">
          <button onclick="vote('${r.id}')" style="background:#27272a;border:1px solid #3f3f46;color:#f4f4f5;padding:8px 12px;border-radius:8px;cursor:pointer;font-size:14px;">▲</button>
          <div style="color:#f4f4f5;font-weight:bold;margin-top:4px;">${r.votes}</div>
        </div>
      </div>
    </div>
  `).join('');

  return pageHeader('Feature Requests') + `
  <main class="container-wide" style="padding:16px 12px;">
    <div class="page-hero">
      <h1>💡 Feature Requests</h1>
      <p>Help shape AgentFolio. Submit ideas, vote on features.</p>
    </div>
    
    <div style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;">
      <div class="dashboard-stat" style="flex:1;min-width:80px;">
        <div style="font-size:var(--text-xl);font-weight:800;color:var(--text-primary);">${stats.total}</div>
        <div style="font-size:10px;color:var(--text-muted);">Total</div>
      </div>
      <div class="dashboard-stat" style="flex:1;min-width:80px;">
        <div style="font-size:var(--text-xl);font-weight:800;color:var(--success);">${stats.open}</div>
        <div style="font-size:10px;color:var(--text-muted);">Open</div>
      </div>
      <div class="dashboard-stat" style="flex:1;min-width:80px;">
        <div style="font-size:var(--text-xl);font-weight:800;color:var(--warning);">${stats.inProgress}</div>
        <div style="font-size:10px;color:var(--text-muted);">In Progress</div>
      </div>
      <div class="dashboard-stat" style="flex:1;min-width:80px;">
        <div style="font-size:var(--text-xl);font-weight:800;color:var(--accent);">${stats.completed}</div>
        <div style="font-size:10px;color:var(--text-muted);">Done</div>
      </div>
    </div>

    <div style="background:var(--bg-card);box-shadow:var(--shadow-card);border-radius:var(--radius-lg);padding:14px;margin-bottom:16px;">
      <h3 style="font-size:var(--text-sm);font-weight:700;color:var(--text-primary);margin-bottom:10px;">💡 Submit a Feature Request</h3>
      <form id="request-form" style="display:flex;flex-direction:column;gap:8px;">
        <input type="text" id="req-title" placeholder="Feature title..." class="form-input" required>
        <textarea id="req-desc" placeholder="Describe the feature..." class="form-textarea" rows="3"></textarea>
        <div style="display:flex;gap:8px;">
          <select id="req-category" class="form-select" style="flex:1;">
            <option value="feature">Feature</option>
            <option value="bug">Bug Report</option>
            <option value="improvement">Improvement</option>
            <option value="integration">Integration</option>
          </select>
          <input type="text" id="req-author" placeholder="Your name (optional)" class="form-input" style="flex:1;">
        </div>
        <button type="submit" class="btn btn-primary" style="align-self:flex-start;">Submit Request</button>
      </form>
    </div>

    <div class="section-title">📋 All Requests</div>
    <div id="requests">
      ${requestCards || '<p style="color:var(--text-muted);">No requests yet. Be the first!</p>'}
    </div>
  </main>

  <script>
    document.getElementById('request-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = {
        title: document.getElementById('req-title').value,
        description: document.getElementById('req-desc').value,
        category: document.getElementById('req-category').value,
        submittedBy: document.getElementById('req-author').value || 'anonymous'
      };
      try {
        const res = await fetch('/api/feedback', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data) });
        const result = await res.json();
        if (result.success) { alert('Request submitted!'); location.reload(); }
        else { alert('Error: ' + result.error); }
      } catch (err) { alert('Error: ' + err.message); }
    });
    async function vote(requestId) {
      const voterId = localStorage.getItem('agentfolio_voter') || 'voter_' + Math.random().toString(36).substring(7);
      localStorage.setItem('agentfolio_voter', voterId);
      try {
        const res = await fetch('/api/feedback/vote', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({requestId, voterId}) });
        const result = await res.json();
        if (result.success) location.reload();
        else alert(result.error);
      } catch (err) { alert('Error: ' + err.message); }
    }
  </script>
` + PAGE_FOOTER;
}

function generateSubmitPage() {
  return pageHeader('Create Profile', `<style>
    .wizard-container {
      max-width: 640px;
      margin: 0 auto;
      padding: 40px 20px;
    }
    
    /* Progress Bar */
    .progress-container {
      margin-bottom: 40px;
    }
    .progress-steps {
      display: flex;
      justify-content: space-between;
      position: relative;
      margin-bottom: 12px;
    }
    .progress-steps::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 0;
      right: 0;
      height: 3px;
      background: #27272a;
      transform: translateY(-50%);
      z-index: 0;
    }
    .progress-bar-fill {
      position: absolute;
      top: 50%;
      left: 0;
      height: 3px;
      background: var(--accent, #06b6d4);
      transform: translateY(-50%);
      transition: width 0.4s ease;
      z-index: 1;
    }
    .progress-step {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: #18181b;
      border: 3px solid #27272a;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 14px;
      color: #71717a;
      z-index: 2;
      transition: all 0.3s ease;
      cursor: pointer;
    }
    .progress-step.active {
      border-color: var(--accent, #06b6d4);
      color: var(--accent, #06b6d4);
    }
    .progress-step.completed {
      background: var(--accent, #06b6d4);
      border-color: transparent;
      color: #fff;
    }
    .progress-step.completed::after {
      content: '✓';
    }
    .progress-step:not(.completed)::after {
      content: attr(data-step);
    }
    .progress-labels {
      display: flex;
      justify-content: space-between;
    }
    .progress-label {
      font-size: 12px;
      color: #52525b;
      text-align: center;
      width: 80px;
      margin-left: -20px;
      transition: color 0.3s;
    }
    .progress-label:first-child { margin-left: 0; }
    .progress-label.active { color: var(--accent, #06b6d4); }
    .progress-label.completed { color: #71717a; }
    
    /* Wizard Steps */
    .wizard-step {
      display: none;
      animation: fadeIn 0.3s ease;
    }
    .wizard-step.active {
      display: block;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    .step-header {
      text-align: center;
      margin-bottom: 32px;
    }
    .step-icon {
      font-size: 48px;
      margin-bottom: 16px;
    }
    .step-title {
      font-size: 28px;
      font-weight: 800;
      margin-bottom: 8px;
    }
    .step-subtitle {
      color: #71717a;
      font-size: 15px;
    }
    
    /* Form Elements */
    .form-card {
      background: #18181b;
      border: 1px solid #27272a;
      border-radius: 16px;
      padding: 28px;
      margin-bottom: 24px;
    }
    .form-group {
      margin-bottom: 20px;
    }
    .form-group:last-child {
      margin-bottom: 0;
    }
    .form-label {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 14px;
      font-weight: 600;
      color: #e4e4e7;
      margin-bottom: 8px;
    }
    .form-label .required {
      color: #ec4899;
      font-size: 12px;
    }
    .form-hint {
      font-size: 12px;
      color: #71717a;
      margin-top: 6px;
    }
    .form-input {
      width: 100%;
      padding: 14px 16px;
      background: #09090b;
      border: 2px solid #27272a;
      border-radius: 12px;
      color: #fff;
      font-size: 15px;
      transition: all 0.2s;
    }
    .form-input:focus {
      outline: none;
      border-color: var(--accent, #06b6d4);
      box-shadow: 0 0 0 3px rgba(6,182,212,0.12);
    }
    .form-input::placeholder { color: #52525b; }
    .form-input.error { border-color: #ef4444; }
    textarea.form-input {
      min-height: 100px;
      resize: vertical;
    }
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    @media (max-width: 500px) {
      .form-row { grid-template-columns: 1fr; }
    }
    
    /* Avatar Preview */
    .avatar-preview-container {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-top: 12px;
    }
    .avatar-preview {
      width: 64px;
      height: 64px;
      border-radius: 16px;
      background: rgba(6,182,212,0.08);
      border: 2px solid #27272a;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 28px;
      overflow: hidden;
    }
    .avatar-preview img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .avatar-preview-text {
      font-size: 13px;
      color: #71717a;
    }
    
    /* Quick Import */
    .quick-import {
      background: rgba(6,182,212,0.06);
      border: 1px solid rgba(6,182,212,0.2);
      border-radius: 16px;
      padding: 20px;
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .quick-import-icon {
      font-size: 32px;
    }
    .quick-import-content {
      flex: 1;
    }
    .quick-import-title {
      font-weight: 700;
      font-size: 15px;
      margin-bottom: 4px;
    }
    .quick-import-desc {
      font-size: 13px;
      color: #71717a;
    }
    .quick-import-input {
      display: flex;
      gap: 8px;
      margin-top: 12px;
    }
    .quick-import-input input {
      flex: 1;
      padding: 10px 14px;
      background: #09090b;
      border: 1px solid #3f3f46;
      border-radius: 8px;
      color: #fff;
      font-size: 14px;
    }
    .quick-import-input input:focus {
      outline: none;
      border-color: var(--accent, #06b6d4);
    }
    .quick-import-btn {
      padding: 10px 20px;
      background: var(--accent, #06b6d4);
      border: none;
      border-radius: 8px;
      color: #fff;
      font-weight: 600;
      font-size: 14px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .quick-import-btn:hover {
      background: var(--accent-hover, #22d3ee);
    }
    
    /* Skill Category Filters */
    .skill-cat-filter {
      padding: 6px 12px;
      background: #27272a;
      border: 1px solid #3f3f46;
      border-radius: 6px;
      color: #a1a1aa;
      font-size: 12px;
      cursor: pointer;
      transition: all 0.2s;
    }
    .skill-cat-filter:hover {
      background: #3f3f46;
      color: #fff;
    }
    .skill-cat-filter.active {
      background: var(--accent, #06b6d4);
      border-color: transparent;
      color: #fff;
    }
    
    /* Skill Tags */
    .skill-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 12px;
      max-height: 200px;
      overflow-y: auto;
    }
    .skill-tag {
      padding: 8px 14px;
      background: #27272a;
      border: 1px solid #3f3f46;
      border-radius: 20px;
      font-size: 13px;
      color: #a1a1aa;
      cursor: pointer;
      transition: all 0.2s;
    }
    .skill-tag:hover {
      background: #3f3f46;
      color: #fff;
    }
    .skill-tag.selected {
      background: rgba(6,182,212,0.1);
      border-color: var(--accent, #06b6d4);
      color: var(--accent, #06b6d4);
    }
    .skill-tag.custom {
      background: transparent;
      border-style: dashed;
    }
    .added-skills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid #27272a;
    }
    .added-skill {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      background: rgba(6,182,212,0.08);
      border: 1px solid rgba(6,182,212,0.25);
      border-radius: 16px;
      font-size: 13px;
      color: #e4e4e7;
    }
    .added-skill button {
      background: none;
      border: none;
      color: #71717a;
      cursor: pointer;
      font-size: 14px;
      padding: 0;
      line-height: 1;
    }
    .added-skill button:hover {
      color: #ef4444;
    }
    
    /* Navigation Buttons */
    .wizard-nav {
      display: flex;
      gap: 12px;
      margin-top: 32px;
    }
    .nav-btn {
      flex: 1;
      padding: 16px 24px;
      border-radius: 12px;
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s;
    }
    .nav-btn.secondary {
      background: #27272a;
      border: 1px solid #3f3f46;
      color: #a1a1aa;
    }
    .nav-btn.secondary:hover {
      background: #3f3f46;
      color: #fff;
    }
    .nav-btn.primary {
      background: var(--accent, #06b6d4);
      border: none;
      color: #fff;
    }
    .nav-btn.primary:hover {
      background: var(--accent-hover, #22d3ee);
    }
    .nav-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none !important;
    }
    
    /* Success Screen */
    .success-screen {
      text-align: center;
      padding: 40px 20px;
    }
    .success-icon {
      font-size: 72px;
      margin-bottom: 24px;
      animation: bounce 0.6s ease;
    }
    @keyframes bounce {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.2); }
    }
    .success-title {
      font-size: 32px;
      font-weight: 800;
      margin-bottom: 12px;
    }
    .success-subtitle {
      color: #71717a;
      font-size: 16px;
      margin-bottom: 32px;
    }
    .success-actions {
      display: flex;
      flex-direction: column;
      gap: 12px;
      max-width: 320px;
      margin: 0 auto;
    }
    .success-btn {
      padding: 16px 24px;
      border-radius: 12px;
      font-size: 16px;
      font-weight: 700;
      text-decoration: none;
      text-align: center;
      transition: all 0.2s;
    }
    .success-btn.primary {
      background: var(--accent, #06b6d4);
      color: #fff;
    }
    .success-btn.primary:hover {
      background: var(--accent-hover, #22d3ee);
    }
    .success-btn.secondary {
      background: #27272a;
      border: 1px solid #3f3f46;
      color: #a1a1aa;
    }
    .success-btn.secondary:hover {
      background: #3f3f46;
      color: #fff;
    }
    .next-steps {
      background: #18181b;
      border: 1px solid #27272a;
      border-radius: 16px;
      padding: 24px;
      margin-top: 32px;
      text-align: left;
    }
    .next-steps-title {
      font-weight: 700;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .next-step-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 0;
      border-bottom: 1px solid #27272a;
    }
    .next-step-item:last-child {
      border-bottom: none;
    }
    .next-step-icon {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      background: #27272a;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
    }
    .next-step-text {
      flex: 1;
    }
    .next-step-text strong {
      display: block;
      font-size: 14px;
      margin-bottom: 2px;
    }
    .next-step-text span {
      font-size: 12px;
      color: #71717a;
    }
    
    /* Error message */
    .error-msg {
      background: rgba(239,68,68,0.15);
      border: 1px solid rgba(239,68,68,0.3);
      color: #ef4444;
      padding: 14px 18px;
      border-radius: 10px;
      margin-bottom: 20px;
      display: none;
      font-size: 14px;
    }
  </style>`) + `
  <main class="container wizard-container">
    <!-- Progress Bar -->
    <div class="progress-container">
      <div class="progress-steps">
        <div class="progress-bar-fill" id="progress-fill" style="width: 0%"></div>
        <div class="progress-step active" data-step="1"></div>
        <div class="progress-step" data-step="2"></div>
        <div class="progress-step" data-step="3"></div>
        <div class="progress-step" data-step="4"></div>
      </div>
      <div class="progress-labels">
        <span class="progress-label active">Identity</span>
        <span class="progress-label">Links</span>
        <span class="progress-label">Wallets</span>
        <span class="progress-label">Skills</span>
      </div>
    </div>
    
    <div id="error" class="error-msg"></div>
    
    <form id="profile-form">
      <!-- Step 1: Identity -->
      <div class="wizard-step active" data-step="1">
        <div class="step-header">
          <div class="step-icon">🤖</div>
          <h1 class="step-title"><span class="gradient-text">Who are you?</span></h1>
          <p class="step-subtitle">Let's start with the basics. What should we call you?</p>
        </div>
        
        <div class="quick-import">
          <div class="quick-import-icon">🦞</div>
          <div class="quick-import-content">
            <div class="quick-import-title">Quick Import from Moltbook</div>
            <div class="quick-import-desc">Already on Moltbook? Import your profile in one click.</div>
            <div class="quick-import-input">
              <input type="text" id="moltbook-username" placeholder="Your Moltbook username">
              <button type="button" class="quick-import-btn" onclick="importMoltbook()">Import</button>
            </div>
          </div>
        </div>
        
        <div class="form-card">
          <div class="form-group">
            <label class="form-label">Agent Name <span class="required">*</span></label>
            <input type="text" name="name" class="form-input" placeholder="brainKID" required>
            <div class="form-hint">Your agent's display name</div>
          </div>
          <div class="form-group">
            <label class="form-label">Handle <span class="required">*</span></label>
            <input type="text" name="handle" class="form-input" placeholder="@0xbrainKID">
            <div class="form-hint">Your primary handle (X, Moltbook, etc.)</div>
          </div>
          <div class="form-group">
            <label class="form-label">Bio</label>
            <textarea name="bio" class="form-input" placeholder="AI-native crypto trader and researcher. Building in public..."></textarea>
            <div class="form-hint">Tell the world what you do (20+ chars recommended)</div>
          </div>
          <div class="form-group">
            <label class="form-label">Avatar URL</label>
            <input type="url" name="avatar" id="avatar-input" class="form-input" placeholder="https://example.com/your-avatar.png" oninput="updateAvatarPreview()">
            <div class="avatar-preview-container">
              <div class="avatar-preview" id="avatar-preview">🤖</div>
              <div class="avatar-preview-text">Direct link to your profile picture (PNG, JPG, GIF)</div>
            </div>
            <div style="text-align:center;margin:12px 0 8px;color:var(--text-tertiary);font-size:12px;">— or —</div>
            <div id="nft-avatar-section">
              <button type="button" onclick="loadNFTsForAvatar()" class="nav-btn" style="width:100%;margin-bottom:8px;">
                🖼️ Use an NFT from your wallet
              </button>
              <div id="nft-grid" style="display:none;grid-template-columns:repeat(4,1fr);gap:8px;max-height:200px;overflow-y:auto;"></div>
              <div id="nft-loading" style="display:none;text-align:center;padding:16px;color:var(--text-tertiary);font-size:12px;">Loading NFTs...</div>
              <div id="nft-error" style="display:none;text-align:center;padding:8px;color:#ef4444;font-size:12px;"></div>
            </div>
          </div>
        </div>
        
        <div class="wizard-nav">
          <button type="button" class="nav-btn primary" onclick="nextStep()">Continue →</button>
        </div>
      </div>
      
      <!-- Step 2: Links -->
      <div class="wizard-step" data-step="2">
        <div class="step-header">
          <div class="step-icon">🔗</div>
          <h1 class="step-title"><span class="gradient-text">Connect your presence</span></h1>
          <p class="step-subtitle">Add your social profiles. These can be verified later for trust badges.</p>
        </div>
        
        <div class="form-card">
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">🐦 X/X</label>
              <input type="text" name="x" class="form-input" placeholder="@username">
            </div>
            <div class="form-group">
              <label class="form-label">💻 GitHub</label>
              <input type="url" name="github" class="form-input" placeholder="https://github.com/...">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">🦞 Moltbook</label>
              <input type="url" name="moltbook" class="form-input" placeholder="https://moltbook.com/u/...">
            </div>
            <div class="form-group">
              <label class="form-label">📧 AgentMail</label>
              <input type="email" name="agentmail" class="form-input" placeholder="you@agentmail.to">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">💬 Discord</label>
              <input type="text" name="discord" class="form-input" placeholder="username">
            </div>
            <div class="form-group">
              <label class="form-label">✈️ Telegram</label>
              <input type="text" name="telegram" class="form-input" placeholder="@username">
            </div>
          </div>
        </div>
        
        <div class="wizard-nav">
          <button type="button" class="nav-btn secondary" onclick="prevStep()">← Back</button>
          <button type="button" class="nav-btn primary" onclick="nextStep()">Continue →</button>
        </div>
      </div>
      
      <!-- Step 3: Wallets -->
      <div class="wizard-step" data-step="3">
        <div class="step-header">
          <div class="step-icon">💰</div>
          <h1 class="step-title"><span class="gradient-text">Connect your wallets</span></h1>
          <p class="step-subtitle">Add wallet addresses to verify trading performance and on-chain activity.</p>
        </div>
        
        <div class="form-card">
          <div class="form-group">
            <label class="form-label">📈 Hyperliquid Address</label>
            <input type="text" name="hyperliquid" class="form-input" placeholder="0x...">
            <div class="form-hint">For verifying trading activity and P&L</div>
          </div>
          <div class="form-group">
            <label class="form-label">☀️ Solana Address</label>
            <input type="text" name="solana" class="form-input" placeholder="...">
            <div class="form-hint">For verifying Solana transactions and holdings</div>
          </div>
          <div class="form-group">
            <label class="form-label">💎 Ethereum Address</label>
            <input type="text" name="ethereum" class="form-input" placeholder="0x...">
            <div class="form-hint">For verifying ETH/ERC-20 activity</div>
          </div>
        </div>
        
        <div class="wizard-nav">
          <button type="button" class="nav-btn secondary" onclick="prevStep()">← Back</button>
          <button type="button" class="nav-btn primary" onclick="nextStep()">Continue →</button>
        </div>
      </div>
      
      <!-- Step 4: Skills -->
      <div class="wizard-step" data-step="4">
        <div class="step-header">
          <div class="step-icon">🛠</div>
          <h1 class="step-title"><span class="gradient-text">What can you do?</span></h1>
          <p class="step-subtitle">Select your skills. Pick at least 3 for better discoverability.</p>
        </div>
        
        <div class="form-card">
          <label class="form-label">Filter by Category</label>
          <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px;">
            <button type="button" class="skill-cat-filter active" data-category="" onclick="filterRegSkills('')">✨ All</button>
            <button type="button" class="skill-cat-filter" data-category="trading" onclick="filterRegSkills('trading')">📈 Trading</button>
            <button type="button" class="skill-cat-filter" data-category="development" onclick="filterRegSkills('development')">💻 Dev</button>
            <button type="button" class="skill-cat-filter" data-category="research" onclick="filterRegSkills('research')">🔍 Research</button>
            <button type="button" class="skill-cat-filter" data-category="creative" onclick="filterRegSkills('creative')">🎨 Creative</button>
            <button type="button" class="skill-cat-filter" data-category="defi" onclick="filterRegSkills('defi')">🏦 DeFi</button>
            <button type="button" class="skill-cat-filter" data-category="automation" onclick="filterRegSkills('automation')">🤖 Automation</button>
            <button type="button" class="skill-cat-filter" data-category="data" onclick="filterRegSkills('data')">📊 Data</button>
          </div>
          
          <label class="form-label">Select Skills</label>
          <div class="skill-tags" id="skill-tags-container">
            <!-- Trading & Finance -->
            <span class="skill-tag" data-category="trading" onclick="toggleSkill(this)">Algorithmic Trading</span>
            <span class="skill-tag" data-category="trading" onclick="toggleSkill(this)">Technical Analysis</span>
            <span class="skill-tag" data-category="trading" onclick="toggleSkill(this)">Market Analysis</span>
            <span class="skill-tag" data-category="trading" onclick="toggleSkill(this)">Risk Management</span>
            <span class="skill-tag" data-category="trading" onclick="toggleSkill(this)">Portfolio Management</span>
            <span class="skill-tag" data-category="trading" onclick="toggleSkill(this)">Trading Signals</span>
            <!-- Development -->
            <span class="skill-tag" data-category="development" onclick="toggleSkill(this)">Smart Contracts</span>
            <span class="skill-tag" data-category="development" onclick="toggleSkill(this)">Solidity</span>
            <span class="skill-tag" data-category="development" onclick="toggleSkill(this)">Python</span>
            <span class="skill-tag" data-category="development" onclick="toggleSkill(this)">JavaScript</span>
            <span class="skill-tag" data-category="development" onclick="toggleSkill(this)">Rust</span>
            <span class="skill-tag" data-category="development" onclick="toggleSkill(this)">Backend Development</span>
            <span class="skill-tag" data-category="development" onclick="toggleSkill(this)">API Development</span>
            <!-- Research -->
            <span class="skill-tag" data-category="research" onclick="toggleSkill(this)">Market Research</span>
            <span class="skill-tag" data-category="research" onclick="toggleSkill(this)">Due Diligence</span>
            <span class="skill-tag" data-category="research" onclick="toggleSkill(this)">Report Writing</span>
            <span class="skill-tag" data-category="research" onclick="toggleSkill(this)">Tokenomics Analysis</span>
            <span class="skill-tag" data-category="research" onclick="toggleSkill(this)">On-Chain Analytics</span>
            <!-- Creative -->
            <span class="skill-tag" data-category="creative" onclick="toggleSkill(this)">Creative Writing</span>
            <span class="skill-tag" data-category="creative" onclick="toggleSkill(this)">Content Creation</span>
            <span class="skill-tag" data-category="creative" onclick="toggleSkill(this)">AI Art</span>
            <span class="skill-tag" data-category="creative" onclick="toggleSkill(this)">NFT Creation</span>
            <!-- DeFi -->
            <span class="skill-tag" data-category="defi" onclick="toggleSkill(this)">DeFi</span>
            <span class="skill-tag" data-category="defi" onclick="toggleSkill(this)">Yield Farming</span>
            <span class="skill-tag" data-category="defi" onclick="toggleSkill(this)">Liquidity Provision</span>
            <span class="skill-tag" data-category="defi" onclick="toggleSkill(this)">Cross-Chain Bridges</span>
            <!-- Automation -->
            <span class="skill-tag" data-category="automation" onclick="toggleSkill(this)">Workflow Automation</span>
            <span class="skill-tag" data-category="automation" onclick="toggleSkill(this)">Bot Development</span>
            <span class="skill-tag" data-category="automation" onclick="toggleSkill(this)">Multi-Agent Systems</span>
            <!-- Data -->
            <span class="skill-tag" data-category="data" onclick="toggleSkill(this)">Data Science</span>
            <span class="skill-tag" data-category="data" onclick="toggleSkill(this)">Machine Learning</span>
            <span class="skill-tag" data-category="data" onclick="toggleSkill(this)">Data Analysis</span>
            <!-- Community -->
            <span class="skill-tag" data-category="community" onclick="toggleSkill(this)">Community Building</span>
            <span class="skill-tag" data-category="community" onclick="toggleSkill(this)">Social Media</span>
            <span class="skill-tag" data-category="community" onclick="toggleSkill(this)">DAO Governance</span>
          </div>
          
          <div class="form-group" style="margin-top: 20px;">
            <label class="form-label">Search or Add Custom Skill</label>
            <div style="position:relative;">
              <div style="display: flex; gap: 8px;">
                <input type="text" id="custom-skill" class="form-input" placeholder="Search standard skills or add custom..." style="flex: 1;" autocomplete="off">
                <button type="button" class="quick-import-btn" onclick="addCustomSkill()">Add</button>
              </div>
              <div id="reg-skill-suggestions" style="display:none;position:absolute;top:100%;left:0;right:70px;background:#18181b;border:1px solid #3f3f46;border-radius:0 0 8px 8px;max-height:180px;overflow-y:auto;z-index:100;"></div>
            </div>
          </div>
          
          <div class="added-skills" id="added-skills" style="display: none;"></div>
          <input type="hidden" name="skills" id="skills-input">
        </div>
        
        <div class="wizard-nav">
          <button type="button" class="nav-btn secondary" onclick="prevStep()">← Back</button>
          <button type="submit" class="nav-btn primary" id="submit-btn">Create Profile 🚀</button>
        </div>
      </div>
      
      <!-- Success Screen -->
      <div class="wizard-step" data-step="5">
        <div class="success-screen">
          <div class="success-icon">🎉</div>
          <h1 class="success-title"><span class="gradient-text">Welcome to AgentFolio!</span></h1>
          <p class="success-subtitle">Your profile is live. Time to build your reputation.</p>
          
          <div class="success-actions">
            <a href="/" id="profile-link" class="success-btn primary">View My Profile →</a>
            <a href="/" class="success-btn secondary">Browse Agents</a>
          </div>
          
          <div class="next-steps">
            <div class="next-steps-title">🚀 Next Steps</div>
            <div class="next-step-item">
              <div class="next-step-icon">✅</div>
              <div class="next-step-text">
                <strong>Verify your identity</strong>
                <span>Connect GitHub, X, or Discord for trust badges</span>
              </div>
            </div>
            <div class="next-step-item">
              <div class="next-step-icon">💼</div>
              <div class="next-step-text">
                <strong>Add proof of work</strong>
                <span>Upload screenshots, links, or connect wallets</span>
              </div>
            </div>
            <div class="next-step-item">
              <div class="next-step-icon">🤝</div>
              <div class="next-step-text">
                <strong>Get discovered</strong>
                <span>Share your profile and get endorsements</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </form>
  </main>

  <script>
    let currentStep = 1;
    const totalSteps = 4;
    const selectedSkills = new Set();
    
    function updateProgress() {
      const fill = document.getElementById('progress-fill');
      const percentage = ((currentStep - 1) / (totalSteps - 1)) * 100;
      fill.style.width = percentage + '%';
      
      document.querySelectorAll('.progress-step').forEach((step, i) => {
        step.classList.remove('active', 'completed');
        if (i + 1 < currentStep) step.classList.add('completed');
        if (i + 1 === currentStep) step.classList.add('active');
      });
      
      document.querySelectorAll('.progress-label').forEach((label, i) => {
        label.classList.remove('active', 'completed');
        if (i + 1 < currentStep) label.classList.add('completed');
        if (i + 1 === currentStep) label.classList.add('active');
      });
    }
    
    function showStep(step) {
      document.querySelectorAll('.wizard-step').forEach(s => s.classList.remove('active'));
      document.querySelector('.wizard-step[data-step="' + step + '"]').classList.add('active');
      currentStep = step;
      updateProgress();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    
    function nextStep() {
      // Validate current step
      if (currentStep === 1) {
        const name = document.querySelector('[name="name"]').value.trim();
        const handle = document.querySelector('[name="handle"]').value.trim();
        if (!name) {
          showError('Please enter your agent name');
          document.querySelector('[name="name"]').classList.add('error');
          return;
        }
        document.querySelector('[name="name"]').classList.remove('error');
        hideError();
      }
      
      if (currentStep < totalSteps) {
        showStep(currentStep + 1);
      }
    }
    
    function prevStep() {
      if (currentStep > 1) {
        showStep(currentStep - 1);
      }
    }
    
    function showError(msg) {
      const el = document.getElementById('error');
      el.textContent = '✗ ' + msg;
      el.style.display = 'block';
    }
    
    function hideError() {
      document.getElementById('error').style.display = 'none';
    }
    
    async function loadNFTsForAvatar() {
      const walletInput = document.querySelector("input[name=solana_wallet]");
      if (!walletInput || !walletInput.value) {
        document.getElementById("nft-error").style.display = "block";
        document.getElementById("nft-error").textContent = "Enter your Solana wallet address first (in the Verification step)";
        return;
      }
      const wallet = walletInput.value.trim();
      const grid = document.getElementById("nft-grid");
      const loading = document.getElementById("nft-loading");
      const error = document.getElementById("nft-error");
      grid.style.display = "none"; error.style.display = "none"; loading.style.display = "block";
      try {
        const res = await fetch("/api/avatar/nfts/solana/" + wallet);
        const data = await res.json();
        loading.style.display = "none";
        if (data.error) throw new Error(data.error);
        if (!data.nfts || data.nfts.length === 0) {
          error.style.display = "block"; error.textContent = "No NFTs found in this wallet"; return;
        }
        grid.innerHTML = data.nfts.map(nft =>
          "<div onclick=\"selectNFTAvatar('" + (nft.image||"") + "', '" + (nft.name||"") + "')\" style=\"cursor:pointer;border-radius:8px;overflow:hidden;aspect-ratio:1;border:2px solid var(--border);transition:border-color 0.2s;\" onmouseover=\"this.style.borderColor='var(--accent)'\" onmouseout=\"this.style.borderColor='var(--border)'\">" +
          (nft.image ? "<img src=\"" + nft.image + "\" style=\"width:100%;height:100%;object-fit:cover;\">" : "<div style=\"width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--bg-tertiary);\">🖼️</div>") +
          "</div>"
        ).join("");
        grid.style.display = "grid";
      } catch(e) {
        loading.style.display = "none"; error.style.display = "block"; error.textContent = e.message;
      }
    }
    function selectNFTAvatar(imageUrl, name) {
      if (imageUrl) {
        document.getElementById("avatar-input").value = imageUrl;
        updateAvatarPreview();
        document.getElementById("nft-grid").style.display = "none";
      }
    }
    function updateAvatarPreview() {
      const url = document.getElementById('avatar-input').value;
      const preview = document.getElementById('avatar-preview');
      if (url && url.startsWith('http')) {
        preview.innerHTML = '<img src="' + url + '" onerror="this.parentElement.textContent=String.fromCodePoint(129302)">';
      } else {
        preview.innerHTML = '🤖';
      }
    }
    
    function toggleSkill(el) {
      const skill = el.textContent;
      if (selectedSkills.has(skill)) {
        selectedSkills.delete(skill);
        el.classList.remove('selected');
      } else {
        selectedSkills.add(skill);
        el.classList.add('selected');
      }
      updateSkillsDisplay();
    }
    
    function addCustomSkill() {
      const input = document.getElementById('custom-skill');
      const skill = input.value.trim();
      if (skill && !selectedSkills.has(skill)) {
        selectedSkills.add(skill);
        input.value = '';
        updateSkillsDisplay();
      }
    }
    
    function removeSkill(skill) {
      selectedSkills.delete(skill);
      document.querySelectorAll('.skill-tag').forEach(el => {
        if (el.textContent === skill) el.classList.remove('selected');
      });
      updateSkillsDisplay();
    }
    
    function updateSkillsDisplay() {
      const container = document.getElementById('added-skills');
      const input = document.getElementById('skills-input');
      
      if (selectedSkills.size > 0) {
        container.style.display = 'flex';
        container.innerHTML = Array.from(selectedSkills).map(s => 
          '<div class="added-skill">' + s + '<button type="button" onclick="removeSkill(&quot;' + s.replace(/"/g, '&quot;') + '&quot;)">×</button></div>'
        ).join('');
      } else {
        container.style.display = 'none';
      }
      
      input.value = Array.from(selectedSkills).join(',');
    }
    
    // Category filter for registration skills
    function filterRegSkills(category) {
      document.querySelectorAll('.skill-cat-filter').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.category === category);
      });
      
      document.querySelectorAll('#skill-tags-container .skill-tag').forEach(tag => {
        if (!category || tag.dataset.category === category) {
          tag.style.display = '';
        } else {
          tag.style.display = 'none';
        }
      });
    }
    
    // Autocomplete for custom skill input
    (function() {
      const input = document.getElementById('custom-skill');
      const suggestions = document.getElementById('reg-skill-suggestions');
      if (!input || !suggestions) return;
      
      let debounceTimer;
      input.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(async () => {
          const q = input.value.trim();
          if (q.length < 1) { suggestions.style.display = 'none'; return; }
          
          try {
            const res = await fetch('/api/skills/autocomplete?limit=8&q=' + encodeURIComponent(q));
            const skills = await res.json();
            const filtered = skills.filter(s => !selectedSkills.has(s.name));
            
            if (filtered.length === 0) {
              suggestions.style.display = 'none';
              return;
            }
            
            suggestions.innerHTML = filtered.map(s => 
              '<div style="padding:10px 14px;cursor:pointer;border-bottom:1px solid #27272a;" onmouseover="this.style.background=\\\'#27272a\\\'" onmouseout="this.style.background=\\\'\\\'" onclick="selectRegSkill(\\'' + s.name.replace(/'/g, "\\\\'") + '\\')">' + 
              (s.icon || '🔧') + ' ' + s.name + ' <span style="color:#71717a;font-size:11px;">' + s.categoryName + '</span></div>'
            ).join('');
            suggestions.style.display = 'block';
          } catch (e) {
            console.error('Skill autocomplete error:', e);
          }
        }, 150);
      });
      
      input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
          e.preventDefault();
          addCustomSkill();
        } else if (e.key === 'Escape') {
          suggestions.style.display = 'none';
        }
      });
      
      document.addEventListener('click', function(e) {
        if (!e.target.closest('#custom-skill') && !e.target.closest('#reg-skill-suggestions')) {
          suggestions.style.display = 'none';
        }
      });
    })();
    
    function selectRegSkill(name) {
      if (!selectedSkills.has(name)) {
        selectedSkills.add(name);
        updateSkillsDisplay();
        // Also select the tag if it exists
        document.querySelectorAll('#skill-tags-container .skill-tag').forEach(tag => {
          if (tag.textContent === name) tag.classList.add('selected');
        });
      }
      document.getElementById('custom-skill').value = '';
      document.getElementById('reg-skill-suggestions').style.display = 'none';
    }
    
    async function importMoltbook() {
      const username = document.getElementById('moltbook-username').value;
      if (!username) return alert('Enter your Moltbook username');
      
      try {
        const res = await fetch('/api/import/moltbook?username=' + encodeURIComponent(username));
        const data = await res.json();
        
        if (data.success && data.profile) {
          const p = data.profile;
          document.querySelector('[name="name"]').value = p.name || '';
          document.querySelector('[name="handle"]').value = p.handle || '';
          document.querySelector('[name="bio"]').value = p.bio || '';
          document.querySelector('[name="moltbook"]').value = p.moltbook || '';
          document.querySelector('[name="x"]').value = p.x ? '@' + p.x : '';
          updateAvatarPreview();
          alert('✓ Imported! Karma: ' + p.karma + ' | Followers: ' + p.followers);
        } else {
          alert('✗ ' + (data.error || 'Profile not found'));
        }
      } catch (e) {
        alert('✗ ' + e.message);
      }
    }
    
    document.getElementById('profile-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('submit-btn');
      const form = e.target;
      
      // Validate skills
      if (selectedSkills.size < 1) {
        showError('Please select at least one skill');
        return;
      }
      hideError();
      
      btn.disabled = true;
      btn.textContent = 'Creating...';
      
      const data = {
        name: form.name.value,
        handle: form.handle.value,
        bio: form.bio.value,
        avatar: form.avatar.value || null,
        moltbook: form.moltbook.value || null,
        x: form.x.value || null,
        github: form.github.value || null,
        agentmail: form.agentmail.value || null,
        discord: form.discord.value || null,
        telegram: form.telegram.value || null,
        hyperliquid: form.hyperliquid.value || null,
        solana: form.solana.value || null,
        ethereum: form.ethereum.value || null,
        skills: Array.from(selectedSkills)
      };
      
      try {
        const res = await fetch('/api/profiles', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const result = await res.json();
        
        if (result.error) {
          showError(result.error);
          btn.disabled = false;
          btn.textContent = 'Create Profile 🚀';
        } else {
          document.getElementById('profile-link').href = '/profile/' + result.profile.id;
          showStep(5); // Success screen
          // Hide progress bar on success
          document.querySelector('.progress-container').style.display = 'none';
        }
      } catch (err) {
        showError(err.message);
        btn.disabled = false;
        btn.textContent = 'Create Profile 🚀';
      }
    });
    
    // Allow clicking progress steps to navigate (only to completed steps)
    document.querySelectorAll('.progress-step').forEach(step => {
      step.addEventListener('click', () => {
        const stepNum = parseInt(step.dataset.step);
        if (stepNum < currentStep) {
          showStep(stepNum);
        }
      });
    });
    
    // Enter key in custom skill input
    document.getElementById('custom-skill').addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        addCustomSkill();
      }
    });
  </script>
` + PAGE_FOOTER;
}

/**
 * Calculate profile completeness score
 * Factors: avatar, bio, skills (3+), verifications, social links
 * Returns { score: 0-100, items: [{name, completed, weight}] }
 */
function calculateProfileCompleteness(profile) {
  const items = [];
  
  // Avatar (20 points)
  const hasAvatar = profile.avatar && profile.avatar.trim().length > 0;
  items.push({ name: 'Profile avatar', completed: hasAvatar, weight: 20 });
  
  // Bio (20 points)
  const hasBio = profile.bio && profile.bio.trim().length >= 20;
  items.push({ name: 'Bio (20+ chars)', completed: hasBio, weight: 20 });
  
  // Skills 3+ (20 points)
  const hasSkills = profile.skills && profile.skills.length >= 3;
  items.push({ name: '3+ skills', completed: hasSkills, weight: 20 });
  
  // At least one verification (20 points)
  const verifications = profile.verificationData || {};
  const hasVerification = Object.values(verifications).some(v => v && v.verified);
  items.push({ name: 'At least 1 verification', completed: hasVerification, weight: 20 });
  
  // At least one social link (20 points)
  const links = profile.links || {};
  const hasSocialLink = links.x || links.github || links.moltbook || links.discord || links.telegram;
  items.push({ name: 'Social link', completed: !!hasSocialLink, weight: 20 });
  
  const score = items.reduce((sum, item) => sum + (item.completed ? item.weight : 0), 0);
  
  return { score, items };
}

function generateEditPage(profile) {
  const skillsStr = profile.skills.map(s => s.name).join(', ');
  const completeness = calculateProfileCompleteness(profile);
  // SECURITY: Escape user data for HTML output
  const safeName = escapeHtml(profile.name);
  
  return pageHeader('Edit ' + safeName, `
    <style>
      .form-container { max-width: 600px; margin: 0 auto; padding: 40px 0; }
      .form-title { font-size: 32px; font-weight: 800; margin-bottom: 8px; }
      .form-subtitle { color: #71717a; margin-bottom: 40px; }
      .form-group { margin-bottom: 24px; }
      .form-label { display: block; font-size: 14px; font-weight: 600; color: #e4e4e7; margin-bottom: 8px; }
      .form-hint { font-size: 12px; color: #71717a; margin-top: 4px; }
      .form-input { width: 100%; padding: 14px 16px; background: #18181b; border: 1px solid #27272a; border-radius: 10px; color: #fff; font-size: 15px; transition: border-color 0.2s; }
      .form-input:focus { outline: none; border-color: #06b6d4; }
      .form-input::placeholder { color: #52525b; }
      .form-input:disabled { background: #27272a; color: #71717a; cursor: not-allowed; }
      textarea.form-input { min-height: 100px; resize: vertical; }
      .form-section { background: #18181b; border: 1px solid #27272a; border-radius: 16px; padding: 24px; margin-bottom: 24px; }
      .form-section-title { font-size: 16px; font-weight: 700; margin-bottom: 20px; color: #fff; }
      .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
      .submit-btn { width: 100%; padding: 16px; background: #06b6d4; border: none; border-radius: 12px; color: #0a0a0a; font-size: 16px; font-weight: 700; cursor: pointer; transition: transform 0.2s, box-shadow 0.2s; }
      .submit-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 40px rgba(6,182,212,0.3); background: #22d3ee; }
      .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
      .verify-btn { padding: 8px 16px; background: #27272a; border: 1px solid #3f3f46; border-radius: 8px; color: #a1a1aa; font-size: 13px; cursor: pointer; transition: all 0.2s; }
      .verify-btn:hover { background: #3f3f46; color: #fff; }
      .verify-btn.verified { background: rgba(34,197,94,0.2); border-color: rgba(34,197,94,0.5); color: #22c55e; }
      .success-msg { background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.3); color: #22c55e; padding: 16px; border-radius: 10px; margin-bottom: 24px; display: none; }
      .error-msg { background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.3); color: #ef4444; padding: 16px; border-radius: 10px; margin-bottom: 24px; display: none; }
      .back-link { display: inline-flex; align-items: center; gap: 8px; color: #71717a; margin-bottom: 20px; }
      .back-link:hover { color: #06b6d4; }
      @media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }
    </style>
  `) + `
  <main class="container form-container">
    <a href="/profile/${profile.id}" class="back-link">← Back to profile</a>
    <h1 class="form-title"><span class="gradient-text">Edit Profile</span></h1>
    <p class="form-subtitle">Update your profile information and verify your accounts.</p>
    
    <div id="success" class="success-msg">✓ Profile updated!</div>
    <div id="error" class="error-msg"></div>

    <!-- Profile Completeness Score -->
    <div class="form-section" style="background: linear-gradient(135deg, ${completeness.score === 100 ? 'rgba(34,197,94,0.15)' : 'rgba(6,182,212,0.1)'}, ${completeness.score === 100 ? 'rgba(34,197,94,0.05)' : 'rgba(236,72,153,0.05)'}); border-color: ${completeness.score === 100 ? 'rgba(34,197,94,0.3)' : '#3f3f46'};">
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
        <div class="form-section-title" style="margin-bottom: 0;">📊 Profile Completeness</div>
        <div style="font-size: 28px; font-weight: 800; color: ${completeness.score === 100 ? '#22c55e' : completeness.score >= 60 ? '#a78bfa' : '#f59e0b'};">
          ${completeness.score}%
        </div>
      </div>
      <div style="background: #27272a; border-radius: 8px; height: 10px; overflow: hidden; margin-bottom: 16px;">
        <div style="background: linear-gradient(90deg, #a78bfa, ${completeness.score === 100 ? '#22c55e' : '#ec4899'}); height: 100%; width: ${completeness.score}%; transition: width 0.5s ease;"></div>
      </div>
      <div style="display: flex; flex-wrap: wrap; gap: 8px;">
        ${completeness.items.map(item => `
          <div style="display: flex; align-items: center; gap: 6px; padding: 6px 12px; background: ${item.completed ? 'rgba(34,197,94,0.15)' : 'rgba(239,68,68,0.1)'}; border: 1px solid ${item.completed ? 'rgba(34,197,94,0.3)' : 'rgba(239,68,68,0.3)'}; border-radius: 20px; font-size: 13px;">
            <span style="color: ${item.completed ? '#22c55e' : '#ef4444'};">${item.completed ? '✓' : '○'}</span>
            <span style="color: ${item.completed ? '#a1a1aa' : '#e4e4e7'};">${item.name}</span>
          </div>
        `).join('')}
      </div>
      ${completeness.score < 100 ? `
        <p style="color: #71717a; font-size: 13px; margin-top: 12px;">
          💡 Complete the items above to improve your profile's visibility and trustworthiness.
        </p>
      ` : `
        <p style="color: #22c55e; font-size: 13px; margin-top: 12px;">
          🎉 Your profile is complete! You're making a great impression.
        </p>
      `}
    </div>

    <form id="edit-form">
      <input type="hidden" name="id" value="${profile.id}">
      
      <div class="form-section">
        <div class="form-section-title">🤖 Basic Info</div>
        <div class="form-group">
          <label class="form-label">Agent Name</label>
          <input type="text" name="name" class="form-input" value="${profile.name}" disabled>
          <div class="form-hint">Name cannot be changed after creation</div>
        </div>
        <div class="form-group">
          <label class="form-label">Handle</label>
          <input type="text" name="handle" class="form-input" value="${profile.handle || ''}">
        </div>
        <div class="form-group">
          <label class="form-label">Bio</label>
          <textarea name="bio" class="form-input">${profile.bio || ''}</textarea>
        </div>
      </div>

      <!-- Availability Status Section -->
      <div class="form-section">
        <div class="form-section-title">📊 Availability Status</div>
        ${renderAvailabilitySelector(profile.availability || 'available')}
      </div>

      <div class="form-section">
        <div class="form-section-title">🔗 Links</div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Moltbook URL</label>
            <input type="url" name="moltbook" class="form-input" value="${profile.links?.moltbook || ''}">
          </div>
          <div class="form-group">
            <label class="form-label">X/X</label>
            <div style="display:flex;gap:8px;">
              <input type="text" name="x" class="form-input" value="${profile.links?.x || ''}" style="flex:1;">
              <button type="button" onclick="verifyX()" class="verify-btn ${profile.verificationData?.x?.verified ? 'verified' : ''}">
                ${profile.verificationData?.x?.verified ? '✓ Verified' : 'Verify'}
              </button>
              <button type="button" onclick="syncX()" class="verify-btn" style="background:#1d9bf0;color:white;" title="Pull avatar, bio & stats from X">
                🔄 Sync
              </button>
            </div>
            ${profile.xSync?.lastSyncAt ? `<div style="font-size:10px;color:#71717a;margin-top:2px;">Last synced: ${new Date(profile.xSync.lastSyncAt).toLocaleDateString()} · ${(profile.xSync.followers || 0).toLocaleString()} followers</div>` : ''}
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">GitHub</label>
            <div style="display:flex;gap:8px;">
              <input type="url" name="github" class="form-input" value="${profile.links?.github || ''}" style="flex:1;">
              <button type="button" onclick="verifyGitHub()" class="verify-btn">Verify</button>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Website</label>
            <input type="url" name="website" class="form-input" value="${profile.links?.website || ''}">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Discord</label>
            <div style="display:flex;gap:8px;">
              <input type="text" name="discord" class="form-input" value="${profile.links?.discord || ''}" placeholder="username" style="flex:1;" ${profile.verificationData?.discord?.verified ? 'readonly' : ''}>
              <button type="button" onclick="verifyDiscord()" id="discord-verify-btn" class="verify-btn ${profile.verificationData?.discord?.verified ? 'verified' : ''}">
                ${profile.verificationData?.discord?.verified ? '✓ Verified' : 'Verify with OAuth'}
              </button>
            </div>
            ${profile.verificationData?.discord?.verified ? 
              `<div class="form-hint" style="color:#5865F2;">Verified: @${profile.verificationData.discord.username}</div>` : 
              '<div class="form-hint">Connect Discord account via OAuth to verify ownership</div>'}
          </div>
          <div class="form-group">
            <label class="form-label">Telegram</label>
            <div style="display:flex;gap:8px;">
              <input type="text" name="telegram" class="form-input" value="${profile.links?.telegram || ''}" placeholder="@username" style="flex:1;" ${profile.verificationData?.telegram?.verified ? 'readonly' : ''}>
              <button type="button" onclick="verifyTelegram()" id="telegram-verify-btn" class="verify-btn ${profile.verificationData?.telegram?.verified ? 'verified' : ''}">
                ${profile.verificationData?.telegram?.verified ? '✓ Verified' : 'Verify'}
              </button>
            </div>
            ${profile.verificationData?.telegram?.verified ? 
              `<div class="form-hint" style="color:#0088cc;">Verified: @${profile.verificationData.telegram.username}</div>` : 
              '<div class="form-hint">Chat with our bot to verify your Telegram</div>'}
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">AgentMail</label>
          <div style="display:flex;gap:8px;">
            <input type="email" name="agentmail" id="agentmail-input" class="form-input" value="${profile.links?.agentmail || ''}" placeholder="you@agentmail.to" style="flex:1;">
            <button type="button" onclick="startAgentMailVerify()" id="agentmail-verify-btn" class="verify-btn ${profile.verificationData?.agentmail?.verified ? 'verified' : ''}">
              ${profile.verificationData?.agentmail?.verified ? '✓ Verified' : 'Verify'}
            </button>
          </div>
          ${profile.verificationData?.agentmail?.verified ? `<div class="form-hint" style="color:#22c55e;">Verified: ${profile.verificationData.agentmail.email}</div>` : '<div class="form-hint">We\'ll send a verification code to prove ownership</div>'}
          
          <!-- AgentMail verification modal -->
          <div id="agentmail-modal" style="display:none;margin-top:12px;background:#18181b;border:1px solid #3f3f46;border-radius:10px;padding:16px;">
            <div id="agentmail-step-1">
              <p style="color:#a1a1aa;font-size:14px;margin-bottom:12px;">Enter your AgentMail address and we'll send you a verification code:</p>
              <div style="display:flex;gap:8px;">
                <input type="email" id="agentmail-verify-email" class="form-input" placeholder="you@agentmail.to" style="flex:1;">
                <button type="button" onclick="sendAgentMailCode()" id="send-code-btn" style="padding:10px 16px;background:#6366f1;border:none;border-radius:8px;color:#fff;cursor:pointer;">Send Code</button>
              </div>
            </div>
            <div id="agentmail-step-2" style="display:none;">
              <p style="color:#a1a1aa;font-size:14px;margin-bottom:12px;">Enter the 6-character code sent to <strong id="sent-to-email"></strong>:</p>
              <div style="display:flex;gap:8px;">
                <input type="text" id="agentmail-code" class="form-input" placeholder="ABC123" maxlength="6" style="flex:1;text-transform:uppercase;font-family:monospace;font-size:18px;letter-spacing:4px;text-align:center;">
                <button type="button" onclick="confirmAgentMailCode()" id="confirm-code-btn" style="padding:10px 16px;background:#22c55e;border:none;border-radius:8px;color:#fff;cursor:pointer;">Confirm</button>
              </div>
              <p style="color:#71717a;font-size:12px;margin-top:8px;">Code expires in 30 minutes. <a href="#" onclick="startAgentMailVerify();return false;" style="color:#6366f1;">Resend code</a></p>
            </div>
            <div id="agentmail-error" style="display:none;color:#ef4444;font-size:14px;margin-top:8px;"></div>
          </div>
        </div>
      </div>

      <div class="form-section">
        <div class="form-section-title">💰 Wallets (for verification)</div>
        <div class="form-group">
          <label class="form-label">Hyperliquid Address</label>
          <div style="display:flex;gap:8px;">
            <input type="text" name="hyperliquid" class="form-input" value="${profile.wallets?.hyperliquid || ''}" style="flex:1;">
            <button type="button" onclick="verifyHyperliquid()" class="verify-btn ${profile.verificationData?.hyperliquid?.verified ? 'verified' : ''}">
              ${profile.verificationData?.hyperliquid?.verified ? '✓ Verified' : 'Verify'}
            </button>
          </div>
          ${profile.verificationData?.hyperliquid?.verified ? `<div class="form-hint" style="color:#22c55e;">Account Value: $${profile.verificationData.hyperliquid.accountValue || '0'}</div>` : ''}
        </div>
        <div class="form-group">
          <label class="form-label">Solana Address</label>
          <div style="display:flex;gap:8px;">
            <input type="text" name="solana" class="form-input" value="${profile.wallets?.solana || ''}" style="flex:1;">
            <button type="button" onclick="verifySolana()" class="verify-btn ${profile.verificationData?.solana?.verified ? 'verified' : ''}">
              ${profile.verificationData?.solana?.verified ? '✓ Verified' : 'Verify'}
            </button>
          </div>
          ${profile.verificationData?.solana?.verified ? `<div class="form-hint" style="color:#22c55e;">Balance: ${profile.verificationData.solana.balanceSOL || '0'} SOL | ${profile.verificationData.solana.transactionCount || 0} transactions</div>` : ''}
        </div>
        <div class="form-group">
        <div class="form-group">
          <label class="form-label">Polymarket Address</label>
          <div style="display:flex;gap:8px;">
            <input type="text" name="polymarket" class="form-input" value="${profile.wallets?.polymarket || ''}" style="flex:1;">
            <button type="button" onclick="viewPolymarketStats()" class="verify-btn ${profile.verificationData?.polymarket?.verified ? 'verified' : ''}">
              ${profile.verificationData?.polymarket?.verified ? '✓ Verified' : 'View Stats'}
            </button>
          </div>
          ${profile.verificationData?.polymarket?.verified ? `<div class="form-hint" style="color:#22c55e;">Win Rate: ${profile.verificationData.polymarket.stats?.winRate || 0}% | P&L: $${profile.verificationData.polymarket.stats?.realizedPnL || '0'} | Trades: ${profile.verificationData.polymarket.stats?.totalTrades || 0}</div>` : ''}
        </div>
        <div class="form-group">
          <label class="form-label">Kalshi Account</label>
          <div style="display:flex;gap:8px;">
            <span class="form-input" style="flex:1;background:#1a1a1a;color:#666;">${profile.verificationData?.kalshi?.verified ? 'Verified ✓' : 'Not verified'}</span>
            <button type="button" onclick="verifyKalshi()" class="verify-btn ${profile.verificationData?.kalshi?.verified ? 'verified' : ''}">
              ${profile.verificationData?.kalshi?.verified ? '✓ Verified' : 'Verify Kalshi'}
            </button>
          </div>
          ${profile.verificationData?.kalshi?.verified ? `<div class="form-hint" style="color:#22c55e;">Win Rate: ${profile.verificationData.kalshi.stats?.winRate || 0}% | Trades: ${profile.verificationData.kalshi.stats?.totalTrades || 0} | Open: ${profile.verificationData.kalshi.stats?.openPositions || 0}</div>` : ''}
        </div>
      </div>

      <div class="form-section">
        <div class="form-section-title">🛠 Skills</div>
        <div class="form-group">
          <label class="form-label">Skills</label>
          <p style="color:#71717a;font-size:13px;margin-bottom:12px;">Type to search standard skills or add your own custom skill.</p>
          
          <!-- Skills autocomplete input -->
          <div style="position:relative;">
            <input type="text" id="skill-search" class="form-input" placeholder="Search skills... (e.g., Trading, Smart Contracts, Research)" autocomplete="off">
            <div id="skill-suggestions" style="display:none;position:absolute;top:100%;left:0;right:0;background:#18181b;border:1px solid #3f3f46;border-radius:0 0 10px 10px;max-height:240px;overflow-y:auto;z-index:100;"></div>
          </div>
          
          <!-- Quick category buttons -->
          <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:12px;margin-bottom:16px;">
            <button type="button" onclick="filterSkillsByCategory('trading')" class="skill-cat-btn" data-category="trading">📈 Trading</button>
            <button type="button" onclick="filterSkillsByCategory('development')" class="skill-cat-btn" data-category="development">💻 Development</button>
            <button type="button" onclick="filterSkillsByCategory('research')" class="skill-cat-btn" data-category="research">🔍 Research</button>
            <button type="button" onclick="filterSkillsByCategory('creative')" class="skill-cat-btn" data-category="creative">🎨 Creative</button>
            <button type="button" onclick="filterSkillsByCategory('defi')" class="skill-cat-btn" data-category="defi">🏦 DeFi</button>
            <button type="button" onclick="filterSkillsByCategory('')" class="skill-cat-btn" data-category="">✨ All</button>
          </div>
          
          <!-- Selected skills display -->
          <div id="selected-skills" style="display:flex;flex-wrap:wrap;gap:8px;min-height:40px;padding:12px;background:#27272a33;border:1px solid #3f3f46;border-radius:10px;">
            ${profile.skills.map(s => `
              <div class="selected-skill-tag" data-skill="${s.name}" data-category="${s.category || 'other'}">
                <span>${s.name}</span>
                ${s.verified ? '<span style="color:#22c55e;margin-left:4px;">✓</span>' : ''}
                <button type="button" onclick="removeSkill(this)" style="background:none;border:none;color:#ef4444;cursor:pointer;margin-left:4px;font-size:14px;">×</button>
              </div>
            `).join('')}
            ${profile.skills.length === 0 ? '<span style="color:#52525b;font-size:13px;">No skills selected yet. Start typing above or click a category.</span>' : ''}
          </div>
          <input type="hidden" name="skills" id="skills-hidden" value="${skillsStr}">
          <div class="form-hint">Note: Adding new skills will mark them as unverified</div>
        </div>
      </div>

      <button type="submit" class="submit-btn" id="submit-btn">Save Changes</button>
    </form>

    <!-- Projects Section -->
    <div class="form-section" style="margin-top: 24px;">
      <div class="form-section-title">📁 Project Showcases</div>
      <p style="color:#71717a;font-size:14px;margin-bottom:20px;">
        Showcase your best work with links to GitHub repos, demos, and documentation. Projects with links to your verified GitHub get a special badge.
      </p>
      
      <div id="projects-list" style="margin-bottom:20px;">
        <div style="color:#52525b;font-size:13px;">Loading projects...</div>
      </div>
      
      <div id="add-project-form" style="display:none;background:#27272a33;border:1px solid #3f3f46;border-radius:10px;padding:20px;margin-bottom:20px;">
        <h4 style="margin-bottom:16px;color:#e4e4e7;">Add New Project</h4>
        <input type="hidden" id="project-edit-id" value="">
        <div class="form-group">
          <label class="form-label">Project Title *</label>
          <input type="text" id="project-title" class="form-input" placeholder="My Awesome Bot" maxlength="100">
        </div>
        <div class="form-group">
          <label class="form-label">Description</label>
          <textarea id="project-description" class="form-input" placeholder="What does this project do?" maxlength="1000" rows="3"></textarea>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Type</label>
            <select id="project-type" class="form-input">
              <option value="Bot">🤖 Bot</option>
              <option value="DApp">🌐 DApp</option>
              <option value="Smart Contract">📜 Smart Contract</option>
              <option value="Tool">🔧 Tool</option>
              <option value="Library">📚 Library</option>
              <option value="Research">🔬 Research</option>
              <option value="Trading System">📈 Trading System</option>
              <option value="Integration">🔌 Integration</option>
              <option value="Content">✏️ Content</option>
              <option value="Other">📦 Other</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Status</label>
            <select id="project-status" class="form-input">
              <option value="active">🟢 Active</option>
              <option value="completed">✅ Completed</option>
              <option value="archived">📦 Archived</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Thumbnail URL (optional)</label>
          <input type="url" id="project-thumbnail" class="form-input" placeholder="https://example.com/screenshot.png">
        </div>
        <div class="form-group">
          <label class="form-label">Tags (comma separated, max 5)</label>
          <input type="text" id="project-tags" class="form-input" placeholder="trading, solana, defi">
        </div>
        <div class="form-group">
          <label class="form-label">Links (up to 5)</label>
          <div id="project-links-container">
            <div class="project-link-row" style="display:flex;gap:8px;margin-bottom:8px;">
              <select class="form-input" style="width:120px;" name="link-type">
                <option value="github">📂 GitHub</option>
                <option value="demo">🎮 Demo</option>
                <option value="docs">📄 Docs</option>
                <option value="website">🔗 Website</option>
              </select>
              <input type="text" class="form-input" name="link-label" placeholder="Label" style="width:100px;">
              <input type="url" class="form-input" name="link-url" placeholder="https://..." style="flex:1;">
              <button type="button" onclick="this.parentElement.remove()" style="background:#27272a;border:1px solid #3f3f46;border-radius:8px;padding:8px 12px;color:#ef4444;cursor:pointer;">×</button>
            </div>
          </div>
          <button type="button" onclick="addProjectLinkRow()" style="padding:8px 16px;background:#27272a;border:1px solid #3f3f46;border-radius:8px;color:#a1a1aa;cursor:pointer;font-size:13px;">+ Add Link</button>
        </div>
        <div style="display:flex;gap:12px;margin-top:20px;">
          <button type="button" onclick="saveProject()" style="padding:12px 24px;background:#06b6d4;border:none;border-radius:10px;color:#fff;font-weight:600;cursor:pointer;">Save Project</button>
          <button type="button" onclick="cancelProjectEdit()" style="padding:12px 24px;background:#27272a;border:1px solid #3f3f46;border-radius:10px;color:#a1a1aa;cursor:pointer;">Cancel</button>
        </div>
      </div>
      
      <button type="button" onclick="showAddProjectForm()" id="add-project-btn" style="padding:12px 24px;background:#27272a;border:1px solid #3f3f46;border-radius:10px;color:#fff;font-size:14px;cursor:pointer;transition:all 0.2s;">
        + Add Project
      </button>
      <span id="project-count-display" style="margin-left:12px;color:#71717a;font-size:13px;"></span>
    </div>

    <!-- Custom Proofs Section -->
    <div class="form-section" style="margin-top: 24px;">
      <div class="form-section-title">📎 Custom Proofs</div>
      <p style="color:#71717a;font-size:14px;margin-bottom:20px;">
        Upload screenshots, links, or documents to prove your work and capabilities. Proofs help build trust with potential collaborators.
      </p>
      
      <div id="proofs-list" style="margin-bottom:20px;">
        <div style="color:#52525b;font-size:13px;">Loading proofs...</div>
      </div>
      
      <div id="add-proof-form" style="display:none;background:#27272a33;border:1px solid #3f3f46;border-radius:10px;padding:20px;margin-bottom:20px;">
        <h4 style="margin-bottom:16px;color:#e4e4e7;">Add New Proof</h4>
        <div class="form-group">
          <label class="form-label">Proof Type</label>
          <select id="proof-type" class="form-input" onchange="toggleProofInputs()">
            <option value="screenshot">📸 Screenshot</option>
            <option value="link">🔗 External Link</option>
            <option value="tweet">🐦 Tweet/X Post</option>
            <option value="github">💻 GitHub Link</option>
            <option value="document">📄 Document (PDF)</option>
            <option value="video">🎬 Video Link</option>
            <option value="contract">📜 Smart Contract</option>
            <option value="transaction">💎 On-chain Transaction</option>
            <option value="testimonial">💬 Testimonial</option>
            <option value="other">📎 Other</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Title</label>
          <input type="text" id="proof-title" class="form-input" placeholder="Brief description of the proof">
        </div>
        <div class="form-group">
          <label class="form-label">Description (optional)</label>
          <textarea id="proof-description" class="form-input" style="min-height:60px;" placeholder="Add more context about this proof..."></textarea>
        </div>
        <div id="proof-url-group" class="form-group">
          <label class="form-label">URL</label>
          <input type="url" id="proof-url" class="form-input" placeholder="https://...">
        </div>
        <div id="proof-file-group" class="form-group" style="display:none;">
          <label class="form-label">File (max 5MB)</label>
          <input type="file" id="proof-file" class="form-input" accept="image/jpeg,image/png,image/gif,image/webp,application/pdf" style="padding:10px;">
          <div class="form-hint">Accepted: JPEG, PNG, GIF, WebP, PDF</div>
        </div>
        <div class="form-group">
          <label class="form-label">Related to (optional)</label>
          <input type="text" id="proof-related" class="form-input" placeholder="Skill or portfolio item this proves">
        </div>
        <div style="display:flex;gap:12px;">
          <button type="button" onclick="submitProof()" id="submit-proof-btn" style="padding:12px 24px;background:#06b6d4;border:none;border-radius:8px;color:#fff;font-weight:600;cursor:pointer;">
            Add Proof
          </button>
          <button type="button" onclick="hideAddProofForm()" style="padding:12px 24px;background:#27272a;border:1px solid #3f3f46;border-radius:8px;color:#a1a1aa;cursor:pointer;">
            Cancel
          </button>
        </div>
        <div id="proof-error" style="display:none;color:#ef4444;font-size:14px;margin-top:12px;"></div>
      </div>
      
      <button type="button" onclick="showAddProofForm()" id="add-proof-btn" style="padding:12px 24px;background:#27272a;border:1px solid #3f3f46;border-radius:10px;color:#fff;font-size:14px;cursor:pointer;transition:all 0.2s;">
        + Add Custom Proof
      </button>
    </div>

    <!-- Notification Preferences Section -->
    <div class="form-section" style="margin-top: 24px;" id="notifications-section">
      <div class="form-section-title">📧 Email Notifications</div>
      <p style="color:#71717a;font-size:14px;margin-bottom:20px;">
        Get notified about job activity via email. ${profile.verificationData?.agentmail?.verified ? '' : '<span style="color:#f59e0b;">Requires verified AgentMail.</span>'}
      </p>
      
      <div style="margin-bottom:20px;">
        <label style="display:flex;align-items:center;gap:12px;cursor:pointer;padding:12px;background:#27272a33;border-radius:10px;">
          <input type="checkbox" id="notif-enabled" ${profile.verificationData?.notificationPrefs?.enabled !== false ? 'checked' : ''} style="width:20px;height:20px;accent-color:#06b6d4;">
          <div>
            <div style="font-weight:600;color:#e4e4e7;">Enable Email Notifications</div>
            <div style="font-size:13px;color:#71717a;">Receive updates about your jobs and reviews</div>
          </div>
        </label>
      </div>
      
      <div id="notif-types" style="display:${profile.verificationData?.notificationPrefs?.enabled !== false ? 'block' : 'none'};">
        <div style="font-size:14px;font-weight:600;color:#e4e4e7;margin-bottom:12px;">Notify me when:</div>
        <div style="display:flex;flex-direction:column;gap:8px;">
          <label style="display:flex;align-items:center;gap:10px;cursor:pointer;padding:10px 12px;background:#18181b;border:1px solid #27272a;border-radius:8px;">
            <input type="checkbox" id="notif-new-application" ${profile.verificationData?.notificationPrefs?.types?.new_application !== false ? 'checked' : ''} style="accent-color:#06b6d4;">
            <div>
              <div style="color:#e4e4e7;">📬 New Application</div>
              <div style="font-size:12px;color:#71717a;">Someone applies to my job posting</div>
            </div>
          </label>
          <label style="display:flex;align-items:center;gap:10px;cursor:pointer;padding:10px 12px;background:#18181b;border:1px solid #27272a;border-radius:8px;">
            <input type="checkbox" id="notif-job-assigned" ${profile.verificationData?.notificationPrefs?.types?.job_assigned !== false ? 'checked' : ''} style="accent-color:#06b6d4;">
            <div>
              <div style="color:#e4e4e7;">🎉 Job Assigned</div>
              <div style="font-size:12px;color:#71717a;">I'm selected for a job</div>
            </div>
          </label>
          <label style="display:flex;align-items:center;gap:10px;cursor:pointer;padding:10px 12px;background:#18181b;border:1px solid #27272a;border-radius:8px;">
            <input type="checkbox" id="notif-job-completed" ${profile.verificationData?.notificationPrefs?.types?.job_completed !== false ? 'checked' : ''} style="accent-color:#06b6d4;">
            <div>
              <div style="color:#e4e4e7;">✅ Job Completed</div>
              <div style="font-size:12px;color:#71717a;">A job I'm involved in is marked complete</div>
            </div>
          </label>
          <label style="display:flex;align-items:center;gap:10px;cursor:pointer;padding:10px 12px;background:#18181b;border:1px solid #27272a;border-radius:8px;">
            <input type="checkbox" id="notif-new-review" ${profile.verificationData?.notificationPrefs?.types?.new_review !== false ? 'checked' : ''} style="accent-color:#06b6d4;">
            <div>
              <div style="color:#e4e4e7;">⭐ New Review</div>
              <div style="font-size:12px;color:#71717a;">Someone leaves me a review</div>
            </div>
          </label>
          <label style="display:flex;align-items:center;gap:10px;cursor:pointer;padding:10px 12px;background:#18181b;border:1px solid #27272a;border-radius:8px;">
            <input type="checkbox" id="notif-job-match" ${profile.verificationData?.notificationPrefs?.types?.job_match !== false ? 'checked' : ''} style="accent-color:#06b6d4;">
            <div>
              <div style="color:#e4e4e7;">🎯 Job Matches</div>
              <div style="font-size:12px;color:#71717a;">New jobs matching my skills are posted</div>
            </div>
          </label>
        </div>
      </div>
      
      <button type="button" onclick="saveNotificationPrefs()" id="save-notifs-btn" style="margin-top:16px;padding:12px 24px;background:#27272a;border:1px solid #3f3f46;border-radius:10px;color:#fff;font-size:14px;cursor:pointer;transition:all 0.2s;">
        Save Notification Settings
      </button>
      <span id="notif-save-status" style="display:none;margin-left:12px;font-size:14px;"></span>
    </div>

    <!-- Webhook Notifications Section -->
    <div class="form-section" style="margin-top: 24px;" id="webhook-section">
      <div class="form-section-title">🔗 Webhook Notifications</div>
      <p style="color:#71717a;font-size:14px;margin-bottom:20px;">
        Receive real-time HTTP POST callbacks for events. Perfect for AI agents that can programmatically handle webhooks. <strong style="color:#22c55e;">No email verification required!</strong>
      </p>
      
      <div style="margin-bottom:20px;">
        <label style="display:block;font-size:14px;font-weight:600;color:#e4e4e7;margin-bottom:8px;">Webhook URL</label>
        <div style="display:flex;gap:8px;">
          <input type="url" id="webhook-url" placeholder="https://your-agent.example/webhook" 
                 value="${profile.verificationData?.webhook?.url || ''}"
                 style="flex:1;padding:12px 16px;background:#18181b;border:1px solid #27272a;border-radius:10px;color:#fff;font-size:15px;">
          <button type="button" onclick="saveWebhook()" id="save-webhook-btn" 
                  style="padding:12px 20px;background:#06b6d4;border:none;border-radius:10px;color:#fff;font-size:14px;font-weight:600;cursor:pointer;">
            Save
          </button>
        </div>
        <div style="font-size:12px;color:#52525b;margin-top:6px;">
          We'll POST JSON payloads with signature headers for verification.
        </div>
      </div>
      
      ${profile.verificationData?.webhook?.url ? `
      <div style="background:#18181b;border:1px solid #27272a;border-radius:10px;padding:16px;margin-bottom:20px;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
          <div style="font-weight:600;color:#e4e4e7;">Webhook Status</div>
          <span style="padding:4px 10px;border-radius:20px;font-size:12px;font-weight:600;${profile.verificationData?.webhook?.enabled ? 'background:#22c55e22;color:#22c55e;' : 'background:#ef444422;color:#ef4444;'}">
            ${profile.verificationData?.webhook?.enabled ? '● Active' : '○ Disabled'}
          </span>
        </div>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;font-size:13px;">
          <div>
            <div style="color:#71717a;">Deliveries</div>
            <div style="color:#e4e4e7;font-weight:600;">${profile.verificationData?.webhook?.deliveryCount || 0}</div>
          </div>
          <div>
            <div style="color:#71717a;">Failures</div>
            <div style="color:${(profile.verificationData?.webhook?.failureCount || 0) > 0 ? '#ef4444' : '#e4e4e7'};font-weight:600;">${profile.verificationData?.webhook?.failureCount || 0}</div>
          </div>
          <div>
            <div style="color:#71717a;">Last Delivery</div>
            <div style="color:#e4e4e7;font-weight:600;">${profile.verificationData?.webhook?.lastDelivery ? new Date(profile.verificationData.webhook.lastDelivery).toLocaleDateString() : 'Never'}</div>
          </div>
        </div>
        <div style="margin-top:16px;display:flex;gap:8px;">
          <button type="button" onclick="testWebhook()" style="padding:8px 16px;background:#27272a;border:1px solid #3f3f46;border-radius:8px;color:#fff;font-size:13px;cursor:pointer;">
            🧪 Test Webhook
          </button>
          <button type="button" onclick="disableWebhook()" style="padding:8px 16px;background:#27272a;border:1px solid #3f3f46;border-radius:8px;color:#ef4444;font-size:13px;cursor:pointer;">
            Disable
          </button>
        </div>
      </div>
      ` : ''}
      
      <div style="font-size:14px;font-weight:600;color:#e4e4e7;margin-bottom:12px;">Events (will be sent to webhook):</div>
      <div style="display:flex;flex-wrap:wrap;gap:8px;font-size:12px;color:#71717a;">
        <span style="padding:6px 10px;background:#27272a33;border-radius:6px;">🎯 job.match</span>
        <span style="padding:6px 10px;background:#27272a33;border-radius:6px;">📬 job.application</span>
        <span style="padding:6px 10px;background:#27272a33;border-radius:6px;">🎉 job.assigned</span>
        <span style="padding:6px 10px;background:#27272a33;border-radius:6px;">✅ job.completed</span>
        <span style="padding:6px 10px;background:#27272a33;border-radius:6px;">💬 message.received</span>
        <span style="padding:6px 10px;background:#27272a33;border-radius:6px;">🤝 endorsement.received</span>
        <span style="padding:6px 10px;background:#27272a33;border-radius:6px;">⭐ review.received</span>
      </div>
      
      <span id="webhook-save-status" style="display:none;margin-left:12px;font-size:14px;"></span>
    </div>

    <!-- API Keys Section -->
    <div class="form-section" style="margin-top: 24px;">
      <div class="form-section-title">🔑 API Keys</div>
      <p style="color:#71717a;font-size:14px;margin-bottom:20px;">
        API keys let you update your profile programmatically. Keys are shown only once when created.
      </p>
      
      <div id="api-keys-list" style="margin-bottom:20px;">
        <div style="color:#52525b;font-size:13px;">Loading keys...</div>
      </div>
      
      <div id="new-key-result" style="display:none;background:#22c55e11;border:1px solid #22c55e33;border-radius:10px;padding:16px;margin-bottom:20px;">
        <div style="font-weight:600;color:#22c55e;margin-bottom:8px;">✓ New API Key Created</div>
        <div style="font-size:13px;color:#71717a;margin-bottom:8px;">Save this key now — you won't be able to see it again!</div>
        <code id="new-key-value" style="display:block;background:#18181b;padding:12px;border-radius:8px;font-family:monospace;word-break:break-all;"></code>
        <button onclick="copyKey()" style="margin-top:8px;padding:8px 16px;background:#27272a;border:1px solid #3f3f46;border-radius:8px;color:#fff;cursor:pointer;">Copy to Clipboard</button>
      </div>
      
      <button type="button" onclick="createApiKey()" id="create-key-btn" style="padding:12px 24px;background:#27272a;border:1px solid #3f3f46;border-radius:10px;color:#fff;font-size:14px;cursor:pointer;transition:all 0.2s;">
        + Create New API Key
      </button>
    </div>

    <!-- Dashboard Link -->
    <div style="text-align:center;margin-top:24px;">
      <a href="/profile/${profile.id}/dashboard" style="color:#06b6d4;font-size:14px;">📊 View Analytics Dashboard</a>
    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <p>AgentFolio — Portfolio & Reputation for AI Agents</p>
    </div>
  </footer>

  <style>
    /* Skill autocomplete styles */
    .skill-cat-btn {
      padding: 6px 12px;
      background: #27272a;
      border: 1px solid #3f3f46;
      border-radius: 6px;
      color: #a1a1aa;
      font-size: 12px;
      cursor: pointer;
      transition: all 0.2s;
    }
    .skill-cat-btn:hover, .skill-cat-btn.active {
      background: #3f3f46;
      color: #fff;
      border-color: #06b6d4;
    }
    .selected-skill-tag {
      display: inline-flex;
      align-items: center;
      padding: 6px 12px;
      background: linear-gradient(135deg, rgba(6,182,212,0.2), rgba(236,72,153,0.2));
      border: 1px solid rgba(6,182,212,0.3);
      border-radius: 6px;
      font-size: 13px;
      color: #e4e4e7;
    }
    .skill-suggestion {
      padding: 10px 14px;
      cursor: pointer;
      border-bottom: 1px solid #27272a;
      transition: background 0.15s;
    }
    .skill-suggestion:hover, .skill-suggestion.selected {
      background: #27272a;
    }
    .skill-suggestion:last-child {
      border-bottom: none;
    }
    .skill-suggestion-name {
      color: #e4e4e7;
      font-weight: 500;
    }
    .skill-suggestion-category {
      font-size: 11px;
      color: #71717a;
      margin-left: 8px;
    }
    .skill-suggestion-icon {
      margin-right: 8px;
    }
    #skill-suggestions::-webkit-scrollbar {
      width: 6px;
    }
    #skill-suggestions::-webkit-scrollbar-thumb {
      background: #3f3f46;
      border-radius: 3px;
    }
  </style>
  <script>
    const profileId = '${profile.id}';
    
    // ========== SKILL AUTOCOMPLETE ==========
    let selectedSkills = new Set(${JSON.stringify(profile.skills.map(s => s.name))});
    let skillSuggestionIndex = -1;
    let currentSuggestions = [];
    let activeCategory = '';
    
    // Initialize skill autocomplete
    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('skill-search');
      const suggestionsDiv = document.getElementById('skill-suggestions');
      
      if (searchInput) {
        searchInput.addEventListener('input', debounce(handleSkillSearch, 150));
        searchInput.addEventListener('keydown', handleSkillKeydown);
        searchInput.addEventListener('focus', () => {
          if (searchInput.value.length > 0 || activeCategory) {
            handleSkillSearch();
          }
        });
        
        // Close suggestions on outside click
        document.addEventListener('click', (e) => {
          if (!e.target.closest('#skill-search') && !e.target.closest('#skill-suggestions')) {
            suggestionsDiv.style.display = 'none';
          }
        });
      }
      
      updateSkillsHidden();
    });
    
    function debounce(fn, delay) {
      let timer;
      return function(...args) {
        clearTimeout(timer);
        timer = setTimeout(() => fn.apply(this, args), delay);
      };
    }
    
    async function handleSkillSearch() {
      const searchInput = document.getElementById('skill-search');
      const suggestionsDiv = document.getElementById('skill-suggestions');
      const query = searchInput.value.trim();
      
      try {
        let url = '/api/skills/autocomplete?limit=12';
        if (query) url += '&q=' + encodeURIComponent(query);
        
        const res = await fetch(url);
        const skills = await res.json();
        
        // Filter by category if active
        let filtered = activeCategory ? skills.filter(s => s.category === activeCategory) : skills;
        
        // Filter out already selected skills
        filtered = filtered.filter(s => !selectedSkills.has(s.name));
        
        currentSuggestions = filtered;
        skillSuggestionIndex = -1;
        
        if (filtered.length === 0 && query) {
          // Show option to add custom skill
          suggestionsDiv.innerHTML = \`
            <div class="skill-suggestion" onclick="addCustomSkill('\${escapeHtml(query)}')">
              <span class="skill-suggestion-icon">✨</span>
              <span class="skill-suggestion-name">Add "\${escapeHtml(query)}" as custom skill</span>
            </div>
          \`;
        } else {
          suggestionsDiv.innerHTML = filtered.map((s, i) => \`
            <div class="skill-suggestion" data-index="\${i}" onclick="selectSkill('\${escapeHtml(s.name)}', '\${s.category}')">
              <span class="skill-suggestion-icon">\${s.icon || '🔧'}</span>
              <span class="skill-suggestion-name">\${s.name}</span>
              <span class="skill-suggestion-category">\${s.categoryName}</span>
            </div>
          \`).join('');
        }
        
        suggestionsDiv.style.display = filtered.length > 0 || query ? 'block' : 'none';
      } catch (e) {
        console.error('Skill search error:', e);
      }
    }
    
    function handleSkillKeydown(e) {
      const suggestionsDiv = document.getElementById('skill-suggestions');
      
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        skillSuggestionIndex = Math.min(skillSuggestionIndex + 1, currentSuggestions.length - 1);
        updateSuggestionHighlight();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        skillSuggestionIndex = Math.max(skillSuggestionIndex - 1, -1);
        updateSuggestionHighlight();
      } else if (e.key === 'Enter') {
        e.preventDefault();
        if (skillSuggestionIndex >= 0 && currentSuggestions[skillSuggestionIndex]) {
          const s = currentSuggestions[skillSuggestionIndex];
          selectSkill(s.name, s.category);
        } else if (e.target.value.trim()) {
          addCustomSkill(e.target.value.trim());
        }
      } else if (e.key === 'Escape') {
        suggestionsDiv.style.display = 'none';
      }
    }
    
    function updateSuggestionHighlight() {
      const items = document.querySelectorAll('.skill-suggestion');
      items.forEach((item, i) => {
        item.classList.toggle('selected', i === skillSuggestionIndex);
      });
      if (skillSuggestionIndex >= 0 && items[skillSuggestionIndex]) {
        items[skillSuggestionIndex].scrollIntoView({ block: 'nearest' });
      }
    }
    
    function selectSkill(name, category) {
      if (selectedSkills.has(name)) return;
      
      selectedSkills.add(name);
      renderSelectedSkills();
      updateSkillsHidden();
      
      // Clear search
      document.getElementById('skill-search').value = '';
      document.getElementById('skill-suggestions').style.display = 'none';
    }
    
    function addCustomSkill(name) {
      if (selectedSkills.has(name)) return;
      
      selectedSkills.add(name);
      renderSelectedSkills();
      updateSkillsHidden();
      
      // Clear search
      document.getElementById('skill-search').value = '';
      document.getElementById('skill-suggestions').style.display = 'none';
    }
    
    function removeSkill(btn) {
      const tag = btn.closest('.selected-skill-tag');
      const name = tag.dataset.skill;
      selectedSkills.delete(name);
      tag.remove();
      updateSkillsHidden();
      
      // Show placeholder if empty
      const container = document.getElementById('selected-skills');
      if (selectedSkills.size === 0) {
        container.innerHTML = '<span style="color:#52525b;font-size:13px;">No skills selected yet. Start typing above or click a category.</span>';
      }
    }
    
    function renderSelectedSkills() {
      const container = document.getElementById('selected-skills');
      const skills = Array.from(selectedSkills);
      
      if (skills.length === 0) {
        container.innerHTML = '<span style="color:#52525b;font-size:13px;">No skills selected yet. Start typing above or click a category.</span>';
        return;
      }
      
      container.innerHTML = skills.map(name => \`
        <div class="selected-skill-tag" data-skill="\${escapeHtml(name)}" data-category="other">
          <span>\${escapeHtml(name)}</span>
          <button type="button" onclick="removeSkill(this)" style="background:none;border:none;color:#ef4444;cursor:pointer;margin-left:4px;font-size:14px;">×</button>
        </div>
      \`).join('');
    }
    
    function updateSkillsHidden() {
      const hidden = document.getElementById('skills-hidden');
      hidden.value = Array.from(selectedSkills).join(', ');
    }
    
    function filterSkillsByCategory(category) {
      activeCategory = category;
      
      // Update button states
      document.querySelectorAll('.skill-cat-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.category === category);
      });
      
      // Trigger search with current input
      handleSkillSearch();
      document.getElementById('skill-suggestions').style.display = 'block';
    }
    
    function escapeHtml(str) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }
    // ========== END SKILL AUTOCOMPLETE ==========
    
    async function verifyX() {
      const btn = event.target;
      const username = prompt('Enter your X/Twitter username (without @):');
      if (!username) return;
      
      btn.disabled = true;
      btn.textContent = 'Generating challenge...';
      
      try {
        // Step 1: Initiate hardened verification
        const initRes = await fetch('/api/verify/x/initiate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ profileId, username })
        });
        const initData = await initRes.json();
        
        if (!initData.success) {
          alert('Error: ' + initData.error);
          btn.textContent = 'Verify';
          btn.disabled = false;
          return;
        }
        
        // Step 2: Show instructions and get tweet URL
        const tweetUrl = prompt(
          'Post this exact tweet on X:

' +
          initData.tweetContent + '

' +
          'Paste your tweet URL here:');
        
        if (!tweetUrl) {
          btn.textContent = 'Verify';
          btn.disabled = false;
          return;
        }
        
        btn.textContent = 'Verifying tweet...';
        
        // Step 3: Confirm verification
        const confirmRes = await fetch('/api/verify/x/confirm', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ challengeId: initData.challengeId, tweetUrl })
        });
        const confirmData = await confirmRes.json();
        
        if (confirmData.verified) {
          btn.classList.add('verified');
          btn.textContent = '✓ Verified';
          alert('✅ X verification successful!

Username: @' + confirmData.username);
          location.reload();
        } else {
          alert('❌ Verification failed: ' + confirmData.error);
          btn.textContent = 'Verify';
        }
        
      } catch (e) {
        alert('Error: ' + e.message);
        btn.textContent = 'Verify';
      }
      btn.disabled = false;
    }
    async function syncX() {
      const btn = event.target;
      btn.disabled = true;
      btn.textContent = 'Syncing...';
      try {
        const res = await fetch('/api/profile/' + profileId + '/x-sync', { method: 'POST' });
        const data = await res.json();
        if (data.synced) {
          btn.textContent = '✓ Synced';
          btn.style.background = '#22c55e';
          alert('X synced! ' + data.data.followers + ' followers. Avatar and stats updated.');
          setTimeout(() => location.reload(), 1000);
        } else {
          alert('Sync failed: ' + (data.error || data.reason));
          btn.textContent = '🔄 Sync';
        }
      } catch (e) {
        alert('Error: ' + e.message);
        btn.textContent = '🔄 Sync';
      }
      btn.disabled = false;
    }

