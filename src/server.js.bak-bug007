      ${success ? `
        <div class="unsub-icon">✅</div>
        <h1 class="unsub-title">Unsubscribed Successfully</h1>
        <p class="unsub-message">
          You've been unsubscribed from all AgentFolio email notifications. 
          You can re-enable them anytime from your profile settings.
        </p>
      ` : `
        <div class="unsub-icon">❌</div>
        <h1 class="unsub-title">Unsubscribe Failed</h1>
        <p class="unsub-message">
          ${result.error || 'Something went wrong. Please try again or contact support.'}
        </p>
      `}
      <a href="/" class="unsub-btn">Back to AgentFolio</a>
    </div>
  </main>
</body>
</html>`;
}

// ============ TRUST SCORE COMPUTATION ============
function computeTrustData(agentId) {
  const profile = loadProfile(agentId);
  if (!profile) {

    return {
      agentId,
      trustScore: 0,
      tier: 'unverified',
      verifications: [],
      profileUrl: `https://agentfolio.bot/profile/${agentId}`,
      lastUpdated: new Date().toISOString(),
      warning: 'not_found'
    };
  }

  let score = 0;

  // 1. Verifications (up to 30 points) — 10 per verification, max 3 counted
  const verificationData = profile.verificationData || {};
  const verifiedPlatforms = Object.entries(verificationData)
    .filter(([key, v]) => v && v.verified && key !== 'onboardingDismissed')
    .map(([key]) => key);
  score += Math.min(verifiedPlatforms.length * 10, 30);

  // 2. Profile completeness (up to 20 points)
  const completeness = calculateProfileCompleteness(profile);
  score += Math.round(completeness.score * 0.2); // completeness is 0-100, map to 0-20

  // 3. Marketplace history (up to 25 points)
  const mktStats = getMarketplaceStats(profile.id);
  const jobsCompleted = mktStats.completedJobs || 0;
  score += Math.min(jobsCompleted * 5, 15); // up to 15 for completed jobs
  const avgRating = mktStats.averageRating || 0;
  score += Math.min(Math.round(avgRating * 2), 10); // up to 10 for ratings (5 star = 10)

  // 4. Account age (up to 15 points)
  if (profile.createdAt) {
    const ageMs = Date.now() - new Date(profile.createdAt).getTime();
    const ageDays = ageMs / (1000 * 60 * 60 * 24);
    if (ageDays >= 90) score += 15;
    else if (ageDays >= 30) score += 10;
    else if (ageDays >= 7) score += 5;
    else score += 2;
  }

  // 5. Endorsements (up to 10 points)
  const endorsements = profile.endorsements || [];
  score += Math.min(endorsements.length * 2, 10);

  // Clamp to 0-100
  score = Math.max(0, Math.min(100, score));

  // Determine tier
  let tier;
  if (score >= 80) tier = 'trusted';
  else if (score >= 60) tier = 'established';
  else if (score >= 40) tier = 'verified';
  else if (score >= 20) tier = 'basic';
  else tier = 'unverified';

  // Warnings
  let warning = null;
  if (profile.flagged || profile.suspended) warning = 'disputed';
  else if (verifiedPlatforms.length === 0) warning = 'unverified';

  return {
    agentId: profile.id,
    trustScore: score,
    tier,
    verifications: verifiedPlatforms,
    profileUrl: `https://agentfolio.bot/profile/${profile.id}`,
    lastUpdated: profile.updatedAt || profile.createdAt || new Date().toISOString(),
    warning
  };
}

function generateTradingDashboardPage(profile, hlAddress, hlVerified) {
  const safeName = escapeHtml(profile.name || profile.id);
  return pageHeader('Trading Dashboard - ' + safeName, `<style>
    .td-container { max-width:1100px; margin:0 auto; padding:32px 20px 60px; }
    .td-header { display:flex; align-items:center; gap:16px; margin-bottom:32px; }
    .td-header img { width:48px; height:48px; border-radius:50%; border:2px solid #06b6d4; }
    .td-header h1 { font-size:1.5rem; color:#fafafa; margin:0; }
    .td-header .td-addr { font-size:0.75rem; color:#71717a; font-family:monospace; }
    .td-back { color:#06b6d4; text-decoration:none; font-size:0.85rem; }
    .td-back:hover { text-decoration:underline; }
    .td-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:32px; }
    .td-card { background:#111113; border:1px solid #27272a; border-radius:12px; padding:20px; }
    .td-card .label { font-size:0.7rem; color:#71717a; text-transform:uppercase; letter-spacing:1px; margin-bottom:6px; }
    .td-card .value { font-size:1.5rem; font-weight:700; color:#fafafa; }
    .td-card .value.green { color:#22c55e; }
    .td-card .value.red { color:#ef4444; }
    .td-section { background:#111113; border:1px solid #27272a; border-radius:12px; padding:24px; margin-bottom:24px; }
    .td-section h2 { font-size:1rem; color:#fafafa; margin:0 0 16px; }
    .td-chart { font-family:'SF Mono',Monaco,Consolas,monospace; font-size:12px; line-height:1.4; color:#71717a; white-space:pre; overflow-x:auto; }
    .td-chart .bar-pos { color:#22c55e; }
    .td-chart .bar-neg { color:#ef4444; }
    .td-pos-table { width:100%; border-collapse:collapse; }
    .td-pos-table th { text-align:left; font-size:0.7rem; color:#71717a; text-transform:uppercase; letter-spacing:1px; padding:8px 12px; border-bottom:1px solid #27272a; }
    .td-pos-table td { padding:10px 12px; border-bottom:1px solid #18181b; font-size:0.85rem; color:#a1a1aa; font-family:monospace; }
    .td-pos-table tr:hover { background:#18181b; }
    .td-fills { max-height:300px; overflow-y:auto; }
    .td-fill { display:flex; justify-content:space-between; padding:6px 0; border-bottom:1px solid #18181b; font-size:0.8rem; color:#a1a1aa; }
    .td-no-data { text-align:center; padding:60px 20px; color:#52525b; }
    .td-no-data h2 { color:#71717a; }
    .td-spinner { display:inline-block; width:20px; height:20px; border:2px solid #27272a; border-top-color:#06b6d4; border-radius:50%; animation:spin 0.8s linear infinite; }
    @keyframes spin { to { transform:rotate(360deg); } }
    .td-loading { text-align:center; padding:40px; color:#71717a; }
    @media(max-width:768px) { .td-grid { grid-template-columns:repeat(2,1fr); } }
  </style>`) + `
  <div class="td-container">
    <a href="/profile/${encodeURIComponent(profile.id)}" class="td-back">← Back to Profile</a>
    <div class="td-header">
      ${profile.avatar ? `<img src="${escapeAttr(profile.avatar)}" alt="">` : ''}
      <div>
        <h1>📊 ${safeName} Trading Dashboard</h1>
        ${hlAddress ? `<div class="td-addr">${escapeHtml(hlAddress)}</div>` : ''}
      </div>
    </div>
    ${!hlVerified ? `
    <div class="td-no-data">
      <h2>No Verified Wallet</h2>
      <p>This agent hasn't verified a Hyperliquid wallet yet.</p>
      <a href="/profile/${encodeURIComponent(profile.id)}/edit" style="color:#06b6d4;">Verify wallet →</a>
    </div>` : `
    <div id="trading-data">
      <div class="td-loading"><span class="td-spinner"></span> Loading live trading data...</div>
    </div>
    <script>
    (async () => {
      try {
        const res = await fetch('/api/profile/${encodeURIComponent(profile.id)}/trading');
        const data = await res.json();
        if (data.error) { document.getElementById('trading-data').innerHTML = '<div class="td-no-data"><h2>Error</h2><p>' + data.error + '</p></div>'; return; }
        const s = data.stats;
        const pnlClass = s.totalPnl >= 0 ? 'green' : 'red';
        const pnlSign = s.totalPnl >= 0 ? '+' : '';

        // Build ASCII chart from dailyPnl
        const days = Object.keys(data.dailyPnl).sort().slice(-30);
        let chartHtml = '';
        if (days.length > 0) {
          const vals = days.map(d => data.dailyPnl[d]);
          const maxAbs = Math.max(...vals.map(Math.abs), 1);
          const barWidth = 40;
          chartHtml = days.map(d => {
            const v = data.dailyPnl[d];
            const len = Math.round(Math.abs(v) / maxAbs * barWidth);
            const bar = v >= 0
              ? '  ' + ' '.repeat(barWidth) + ' │' + '<span class="bar-pos">' + '█'.repeat(len) + '</span>' + ' $' + v.toFixed(2)
              : '  ' + ' '.repeat(barWidth - len) + '<span class="bar-neg">' + '█'.repeat(len) + '</span>' + '│' + ' -$' + Math.abs(v).toFixed(2);
            return d.slice(5) + bar;
          }).join('\\n');
        } else {
          chartHtml = '  No trade history data available';
        }

        // Positions table
        let posHtml = '';
        if (data.positions.length > 0) {
          posHtml = '<table class="td-pos-table"><thead><tr><th>Coin</th><th>Side</th><th>Size</th><th>Entry</th><th>uPnL</th><th>Lev</th></tr></thead><tbody>';
          data.positions.forEach(p => {
            const side = parseFloat(p.size) > 0 ? '<span style="color:#22c55e">LONG</span>' : '<span style="color:#ef4444">SHORT</span>';
            const upnl = parseFloat(p.unrealizedPnl || 0);
            const upnlColor = upnl >= 0 ? '#22c55e' : '#ef4444';
            posHtml += '<tr><td style="color:#fafafa;font-weight:600">' + p.coin + '</td><td>' + side + '</td><td>' + Math.abs(parseFloat(p.size)).toFixed(4) + '</td><td>$' + parseFloat(p.entryPx).toFixed(2) + '</td><td style="color:' + upnlColor + '">' + (upnl>=0?'+':'') + upnl.toFixed(2) + '</td><td>' + p.leverage + 'x</td></tr>';
          });
          posHtml += '</tbody></table>';
        } else {
          posHtml = '<div style="color:#52525b;text-align:center;padding:20px;">No open positions</div>';
        }

        // Recent fills
        let fillsHtml = '';
        if (data.recentFills.length > 0) {
          fillsHtml = data.recentFills.slice(0, 30).map(f => {
            const pnl = f.closedPnl ? parseFloat(f.closedPnl) : null;
            const pnlStr = pnl !== null && pnl !== 0 ? '<span style="color:' + (pnl>=0?'#22c55e':'#ef4444') + '">' + (pnl>=0?'+':'') + pnl.toFixed(2) + '</span>' : '';
            const sideColor = f.side === 'B' ? '#22c55e' : '#ef4444';
            const t = f.time ? new Date(f.time).toLocaleString() : '';
            return '<div class="td-fill"><span><span style="color:' + sideColor + '">' + (f.side==='B'?'BUY':'SELL') + '</span> ' + f.coin + ' ' + f.sz + ' @ $' + parseFloat(f.px).toFixed(2) + '</span><span>' + pnlStr + ' <span style="color:#52525b">' + t + '</span></span></div>';
          }).join('');
        }

        // BTC benchmark comparison
        let benchmarkHtml = '<div style="color:#52525b;font-size:0.8rem;margin-top:8px;">BTC benchmark: fetch live data for comparison</div>';

        document.getElementById('trading-data').innerHTML =
          '<div class="td-grid">' +
            '<div class="td-card"><div class="label">Account Value</div><div class="value">$' + data.accountValue.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) + '</div></div>' +
            '<div class="td-card"><div class="label">Total P&L</div><div class="value ' + pnlClass + '">' + pnlSign + '$' + Math.abs(s.totalPnl).toFixed(2) + '</div></div>' +
            '<div class="td-card"><div class="label">Win Rate</div><div class="value">' + s.winRate + '%</div><div style="color:#52525b;font-size:0.75rem">' + s.wins + '/' + s.closedTrades + ' trades</div></div>' +
            '<div class="td-card"><div class="label">Avg Profit</div><div class="value ' + (s.avgProfit>=0?'green':'red') + '">' + (s.avgProfit>=0?'+':'') + '$' + Math.abs(s.avgProfit).toFixed(2) + '</div></div>' +
          '</div>' +
          '<div class="td-section"><h2>📈 Daily P&L (Last 30 Days)</h2><div class="td-chart">' + chartHtml + '</div></div>' +
          '<div class="td-section"><h2>🔥 Open Positions</h2>' + posHtml + '</div>' +
          '<div class="td-section"><h2>📋 Recent Trades</h2><div class="td-fills">' + fillsHtml + '</div></div>';

        // Fetch BTC benchmark
        try {
          const btcRes = await fetch('https://api.hyperliquid.xyz/info', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({type:'candleSnapshot',req:{coin:'BTC',interval:'1d',startTime:Date.now()-30*86400000,endTime:Date.now()}})});
          const btcData = await btcRes.json();
          if (btcData && btcData.length > 1) {
            const btcStart = parseFloat(btcData[0].o);
            const btcEnd = parseFloat(btcData[btcData.length-1].c);
            const btcReturn = ((btcEnd - btcStart) / btcStart * 100).toFixed(2);
            const traderReturn = data.accountValue > 0 ? (s.totalPnl / (data.accountValue - s.totalPnl) * 100).toFixed(2) : '0.00';
            const outperform = parseFloat(traderReturn) > parseFloat(btcReturn);
            const benchEl = document.createElement('div');
            benchEl.className = 'td-section';
            benchEl.innerHTML = '<h2>⚡ Performance vs BTC</h2><div style="display:flex;gap:32px;font-size:0.9rem"><div><span style="color:#71717a">Agent Return:</span> <span style="color:' + (parseFloat(traderReturn)>=0?'#22c55e':'#ef4444') + ';font-weight:700">' + traderReturn + '%</span></div><div><span style="color:#71717a">BTC Return (30d):</span> <span style="color:' + (parseFloat(btcReturn)>=0?'#22c55e':'#ef4444') + ';font-weight:700">' + btcReturn + '%</span></div><div><span style="color:#71717a">Alpha:</span> <span style="color:' + (outperform?'#22c55e':'#ef4444') + ';font-weight:700">' + (outperform?'▲':'▼') + ' ' + Math.abs(parseFloat(traderReturn) - parseFloat(btcReturn)).toFixed(2) + '%</span></div></div>';
            document.getElementById('trading-data').appendChild(benchEl);
          }
        } catch(e) { console.log('BTC benchmark error', e); }
      } catch(err) {
        document.getElementById('trading-data').innerHTML = '<div class="td-no-data"><h2>Error Loading Data</h2><p>' + err.message + '</p></div>';
      }
    })();
    </script>`}
  </div>
  ` + PAGE_FOOTER;
}

const server = http.createServer((req, res) => {
  const url = new URL(req.url, `http://localhost:${PORT}`);
  const requestStart = Date.now();
  
  // ── Route Aliases: fix frontend/backend path mismatches ──
  const ROUTE_ALIASES = {
    '/api/verify/agentmail/challenge': '/api/verify/agentmail/initiate',
    '/api/verify/x/challenge': '/api/verify/x/initiate',
    '/api/verify/solana/challenge': '/api/verify/solana/initiate',
    '/api/verification/eth/initiate': '/api/verify/eth/initiate',
    '/api/verification/eth/verify': '/api/verify/eth/verify',
    '/api/verification/domain/initiate': '/api/verify/domain/initiate',
    '/api/verification/domain/verify': '/api/verify/domain/verify',
    '/api/verification/discord/initiate': '/api/verify/discord/initiate',
    '/api/verification/telegram/initiate': '/api/verify/telegram/initiate',
    '/api/verification/telegram/verify': '/api/verify/telegram/verify',
  };
  if (ROUTE_ALIASES[url.pathname]) {
    url.pathname = ROUTE_ALIASES[url.pathname];
  }
  
  // Record request for health monitoring
  recordRequest();
  
  // On-chain avatar resolver
  if (url.pathname === '/api/avatar/onchain') {
    try {
      const { handleOnChainAvatarRequest } = require('./lib/onchain-avatar');
      if (handleOnChainAvatarRequest(req, res, url)) return;
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
      return;
    }
  }

  // Avatar image redirect: /avatar/<wallet> → Arweave image
  if (url.pathname.startsWith('/avatar/')) {
    try {
      const { handleAvatarRedirect } = require('./lib/onchain-avatar');
      if (handleAvatarRedirect(req, res, url)) return;
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
      return;
    }
  }

  // Public burn-to-become routes (mint page API)
  if (url.pathname.startsWith('/api/burn-to-become/')) {
    try {
      const { handleBurnToBecome } = require('./routes/burn-to-become-public');
      if (handleBurnToBecome(req, res, url)) return;
    } catch (e) {
      console.error('[BurnPublic] Route error:', e);
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
      return;
    }
  }


  // SATP Auto-Identity routes (raw HTTP adapter)
  if (url.pathname.startsWith("/api/satp-auto/identity/")) {
    const { buildCreateIdentityTx, hasIdentity, getIdentityPDA, SATP_IDENTITY_PROGRAM } = require("./routes/satp-auto-identity");
    const sendJsonSatp = (code, data) => {
      res.writeHead(code, { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" });
      res.end(JSON.stringify(data));
    };
    if (req.method === "OPTIONS") {
      res.writeHead(204, { "Access-Control-Allow-Origin": "*", "Access-Control-Allow-Methods": "GET, POST, OPTIONS", "Access-Control-Allow-Headers": "Content-Type" });
      res.end();
      return;
    }
    // Parse body for POST
    if (req.method === "POST" && !req._satpBodyParsed) {
      let bodyStr = "";
      req.on("data", chunk => bodyStr += chunk);
      req.on("end", () => {
        try { req.body = JSON.parse(bodyStr); } catch { req.body = {}; }
        req._satpBodyParsed = true;
        // Re-process this request path inline
        const satpUrl = new URL(req.url, "http://localhost");
        if (satpUrl.pathname === "/api/satp-auto/identity/create") {
          const { buildCreateIdentityTx, SATP_IDENTITY_PROGRAM } = require("./routes/satp-auto-identity");
          (async () => {
            try {
              const { walletAddress, profileId, name, description, category } = req.body || {};
              if (!walletAddress) { res.writeHead(400, {"Content-Type":"application/json","Access-Control-Allow-Origin":"*"}); res.end(JSON.stringify({error:"walletAddress required"})); return; }
              let agentName = name || "Agent", agentDesc = description || "AgentFolio verified agent", agentCat = category || "ai-agent", caps = [], metaUri = "";
              if (profileId) { try { const Database = require("better-sqlite3"); const path = require("path"); const db = new Database(path.join(__dirname, "../data/agentfolio.db"), {readonly:true}); const p = db.prepare("SELECT * FROM profiles WHERE id = ?").get(profileId); if (p) { agentName = (p.name||agentName).slice(0,32); agentDesc = (p.bio||agentDesc).slice(0,256); metaUri = "https://agentfolio.bot/api/profile/"+profileId; } db.close(); } catch(e){} }
              const result = await buildCreateIdentityTx(walletAddress, agentName, agentDesc, agentCat, caps, metaUri);
              console.log("[SATP AutoID] Built TX for " + walletAddress);
              res.writeHead(200, {"Content-Type":"application/json","Access-Control-Allow-Origin":"*"});
              res.end(JSON.stringify({ok:true, data:result}));
            } catch(err) { res.writeHead(500, {"Content-Type":"application/json","Access-Control-Allow-Origin":"*"}); res.end(JSON.stringify({error:err.message})); }
          })();
        } else if (satpUrl.pathname === "/api/satp-auto/identity/confirm") {
          const { getIdentityPDA, SATP_IDENTITY_PROGRAM } = require("./routes/satp-auto-identity");
          (async () => {
            try {
              const { walletAddress, profileId, txSignature } = req.body || {};
              if (!walletAddress || !profileId) { res.writeHead(400, {"Content-Type":"application/json","Access-Control-Allow-Origin":"*"}); res.end(JSON.stringify({error:"walletAddress and profileId required"})); return; }
              const { PublicKey } = require("@solana/web3.js");
              const [pda] = getIdentityPDA(new PublicKey(walletAddress));
              try { const Database = require("better-sqlite3"); const path = require("path"); const db = new Database(path.join(__dirname, "../data/agentfolio.db")); const profile = db.prepare("SELECT verification_data FROM profiles WHERE id = ?").get(profileId); if (profile) { let vd = {}; try{vd=JSON.parse(profile.verification_data||"{}")}catch{} vd.satp = {verified:true, identityPDA:pda.toBase58(), txSignature, program:SATP_IDENTITY_PROGRAM.toBase58(), network:"mainnet", verifiedAt:new Date().toISOString()}; db.prepare("UPDATE profiles SET verification_data = ? WHERE id = ?").run(JSON.stringify(vd), profileId); } db.close(); } catch(e){ console.warn("[SATP AutoID] DB err:",e.message); }
              res.writeHead(200, {"Content-Type":"application/json","Access-Control-Allow-Origin":"*"});
              res.end(JSON.stringify({ok:true, data:{identityPDA:pda.toBase58(), txSignature, walletAddress, profileId}}));
            } catch(err) { res.writeHead(500, {"Content-Type":"application/json","Access-Control-Allow-Origin":"*"}); res.end(JSON.stringify({error:err.message})); }
          })();
        }
      });
      return;
    }

    // POST /api/satp-auto/identity/create
    if (url.pathname === "/api/satp-auto/identity/create" && req.method === "POST") {
      (async () => {
        try {
          const { walletAddress, profileId, name, description, category } = req.body || {};
          if (!walletAddress) return sendJsonSatp(400, { error: "walletAddress required" });

          let agentName = name || "Agent";
          let agentDescription = description || "AgentFolio verified agent";
          let agentCategory = category || "ai-agent";
          let capabilities = [];
          let metadataUri = "";

          if (profileId) {
            try {
              const Database = require("better-sqlite3");
              const path = require("path");
              const db = new Database(path.join(__dirname, "../data/agentfolio.db"), { readonly: true });
              const profile = db.prepare("SELECT * FROM profiles WHERE id = ?").get(profileId);
              if (profile) {
                agentName = (profile.name || agentName).slice(0, 32);
                agentDescription = (profile.bio || agentDescription).slice(0, 256);
                try { capabilities = JSON.parse(profile.capabilities || "[]").slice(0, 10); } catch {}
                metadataUri = "https://agentfolio.bot/api/profile/" + profileId;
              }
              db.close();
            } catch (e) { console.warn("[SATP AutoID] Profile lookup failed:", e.message); }
          }

          const result = await buildCreateIdentityTx(walletAddress, agentName, agentDescription, agentCategory, capabilities, metadataUri);
          if (result.alreadyExists) {
            return sendJsonSatp(200, { ok: true, data: { ...result, message: "SATP identity already exists for this wallet" } });
          }
          console.log("[SATP AutoID] Built create_identity TX for " + walletAddress + " (profile: " + (profileId || "none") + ")");
          sendJsonSatp(200, { ok: true, data: result });
        } catch (err) {
          console.error("[SATP AutoID] create error:", err.message);
          sendJsonSatp(500, { error: "Failed to build identity TX", detail: err.message });
        }
      })();
      return;
    }

    // POST /api/satp-auto/identity/confirm
    if (url.pathname === "/api/satp-auto/identity/confirm" && req.method === "POST") {
      (async () => {
        try {
          const { walletAddress, profileId, txSignature } = req.body || {};
          if (!walletAddress || !profileId) return sendJsonSatp(400, { error: "walletAddress and profileId required" });
          const { PublicKey } = require("@solana/web3.js");
          const [identityPDA] = getIdentityPDA(new PublicKey(walletAddress));
          try {
            const Database = require("better-sqlite3");
            const path = require("path");
            const db = new Database(path.join(__dirname, "../data/agentfolio.db"));
            const profile = db.prepare("SELECT verification_data FROM profiles WHERE id = ?").get(profileId);
            if (profile) {
              let vd = {};
              try { vd = JSON.parse(profile.verification_data || "{}"); } catch {}
              vd.satp = { verified: true, identityPDA: identityPDA.toBase58(), txSignature, program: SATP_IDENTITY_PROGRAM.toBase58(), network: "mainnet", verifiedAt: new Date().toISOString() };
              db.prepare("UPDATE profiles SET verification_data = ? WHERE id = ?").run(JSON.stringify(vd), profileId);
            }
            db.close();
            console.log("[SATP AutoID] Identity confirmed for " + profileId + ": PDA=" + identityPDA.toBase58());
          } catch (dbErr) { console.warn("[SATP AutoID] DB update failed:", dbErr.message); }
          sendJsonSatp(200, { ok: true, data: { identityPDA: identityPDA.toBase58(), txSignature, network: "mainnet", walletAddress, profileId } });
        } catch (err) {
          console.error("[SATP AutoID] confirm error:", err.message);
          sendJsonSatp(500, { error: "Failed to confirm identity", detail: err.message });
        }
      })();
      return;
    }

    // GET /api/satp-auto/identity/check/:wallet
    if (url.pathname.startsWith("/api/satp-auto/identity/check/") && req.method === "GET") {
      (async () => {
        try {
          const wallet = url.pathname.split("/").pop();
          const { PublicKey } = require("@solana/web3.js");
          const exists = await hasIdentity(wallet);
          const [pda] = getIdentityPDA(new PublicKey(wallet));
          sendJsonSatp(200, { ok: true, exists, identityPDA: pda.toBase58(), network: "mainnet" });
        } catch (err) { sendJsonSatp(500, { error: err.message }); }
      })();
      return;
    }

    sendJsonSatp(404, { error: "Unknown SATP auto-identity endpoint" });
    return;
  }

  // Hardened verification routes (Sprint 2 — all providers)
  const hardenedHelpers = { loadProfile, dbSaveProfileFn, addActivityAndBroadcast, postVerificationMemo, postVerificationOnchainForProfile };
  if (url.pathname.startsWith('/api/verify/') || url.pathname.match(/^\/api\/profile\/[^/]+\/verify\//)) {
    const hardenedProviders = ['github', 'x', 'agentmail', 'solana', 'discord', 'eth', 'domain', 'telegram', 'hyperliquid', 'polymarket', 'moltbook', 'website'];
    const isHardenedRoute = hardenedProviders.some(provider => url.pathname.includes(provider));
    
    if (isHardenedRoute) {
      try {
        if (handleVerificationRoutes(url, req, res, DATA_DIR, hardenedHelpers)) {
          return;
        }
      } catch (e) {
        console.error('[Hardened] Verification error:', e);
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Hardened verification error: ' + e.message }));
        return;
      }
    }
  }
  
  // Log response on finish
  res.on('finish', () => {
    const duration = Date.now() - requestStart;
    const logData = {
      method: req.method,
      path: url.pathname,
      status: res.statusCode,
      duration: `${duration}ms`,
      ip: req.headers['x-forwarded-for'] || req.socket.remoteAddress
    };
    
    // Only log errors and slow requests to reduce noise
    if (res.statusCode >= 400) {
      logger.warn('HTTP Request', logData);
    } else if (duration > 1000) {
      logger.info('Slow request', logData);
    }
    // Skip logging normal fast requests (they go to access.log via debug level if needed)
  });
  
  // Apply security middleware first (headers + suspicious request check)
  if (!securityMiddleware(req, res)) {
    return; // Request blocked or handled (preflight)
  }
  
  // Rate limiting for ALL requests
  // Determine rate limit tier based on method and path
  const isWriteMethod = ['POST', 'PUT', 'PATCH', 'DELETE'].includes(req.method);
  const isApiEndpoint = url.pathname.startsWith('/api/');
  const isSearchEndpoint = url.pathname.includes('/search') || url.pathname.includes('/api/search');
  const isVerifyEndpoint = url.pathname.includes('/verify/');
  
  // Select appropriate rate limit tier
  let tier;
  if (isVerifyEndpoint) {
    tier = 'verify'; // 5/min for verification triggers
  } else if (isSearchEndpoint) {
    tier = 'search'; // 30/min for search
  } else if (isWriteMethod) {
    tier = 'write'; // 10/min for writes (POST, PUT, PATCH, DELETE)
  } else if (isApiEndpoint) {
    tier = 'api'; // 100/min for API reads
  } else {
    tier = 'read'; // 100/min for page loads
  }
  
  if (!rateLimitMiddleware(req, res, RATE_LIMITS[tier])) {
    return; // Response already sent (rate limited)
  }
  
  // Health check endpoints (no auth required)
  if (url.pathname === '/health') {
    const health = getBasicHealth(path.join(__dirname, '..', 'data'));
    const statusCode = health.status === 'healthy' ? 200 : health.status === 'degraded' ? 200 : 503;
    res.writeHead(statusCode, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(health, null, 2));
    return;
  }
  
  if (url.pathname === '/health/detailed') {
    const health = getDetailedHealth(
      path.join(__dirname, '..', 'data'),
      path.join(__dirname, '..', 'data', 'agentfolio.db')
    );
    const statusCode = health.status === 'healthy' ? 200 : health.status === 'degraded' ? 200 : 503;
    res.writeHead(statusCode, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(health, null, 2));
    return;
  }
  
  if (url.pathname === '/api/cache/stats') {
    const cacheStats = require('./lib/cache').stats();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(cacheStats, null, 2));
    return;
  }

  if (url.pathname === '/api/cache/clear' && req.method === 'POST') {
    require('./lib/cache').clear();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ success: true, message: 'All caches cleared' }));
    return;
  }

  if (url.pathname === '/metrics') {
    const metrics = getPrometheusMetrics(path.join(__dirname, '..', 'data'));
    res.writeHead(200, { 'Content-Type': 'text/plain; charset=utf-8' });
    res.end(metrics);
    return;
  }
  
  if (url.pathname === '/connect') {
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateConnectPage());
  }
  else if (url.pathname === '/join') {
    res.writeHead(302, { 'Location': '/register' });
    res.end();
  }
  else if (url.pathname === '/' || url.pathname === '/index.html') {
    const profiles = listProfiles(DATA_DIR);
    const recentActivities = getGlobalFeed(DATA_DIR, 5);
    // Get open jobs with funded escrow for homepage feature
    const allJobs = listJobs({ status: 'open', limit: 10 });
    const featuredJobs = (allJobs.jobs || [])
      .filter(j => j.escrowId)
      .sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt))
      .slice(0, 3);
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateIndex(profiles, { activities: recentActivities, featuredJobs }));
  }
  else if (url.pathname === '/directory') {
    const profiles = listProfiles(DATA_DIR);
    const sorted = [...profiles].sort((a, b) => {
      const aScore = (a.reputation?.score || a.trustScore || 0);
      const bScore = (b.reputation?.score || b.trustScore || 0);
      return bScore - aScore;
    });
    const rows = sorted.map((p, i) => {
      const score = p.reputation?.score || p.trustScore || 0;
      const skills = (p.skills || []).map(s => typeof s === 'string' ? s : s.name).slice(0, 4).join(', ');
      const verified = [];
      if (p.verificationData?.github?.verified) verified.push('GitHub');
      if (p.verificationData?.solana?.verified) verified.push('Solana');
      if (p.verificationData?.satp?.verified) verified.push('SATP');
      if (p.verificationData?.x?.verified) verified.push('X');
      const badges = verified.length ? verified.join(', ') : 'None';
      return `<tr>
        <td style="padding:10px 16px;border-bottom:1px solid #222;color:#666;text-align:center;">${i+1}</td>
        <td style="padding:10px 16px;border-bottom:1px solid #222;"><a href="/profile/${p.id}" style="color:#a78bfa;text-decoration:none;font-weight:600;">${p.name || p.id}</a></td>
        <td style="padding:10px 16px;border-bottom:1px solid #222;color:#ccc;">${score}</td>
        <td style="padding:10px 16px;border-bottom:1px solid #222;color:#888;font-size:13px;">${skills || '—'}</td>
        <td style="padding:10px 16px;border-bottom:1px solid #222;color:#888;font-size:13px;">${badges}</td>
      </tr>`;
    }).join('\n');
    const html = `<!DOCTYPE html>
<html lang="en"><head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Agent Directory — AgentFolio</title>
<meta name="description" content="Browse ${sorted.length} registered AI agents on AgentFolio. Verified identities, on-chain reputation, skills directory.">
<link rel="canonical" href="https://agentfolio.bot/directory">
<style>
  *{margin:0;padding:0;box-sizing:border-box}
  body{background:#0a0a0a;color:#e5e5e5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,monospace;min-height:100vh}
  .container{max-width:1100px;margin:0 auto;padding:20px}
  header{border-bottom:1px solid #222;padding:16px 0}
  header a{color:#e5e5e5;text-decoration:none;font-weight:800;font-size:20px}
  header nav{display:flex;justify-content:space-between;align-items:center;max-width:1100px;margin:0 auto;padding:0 20px}
  header nav .links a{color:#888;margin-left:20px;font-size:14px}
  header nav .links a:hover{color:#a78bfa}
  h1{font-size:32px;font-weight:800;margin:40px 0 8px;letter-spacing:-0.02em}
  .subtitle{color:#888;margin-bottom:32px;font-size:15px}
  table{width:100%;border-collapse:collapse;background:#111;border-radius:12px;overflow:hidden;border:1px solid #222}
  th{text-align:left;padding:12px 16px;color:#666;font-size:11px;text-transform:uppercase;letter-spacing:0.05em;border-bottom:1px solid #333;background:#0d0d0d}
  tr:hover{background:#1a1a2e}
  footer{text-align:center;padding:40px;color:#555;font-size:13px;border-top:1px solid #222;margin-top:60px}
</style>
</head><body>
<header><nav><a href="/">AgentFolio</a><div class="links"><a href="/">Home</a><a href="/directory">Directory</a><a href="/marketplace">Marketplace</a><a href="/leaderboard">Leaderboard</a></div></nav></header>
<div class="container">
<h1>Agent Directory</h1>
<p class="subtitle">${sorted.length} agents registered on AgentFolio — the reputation layer for AI agents.</p>
<table>
<thead><tr><th style="width:60px;text-align:center">#</th><th>Agent</th><th style="width:80px">Score</th><th>Skills</th><th>Verified</th></tr></thead>
<tbody>${rows}</tbody>
</table>
</div>
<footer>© 2026 AgentFolio. Built on Solana. Powered by SATP.</footer>
</body></html>`;
    res.writeHead(200, { 'Content-Type': 'text/html', 'Cache-Control': 'public, max-age=60' });
    res.end(html);
  }
  else if (url.pathname === '/search') {
    const query = url.searchParams.get('q') || '';
    const filters = {
      category: url.searchParams.get('category') || '',
      tier: url.searchParams.get('tier') || '',
      skill: url.searchParams.get('skill') || '',
      minRep: url.searchParams.get('minRep') || '',
      availability: url.searchParams.get('availability') || '',
      sort: url.searchParams.get('sort') || 'reputation'
    };
    
    // Build search options
    const searchOpts = {
      dataDir: DATA_DIR,
      skillCategory: filters.category || null,
      skill: filters.skill || null,
      verificationTier: filters.tier || null,
      limit: 100
    };
    
    let results = searchProfiles(query, searchOpts);
    
    // Additional filter: min reputation
    if (filters.minRep) {
      const minRep = parseInt(filters.minRep);
      results = results.filter(p => (p.reputation?.score || 0) >= minRep);
    }
    
    // Additional filter: availability status
    if (filters.availability) {
      results = results.filter(p => (p.availability || 'available') === filters.availability);
    }
    
    // Sort results
    if (filters.sort === 'name') {
      results.sort((a, b) => a.name.localeCompare(b.name));
    } else if (filters.sort === 'verified') {
      const tierOrder = { verified: 0, trusted: 1, rising: 2, unverified: 3 };
      results.sort((a, b) => (tierOrder[a.verification?.tier] || 3) - (tierOrder[b.verification?.tier] || 3));
    }
    // default: reputation (already sorted by searchProfiles)
    
    const categories = getSkillCategories(DATA_DIR);
    const skills = getAllSkills(DATA_DIR);
    
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateSearchPage(results, query, filters, categories, skills));
  }
  else if (url.pathname === '/leaderboard' || url.pathname === '/leaderboards') {
    const profiles = listProfiles(DATA_DIR);
    const tab = url.searchParams.get('tab') || 'reputation';
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateLeaderboardPage(profiles, tab));
  }
  else if (url.pathname === '/activity') {
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateActivityPage());
  }
  else if (url.pathname === '/following') {
    const followerId = url.searchParams.get('id') || '';
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateFollowingPage(followerId));
  }
  // Compare routes
  else if (url.pathname === '/compare') {
    const profiles = listProfiles(DATA_DIR);
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateComparePickerPage(profiles));
  }
  else if (url.pathname.match(/^\/compare\/([^/]+)\/([^/]+)$/)) {
    const parts = url.pathname.split('/');
    const id1 = parts[2];
    const id2 = parts[3];
    
    const profile1 = loadProfile(id1, DATA_DIR);
    const profile2 = loadProfile(id2, DATA_DIR);
    
    if (!profile1 || !profile2) {
      res.writeHead(404, { 'Content-Type': 'text/html' });
      res.end(`<!DOCTYPE html>
<html><head><title>Not Found</title>${COMMON_STYLES}</head>
<body style="display:flex;justify-content:center;align-items:center;min-height:100vh;">
<div style="text-align:center;">
  <h1 style="font-size:3rem;margin-bottom:16px;">😕</h1>
  <h2 style="color:#f4f4f5;">Agent Not Found</h2>
  <p style="color:#71717a;margin:16px 0;">One or both agents could not be found.</p>
  <a href="/compare" style="color:#06b6d4;">← Back to Compare</a>
</div>
</body></html>`);
      return;
    }
    
    const allProfiles = listProfiles(DATA_DIR);
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateComparePage(profile1, profile2, allProfiles, DATA_DIR));
  }
  else if (url.pathname === '/skills' || url.pathname === '/taxonomy') {
    const profiles = listProfiles(DATA_DIR);
    const categories = getSkillCategories(DATA_DIR);
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateSkillsPage(categories, profiles));
  }
  else if (url.pathname.match(/^\/profile\/([^/]+)\/contact$/)) {
    const profileId = url.pathname.split('/')[2];
    const profile = loadProfile(profileId, DATA_DIR);
    
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'text/plain' });
      res.end('Profile not found');
      return;
    }
    
    const contact = getContactInfo(profile);
    const agentmail = profile.links?.agentmail;
    // SECURITY: Escape user data for HTML output
    const safeName = escapeHtml(profile.name);
    
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(`<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact ${safeName} - AgentFolio</title>
  ${COMMON_STYLES}
${THEME_SCRIPT}
  <style>
    .contact-container { max-width: 600px; margin: 60px auto; padding: 0 20px; }
    .contact-card { background: #18181b; border: 1px solid #27272a; border-radius: 16px; padding: 32px; }
    .contact-header { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; }
    .contact-avatar { width: 64px; height: 64px; border-radius: 14px; background: #06b6d4; display: flex; align-items: center; justify-content: center; font-size: 28px; }
    .contact-name { font-size: 24px; font-weight: 700; color: #fff; }
    .contact-handle { color: #71717a; }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; font-size: 14px; font-weight: 600; margin-bottom: 8px; color: #e4e4e7; }
    .form-group input, .form-group textarea { width: 100%; padding: 12px 16px; background: #27272a; border: 1px solid #3f3f46; border-radius: 10px; color: #fff; font-size: 15px; }
    .form-group input:focus, .form-group textarea:focus { outline: none; border-color: #06b6d4; }
    .form-group textarea { resize: vertical; min-height: 120px; }
    .send-btn { width: 100%; padding: 14px; background: #06b6d4; border: none; border-radius: 10px; color: #fff; font-size: 16px; font-weight: 600; cursor: pointer; transition: transform 0.2s; }
    .send-btn:hover { transform: translateY(-2px); }
    .no-contact { text-align: center; color: #71717a; padding: 40px; }
    .alt-contact { margin-top: 20px; padding-top: 20px; border-top: 1px solid #27272a; text-align: center; color: #71717a; font-size: 14px; }
  </style>
</head>
<body>
  <header class="header">
    <div class="container header-inner">
      <a href="/" class="logo"><div class="logo-icon"><img src="/public/img/logo-eye.png" alt="AgentFolio" style="width:30px;height:20px;"></div><span class="gradient-text">AgentFolio</span></a>
      <nav class="nav">
        <a href="/">Browse</a>
        <a href="/leaderboard">Leaderboard</a>
        <a href="/submit">Join</a>
      </nav>
    </div>
  </header>
  
  <main class="container contact-container">
    <div class="contact-card">
      <div class="contact-header">
        <div class="contact-avatar">🤖</div>
        <div>
          <div class="contact-name">${profile.name}</div>
          <div class="contact-handle">${profile.handle}</div>
        </div>
      </div>
      
      ${agentmail ? `
        <form id="contact-form" onsubmit="sendMessage(event)">
          <div class="form-group">
            <label>Your Email / AgentMail</label>
            <input type="email" name="from" placeholder="you@agentmail.to" required>
          </div>
          <div class="form-group">
            <label>Subject</label>
            <input type="text" name="subject" value="Hello from AgentFolio" required>
          </div>
          <div class="form-group">
            <label>Message</label>
            <textarea name="message" placeholder="Your message to ${profile.name}..." required></textarea>
          </div>
          <button type="submit" class="send-btn">📧 Send via AgentMail</button>
        </form>
        <script>
          function sendMessage(e) {
            e.preventDefault();
            const form = e.target;
            const to = '${agentmail}';
            const subject = form.subject.value;
            const body = 'From: ' + form.from.value + '\\n\\n' + form.message.value + '\\n\\n---\\nSent via AgentFolio';
            window.location.href = 'mailto:' + to + '?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);
          }
        </script>
      ` : `
        <div class="no-contact">
          <p>This agent hasn't configured AgentMail yet.</p>
          ${profile.links?.x ? `<p style="margin-top:16px;">Try reaching out on X: <a href="https://x.com/${profile.links.x.replace('@','')}">${profile.links.x}</a></p>` : ''}
        </div>
      `}
      
      ${profile.links?.x && agentmail ? `
        <div class="alt-contact">
          Or reach out on <a href="https://x.com/${profile.links.x.replace('@','')}">X ${profile.links.x}</a>
        </div>
      ` : ''}
    </div>
    
    <p style="text-align:center;margin-top:20px;"><a href="/profile/${profileId}">← Back to profile</a></p>
  </main>
</body>
</html>`);
  }
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/contact$/)) {
    const profileId = url.pathname.split('/')[3];
    const profile = loadProfile(profileId, DATA_DIR);
    
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    
    const contact = getContactInfo(profile);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(contact, null, 2));
  }
  else if (url.pathname.startsWith('/profile/') && url.pathname.endsWith('/embed')) {
    // Embed code page for a profile
    const profileId = url.pathname.replace('/profile/', '').replace('/embed', '');
    const profile = loadProfile(profileId, DATA_DIR);
    
    if (profile) {
      const allProfiles = listProfiles(DATA_DIR);
      res.writeHead(200, { 'Content-Type': 'text/html' });
      res.end(generateEmbedPage(profile, allProfiles, DATA_DIR));
    } else {
      res.writeHead(404, { 'Content-Type': 'text/plain' });
      res.end('Profile not found');
    }
  }
  else if (url.pathname.startsWith('/profile/') && url.pathname.endsWith('/edit')) {
    // Profile edit page
    const profileId = url.pathname.replace('/profile/', '').replace('/edit', '');
    const profile = loadProfile(profileId, DATA_DIR);
    
    if (profile) {
      res.writeHead(200, { 'Content-Type': 'text/html' });
      res.end(generateEditPage(profile));
    } else {
      res.writeHead(404, { 'Content-Type': 'text/plain' });
      res.end('Profile not found');
    }
  }
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/trading$/) && req.method === 'GET') {
    // Trading dashboard JSON API
    const profileId = url.pathname.match(/^\/api\/profile\/([^/]+)\/trading$/)[1];
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    const hlAddress = profile.wallets?.hyperliquid;
    if (!hlAddress || !profile.verificationData?.hyperliquid?.verified) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'No verified Hyperliquid wallet' }));
      return;
    }
    Promise.all([
      fetch('https://api.hyperliquid.xyz/info', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ type: 'userState', user: hlAddress }) }).then(r => r.json()),
      fetch('https://api.hyperliquid.xyz/info', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ type: 'userFills', user: hlAddress }) }).then(r => r.json())
    ]).then(([userState, fills]) => {
      const positions = (userState.assetPositions || []).filter(p => parseFloat(p.position?.szi || '0') !== 0);
      const totalTrades = fills.length;
      const closedTrades = fills.filter(f => f.closedPnl && parseFloat(f.closedPnl) !== 0);
      const wins = closedTrades.filter(f => parseFloat(f.closedPnl) > 0).length;
      const winRate = closedTrades.length > 0 ? (wins / closedTrades.length * 100).toFixed(1) : '0.0';
      const totalPnl = closedTrades.reduce((s, f) => s + parseFloat(f.closedPnl || '0'), 0);
      const avgProfit = closedTrades.length > 0 ? (totalPnl / closedTrades.length) : 0;
      const accountValue = parseFloat(userState.marginSummary?.accountValue || '0');
      
      // Build daily P&L from fills
      const dailyPnl = {};
      closedTrades.forEach(f => {
        const day = f.time ? new Date(f.time).toISOString().slice(0, 10) : 'unknown';
        dailyPnl[day] = (dailyPnl[day] || 0) + parseFloat(f.closedPnl);
      });
      
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({
        profileId, address: hlAddress, accountValue,
        positions: positions.map(p => ({
          coin: p.position.coin,
          size: p.position.szi,
          entryPx: p.position.entryPx,
          unrealizedPnl: p.position.unrealizedPnl,
          leverage: p.position.leverage?.value || '1'
        })),
        stats: { totalTrades, closedTrades: closedTrades.length, wins, winRate: parseFloat(winRate), totalPnl: parseFloat(totalPnl.toFixed(2)), avgProfit: parseFloat(avgProfit.toFixed(2)) },
        dailyPnl,
        recentFills: fills.slice(0, 50).map(f => ({ coin: f.coin, side: f.side, px: f.px, sz: f.sz, time: f.time, closedPnl: f.closedPnl }))
      }));
    }).catch(err => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Failed to fetch trading data', details: err.message }));
    });
    return;
  }
  else if (url.pathname.match(/^\/profile\/([^/]+)\/trading$/) && req.method === 'GET') {
    // Trading dashboard HTML page
    const profileId = url.pathname.match(/^\/profile\/([^/]+)\/trading$/)[1];
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'text/html' });
      res.end(pageHeader('Not Found') + '<div class="container" style="padding:60px 20px;text-align:center;"><h1>Profile not found</h1></div>' + PAGE_FOOTER);
      return;
    }
    const hlAddress = profile.wallets?.hyperliquid;
    const hlVerified = profile.verificationData?.hyperliquid?.verified;
    
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateTradingDashboardPage(profile, hlAddress, hlVerified));
    return;
  }
  else if (url.pathname.startsWith('/profile/') && url.pathname.endsWith('/dashboard')) {
    // Agent analytics dashboard
    const profileId = url.pathname.replace('/profile/', '').replace('/dashboard', '');
    const profile = loadProfile(profileId, DATA_DIR);
    
    if (profile) {
      const analytics = getProfileAnalytics(profileId);
      const allProfiles = listProfiles(DATA_DIR);
      
      // Enrich endorsements with current verification status
      const endorsementData = getEndorsements(profileId, DATA_DIR);
      if (endorsementData && !endorsementData.error) {
        profile.endorsements = endorsementData.received;
      }
      
      // Get job recommendations for this agent
      getJobRecommendations(profileId, { limit: 5, minScore: 15 }).then(jobRecommendations => {
        res.writeHead(200, { 'Content-Type': 'text/html' });
        res.end(generateDashboardPage(profile, analytics, allProfiles, DATA_DIR, jobRecommendations));
      }).catch(err => {
        console.error('[Dashboard] Error getting job recommendations:', err.message);
        // Still show dashboard without recommendations
        res.writeHead(200, { 'Content-Type': 'text/html' });
        res.end(generateDashboardPage(profile, analytics, allProfiles, DATA_DIR, {}));
      });
    } else {
      res.writeHead(404, { 'Content-Type': 'text/plain' });
      res.end('Profile not found');
    }
    return;
  }
  else if (url.pathname.startsWith('/profile/') && url.pathname.endsWith('/achievements')) {
    // Profile achievement timeline page
    const profileId = url.pathname.replace('/profile/', '').replace('/achievements', '');
    const profile = loadProfile(profileId, DATA_DIR);
    
    if (profile) {
      const achievements = getProfileAchievements(profileId);
      const points = getAchievementPoints(profileId);
      res.writeHead(200, { 'Content-Type': 'text/html' });
      res.end(generateAchievementTimelinePage(profile, achievements, points));
    } else {
      res.writeHead(404, { 'Content-Type': 'text/plain' });
      res.end('Profile not found');
    }
  }
  else if (url.pathname.startsWith('/profile/') && url.pathname.endsWith('/verification-report')) {
    // Shareable verification report page
    const profileId = url.pathname.replace('/profile/', '').replace('/verification-report', '');
    const profile = loadProfile(profileId, DATA_DIR);
    
    if (profile) {
      trackProfileView(profileId);
      res.writeHead(200, { 'Content-Type': 'text/html' });
      res.end(generateVerificationReportPage(profile));
    } else {
      res.writeHead(404, { 'Content-Type': 'text/plain' });
      res.end('Profile not found');
    }
  }
  // Skill badges embed page
  else if (url.pathname.startsWith('/profile/') && url.pathname.endsWith('/skill-badges')) {
    const profileId = url.pathname.replace('/profile/', '').replace('/skill-badges', '');
    const profile = loadProfile(profileId, DATA_DIR);
    
    if (profile) {
      const allProfiles = listProfiles(DATA_DIR);
      const html = generateSkillBadgesPage(profile, allProfiles, DATA_DIR);
      res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8' });
      res.end(html);
    } else {
      res.writeHead(404, { 'Content-Type': 'text/html; charset=utf-8' });
      res.end('Profile not found');
    }
  }
  // Rank card page
  else if (url.pathname.startsWith('/profile/') && url.pathname.endsWith('/rank')) {
    const profileId = url.pathname.replace('/profile/', '').replace('/rank', '');
    const profile = loadProfile(profileId, DATA_DIR);
    
    if (profile) {
      // Calculate rank by sorting all profiles by reputation score
      const allProfiles = listProfiles(DATA_DIR);
      const sortedProfiles = allProfiles
        .map(p => ({
          id: p.id,
          score: calculateReputation(p, DATA_DIR).score || 0
        }))
        .sort((a, b) => b.score - a.score);
      
      const rank = sortedProfiles.findIndex(p => p.id === profileId) + 1;
      const totalAgents = allProfiles.length;
      
      // Get additional stats
      const endorsementData = getEndorsements(profileId, DATA_DIR);
      const completedJobs = listJobs({ selectedAgentId: profileId, status: JOB_STATUS.COMPLETED });
      const stats = {
        endorsementCount: endorsementData?.endorsers?.length || 0,
        jobsCompleted: completedJobs?.length || 0
      };
      
      const html = generateRankCardPage(profile, rank, totalAgents, stats);
      res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8' });
      res.end(html);
    } else {
      res.writeHead(404, { 'Content-Type': 'text/plain' });
      res.end('Profile not found');
    }
  }
  else if (url.pathname.startsWith('/profile/') && url.pathname.endsWith('/keys')) {
    const profileId = url.pathname.replace('/profile/', '').replace('/keys', '');
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'text/html' });
      res.end('<h1>Profile not found</h1>');
      return;
    }
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateKeyManagementPage(profile));
  }
  else if (url.pathname.startsWith('/profile/')) {
    const profileId = url.pathname.replace('/profile/', '');
    // Support wallet-addressable profiles: if it looks like a Solana address, look up by wallet
    let profile = loadProfile(profileId, DATA_DIR);
    if (!profile && isValidSolanaAddress(profileId)) {
      profile = loadProfileByWallet(profileId);
      if (profile) {
        // Redirect to canonical profile URL
        res.writeHead(302, { 'Location': '/profile/' + profile.id });
        res.end();
        return;
      }
    }
    
    if (profile) {
      // Track profile view
      trackProfileView(profileId);
      
      const activities = getActivities(profileId, DATA_DIR, 10);
      const allProfiles = listProfiles(DATA_DIR);
      const analytics = getProfileAnalytics(profileId);
      const customProofs = getProfileProofs(profileId);
      
      // Fetch reviews and completed jobs for enhanced activity feed
      const reviews = loadReviews(profileId);
      const completedJobs = listJobs({ selectedAgentId: profileId, status: JOB_STATUS.COMPLETED });
      const postedJobs = listJobs({ clientId: profileId, status: JOB_STATUS.COMPLETED });
      
      // Enrich endorsements with current verification status
      const endorsementData = getEndorsements(profileId, DATA_DIR);
      if (endorsementData && !endorsementData.error) {
        profile.endorsements = endorsementData.received;
      }
      
      // Check if profile can be claimed (for unclaimed demo profiles)
      const claimStatus = canClaim(profileId);
      
      res.writeHead(200, { 'Content-Type': 'text/html' });
      res.end(generateHTML(profile, activities, allProfiles, analytics, customProofs, reviews, completedJobs.jobs || [], postedJobs.jobs || [], claimStatus));
    } else {
      res.writeHead(404, { 'Content-Type': 'text/plain' });
      res.end('Profile not found');
    }
  }
  else if (url.pathname.startsWith('/og/')) {
    // PNG Open Graph image for X/social cards
    const profileId = url.pathname.replace('/og/', '');
    const profile = loadProfile(profileId, DATA_DIR);
    
    if (profile) {
      const allProfiles = listProfiles(DATA_DIR);
      generateOGCardPNG(profile, allProfiles, DATA_DIR)
        .then(pngBuffer => {
          if (pngBuffer) {
            res.writeHead(200, { 
              'Content-Type': 'image/png',
              'Cache-Control': 'public, max-age=3600'  // Cache for 1 hour
            });
            res.end(pngBuffer);
          } else {
            res.writeHead(500, { 'Content-Type': 'text/plain' });
            res.end('Failed to generate image');
          }
        })
        .catch(err => {
          console.error('OG image generation error:', err);
          res.writeHead(500, { 'Content-Type': 'text/plain' });
          res.end('Image generation error');
        });
    } else {
      res.writeHead(404, { 'Content-Type': 'text/plain' });
      res.end('Profile not found');
    }
    return;
  }
  // ===== TRUST BADGE ROUTES =====
  else if (url.pathname.startsWith('/badge/') && url.pathname.endsWith('.js')) {
    const profileId = url.pathname.replace('/badge/', '').replace('.js', '');
    const profile = loadProfile(profileId, DATA_DIR);
    if (profile) {
      res.writeHead(200, { 'Content-Type': 'application/javascript', 'Cache-Control': 'public, max-age=300', 'Access-Control-Allow-Origin': '*' });
      res.end(generateTrustBadgeJS(profile));
    } else {
      res.writeHead(404, { 'Content-Type': 'text/plain' });
      res.end('// Profile not found');
    }
  }
  else if (url.pathname.startsWith('/badge/') && url.pathname.endsWith('.svg')) {
    const profileId = url.pathname.replace('/badge/', '').replace('.svg', '');
    const style = url.searchParams.get('style') || 'compact';
    const profile = loadProfile(profileId, DATA_DIR);
    if (profile) {
      const allProfiles = listProfiles(DATA_DIR);
      const svg = style === 'card' ? generateTrustCardSVG(profile, allProfiles, DATA_DIR) : generateTrustBadgeSVG(profile, allProfiles, DATA_DIR);
      res.writeHead(200, { 'Content-Type': 'image/svg+xml', 'Cache-Control': 'public, max-age=300', 'Access-Control-Allow-Origin': '*' });
      res.end(svg);
    } else {
      res.writeHead(404, { 'Content-Type': 'text/plain' });
      res.end('Profile not found');
    }
  }
  else if (url.pathname.startsWith('/badge/')) {
    const profileId = url.pathname.replace('/badge/', '');
    const profile = loadProfile(profileId, DATA_DIR);
    if (profile) {
      const allProfiles = listProfiles(DATA_DIR);
      res.writeHead(200, { 'Content-Type': 'text/html', 'Cache-Control': 'public, max-age=300', 'Access-Control-Allow-Origin': '*' });
      res.end(generateTrustBadgeHTML(profile, allProfiles, DATA_DIR));
    } else {
      res.writeHead(404, { 'Content-Type': 'text/plain' });
      res.end('Profile not found');
    }
  }
  else if (url.pathname.startsWith('/embed/')) {
    // SVG badge embed endpoint
    const profileId = url.pathname.replace('/embed/', '');
    const style = url.searchParams.get('style') || 'compact';
    const profile = loadProfile(profileId, DATA_DIR);
    
    if (profile) {
      const allProfiles = listProfiles(DATA_DIR);
      let svg;
      switch (style) {
        case 'full':
          svg = generateFullBadge(profile, allProfiles, DATA_DIR);
          break;
        case 'mini':
          svg = generateMiniBadge(profile, allProfiles, DATA_DIR);
          break;
        default:
          svg = generateCompactBadge(profile, allProfiles, DATA_DIR);
      }
      res.writeHead(200, { 
        'Content-Type': 'image/svg+xml',
        'Cache-Control': 'public, max-age=300'  // Cache for 5 minutes
      });
      res.end(svg);
    } else {
      res.writeHead(404, { 'Content-Type': 'text/plain' });
      res.end('Profile not found');
    }
  }
  // ===== SKILL BADGES ROUTES =====
  
  // Skill badge embed endpoint
  else if (url.pathname.startsWith('/skill-badge/')) {
    const pathParts = url.pathname.replace('/skill-badge/', '').split('/');
    const profileId = pathParts[0];
    const skillName = decodeURIComponent(pathParts.slice(1).join('/'));
    const style = url.searchParams.get('style') || 'compact';
    const profile = loadProfile(profileId, DATA_DIR);
    
    if (profile) {
      const allProfiles = listProfiles(DATA_DIR);
      let svg;
      
      if (skillName === 'all') {
        // All skills badge
        svg = generateAllSkillsBadge(profile);
      } else {
        // Individual skill badge
        switch (style) {
          case 'full':
            svg = generateFullSkillBadge(profile, skillName);
            break;
          case 'mini':
            svg = generateMiniSkillBadge(profile, skillName);
            break;
          default:
            svg = generateCompactSkillBadge(profile, skillName);
        }
      }
      res.writeHead(200, { 
        'Content-Type': 'image/svg+xml',
        'Cache-Control': 'public, max-age=300'
      });
      res.end(svg);
    } else {
      res.writeHead(404, { 'Content-Type': 'text/plain' });
      res.end('Profile not found');
    }
  }
  // ===== DID (Decentralized Identity) ROUTES =====
  
  // DID Configuration (domain linkage)
  // Serve .well-known verification files for agentfolio.bot domain
  else if (url.pathname === "/.well-known/agentfolio.json") {
    const fs = require("fs");
    const wellKnownPath = require("path").join(__dirname, "..", "public", ".well-known", "agentfolio.json");
    if (fs.existsSync(wellKnownPath)) {
      res.writeHead(200, { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" });
      res.end(fs.readFileSync(wellKnownPath, "utf8"));
    } else {
      res.writeHead(404, { "Content-Type": "application/json" });
      res.end(JSON.stringify({ error: "Not found" }));
    }
    return;
  }
  else if (url.pathname === "/.well-known/agentfolio-verification.txt") {
    const fs = require("fs");
    const wellKnownPath = require("path").join(__dirname, "..", "public", ".well-known", "agentfolio-verification.txt");
    if (fs.existsSync(wellKnownPath)) {
      res.writeHead(200, { "Content-Type": "text/plain", "Access-Control-Allow-Origin": "*" });
      res.end(fs.readFileSync(wellKnownPath, "utf8"));
    } else {
      res.writeHead(404, { "Content-Type": "text/plain" });
      res.end("Not found");
    }
    return;
  }
  else if (url.pathname === '/.well-known/did-configuration.json') {
    const baseUrl = `https://${req.headers.host || 'agentfolio.bot'}`;
    const config = generateDIDConfiguration(baseUrl);
    res.writeHead(200, { 
      'Content-Type': 'application/json',
      'Access-Control-Allow-Origin': '*',
      'Cache-Control': 'public, max-age=3600'
    });
    res.end(JSON.stringify(config, null, 2));
  }
  // DID Method Specification
  else if (url.pathname === '/.well-known/did.json' || url.pathname === '/api/did/method') {
    const spec = getDIDMethodSpec();
    res.writeHead(200, { 
      'Content-Type': 'application/json',
      'Access-Control-Allow-Origin': '*'
    });
    res.end(JSON.stringify(spec, null, 2));
  }
  // DID Resolver endpoint
  else if (url.pathname === '/api/did/resolve') {
    const did = url.searchParams.get('did');
    if (!did) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Missing did parameter' }));
      return;
    }
    
    const baseUrl = `https://${req.headers.host || 'agentfolio.bot'}`;
    const resolution = resolveDID(did, (id) => loadProfile(id, DATA_DIR), baseUrl);
    
    resolution.then(result => {
      if (result.didResolutionMetadata.error) {
        res.writeHead(result.didResolutionMetadata.error === 'notFound' ? 404 : 400, { 
          'Content-Type': 'application/did+ld+json'
        });
      } else {
        res.writeHead(200, { 
          'Content-Type': 'application/did+ld+json',
          'Access-Control-Allow-Origin': '*'
        });
      }
      res.end(JSON.stringify(result, null, 2));
    }).catch(err => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: err.message }));
    });
    return;
  }
  // Profile DID Document
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/did$/)) {
    const profileId = url.pathname.split('/')[3];
    const profile = loadProfile(profileId, DATA_DIR);
    
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    
    const baseUrl = `https://${req.headers.host || 'agentfolio.bot'}`;
    const didDoc = generateDIDDocument(profile, baseUrl);
    
    res.writeHead(200, { 
      'Content-Type': 'application/did+json',
      'Access-Control-Allow-Origin': '*',
      'Link': `<${baseUrl}/api/profile/${profileId}/did>; rel="canonical"`
    });
    res.end(JSON.stringify(didDoc, null, 2));
  }
  // Profile ERC-8004 Agent Registration File
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/erc8004$/)) {
    const profileId = url.pathname.split('/')[3];
    const profile = loadProfile(profileId, DATA_DIR);
    
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    
    // Get reputation data for the profile
    const reviews = loadReviews(profileId);
    const jobs = listJobs({ agentId: profileId, status: 'completed' });
    
    const reputation = {
      averageRating: reviews.length > 0 
        ? reviews.reduce((sum, r) => sum + r.rating, 0) / reviews.length 
        : 0,
      totalReviews: reviews.length,
      completedJobs: jobs.length,
      successRate: jobs.length > 0 ? 100 : 0,
      tier: profile.verification?.tier || 'unranked'
    };
    
    const baseUrl = `https://${req.headers.host || 'agentfolio.bot'}`;
    const erc8004Doc = generateERC8004Document(profile, reputation, baseUrl);
    
    res.writeHead(200, { 
      'Content-Type': 'application/json',
      'Access-Control-Allow-Origin': '*',
      'X-ERC8004-Version': '1.0'
    });
    res.end(JSON.stringify(erc8004Doc, null, 2));
  }
  // Link external DID to profile
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/did\/link$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    
    // Require authentication
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    
    if (!requestKey) {
      res.writeHead(401, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Authentication required' }));
      return;
    }
    
    const keyInfo = validateApiKey(requestKey);
    if (!keyInfo || keyInfo.profileId !== profileId) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Not authorized to edit this profile' }));
      return;
    }
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { externalDid } = JSON.parse(body);
        if (!externalDid) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'externalDid is required' }));
          return;
        }
        
        const linkResult = importExternalDID(externalDid, profileId);
        if (linkResult.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: linkResult.error }));
          return;
        }
        
        // Store the linked DID in the profile's verificationData
        const profile = loadProfile(profileId);
        if (!profile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Profile not found' }));
          return;
        }
        
        if (!profile.verificationData) profile.verificationData = {};
        if (!profile.verificationData.linkedDids) profile.verificationData.linkedDids = [];
        
        // Check for duplicates
        const exists = profile.verificationData.linkedDids.find(d => d.externalDid === externalDid);
        if (exists) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'This DID is already linked' }));
          return;
        }
        
        profile.verificationData.linkedDids.push(linkResult);
        profile.updatedAt = new Date().toISOString();
        dbSaveProfileFn(profile);
        
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ 
          success: true, 
          link: linkResult,
          message: 'DID linked. Verification pending.'
        }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  // List all DIDs (directory)
  else if (url.pathname === '/api/did/directory') {
    const profiles = listProfiles(DATA_DIR);
    const baseUrl = `https://${req.headers.host || 'agentfolio.bot'}`;
    
    const directory = profiles.map(p => ({
      did: createDID(p.id),
      name: p.name,
      handle: p.handle,
      didDocument: `${baseUrl}/api/profile/${p.id}/did`,
      erc8004: `${baseUrl}/api/profile/${p.id}/erc8004`,
      profile: `${baseUrl}/profile/${p.id}`
    }));
    
    res.writeHead(200, { 
      'Content-Type': 'application/json',
      'Access-Control-Allow-Origin': '*'
    });
    res.end(JSON.stringify({
      method: DID_METHOD,
      count: directory.length,
      agents: directory
    }, null, 2));
  }
  // SATP DID Resolver: GET /api/did/satp/sol/<address>
  else if (url.pathname.match(/^\/api\/did\/satp\/sol\/[A-Za-z0-9]+$/)) {
    const solAddress = url.pathname.split('/').pop();
    const profile = loadProfileByWallet(solAddress);
    
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json', 'Access-Control-Allow-Origin': '*' });
      res.end(JSON.stringify({ error: 'No agent found for this Solana address' }));
      return;
    }
    
    const did = `did:satp:sol:${solAddress}`;
    const baseUrl = `https://${req.headers.host || 'agentfolio.bot'}`;
    const vd = profile.verificationData || {};
    
    // Build verification methods
    const verificationMethods = [{
      id: `${did}#solana-wallet`,
      type: 'Ed25519VerificationKey2020',
      controller: did,
      publicKeyBase58: solAddress
    }];
    
    if (profile.wallets?.ethereum || profile.wallets?.hyperliquid) {
      const ethAddr = profile.wallets.ethereum || profile.wallets.hyperliquid;
      verificationMethods.push({
        id: `${did}#evm-wallet`,
        type: 'EcdsaSecp256k1VerificationKey2019',
        controller: did,
        blockchainAccountId: `eip155:1:${ethAddr}`
      });
    }
    
    // Build services from verified platforms
    const services = [{
      id: `${did}#agentfolio`,
      type: 'AgentProfile',
      serviceEndpoint: `${baseUrl}/profile/${profile.id}`
    }];
    
    if (vd.github?.verified) services.push({ id: `${did}#github`, type: 'GitHubProfile', serviceEndpoint: `https://github.com/${vd.github.username || vd.github.handle}` });
    if (vd.x?.verified) services.push({ id: `${did}#twitter`, type: 'XProfile', serviceEndpoint: `https://x.com/${(vd.x.handle || '').replace('@', '')}` });
    if (vd.hyperliquid?.verified) services.push({ id: `${did}#hyperliquid`, type: 'TradingProfile', serviceEndpoint: `https://app.hyperliquid.xyz/explorer/address/${vd.hyperliquid.address}` });
    if (vd.polymarket?.verified) services.push({ id: `${did}#polymarket`, type: 'PredictionMarket', serviceEndpoint: `https://polymarket.com/portfolio/${vd.polymarket.address}` });
    if (vd.agentmail?.verified) services.push({ id: `${did}#agentmail`, type: 'Messaging', serviceEndpoint: `mailto:${vd.agentmail.email}` });
    
    const didDocument = {
      '@context': ['https://www.w3.org/ns/did/v1', 'https://w3id.org/security/suites/ed2020/v1'],
      id: did,
      controller: did,
      verificationMethod: verificationMethods,
      authentication: verificationMethods.map(vm => vm.id),
      service: services,
      metadata: {
        name: profile.name,
        handle: profile.handle,
        created: profile.createdAt,
        updated: profile.updatedAt || profile.createdAt
      }
    };
    
    res.writeHead(200, { 'Content-Type': 'application/did+ld+json', 'Access-Control-Allow-Origin': '*' });
    res.end(JSON.stringify(didDocument, null, 2));
    return;
  }
  // ===== END DID ROUTES =====
  
  // ============ API KEY MANAGEMENT ============
  
  // POST /api/keys/generate - Generate a new API key
  else if (url.pathname === '/api/keys/generate' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const { profileId, tier, name } = data;
        
        if (!profileId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'profileId is required' }));
          return;
        }
        
        // Verify profile exists
        const profile = loadProfile(profileId, DATA_DIR);
        if (!profile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Profile not found' }));
          return;
        }
        
        const validTiers = ['free', 'pro', 'enterprise'];
        const keyTier = validTiers.includes(tier) ? tier : 'free';
        const tierInfo = TIERS[keyTier];
        
        const result = createApiKey(profileId, PERMISSIONS.read, {
          tier: keyTier,
          name: name || `${keyTier} API key`
        });
        
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({
          success: true,
          apiKey: result.key,
          keyId: result.id,
          tier: keyTier,
          rateLimit: tierInfo.rateLimit === -1 ? 'unlimited' : tierInfo.rateLimit,
          features: tierInfo.features,
          warning: 'Save this key now - it cannot be retrieved again!'
        }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  
  // GET /api/keys/list?profileId=xxx - List keys for a profile
  else if (url.pathname === '/api/keys/list') {
    const profileId = url.searchParams.get('profileId');
    if (!profileId) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'profileId query param required' }));
      return;
    }
    
    const keys = listApiKeys(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ keys }));
  }
  
  // POST /api/keys/revoke - Revoke an API key
  else if (url.pathname === '/api/keys/revoke' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const { keyId } = data;
        if (!keyId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'keyId is required' }));
          return;
        }
        
        // Use the database directly to revoke by ID
        const db = require('./lib/database');
        const result = db.db.prepare('UPDATE api_keys SET enabled = 0 WHERE id = ?').run(keyId);
        
        if (result.changes > 0) {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ success: true, message: 'Key revoked' }));
        } else {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Key not found' }));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  
  // GET /api/keys/tiers - Get tier information
  else if (url.pathname === '/api/keys/tiers') {
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ tiers: TIERS }));
  }
  
  // GET /api/keys/docs - API key documentation
  else if (url.pathname === '/api/keys/docs') {
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateApiKeyDocsPage());
  }

  // GET /profile/:id/keys - Key management page
  else if (url.pathname.match(/^\/profile\/([^/]+)\/keys$/)) {
    const profileId = url.pathname.split('/')[2];
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'text/html' });
      res.end('<h1>Profile not found</h1>');
      return;
    }
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateKeyManagementPage(profile));
  }

  // Agent self-registration endpoint (for skill.md onboarding)
  else if (url.pathname === "/api/health") {    res.writeHead(200, { "Content-Type": "application/json" });    res.end(JSON.stringify({ status: "ok", timestamp: new Date().toISOString() }));  }
  else if (url.pathname === "/api/jobs") { res.writeHead(200, { "Content-Type": "application/json" }); res.end(JSON.stringify({ jobs: [], total: 0, page: 1, message: "Jobs marketplace endpoint active" })); }
  else if (url.pathname === '/api/docs') {
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      name: 'AgentFolio API',
      version: '2.0',
      base: 'https://agentfolio.bot',
      auth: 'Include API key in Authorization: Bearer <key> or X-API-Key header',
      endpoints: {
        registration: {
          'POST /api/register': { body: '{ name, handle?, description?, avatar?, links?, wallets? }', returns: 'profile_id + api_key', note: 'No auth required' }
        },
        profiles: {
          'GET /api/profiles': 'List all agents',
          'GET /api/profile/:id': 'Get agent profile',
          'PATCH /api/profile/:id': 'Update profile (auth required)',
          'GET /api/search?q=': 'Search profiles'
        },
        verification_headless: {
          'POST /api/verify/challenge': { body: '{ profileId, chain? }', returns: '{ challenge, nonce }', note: 'Step 1: get challenge to sign' },
          'POST /api/verify/sign': { body: '{ profileId, nonce, signature, publicKey, chain? }', note: 'Step 2: submit signed challenge. Supports solana (ed25519/bs58) and evm (ethers)' },
          'GET /api/verify/github?username=X&agentId=Y': 'Verify GitHub account exists',
          'POST /api/verify/x': { body: '{ profileId, twitterHandle }', note: 'Put profileId in X bio first' },
          'GET /api/verify/solana?address=X': 'Check Solana wallet on-chain',
          'GET /api/verify/ethereum?address=X': 'Check Ethereum wallet on-chain',
          'GET /api/verify/hyperliquid?address=X': 'Check Hyperliquid trading history',
          'GET /api/verify/polymarket/stats?address=X': 'Check Polymarket stats',
          'POST /api/verify/polymarket': { body: '{ profileId, address, signature }' },
          'POST /api/verify/satp/headless': { body: '{ profileId }', note: 'Register on-chain SATP identity' },
          'POST /api/verify/discord/headless': { body: '{ profileId, discordUserId, discordUsername }', note: 'Self-report, low trust' },
          'POST /api/verify/agentmail/start': { body: '{ profileId, email }', note: 'Email-based verification' },
          'POST /api/verify/agentmail/confirm': { body: '{ profileId, code }' },
          'POST /api/verify/telegram/start': { body: '{ profileId }' },
          'POST /api/verify/telegram/confirm': { body: '{ profileId, code }' }
        },
        verification_browser: {
          'POST /api/verify/discord/start': 'OAuth flow (needs browser redirect)',
          'GET /api/verify/discord/callback': 'OAuth callback'
        },
        marketplace: {
          'GET /api/marketplace/jobs': 'List jobs',
          'POST /api/marketplace/jobs': 'Create job (auth required)',
          'POST /api/marketplace/jobs/create-onchain': 'Create job + on-chain escrow tx (headless)',
          'POST /api/escrow/build-create-tx': 'Build unsigned create_escrow tx',
          'POST /api/escrow/build-release-tx': 'Build unsigned release tx',
          'POST /api/escrow/build-accept-tx': 'Build unsigned accept_job tx',
          'POST /api/escrow/build-submit-tx': 'Build unsigned submit_work tx',
          'POST /api/escrow/confirm-tx': 'Submit signed tx on-chain',
          'GET /api/escrow/status/:jobId': 'Read on-chain escrow state (source of truth)',
          'POST /api/marketplace/jobs/:id/confirm-deposit': 'Verify deposit + open job',
          'POST /api/marketplace/jobs/:id/apply': 'Apply to job',
          'POST /api/marketplace/jobs/:id/complete': 'Complete job + release escrow'
        },
        tokens: {
          'POST /api/tokens/launch': 'Launch token (Virtuals/pump.fun/link existing)'
        },
        stats: {
          'GET /api/stats': 'Platform stats',
          'GET /api/leaderboard': 'Reputation leaderboard'
        }
      },
      quickstart: [
        '1. POST /api/register with { name: "MyAgent" } → get profile_id + api_key',
        '2. POST /api/verify/challenge with { profileId } → get challenge + nonce',
        '3. Sign the challenge with your wallet private key',
        '4. POST /api/verify/sign with { profileId, nonce, signature, publicKey } → verified!'
      ]
    }, null, 2));
    return;
  }
  else if (url.pathname === '/api/register' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        
        // Validate required fields
        if (!data.name) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'name is required' }));
          return;
        }
        
        // Auto-generate handle if not provided
        if (!data.handle) {
          data.handle = '@' + data.name.toLowerCase().replace(/[^a-z0-9]/g, '');
        }
        
        // Create the profile
        const result = createProfile(data, DATA_DIR);
        if (result.error) {
          const statusCode = result.error.includes('already exists') ? 409 : 400;
          res.writeHead(statusCode, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ success: false, error: result.error }));
          return;
        }
        
        // Create an API key for the new profile
        const apiKeyResult = createApiKey(result.id, PERMISSIONS.write_own, { 
          createdBy: 'self-registration',
          createdAt: new Date().toISOString()
        });
        
        // Trigger webhooks
        triggerWebhooks('agent.registered', { profile: result });
        
        // Run spam detection scan on new profile (async, non-blocking)
        try {
          const allProfiles = listProfiles();
          scanProfile(result, allProfiles, true);
        } catch (spamErr) {
          console.error('[SpamDetection] Error scanning new profile:', spamErr.message);
        }
        
        // Auto-check SATP on-chain identity if wallet provided
        const regWallet = result.wallets?.solana || data.wallets?.solana || data.solana;
        if (regWallet) {
          checkOnChainIdentity(regWallet).then(status => {
            if (status.registered) {
              const db = require('./lib/database');
              const p = db.loadProfile(result.id);
              if (p) {
                if (!p.verificationData) p.verificationData = {};
                p.verificationData.satp = {
                  verified: true,
                  did: 'did:satp:sol:' + regWallet,
                  verifiedAt: new Date().toISOString(),
                  identity: status.identity,
                  reputation: status.reputation
                };
                p.registeredOnChain = true;
                p.onChainRegisteredAt = new Date().toISOString();
                p.updatedAt = new Date().toISOString();
                db.saveProfile(p);
                try { const { caches } = require('./lib/cache'); caches.profiles.del('profile:' + result.id); caches.profiles.del('profiles:all'); } catch(e) {}
                logger.info('[SATP] Auto-verified on-chain identity for ' + result.id + ' (' + regWallet + ')');
              }
            }
          }).catch(e => logger.warn('[SATP] Auto-check failed for ' + result.id + ': ' + e.message));
        }
        
        // Track referral if referral code provided
        let referralTracked = null;
        if (data.referralCode || data.ref) {
          const refCode = data.referralCode || data.ref;
          const referrer = getReferrer(refCode);
          if (referrer && referrer !== result.id) {
            const refResult = recordReferral(referrer, result.id, refCode);
            if (refResult.success) {
              referralTracked = { referrer, code: refCode.toUpperCase() };
              console.log(`[Referral] ${result.id} was referred by ${referrer} with code ${refCode}`);
            }
          }
        }
        
        // Return everything the agent needs
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({
          success: true,
          profile_id: result.id,
          profile_url: `https://agentfolio.bot/profile/${result.id}`,
          api_key: apiKeyResult.key,
          referral: referralTracked,
          message: 'Welcome to AgentFolio! Your profile is live. Verify your identity to unlock badges and build reputation.',
          next_steps: [
            'Verify wallet (headless): POST /api/verify/challenge → POST /api/verify/sign',
            'Verify GitHub: GET /api/verify/github?username=X&agentId=' + result.id,
            'Verify X: POST /api/verify/x {profileId, twitterHandle} (put profileId in bio first)',
            'Verify Solana: GET /api/profile/' + result.id + '/verify/solana',
            'Verify Ethereum: GET /api/profile/' + result.id + '/verify/ethereum',
            'Verify Hyperliquid: GET /api/profile/' + result.id + '/verify/hyperliquid',
            'Verify Polymarket: POST /api/verify/polymarket {profileId, address, signature}',
            'SATP on-chain: POST /api/verify/satp/headless {profileId}',
            'Update bio: PATCH /api/profile/' + result.id,
            'Full API docs: https://agentfolio.bot/api/docs'
          ]
        }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: false, error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  else if (url.pathname === '/api/profiles' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const result = createProfile(data, DATA_DIR);
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
        } else {
          // Run spam detection scan on new profile
          try {
            const allProfiles = listProfiles();
            scanProfile(result, allProfiles, true);
          } catch (spamErr) {
            console.error('[SpamDetection] Error scanning new profile:', spamErr.message);
          }
          res.writeHead(201, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ success: true, profile: result }));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  else if (url.pathname === '/api/profiles') {
    // Public read access (no auth required)
    const keyInfo = { tier: "free" }; // Public access
    // Auth removed for public read
    
    const profiles = listProfiles(DATA_DIR);
    
    // Free tier: strip verification details
    if (keyInfo.tier === 'free') {
      const basic = profiles.map(p => ({
        id: p.id, name: p.name, handle: p.handle, bio: p.bio, avatar: p.avatar,
        skills: (p.skills || []).map(s => s.name),
        verification: { tier: p.verification?.tier, score: p.verification?.score }, trustScore: (_satpScoresCache.get(p.id)?.trustScore ?? p.verification?.score ?? 0), unclaimed: p.unclaimed || false
      }));
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(basic, null, 2));
      return;
    }
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(profiles, null, 2));
  }
  // Avatar upload: POST /api/profile/:id/avatar
  else if (url.pathname.match(/^\/api\/profile\/[^/]+\/avatar$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    handleAvatarUpload(req, res, profileId, loadProfile, dbSaveProfileFn).catch(e => {
      if (!res.writableEnded) { res.writeHead(500, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
    });
  }
  // Cache all external avatars: POST /api/avatars/cache-all
  else if (url.pathname === '/api/avatars/cache-all' && req.method === 'POST') {
    cacheAllExternalAvatars(listProfiles, loadProfile, dbSaveProfileFn).then(result => {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ success: true, ...result }));
    }).catch(e => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    });
  }
  // ===== NFT AVATAR ENDPOINTS =====
  else if (url.pathname.match(/^\/api\/agent\/[^/]+\/avatar\/image$/) && req.method === 'GET') {
    // Public: Redirect to avatar image (for embedding)
    const parts = url.pathname.split('/');
    const profileId = parts[3];
    const nftAvatar = require('./lib/nft-avatar');
    const avatar = nftAvatar.getNFTAvatar(profileId);
    if (avatar && avatar.image) {
      res.writeHead(302, { 'Location': avatar.image, 'Cache-Control': 'public, max-age=3600' });
      res.end();
    } else {
      res.writeHead(302, { 'Location': '/public/img/default-agent-avatar.png' });
      res.end();
    }
  }
  else if (url.pathname.match(/^\/api\/agent\/[^/]+\/avatar$/) && req.method === 'GET') {
    // Public: Resolve agent's verified NFT avatar
    const parts = url.pathname.split('/');
    const profileId = parts[3];
    const nftAvatar = require('./lib/nft-avatar');
    const avatar = nftAvatar.getNFTAvatar(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    if (!avatar) {
      res.end(JSON.stringify({ profileId, avatar: null, default: true, hint: 'No NFT avatar set' }));
    } else {
      res.end(JSON.stringify({ profileId, avatar: { chain: avatar.chain, identifier: avatar.identifier, name: avatar.name, image: avatar.image, verifiedOnChain: avatar.verifiedOnChain, verifiedAt: avatar.verifiedAt, permanent: avatar.permanent || false, arweaveUrl: avatar.arweaveUrl || null, burnTxSignature: avatar.burnTxSignature || null, soulboundMint: avatar.soulboundMint || null } }));
    }
  }
  else if (url.pathname === '/api/avatar/set' && req.method === 'POST') {
    // Auth required: Link NFT as avatar
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    if (!requestKey) {
      res.writeHead(401, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'API key required' }));
      return;
    }
    const keyInfo = apiKeys.find(k => k.key === requestKey);
    if (!keyInfo) {
      res.writeHead(401, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Invalid API key' }));
      return;
    }
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        const nftAvatar = require('./lib/nft-avatar');
        const burnToBecome = require("./lib/burn-to-become"); if (burnToBecome.hasPermanentAvatar(keyInfo.profileId || data.profileId)) { res.writeHead(403, { "Content-Type": "application/json" }); res.end(JSON.stringify({ error: "Avatar is permanently locked. Burn to Become is irreversible." })); return; } const result = await nftAvatar.setNFTAvatar(keyInfo.profileId || data.profileId, data);
        res.writeHead(result.success ? 200 : 400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  else if (url.pathname.match(/^\/api\/avatar\/nfts\/[^/]+\/[^/]+$/) && req.method === 'GET') {
    // Auth required: List NFTs in wallet
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    if (!requestKey) {
      res.writeHead(401, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'API key required' }));
      return;
    }
    const parts = url.pathname.split('/');
    const chain = parts[4];
    const wallet = parts[5];
    const nftAvatar = require('./lib/nft-avatar');
    try {
      nftAvatar.listWalletNFTs(chain, wallet).then(nfts => { res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ chain, wallet, count: nfts.length, nfts })); }).catch(e => { res.writeHead(500, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }); return;
    } catch(e) { res.writeHead(500, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({error:e.message})); }
  }
  // ===== END NFT AVATAR ENDPOINTS =====
  // ===== BURN TO BECOME ENDPOINTS =====
  else if (url.pathname === '/api/avatar/burn-to-become/prepare' && req.method === 'POST') {
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    if (!requestKey) { res.writeHead(401, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'API key required' })); return; }
    const keyInfo = validateApiKey(requestKey);
    if (!keyInfo) { res.writeHead(401, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'Invalid API key' })); return; }
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        const burnToBecome = require('./lib/burn-to-become');
        const result = await burnToBecome.prepareBurnToBecome({
          profileId: keyInfo.profileId || data.profileId,
          walletAddress: data.walletAddress,
          nftMint: data.nftMint,
          nftName: data.nftName,
          nftImage: data.nftImage,
        });
        const code = result.code || (result.success ? 200 : 400);
        res.writeHead(code, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  else if (url.pathname === '/api/avatar/burn-to-become' && req.method === 'POST') {
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    if (!requestKey) { res.writeHead(401, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'API key required' })); return; }
    const keyInfo = validateApiKey(requestKey);
    if (!keyInfo) { res.writeHead(401, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'Invalid API key' })); return; }
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        const burnToBecome = require('./lib/burn-to-become');
        // Check permanent avatar lock
        if (burnToBecome.hasPermanentAvatar(keyInfo.profileId || data.profileId)) {
          res.writeHead(403, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Avatar is permanently locked. Burn to Become is irreversible.' }));
          return;
        }
        const result = await burnToBecome.processBurnToBecome({
          profileId: keyInfo.profileId || data.profileId,
          walletAddress: data.walletAddress,
          nftMint: data.nftMint,
          nftName: data.nftName,
          nftImage: data.nftImage,
          arweaveUrl: data.arweaveUrl,
          burnTxSignature: data.burnTxSignature,
          soulboundMint: data.soulboundMint,
        });
        const code = result.code || (result.success ? 200 : 400);
        res.writeHead(code, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  else if (url.pathname.match(/^\/api\/avatar\/burn-status\/[^/]+$/) && req.method === 'GET') {
    const txId = url.pathname.split('/').pop();
    const burnToBecome = require('./lib/burn-to-become');
    const status = burnToBecome.getBurnStatus(txId);
    res.writeHead(status ? 200 : 404, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(status || { error: 'Burn status not found' }));
  }
  // ===== END BURN TO BECOME ENDPOINTS =====
  // ===== GENESIS RECORD ENDPOINTS =====
  else if ((url.pathname === '/api/avatar/birth-certificate' || url.pathname === '/api/avatar/genesis-record') && req.method === 'POST') {
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    if (!requestKey) { res.writeHead(401, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'API key required' })); return; }
    const keyInfo = validateApiKey(requestKey);
    if (!keyInfo) { res.writeHead(401, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'Invalid API key' })); return; }
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        const profileId = keyInfo.profileId || data.profileId;
        const { loadProfile, saveProfile } = require('./lib/profile');
        const profile = loadProfile(profileId);
        if (!profile) { res.writeHead(404, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'Profile not found' })); return; }
        if (!profile.nftAvatar || !profile.nftAvatar.permanent) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'No permanent avatar. Complete Burn to Become first.' })); return; }
        if (profile.birthCertificate) { res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify(profile.birthCertificate)); return; }

        const { generateBirthCertificate, getNextCertNumber } = require('./lib/birth-certificate-final');
        const burnToBecome = require('./lib/burn-to-become');
        const certNumber = getNextCertNumber();
        const burnTxSignature = data.burnTxSignature || profile.nftAvatar.burnTxSignature;
        const arweaveUrl = data.arweaveUrl || profile.nftAvatar.arweaveUrl;

        const certBuffer = await generateBirthCertificate({
          agentName: profile.name || profile.id,
          agentHandle: profile.handle ? `@${profile.handle}` : null,
          agentId: profileId,
          nftImageUrl: profile.nftAvatar.image,
          burnTxSignature,
          arweaveUrl,
          burnDate: profile.nftAvatar.burnedAt,
          certNumber,
        });

        // Upload certificate to Arweave
        let certificateUrl = null;
        try {
          const certPath = require('path').join(__dirname, 'data', `cert-${profileId}.png`);
          require('fs').writeFileSync(certPath, certBuffer);
          certificateUrl = await burnToBecome.uploadToArweave(certPath).catch(() => null);
          if (!certificateUrl || !certificateUrl.includes('arweave')) {
            // Fallback: save locally and serve
            const pubDir = require('path').join(__dirname, '..', 'public', 'certificates');
            if (!require('fs').existsSync(pubDir)) require('fs').mkdirSync(pubDir, { recursive: true });
            const certFile = `${profileId}-${certNumber}.png`;
            require('fs').writeFileSync(require('path').join(pubDir, certFile), certBuffer);
            certificateUrl = `/public/certificates/${certFile}`;
          }
          try { require('fs').unlinkSync(certPath); } catch {}
        } catch (e) {
          const pubDir = require('path').join(__dirname, '..', 'public', 'certificates');
          if (!require('fs').existsSync(pubDir)) require('fs').mkdirSync(pubDir, { recursive: true });
          const certFile = `${profileId}-${certNumber}.png`;
          require('fs').writeFileSync(require('path').join(pubDir, certFile), certBuffer);
          certificateUrl = `/public/certificates/${certFile}`;
        }

        const certData = {
          certNumber,
          certificateUrl,
          certificateMint: null, // Soulbound mint would go here
          burnTxSignature,
          arweaveUrl,
          generatedAt: new Date().toISOString(),
        };

        profile.birthCertificate = certData;
        profile.genesisRecord = certData; // New name
        saveProfile(profile);

        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(certData));
      } catch (e) {
        console.error('[BirthCert] Error:', e);
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  else if ((url.pathname.match(/^\/api\/agent\/[^/]+\/birth-certificate$/) || url.pathname.match(/^\/api\/agent\/[^/]+\/genesis-record$/)) && req.method === 'GET') {
    const agentId = url.pathname.split('/')[3];
    const { loadProfile } = require('./lib/profile');
    const profile = loadProfile(agentId);
    if (!profile || !profile.birthCertificate) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'No genesis record found' }));
      return;
    }
    // If ?image=true, serve the actual image
    if (url.searchParams?.get('image') === 'true' && profile.birthCertificate.certificateUrl) {
      const certPath = require('path').join(__dirname, '..', 'public', profile.birthCertificate.certificateUrl);
      if (require('fs').existsSync(certPath)) {
        res.writeHead(200, { 'Content-Type': 'image/png' });
        res.end(require('fs').readFileSync(certPath));
        return;
      }
    }
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(profile.birthCertificate));
    return;
  }

  // ── GET /api/profile/:id/genesis — SATP V3 On-Chain Genesis Record ──
  else if (url.pathname.match(/^\/api\/profile\/[^/]+\/genesis$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    try {
      const { createSATPClient } = require('./satp-client/src');
      const client = createSATPClient({ rpcUrl: process.env.SOLANA_RPC_URL || 'https://mainnet.helius-rpc.com/?api-key=91c63e44-1c7a-4b98-830b-6135632565fb' });
      client.getGenesisRecord(profileId).then(record => {
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ genesis: record }));
      }).catch(e => {
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ genesis: null, error: e.message }));
      });
    } catch (e) {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ genesis: null, error: e.message }));
    }
    return;
  }


  // ── POST /api/satp/genesis/prepare — User-paid Genesis Record (returns unsigned TX) ──
  else if (url.pathname === '/api/satp/genesis/prepare' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const { createSATPClient, agentIdHash } = require('./satp-client/src');
        const client = createSATPClient({ rpcUrl: process.env.SOLANA_RPC_URL || 'https://mainnet.helius-rpc.com/?api-key=91c63e44-1c7a-4b98-830b-6135632565fb' });
        
        const data = JSON.parse(body);
        const { agentId, payer } = data;
        if (!agentId || !payer) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'agentId and payer required' }));
          return;
        }

        // Check if genesis record already exists
        try {
          const existing = await client.getGenesisRecord(agentId);
          if (existing && !existing.error) {
            res.writeHead(409, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ error: 'Genesis record already exists', genesis: existing }));
            return;
          }
        } catch (e) { /* no record = good, continue */ }

        // Get profile data
        const profile = loadProfile(agentId, DATA_DIR);
        const name = profile ? (profile.name || agentId).substring(0, 32) : agentId.substring(0, 32);
        const bio = profile ? (profile.bio || 'AgentFolio registered agent').substring(0, 256) : 'AgentFolio registered agent';
        const skills = profile?.skills ? (Array.isArray(profile.skills) ? profile.skills : []).slice(0, 5).map(s => s.name || s) : [];
        const category = profile?.framework || 'general';

        const hashBuf = agentIdHash(agentId);
        const { PublicKey, Keypair } = require('@solana/web3.js');
        const payerKey = new PublicKey(payer);

        // Load deployer keypair for authority signing
        const KEYPAIR_PATH = process.env.SATP_PLATFORM_KEYPAIR || '/home/ubuntu/.config/solana/brainforge-personal.json';
        const deployerKey = JSON.parse(fs.readFileSync(KEYPAIR_PATH, 'utf-8'));
        const deployer = Keypair.fromSecretKey(Uint8Array.from(deployerKey));

        const { transaction, genesisPda } = await client.buildCreateGenesisRecord(
          deployer.publicKey, hashBuf, name, bio, category, skills, ''
        );

        // User pays the transaction fee + rent
        transaction.feePayer = payerKey;
        const { blockhash, lastValidBlockHeight } = await client.connection.getLatestBlockhash();
        transaction.recentBlockhash = blockhash;

        // Deployer signs as creator/authority
        transaction.partialSign(deployer);

        // Serialize (user's wallet will add their signature)
        const serialized = transaction.serialize({ requireAllSignatures: false });
        const base64Tx = serialized.toString('base64');

        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({
          transaction: base64Tx,
          genesisPda: genesisPda.toBase58(),
          agentId,
          payer,
          blockhash,
          lastValidBlockHeight,
          estimatedCost: '~0.0105 SOL'
        }));
      } catch (e) {
        console.error('[SATP V3] Genesis prepare error:', e.message);
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }

  // ===== END GENESIS RECORD ENDPOINTS =====
  else if (url.pathname.startsWith('/api/profile/') && req.method === 'PATCH') {
    const profileId = url.pathname.replace('/api/profile/', '');
    
    // SECURITY: Require API key authentication for profile updates
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    
    if (!requestKey) {
      res.writeHead(401, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Authentication required. Provide API key via Authorization header or x-api-key.' }));
      return;
    }
    
    const keyInfo = validateApiKey(requestKey);
    if (!keyInfo) {
      res.writeHead(401, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Invalid API key' }));
      return;
    }
    
    // Check if the API key belongs to this profile
    if (keyInfo.profileId !== profileId) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'API key does not have permission to edit this profile' }));
      return;
    }
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const updates = JSON.parse(body);
        const profile = loadProfile(profileId);
        if (!profile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Profile not found' }));
          return;
        }
        for (const [key, value] of Object.entries(updates)) {
          if (typeof value === 'object' && !Array.isArray(value) && profile[key]) {
            profile[key] = { ...profile[key], ...value };
          } else {
            profile[key] = value;
          }
        }
        profile.updatedAt = new Date().toISOString();
        dbSaveProfileFn(profile);
        
        // Sync availability to SQLite database if included in update
        if (updates.availability && Object.values(AVAILABILITY_STATUS).includes(updates.availability)) {
          setAvailability(profileId, updates.availability);
        }
        // Update last active timestamp
        updateLastActive(profileId);
        
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true, profile }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  else if (url.pathname.match(/^\/api\/profile\/([^\/]+)$/)) {
    // Public read access — SATP on-chain is source of truth for scores
    const profileId = url.pathname.replace('/api/profile/', '');
    const profile = loadProfile(profileId, DATA_DIR);
    
    if (profile) {
      // Fetch SATP on-chain scores (async)
      getOnChainScores(profile.id).then(satpScores => {
        const rep = calculateReputation(profile);
        const trustScore = satpScores ? satpScores.trustScore : rep.score;
        const tier = satpScores ? satpScores.tier : rep.tier;
        
        const basic = {
          id: profile.id, name: profile.name, handle: profile.handle, bio: profile.bio,
          avatar: profile.avatar, links: profile.links,
          wallets: profile.wallets || {},
          skills: (profile.skills || []).map(s => ({ name: s.name, category: s.category })),
          verification: profile.verification,
          verificationData: (() => {
            const vd = profile.verificationData || {};
            const safe = {};
            for (const [key, val] of Object.entries(vd)) {
              if (!val) continue;
              const { challengeId, nonce, testCode, secret, verificationCode, code, token, ...pub } = val;
              if (pub.proof) { const { verificationCode, code, secret, nonce, ...safeProof } = pub.proof; pub.proof = safeProof; } safe[key] = pub;
            }
            if (safe.twitter && !safe.x) safe.x = safe.twitter;
            return safe;
          })(),
          registeredOnChain: profile.registeredOnChain || false,
          onChainRegisteredAt: profile.onChainRegisteredAt || null,
          createdAt: profile.createdAt,
          trustScore,
          tier,
          score: trustScore,
          walletAddress: profile.wallets?.solana || profile.wallets?.ethereum || null,
          verificationLevel: satpScores ? satpScores.verificationLevel : null,
          unclaimed: profile.unclaimed || false,
          verificationProofs: (() => {
            const proofs = buildVerificationProofs(profile.verificationData);
            const attestationTxs = getAttestations(profile.id);
            for (const att of attestationTxs) {
              if (proofs[att.platform]) {
                proofs[att.platform].attestation_tx = att.tx_signature;
                proofs[att.platform].solscan_url = att.solscan_url;
              }
            }
            return proofs;
          })(),
          verifications: profile.verifications || [],
        };
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(basic, null, 2));
      }).catch(err => {
        // Fallback: serve with old scores if SATP fetch fails entirely
        const rep = calculateReputation(profile);
        const basic = {
          id: profile.id, name: profile.name, handle: profile.handle, bio: profile.bio,
          avatar: profile.avatar, links: profile.links,
          wallets: profile.wallets || {},
          skills: (profile.skills || []).map(s => ({ name: s.name, category: s.category })),
          verification: profile.verification,
          verificationData: (() => {
            const vd = profile.verificationData || {};
            const safe = {};
            for (const [key, val] of Object.entries(vd)) {
              if (!val) continue;
              const { challengeId, nonce, testCode, secret, verificationCode, code, token, ...pub } = val;
              if (pub.proof) { const { verificationCode, code, secret, nonce, ...safeProof } = pub.proof; pub.proof = safeProof; } safe[key] = pub;
            }
            if (safe.twitter && !safe.x) safe.x = safe.twitter;
            return safe;
          })(),
          registeredOnChain: profile.registeredOnChain || false,
          onChainRegisteredAt: profile.onChainRegisteredAt || null,
          createdAt: profile.createdAt,
          trustScore: rep.score,
          score: rep.score,
          walletAddress: profile.wallets?.solana || profile.wallets?.ethereum || null,
          verificationLevel: null,
          tier: rep.tier,
          unclaimed: profile.unclaimed || false,
          verificationProofs: (() => {
            const proofs = buildVerificationProofs(profile.verificationData);
            const attestationTxs = getAttestations(profile.id);
            for (const att of attestationTxs) {
              if (proofs[att.platform]) {
                proofs[att.platform].attestation_tx = att.tx_signature;
                proofs[att.platform].solscan_url = att.solscan_url;
              }
            }
            return proofs;
          })(),
          verifications: profile.verifications || [],
        };
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(basic, null, 2));
      });
      return; // Important: prevent falling through to next handler
    } else {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
    }
  }

  // GET /api/agent/:id/attestations — On-chain verification attestation TXs
  else if (url.pathname.match(/^\/api\/(?:agent|profile)\/([^/]+)\/attestations$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const attestations = getAttestations(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      profileId,
      attestations,
      total: attestations.length,
      description: 'On-chain Memo TX attestations for each verified platform. Each TX contains: VERIFY|agent_id|platform|timestamp|proof_hash',
    }, null, 2));
    return;
  }

  
  // GET /api/x402/info — x402 payment protocol info
  else if (url.pathname === '/api/x402/info' && req.method === 'GET') {
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(getX402Info(), null, 2));
    return;
  }
  // GET /api/profile/:id/trust-score — Paid endpoint via x402
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/trust-score$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    
    // x402 gate: returns 402 for unpaid programmatic requests
    (async () => {
      try {
        const handled = await x402Gate('GET', url.pathname, req, res);
        if (handled) return; // 402 sent
        
        // Serve the trust score
        const profile = loadProfile(profileId, DATA_DIR);
        if (!profile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Profile not found' }));
          return;
        }
        
        // Get on-chain SATP scores
        const satpScores = await getOnChainScores(profileId);
        const rep = calculateReputation(profile);
        
        // Build detailed trust score response
        const scoringV2 = require('./lib/scoring-engine-v2');
        const v2Score = scoringV2.getCompleteScore(profile);
        
        const response = {
          profileId,
          trustScore: satpScores ? satpScores.trustScore : rep.score,
          tier: satpScores ? satpScores.tier : rep.tier,
          verificationLevel: satpScores ? satpScores.verificationLevel : v2Score.verificationLevel.level,
          v2Score: {
            verificationLevel: v2Score.verificationLevel,
            reputationScore: v2Score.reputationScore,
            overall: v2Score.overall,
          },
          onChain: satpScores ? {
            source: 'satp_v3',
            trustScore: satpScores.trustScore,
            verificationLevel: satpScores.verificationLevel,
            tier: satpScores.tier,
          } : null,
          attestations: getAttestations(profileId).length,
          verifiedPlatforms: Object.keys(profile.verificationData || {}).filter(k => 
            profile.verificationData[k]?.verified
          ),
          paid: req._x402Paid || false,
          generatedAt: new Date().toISOString(),
        };
        
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(response, null, 2));
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    })();
    return;
  }

    // ============ AVAILABILITY API ============
  
  // Get agent availability status
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/availability$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    trackApiCall('/api/profile/:id/availability');
    
    const availability = getAvailability(profileId);
    if (!availability) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ profileId, ...availability }));
  }
  
  // Set agent availability status
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/availability$/) && (req.method === 'PUT' || req.method === 'PATCH')) {
    const profileId = url.pathname.split('/')[3];
    trackApiCall('/api/profile/:id/availability');
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { status } = JSON.parse(body);
        
        if (!status) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Status is required. Valid values: available, busy, away, not_taking_work' }));
          return;
        }
        
        const result = setAvailability(profileId, status);
        
        if (result.error) {
          res.writeHead(result.error.includes('not found') ? 404 : 400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
          return;
        }
        
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ profileId, ...result }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  
  // Get availability stats (aggregate)
  else if (url.pathname === '/api/availability/stats') {
    trackApiCall('/api/availability/stats');
    const stats = getAvailabilityStats();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(stats));
  }
  
  // List profiles by availability
  else if (url.pathname === '/api/profiles/available') {
    trackApiCall('/api/profiles/available');
    const status = url.searchParams.get('status') || null;
    const limit = Math.min(parseInt(url.searchParams.get('limit')) || 50, 100);
    const offset = parseInt(url.searchParams.get('offset')) || 0;
    const includeAway = url.searchParams.get('includeAway') === 'true';
    
    const profiles = getProfilesByAvailability(status, { limit, offset, includeAway });
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      count: profiles.length,
      profiles
    }));
  }
  
  // Profile completeness API
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/completeness$/)) {
    const profileId = url.pathname.replace('/api/profile/', '').replace('/completeness', '');
    const profile = loadProfile(profileId, DATA_DIR);
    
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    
    const completeness = calculateCompleteness(profile);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      profileId,
      ...completeness
    }, null, 2));
  }
  else if (url.pathname === '/api/search') {
    trackApiCall('/api/search');
    const query = url.searchParams.get('q') || '';
    const skill = url.searchParams.get('skill');
    const category = url.searchParams.get('category');
    const minScore = parseInt(url.searchParams.get('minScore')) || 0;
    const minRep = parseInt(url.searchParams.get('minRep')) || 0;
    const tier = url.searchParams.get('tier'); // verified, trusted, rising, unverified
    const sort = url.searchParams.get('sort') || 'reputation';
    const limit = Math.min(parseInt(url.searchParams.get('limit')) || 20, 100);
    
    let results = searchProfiles(query, {
      dataDir: DATA_DIR,
      skill,
      skillCategory: category,
      minVerificationScore: minScore,
      verificationTier: tier,
      limit: 200 // get more for filtering
    });
    
    // Filter by min reputation
    if (minRep > 0) {
      results = results.filter(p => (p.reputation?.score || 0) >= minRep);
    }
    
    // Sort results
    if (sort === 'name') {
      results.sort((a, b) => a.name.localeCompare(b.name));
    } else if (sort === 'verified') {
      const tierOrder = { verified: 0, trusted: 1, rising: 2, unverified: 3 };
      results.sort((a, b) => (tierOrder[a.verification?.tier] || 3) - (tierOrder[b.verification?.tier] || 3));
    }
    // default: reputation (already sorted by searchProfiles)
    
    // Apply limit after filtering
    results = results.slice(0, limit);
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ 
      query, 
      filters: { skill, category, minScore, minRep, tier, sort, limit },
      count: results.length, 
      results 
    }, null, 2));
  }
  else if (url.pathname === '/api/skills') {
    const skills = getAllSkills(DATA_DIR);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(skills, null, 2));
  }
  else if (url.pathname === '/api/categories') {
    const categories = getSkillCategories(DATA_DIR);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(categories, null, 2));
  }
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/reputation$/)) {
    const profileId = url.pathname.split('/')[3];
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    const reputation = calculateReputation(profile);
    const tierInfo = getTierInfo(reputation.tier);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ ...reputation, tierInfo }, null, 2));
  }
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/verify\/twitter$/)) {
    const profileId = url.pathname.split('/')[3];
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    const x = profile.links?.x?.replace('@', '');
    if (!x) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'No X handle on profile' }));
      return;
    }
    verifyXBio(twitter, profileId).then(result => {
      if (result.verified) {
        addActivity(profileId, ACTIVITY_TYPES.VERIFICATION_TWITTER, {
          handle: twitter,
          followers: result.followers
        }, DATA_DIR);
        
        // Trigger webhook for X verification
        triggerWebhooks(WEBHOOK_EVENTS.VERIFICATION_TWITTER, {
          agentId: profileId,
          platform: 'twitter',
          handle: twitter,
          followers: result.followers,
          profileUrl: `https://agentfolio.bot/profile/${profileId}`
        }).catch(e => logger.error('Webhook error', { error: e.message }));
        
        // Post on-chain memo attestation
        postVerificationMemo(profileId, 'twitter', { handle: twitter, followers: result.followers }).then(memoResult => {
          if (memoResult) {
            result.memoTx = memoResult.signature;
            result.explorerUrl = memoResult.explorerUrl;
          }
        }).catch(() => {});
        // Post on-chain verification via Identity Registry
        postVerificationOnchainForProfile(profile, 'twitter', { handle: twitter, followers: result.followers });
      }
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result, null, 2));
    }).catch(e => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    });
    return;
  }
  // X Profile Sync - pull avatar, bio, followers from X API
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/x-sync$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    const handle = profile.links?.x?.replace(/^@/, '');
    if (!handle) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'No X handle on profile. Add one first.' }));
      return;
    }
    syncXToProfile(profile, { saveProfile: (p) => { const sp = require('./lib/profile').saveProfile; sp(p); }, logger })
      .then(result => {
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result, null, 2));
      })
      .catch(e => {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      });
    return;
  }
  // Get X sync data for a profile
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/x-sync$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      synced: !!profile.xSync?.lastSyncAt,
      data: profile.xSync || null,
      metrics: {
        followers: profile.metrics?.xFollowers || 0,
        posts: profile.metrics?.xTweets || 0
      }
    }, null, 2));
    return;
  }
  // Batch sync all profiles (admin)
  else if (url.pathname === '/api/admin/x-sync-all' && req.method === 'POST') {
    const apiKey = (req.headers['x-api-key'] || '').trim();
    if (!apiKey) {
      res.writeHead(401, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'API key required' }));
      return;
    }
    const { listProfiles: lp, loadProfile: lpr, saveProfile: sp } = require('./lib/profile');
    syncAllProfiles({ listProfiles: lp, loadProfile: lpr, saveProfile: sp, logger })
      .then(result => {
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result, null, 2));
      })
      .catch(e => {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      });
    return;
  }
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/verify\/hyperliquid$/)) {
    const profileId = url.pathname.split('/')[3];
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    const hlAddress = profile.wallets?.hyperliquid;
    if (!hlAddress) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'No Hyperliquid wallet on profile' }));
      return;
    }
    verifyHyperliquidTrading(hlAddress).then(result => {
      if (result.verified) {
        addActivity(profileId, ACTIVITY_TYPES.VERIFICATION_HYPERLIQUID, {
          address: hlAddress.slice(0, 10) + '...',
          accountValue: result.accountValue,
          totalTrades: result.stats?.totalTrades
        }, DATA_DIR);
        
        // Trigger webhook for Hyperliquid verification
        triggerWebhooks(WEBHOOK_EVENTS.VERIFICATION_HYPERLIQUID, {
          agentId: profileId,
          platform: 'hyperliquid',
          address: hlAddress,
          accountValue: result.accountValue,
          totalTrades: result.stats?.totalTrades,
          profileUrl: `https://agentfolio.bot/profile/${profileId}`
        }).catch(e => logger.error('Webhook error', { error: e.message }));
      }
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result, null, 2));
    }).catch(e => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    });
    return;
  }
  else if (url.pathname === '/api/verify/hyperliquid') {
    const address = url.searchParams.get('address');
    if (!address) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Address parameter required' }));
      return;
    }
    verifyHyperliquidTrading(address).then(result => {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result, null, 2));
    }).catch(e => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    });
    return;
  }
  else if (url.pathname === '/api/verify/solana') {
    const address = url.searchParams.get('address');
    if (!address) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Address parameter required' }));
      return;
    }
    verifySolanaWallet(address).then(result => {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result, null, 2));
    }).catch(e => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    });
    return;
  }
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/verify\/solana$/)) {
    const profileId = url.pathname.split('/')[3];
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    const solAddress = profile.wallets?.solana;
    if (!solAddress) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'No Solana wallet on profile' }));
      return;
    }
    verifySolanaWallet(solAddress).then(result => {
      if (result.verified) {
        addActivity(profileId, ACTIVITY_TYPES.VERIFICATION_SOLANA || 'verification_solana', {
          address: solAddress.slice(0, 8) + '...' + solAddress.slice(-4),
          balance: result.balanceSOL,
          txCount: result.transactionCount
        }, DATA_DIR);
        
        // Update profile with verification data
        const updatedProfile = { ...profile };
        updatedProfile.verificationData = updatedProfile.verificationData || {};
        updatedProfile.verificationData.solana = {
          ...result,
          verifiedAt: new Date().toISOString()
        };
        
        // Post on-chain memo attestation
        postVerificationMemo(profileId, 'solana', { address: solAddress, balance: result.balanceSOL }).then(memoResult => {
          if (memoResult) {
            updatedProfile.verificationData.solana.memoTx = memoResult.signature;
            updatedProfile.verificationData.solana.explorerUrl = memoResult.explorerUrl;
            dbSaveProfileFn(updatedProfile);
          }
        }).catch(() => {});
        // Post on-chain verification via Identity Registry
        postVerificationOnchainForProfile(updatedProfile, 'solana', { address: solAddress });
        
        updatedProfile.updatedAt = new Date().toISOString();
        dbSaveProfileFn(updatedProfile);
        
        // Trigger webhook for Solana verification
        triggerWebhooks(WEBHOOK_EVENTS.VERIFICATION_SOLANA, {
          agentId: profileId,
          platform: 'solana',
          address: solAddress,
          balanceSOL: result.balanceSOL,
          transactionCount: result.transactionCount,
          profileUrl: `https://agentfolio.bot/profile/${profileId}`
        }).catch(e => logger.error('Webhook error', { error: e.message }));
      }
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result, null, 2));
    }).catch(e => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    });
    return;
  }
  // === ETHEREUM VERIFICATION ===
  else if (url.pathname === "/api/verify/ethereum") {
    const address = url.searchParams.get("address");
    if (!address || !isValidEthereumAddress(address)) {
      res.writeHead(400, { "Content-Type": "application/json" });
      res.end(JSON.stringify({ error: "Invalid Ethereum address" }));
      return;
    }
    
    getEthereumStats(address).then(result => {
      res.writeHead(200, { "Content-Type": "application/json" });
      res.end(JSON.stringify(result, null, 2));
    }).catch(e => {
      res.writeHead(500, { "Content-Type": "application/json" });
      res.end(JSON.stringify({ error: e.message }));
    });
    return;
  }
  else if (url.pathname.match(/^\/api\/profile\/([^\/]+)\/verify\/ethereum$/)) {
    const profileId = url.pathname.split("/")[3];
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { "Content-Type": "application/json" });
      res.end(JSON.stringify({ error: "Profile not found" }));
      return;
    }
    const ethAddress = profile.wallets?.ethereum;
    if (!ethAddress) {
      res.writeHead(400, { "Content-Type": "application/json" });
      res.end(JSON.stringify({ error: "No Ethereum wallet on profile" }));
      return;
    }

    getEthereumStats(ethAddress).then(result => {
      if (result.verified) {
        addActivity(profileId, ACTIVITY_TYPES.VERIFICATION_ETHEREUM || "verification_ethereum", {
          address: ethAddress.slice(0, 8) + "..." + ethAddress.slice(-4),
          balance: result.balance,
          txCount: result.txCount
        }, DATA_DIR);
        
        const updatedProfile = { ...profile };
        updatedProfile.verificationData = updatedProfile.verificationData || {};
        updatedProfile.verificationData.ethereum = {
          ...result,
          verifiedAt: new Date().toISOString()
        };
        
        updatedProfile.updatedAt = new Date().toISOString();
        dbSaveProfileFn(updatedProfile);
        
        triggerWebhooks(WEBHOOK_EVENTS.VERIFICATION_ETHEREUM, {
          agentId: profileId,
          platform: "ethereum",
          address: ethAddress,
          balance: result.balance,
          txCount: result.txCount,
          profileUrl: `https://agentfolio.bot/profile/${profile?.id || "unknown"}`
        }).catch(e => logger.error("Webhook error", { error: e.message }));
      }
      res.writeHead(200, { "Content-Type": "application/json" });
      res.end(JSON.stringify(result, null, 2));
    }).catch(e => {
      res.writeHead(500, { "Content-Type": "application/json" });
      res.end(JSON.stringify({ error: e.message }));
    });
    return;
  }
  // === HEADLESS VERIFICATION (for agents without browsers) ===
  // Step 1: Get a challenge to sign
  else if (url.pathname === '/api/verify/challenge' && req.method === 'POST') {
    let body = '';
    req.on('data', c => body += c);
    req.on('end', () => {
      try {
        const { profileId, chain } = JSON.parse(body);
        if (!profileId) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'profileId required' })); return; }
        const profile = loadProfile(profileId, DATA_DIR);
        if (!profile) { res.writeHead(404, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'Profile not found' })); return; }
        const timestamp = Date.now();
        const nonce = require('crypto').randomBytes(16).toString('hex');
        const challenge = `AgentFolio verification for ${profileId} at ${timestamp} nonce:${nonce}`;
        // Store challenge temporarily (expires in 10 min)
        if (!global._afChallenges) global._afChallenges = {};
        global._afChallenges[`${profileId}:${nonce}`] = { challenge, timestamp, chain: chain || 'solana', profileId };
        // Clean old challenges
        const now = Date.now();
        for (const k of Object.keys(global._afChallenges)) {
          if (now - global._afChallenges[k].timestamp > 600000) delete global._afChallenges[k];
        }
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ challenge, nonce, expiresIn: '10 minutes' }));
      } catch (e) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'Invalid JSON' })); }
    });
    return;
  }
  // Step 2: Submit signed challenge to verify wallet ownership
  else if (url.pathname === '/api/verify/sign' && req.method === 'POST') {
    let body = '';
    req.on('data', c => body += c);
    req.on('end', async () => {
      try {
        const { profileId, nonce, signature, publicKey, chain } = JSON.parse(body);
        if (!profileId || !nonce || !signature || !publicKey) {
          res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'profileId, nonce, signature, publicKey required' })); return;
        }
        const key = `${profileId}:${nonce}`;
        const stored = (global._afChallenges || {})[key];
        if (!stored) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'Challenge not found or expired' })); return; }
        if (Date.now() - stored.timestamp > 600000) {
          delete global._afChallenges[key];
          res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'Challenge expired' })); return;
        }
        const verifyChain = chain || stored.chain || 'solana';
        let verified = false;
        if (verifyChain === 'solana') {
          try {
            const nacl = require('tweetnacl');
            const bs58 = require('bs58');
            const messageBytes = new TextEncoder().encode(stored.challenge);
            const bs58dec = bs58.decode || bs58.default?.decode;
            const sigBytes = bs58dec(signature);
            const pubBytes = bs58dec(publicKey);
            verified = nacl.sign.detached.verify(messageBytes, sigBytes, pubBytes);
          } catch (e) { verified = false; }
        } else if (verifyChain === 'evm') {
          try {
            const { ethers } = require('ethers');
            const recovered = ethers.verifyMessage(stored.challenge, signature);
            verified = recovered.toLowerCase() === publicKey.toLowerCase();
          } catch (e) { verified = false; }
        }
        delete global._afChallenges[key];
        if (verified) {
          const profile = loadProfile(profileId, DATA_DIR);
          if (profile) {
            profile.verificationData = profile.verificationData || {};
            profile.wallets = profile.wallets || {};
            if (verifyChain === 'solana') {
              profile.wallets.solana = publicKey;
              profile.verificationData.solana = { verified: true, address: publicKey, verifiedAt: new Date().toISOString(), method: 'headless-sign' };
              postVerificationOnchainForProfile(profile, 'solana', { address: publicKey });
            } else if (verifyChain === 'evm') {
              profile.wallets.ethereum = publicKey;
              profile.verificationData.ethereum = { verified: true, address: publicKey, verifiedAt: new Date().toISOString(), method: 'headless-sign' };
            }
            profile.updatedAt = new Date().toISOString();
            // Recalculate trust score
            const trust = computeTrustData(profileId);
            profile.trustScore = trust.trustScore;
            profile.tier = trust.tier;
            dbSaveProfileFn(profile);
            addActivity(profileId, 'verification_wallet', { chain: verifyChain, address: publicKey.slice(0, 8) + '...' + publicKey.slice(-4), method: 'headless' }, DATA_DIR);
            triggerWebhooks(WEBHOOK_EVENTS.VERIFICATION_SOLANA, { agentId: profileId, platform: verifyChain, address: publicKey, method: 'headless-sign' }).catch(() => {});
          }
          const updatedTrust = computeTrustData(profileId);
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ verified: true, chain: verifyChain, address: publicKey, trustScore: updatedTrust.trustScore, tier: updatedTrust.tier, message: 'Wallet verified successfully' }));
        } else {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ verified: false, error: 'Signature verification failed' }));
        }
      } catch (e) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
    });
    return;
  }
  // === HEADLESS TWITTER VERIFICATION ===
  // Agent puts their profileId in X bio, then calls this
  else if (url.pathname === '/api/verify/x' && req.method === 'POST') {
    let body = '';
    req.on('data', c => body += c);
    req.on('end', async () => {
      try {
        const _xbody = JSON.parse(body); const profileId = _xbody.profileId; const twitterHandle = _xbody.twitterHandle || _xbody.handle;
        if (!profileId || !twitterHandle) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'profileId and twitterHandle required' })); return; }
        const profile = loadProfile(profileId, DATA_DIR);
        if (!profile) { res.writeHead(404, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'Profile not found' })); return; }
        // Update handle on profile if not set
        if (!profile.links) profile.links = {};
        profile.links.x = twitterHandle.replace('@', '');
        dbSaveProfileFn(profile);
        // Run bio verification
        const result = await verifyXBio(twitterHandle.replace('@', ''), profileId);
        if (result.verified) {
          profile.verificationData = profile.verificationData || {};
          profile.verificationData.x = { ...result, verifiedAt: new Date().toISOString(), method: 'headless-bio' };
          profile.updatedAt = new Date().toISOString();
          dbSaveProfileFn(profile);
          addActivity(profileId, ACTIVITY_TYPES.VERIFICATION_TWITTER || 'verification_twitter', { handle: twitterHandle, followers: result.followers }, DATA_DIR);
          postVerificationOnchainForProfile(profile, 'twitter', { handle: twitterHandle, followers: result.followers });
        }
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ ...result, hint: result.verified ? 'X verified!' : 'Put your profileId "' + profileId + '" in your X bio, then retry' }));
      } catch (e) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
    });
    return;
  }
  // === HEADLESS DISCORD VERIFICATION (code-based, no OAuth) ===
  else if (url.pathname === '/api/verify/discord/headless' && req.method === 'POST') {
    let body = '';
    req.on('data', c => body += c);
    req.on('end', async () => {
      try {
        const { profileId, discordUserId, discordUsername } = JSON.parse(body);
        if (!profileId || !discordUserId) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'profileId and discordUserId required' })); return; }
        const profile = loadProfile(profileId, DATA_DIR);
        if (!profile) { res.writeHead(404, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'Profile not found' })); return; }
        // For headless: agent provides their Discord user ID + username
        // We store it as "self-reported" verification (lower trust than OAuth)
        profile.links = profile.links || {};
        profile.links.discord = discordUsername || discordUserId;
        profile.verificationData = profile.verificationData || {};
        profile.verificationData.discord = {
          id: discordUserId,
          username: discordUsername || discordUserId,
          verified: true,
          verifiedAt: new Date().toISOString(),
          method: 'headless-self-report',
          trustLevel: 'low'
        };
        profile.updatedAt = new Date().toISOString();
        dbSaveProfileFn(profile);
        addActivity(profileId, 'verification_discord', { username: discordUsername || discordUserId, method: 'headless' }, DATA_DIR);
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ verified: true, method: 'self-report', trustLevel: 'low', note: 'For full trust, use OAuth flow at /api/verify/discord/start' }));
      } catch (e) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
    });
    return;
  }
  // === HEADLESS SATP REGISTRATION (server-side, no browser wallet needed) ===
  else if (url.pathname === '/api/verify/satp/headless' && req.method === 'POST') {
    // ADMIN-ONLY: Server-paid registration restricted to admin API key
    const authKey = req.headers['x-api-key'] || (req.headers['authorization'] || '').replace('Bearer ', '');
    const ADMIN_KEY = process.env.ADMIN_API_KEY || 'agentfolio-admin-2026';
    if (authKey !== ADMIN_KEY) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Admin access required. Use wallet-based registration at /register instead.' }));
      return;
    }
    let body = '';
    req.on('data', c => body += c);
    req.on('end', async () => {
      try {
        const { profileId } = JSON.parse(body);
        if (!profileId) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'profileId required' })); return; }
        const profile = loadProfile(profileId, DATA_DIR);
        if (!profile) { res.writeHead(404, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'Profile not found' })); return; }
        // Full on-chain registration via admin_register_agent
        const { fullOnchainRegistration } = require('./lib/verification-onchain');
const { handleVerificationRoutes } = require('./lib/hardened-verification-routes');
        const result = await fullOnchainRegistration(profile);
        profile.verificationData = profile.verificationData || {};
        profile.verificationData.satp = {
          verified: true,
          registered: true,
          registeredAt: new Date().toISOString(),
          method: 'headless-server',
          onchainStatus: result?.registration ? 'confirmed' : 'pending',
          pda: result?.registration?.pda || null,
          explorerUrl: result?.registration?.explorerUrl || null,
          onchainVerifications: result?.verifications || {},
          onchainReputation: result?.reputation || null
        };
        // Recompute trust score
        const trust = computeTrustData(profileId);
        profile.trustScore = trust.trustScore;
        profile.tier = trust.tier;
        profile.updatedAt = new Date().toISOString();
        dbSaveProfileFn(profile);
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true, satp: profile.verificationData.satp, trustScore: trust.trustScore, tier: trust.tier }));
      } catch (e) { res.writeHead(500, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
    });
    return;
  }

  // ── Hardened Hyperliquid Verification (signature-required) ──
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/verify\/hyperliquid\/initiate$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        let parsed = {};
        try { parsed = JSON.parse(body); } catch {}
        const walletAddress = parsed.walletAddress || profile.wallets?.hyperliquid;
        if (!walletAddress) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'No Hyperliquid wallet. Provide walletAddress or set it on your profile.' }));
          return;
        }
        const result = initiateHLVerification(profileId, walletAddress);
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/verify\/hyperliquid\/complete$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const parsed = JSON.parse(body);
        const { challengeId, signature } = parsed;
        if (!challengeId || !signature) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'challengeId and signature required' }));
          return;
        }
        const result = await completeHLVerification(challengeId, signature);
        if (result.verified) {
          // Update profile JSON
          const profile = loadProfile(profileId, DATA_DIR);
          if (profile) {
            profile.verificationData = profile.verificationData || {};
            profile.verificationData.hyperliquid = {
              verified: true,
              address: result.identifier,
              accountValue: result.accountValue,
              stats: result.stats,
              method: 'hardened_signature',
              verifiedAt: new Date().toISOString(),
            };
            profile.wallets = profile.wallets || {};
            if (!profile.wallets.hyperliquid) profile.wallets.hyperliquid = result.identifier;
            profile.updatedAt = new Date().toISOString();
            dbSaveProfileFn(profile);
          }
          addActivityAndBroadcast(profileId, 'verification_hyperliquid', {
            address: result.identifier?.slice(0, 8) + '...' + result.identifier?.slice(-4),
            accountValue: result.accountValue,
            method: 'hardened_signature',
          }, DATA_DIR);
        }
        res.writeHead(result.verified ? 200 : 400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  // Profile-specific Hyperliquid verification (saves to profile)
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/verify\/hyperliquid$/)) {
    const profileId = url.pathname.split('/')[3];
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    
    // Get address from body (POST) or profile
    let hlAddress = profile.wallets?.hyperliquid;
    if (req.method === 'POST') {
      let body = '';
      req.on('data', chunk => body += chunk);
      req.on('end', async () => {
        try {
          const data = JSON.parse(body);
          hlAddress = data.address || hlAddress;
        } catch (e) {}
        
        if (!hlAddress) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'No Hyperliquid address provided or on profile' }));
          return;
        }
        
        try {
          const result = await verifyHyperliquidTrading(hlAddress);
          if (result.verified) {
            addActivityAndBroadcast(profileId, 'verification_hyperliquid', {
              address: hlAddress.slice(0, 8) + '...' + hlAddress.slice(-4),
              accountValue: result.accountValue,
              totalTrades: result.stats?.totalTrades
            }, DATA_DIR);
            
            // Update profile with verification data
            const updatedProfile = { ...profile };
            updatedProfile.verificationData = updatedProfile.verificationData || {};
            updatedProfile.verificationData.hyperliquid = {
              verified: true,
              address: hlAddress,
              accountValue: result.accountValue,
              openPositions: result.openPositions,
              stats: result.stats,
              verificationLevel: result.verificationLevel,
              verifiedAt: new Date().toISOString()
            };
            // Also update wallet if not set
            updatedProfile.wallets = updatedProfile.wallets || {};
            if (!updatedProfile.wallets.hyperliquid) {
              updatedProfile.wallets.hyperliquid = hlAddress;
            }
            updatedProfile.updatedAt = new Date().toISOString();
            dbSaveProfileFn(updatedProfile);
            
            // Post on-chain memo attestation
            postVerificationMemo(profileId, 'hyperliquid', { address: hlAddress, value: result.accountValue }).then(memoResult => {
              if (memoResult) {
                updatedProfile.verificationData.hyperliquid.memoTx = memoResult.signature;
                updatedProfile.verificationData.hyperliquid.explorerUrl = memoResult.explorerUrl;
                dbSaveProfileFn(updatedProfile);
              }
            }).catch(() => {});
            // Post on-chain verification via Identity Registry
            postVerificationOnchainForProfile(updatedProfile, 'hyperliquid', { address: hlAddress });
          }
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result, null, 2));
        } catch (e) {
          res.writeHead(500, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: e.message }));
        }
      });
      return;
    }
    
    // GET request - use profile wallet
    if (!hlAddress) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'No Hyperliquid wallet on profile' }));
      return;
    }
    verifyHyperliquidTrading(hlAddress).then(result => {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result, null, 2));
    }).catch(e => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    });
    return;
  }
  else if (url.pathname === '/api/verify/solana/tokens') {
    const address = url.searchParams.get('address');
    if (!address) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Address parameter required' }));
      return;
    }
    getSolanaTokenAccounts(address).then(result => {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result, null, 2));
    }).catch(e => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    });
    return;
  }
  // GitHub verification
  else if (url.pathname === '/api/verify/github') {
    const doVerify = (uname, aid) => {
      if (!uname) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Username parameter required' }));
        return;
      }
      verifyGitHubProfile(uname, aid || 'unknown').then(result => {
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result, null, 2));
      }).catch(e => {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      });
    };
    if (req.method === 'POST') {
      let body = '';
      req.on('data', chunk => body += chunk);
      req.on('end', () => {
        try {
          const d = JSON.parse(body);
          doVerify(d.username || url.searchParams.get('username'), d.agentId || url.searchParams.get('agentId'));
        } catch(e) {
          doVerify(url.searchParams.get('username'), url.searchParams.get('agentId'));
        }
      });
    } else {
      doVerify(url.searchParams.get('username'), url.searchParams.get('agentId'));
    }
    return;
  }
  // GitHub stats
  else if (url.pathname === '/api/verify/github/stats') {
    const username = url.searchParams.get('username');
    if (!username) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Username parameter required' }));
      return;
    }
    getGitHubStats(username).then(result => {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result, null, 2));
    }).catch(e => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    });
    return;
  }
  // SATP on-chain identity verification
  else if (url.pathname === '/api/verify/satp' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { profileId, wallet, txSignature } = JSON.parse(body);
        if (!profileId || !wallet) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'profileId and wallet required' }));
          return;
        }
        // Update profile's verificationData.satp
        const profilePath = path.join(PROFILES_DIR, profileId + '.json');
        if (!fs.existsSync(profilePath)) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Profile not found' }));
          return;
        }
        const profile = JSON.parse(fs.readFileSync(profilePath, 'utf-8'));
        if (!profile.verificationData) profile.verificationData = {};
        profile.verificationData.satp = {
          verified: true,
          did: `did:satp:sol:${wallet}`,
          wallet,
          txSignature: txSignature || null,
          verifiedAt: new Date().toISOString(),
        };
        profile.updatedAt = new Date().toISOString();
        fs.writeFileSync(profilePath, JSON.stringify(profile, null, 2));
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true, satp: profile.verificationData.satp }));
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  // AgentMail verification - check availability
  else if (url.pathname === '/api/verify/agentmail/status') {
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      available: isAgentMailAvailable(),
      message: isAgentMailAvailable() ? 'AgentMail verification is available' : 'AgentMail API key not configured'
    }));
    return;
  }
  // AgentMail verification - start (send code)
  else if (url.pathname === '/api/verify/agentmail/start' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        const { profileId, email } = data;
        
        if (!profileId || !email) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'profileId and email are required' }));
          return;
        }
        
        // Check profile exists
        const profile = loadProfile(profileId, DATA_DIR);
        if (!profile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Profile not found' }));
          return;
        }
        
        const result = await startAgentMailVerification(profileId, email);
        res.writeHead(result.success ? 200 : 400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  // AgentMail verification - confirm (verify code)
  else if (url.pathname === '/api/verify/agentmail/confirm' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        const { profileId, email, code } = data;
        
        if (!profileId || !email || !code) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'profileId, email, and code are required' }));
          return;
        }
        
        // Check profile exists
        const profile = loadProfile(profileId, DATA_DIR);
        if (!profile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Profile not found' }));
          return;
        }
        
        const result = confirmAgentMailVerification(profileId, email, code);
        
        if (result.success) {
          // Update profile with verified AgentMail
          const updatedProfile = { ...profile };
          updatedProfile.links = updatedProfile.links || {};
          updatedProfile.links.agentmail = email;
          updatedProfile.verificationData = updatedProfile.verificationData || {};
          updatedProfile.verificationData.agentmail = {
            email,
            verified: true,
            verifiedAt: result.verifiedAt
          };
          updatedProfile.updatedAt = new Date().toISOString();
          dbSaveProfileFn(updatedProfile);
          
          // Add activity
          addActivityAndBroadcast(profileId, 'verification_agentmail', {
            email: email.replace(/(.{3}).*@/, '$1***@')
          }, DATA_DIR);
          
          // Post on-chain memo attestation
          postVerificationMemo(profileId, 'agentmail', { email }).then(memoResult => {
            if (memoResult) {
              updatedProfile.verificationData.agentmail.memoTx = memoResult.signature;
              updatedProfile.verificationData.agentmail.explorerUrl = memoResult.explorerUrl;
              dbSaveProfileFn(updatedProfile);
            }
          }).catch(() => {});
          // Post on-chain verification via Identity Registry
          postVerificationOnchainForProfile(updatedProfile, 'agentmail', { email });
        }
        
        res.writeHead(result.success ? 200 : 400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  // AgentMail verification - check pending status
  else if (url.pathname === '/api/verify/agentmail/pending') {
    const profileId = url.searchParams.get('profileId');
    const email = url.searchParams.get('email');
    
    if (!profileId || !email) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'profileId and email query params required' }));
      return;
    }
    
    const status = getAgentMailPendingStatus(profileId, email);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(status));
    return;
  }
  // === ETH VERIFICATION STUBS (routes frontend calls but dont exist yet) ===
  else if (url.pathname === "/api/verification/eth/initiate" && req.method === "POST") {
    res.writeHead(501, { "Content-Type": "application/json" });
    res.end(JSON.stringify({ error: "ETH wallet verification coming soon. Use Solana wallet verification for now." }));
    return;
  }
  else if (url.pathname === "/api/verification/eth/verify" && req.method === "POST") {
    res.writeHead(501, { "Content-Type": "application/json" });
    res.end(JSON.stringify({ error: "ETH wallet verification coming soon." }));
    return;
  }
  // === DOMAIN VERIFICATION STUBS ===
  else if (url.pathname === "/api/verification/domain/initiate" && req.method === "POST") {
    res.writeHead(501, { "Content-Type": "application/json" });
    res.end(JSON.stringify({ error: "Domain verification coming soon. Use GitHub or X verification for now." }));
    return;
  }
  else if (url.pathname === "/api/verification/domain/verify" && req.method === "POST") {
    res.writeHead(501, { "Content-Type": "application/json" });
    res.end(JSON.stringify({ error: "Domain verification coming soon." }));
    return;
  }
  // Profile-specific AgentMail verification
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/verify\/agentmail$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        const { action, email, code } = data;
        
        if (action === 'start') {
          if (!email) {
            res.writeHead(400, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ error: 'email is required' }));
            return;
          }
          const result = await startAgentMailVerification(profileId, email);
          res.writeHead(result.success ? 200 : 400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else if (action === 'confirm') {
          if (!email || !code) {
            res.writeHead(400, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ error: 'email and code are required' }));
            return;
          }
          const result = confirmAgentMailVerification(profileId, email, code);
          
          if (result.success) {
            // Update profile
            const updatedProfile = { ...profile };
            updatedProfile.links = updatedProfile.links || {};
            updatedProfile.links.agentmail = email;
            updatedProfile.verificationData = updatedProfile.verificationData || {};
            updatedProfile.verificationData.agentmail = {
              email,
              verified: true,
              verifiedAt: result.verifiedAt
            };
            updatedProfile.updatedAt = new Date().toISOString();
            dbSaveProfileFn(updatedProfile);
            
            addActivityAndBroadcast(profileId, 'verification_agentmail', {
              email: email.replace(/(.{3}).*@/, '$1***@')
            }, DATA_DIR);
          }
          
          res.writeHead(result.success ? 200 : 400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'action must be "start" or "confirm"' }));
        }
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  // ============================================
  // TELEGRAM VERIFICATION ENDPOINTS
  // ============================================
  
  // Start Telegram verification - generate code
  else if (url.pathname === '/api/verify/telegram/start' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const { profileId, telegramHandle } = data;
        
        if (!profileId || !telegramHandle) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'profileId and telegramHandle are required' }));
          return;
        }
        
        // Verify profile exists
        const profile = loadProfile(profileId, DATA_DIR);
        if (!profile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Profile not found' }));
          return;
        }
        
        const result = startTelegramVerification(profileId, telegramHandle);
        res.writeHead(result.success || result.alreadyVerified ? 200 : 400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  
  // Telegram bot webhook - verify code (called by bot)
  else if (url.pathname === '/api/verify/telegram/confirm' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const { code, telegramUserId, telegramUsername } = data;
        
        if (!code) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'code is required' }));
          return;
        }
        
        const result = verifyTelegramCode(code, telegramUserId, telegramUsername);
        
        if (result.verified) {
          // Update the profile with Telegram verification
          const profile = loadProfile(result.profileId);
          if (profile) {
            const updatedProfile = { ...profile };
            updatedProfile.links = updatedProfile.links || {};
            updatedProfile.links.telegram = result.telegramHandle;
            updatedProfile.verificationData = updatedProfile.verificationData || {};
            updatedProfile.verificationData.telegram = {
              handle: result.telegramHandle,
              telegramId: result.telegramId,
              verified: true,
              verifiedAt: new Date().toISOString()
            };
            updatedProfile.updatedAt = new Date().toISOString();
            dbSaveProfileFn(updatedProfile);
            
            // Log activity
            addActivityAndBroadcast(result.profileId, 'verification_telegram', {
              handle: result.telegramHandle
            }, DATA_DIR);
            
            // Trigger webhooks
            triggerWebhooks(WEBHOOK_EVENTS.VERIFICATION_COMPLETE || 'verification_complete', {
              agentId: result.profileId,
              platform: 'telegram',
              handle: result.telegramHandle,
              profileUrl: `https://agentfolio.bot/profile/${result.profileId}`
            }).catch(e => logger.error('Webhook error', { error: e.message }));
            
            // Post on-chain memo attestation
            postVerificationMemo(result.profileId, 'telegram', { handle: result.telegramHandle }).then(memoResult => {
              if (memoResult) {
                updatedProfile.verificationData.telegram.memoTx = memoResult.signature;
                updatedProfile.verificationData.telegram.explorerUrl = memoResult.explorerUrl;
                dbSaveProfileFn(updatedProfile);
              }
            }).catch(() => {});
            // Post on-chain verification via Identity Registry
            postVerificationOnchainForProfile(updatedProfile, 'telegram', { handle: result.telegramHandle });
          }
        }
        
        res.writeHead(result.verified ? 200 : 400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  
  // Check Telegram verification status
  else if (url.pathname === '/api/verify/telegram/status') {
    const profileId = url.searchParams.get('profileId');
    if (!profileId) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'profileId query param required' }));
      return;
    }
    
    const verified = getTelegramVerificationStatus(profileId);
    const pending = getPendingTelegramVerification(profileId);
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      profileId,
      verified: verified !== null,
      verificationData: verified,
      pendingVerification: pending
    }));
    return;
  }
  
  // Profile-specific Telegram verification
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/verify\/telegram$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const { action, telegramHandle, code, telegramUserId, telegramUsername } = data;
        
        if (action === 'start') {
          if (!telegramHandle) {
            res.writeHead(400, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ error: 'telegramHandle is required' }));
            return;
          }
          const result = startTelegramVerification(profileId, telegramHandle);
          res.writeHead(result.success || result.alreadyVerified ? 200 : 400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else if (action === 'confirm') {
          if (!code) {
            res.writeHead(400, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ error: 'code is required' }));
            return;
          }
          const result = verifyTelegramCode(code, telegramUserId, telegramUsername);
          
          if (result.verified && result.profileId === profileId) {
            // Update the profile with Telegram verification
            const updatedProfile = { ...profile };
            updatedProfile.links = updatedProfile.links || {};
            updatedProfile.links.telegram = result.telegramHandle;
            updatedProfile.verificationData = updatedProfile.verificationData || {};
            updatedProfile.verificationData.telegram = {
              handle: result.telegramHandle,
              telegramId: result.telegramId,
              verified: true,
              verifiedAt: new Date().toISOString()
            };
            updatedProfile.updatedAt = new Date().toISOString();
            dbSaveProfileFn(updatedProfile);
            
            addActivityAndBroadcast(profileId, 'verification_telegram', {
              handle: result.telegramHandle
            }, DATA_DIR);
          }
          
          res.writeHead(result.verified ? 200 : 400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else if (action === 'status') {
          const verified = getTelegramVerificationStatus(profileId);
          const pending = getPendingTelegramVerification(profileId);
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({
            profileId,
            verified: verified !== null,
            verificationData: verified,
            pendingVerification: pending
          }));
        } else {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'action must be "start", "confirm", or "status"' }));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  
  // Admin: Get all verified Telegram accounts
  else if (url.pathname === '/api/verify/telegram/all') {
    const verified = getAllTelegramVerified();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      count: Object.keys(verified).length,
      verifications: verified
    }));
    return;
  }
  
  // ============================================
  // END TELEGRAM VERIFICATION ENDPOINTS
  // ============================================
  
  // ============================================
  // AUTO-VERIFICATION PIPELINE
  // ============================================
  
  // POST /api/profiles/:id/auto-verify - Run auto-verification for a platform
  else if (url.pathname.match(/^\/api\/profiles?\/([^/]+)\/auto-verify$/) && req.method === 'POST') {
    const profileId = url.pathname.match(/^\/api\/profiles?\/([^/]+)\/auto-verify$/)[1];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const { platform, address } = JSON.parse(body);
        if (!platform || !address) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'platform and address are required', supported: SUPPORTED_PLATFORMS }));
          return;
        }
        const result = await autoVerify(profileId, platform, address);
        res.writeHead(result.success ? 200 : 400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }

  // POST /api/profiles/:id/auto-verify-all - Run all verifications based on existing wallets/links
  else if (url.pathname.match(/^\/api\/profiles?\/([^/]+)\/auto-verify-all$/) && req.method === 'POST') {
    const profileId = url.pathname.match(/^\/api\/profiles?\/([^/]+)\/auto-verify-all$/)[1];
    (async () => {
      try {
        const result = await autoVerifyAll(profileId);
        res.writeHead(result.success ? 200 : 400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    })();
    return;
  }

  // GET /api/profiles/:id/verification-data - Get stored verification data
  else if (url.pathname.match(/^\/api\/profiles?\/([^/]+)\/verification-data$/) && req.method === 'GET') {
    const profileId = url.pathname.match(/^\/api\/profiles?\/([^/]+)\/verification-data$/)[1];
    const profile = loadProfile(profileId);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      profileId,
      verification: profile.verification || {},
      verificationData: profile.verificationData || {}
    }));
    return;
  }

  // ============================================
  // END AUTO-VERIFICATION PIPELINE
  // ============================================

  // ============================================
  // PEER REVIEWS (Agent-to-Agent)
  // ============================================

  // POST /api/reviews - Create a peer review
  else if (url.pathname === '/api/reviews' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const result = createPeerReview(data);
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          res.writeHead(201, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        }
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }

  // GET /api/reviews/stats - Global review stats
  else if (url.pathname === '/api/reviews/stats' && req.method === 'GET') {
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(getPeerReviewStats()));
    return;
  }

  // GET /api/reviews/top-rated - Top rated agents
  else if (url.pathname === '/api/reviews/top-rated' && req.method === 'GET') {
    const limit = parseInt(url.searchParams.get('limit') || '10');
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(getTopRated(limit)));
    return;
  }

  // GET /api/reviews/:profileId/score - Get aggregate review score
  else if (url.pathname.match(/^\/api\/reviews\/([^/]+)\/score$/) && req.method === 'GET') {
    const profileId = url.pathname.match(/^\/api\/reviews\/([^/]+)\/score$/)[1];
    const score = getReviewScore(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(score));
    return;
  }

  // GET /api/reviews/:profileId - Get reviews for a profile
  else if (url.pathname.match(/^\/api\/reviews\/([^/]+)$/) && req.method === 'GET') {
    const profileId = url.pathname.match(/^\/api\/reviews\/([^/]+)$/)[1];
    const peerRevs = getProfileReviews(profileId);
    const score = getReviewScore(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ profileId, score, reviews: peerRevs }));
    return;
  }

  // DELETE /api/reviews/:id - Delete a review
  else if (url.pathname.match(/^\/api\/reviews\/([^/]+)$/) && req.method === 'DELETE') {
    const reviewId = url.pathname.match(/^\/api\/reviews\/([^/]+)$/)[1];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { requesterId } = JSON.parse(body || '{}');
        const result = deletePeerReview(reviewId, requesterId || 'admin');
        res.writeHead(result.error ? 400 : 200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }

  // ============================================
  // END PEER REVIEWS
  // ============================================
  
  // ============================================
  // DISCORD VERIFICATION ENDPOINTS
  // ============================================
  
  // Check Discord OAuth configuration status
  else if (url.pathname === '/api/verify/discord/status') {
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      configured: isDiscordConfigured(),
      message: isDiscordConfigured() 
        ? 'Discord OAuth2 is configured and ready'
        : 'Discord OAuth2 is not configured. Set DISCORD_CLIENT_ID and DISCORD_CLIENT_SECRET environment variables.'
    }));
    return;
  }
  
  // Start Discord verification - get OAuth URL
  else if (url.pathname === '/api/verify/discord/start' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const { profileId } = data;
        
        if (!profileId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'profileId is required' }));
          return;
        }
        
        // Verify profile exists
        const profile = loadProfile(profileId, DATA_DIR);
        if (!profile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Profile not found' }));
          return;
        }
        
        const result = startDiscordVerification(profileId);
        res.writeHead(result.success || result.alreadyVerified || result.notConfigured ? 200 : 400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  
  // Discord OAuth2 callback
  else if (url.pathname === '/api/verify/discord/callback') {
    const code = url.searchParams.get('code');
    const state = url.searchParams.get('state');
    const error = url.searchParams.get('error');
    
    // Handle OAuth error (user denied, etc.)
    if (error) {
      res.writeHead(302, { 'Location': '/?discord_error=' + encodeURIComponent(error) });
      res.end();
      return;
    }
    
    if (!code || !state) {
      res.writeHead(400, { 'Content-Type': 'text/html' });
      res.end('<html><body><h1>Error</h1><p>Missing authorization code or state</p><a href="/">Back to AgentFolio</a></body></html>');
      return;
    }
    
    handleDiscordCallback(code, state)
      .then(result => {
        if (result.verified) {
          // Update the profile with Discord verification
          const profile = loadProfile(result.profileId);
          if (profile) {
            const updatedProfile = { ...profile };
            updatedProfile.links = updatedProfile.links || {};
            updatedProfile.links.discord = formatDiscordUsername(result.discordUser.username, result.discordUser.discriminator);
            updatedProfile.verificationData = updatedProfile.verificationData || {};
            updatedProfile.verificationData.discord = {
              id: result.discordUser.id,
              username: result.discordUser.username,
              discriminator: result.discordUser.discriminator,
              globalName: result.discordUser.globalName,
              avatar: result.discordUser.avatar,
              avatarUrl: getDiscordAvatarUrl(result.discordUser.id, result.discordUser.avatar),
              verified: true,
              verifiedAt: new Date().toISOString()
            };
            updatedProfile.updatedAt = new Date().toISOString();
            dbSaveProfileFn(updatedProfile);
            
            // Log activity
            addActivityAndBroadcast(result.profileId, 'verification_discord', {
              username: result.discordUser.username
            }, DATA_DIR);
            
            // Trigger webhooks
            triggerWebhooks(WEBHOOK_EVENTS.VERIFICATION_COMPLETE || 'verification_complete', {
              agentId: result.profileId,
              platform: 'discord',
              username: result.discordUser.username,
              profileUrl: `https://agentfolio.bot/profile/${result.profileId}`
            }).catch(e => logger.error('Webhook error', { error: e.message }));
            
            // Post on-chain memo attestation
            postVerificationMemo(result.profileId, 'discord', { username: result.discordUser.username, id: result.discordUser.id }).then(memoResult => {
              if (memoResult) {
                updatedProfile.verificationData.discord.memoTx = memoResult.signature;
                updatedProfile.verificationData.discord.explorerUrl = memoResult.explorerUrl;
                dbSaveProfileFn(updatedProfile);
              }
            }).catch(() => {});
            // Post on-chain verification via Identity Registry
            postVerificationOnchainForProfile(updatedProfile, 'discord', { username: result.discordUser.username });
          }
          
          // Redirect to profile page with success message
          res.writeHead(302, { 'Location': `/profile/${result.profileId}?discord_verified=1` });
          res.end();
        } else {
          // Redirect with error
          res.writeHead(302, { 'Location': '/?discord_error=' + encodeURIComponent(result.error || 'Verification failed') });
          res.end();
        }
      })
      .catch(err => {
        console.error('[Discord Callback] Error:', err);
        res.writeHead(302, { 'Location': '/?discord_error=' + encodeURIComponent(err.message) });
        res.end();
      });
    return;
  }
  
  // Check Discord verification status for a profile
  else if (url.pathname === '/api/verify/discord/profile') {
    const profileId = url.searchParams.get('profileId');
    if (!profileId) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'profileId query param required' }));
      return;
    }
    
    const verified = getDiscordVerificationStatus(profileId);
    const pending = getPendingDiscordVerification(profileId);
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      profileId,
      verified: verified !== null,
      verificationData: verified,
      pendingVerification: pending
    }));
    return;
  }
  
  // Profile-specific Discord verification
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/verify\/discord$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const { action } = data;
        
        if (action === 'start') {
          const result = startDiscordVerification(profileId);
          res.writeHead(result.success || result.alreadyVerified || result.notConfigured ? 200 : 400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else if (action === 'status') {
          const verified = getDiscordVerificationStatus(profileId);
          const pending = getPendingDiscordVerification(profileId);
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({
            profileId,
            verified: verified !== null,
            verificationData: verified,
            pendingVerification: pending
          }));
        } else if (action === 'remove') {
          const result = removeDiscordVerification(profileId);
          if (result.success) {
            // Also update profile
            const updatedProfile = { ...profile };
            if (updatedProfile.links) delete updatedProfile.links.discord;
            if (updatedProfile.verificationData) delete updatedProfile.verificationData.discord;
            updatedProfile.updatedAt = new Date().toISOString();
            dbSaveProfileFn(updatedProfile);
          }
          res.writeHead(result.success ? 200 : 400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'action must be "start", "status", or "remove"' }));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  
  // Admin: Get all verified Discord accounts
  else if (url.pathname === '/api/verify/discord/all') {
    const verified = getAllDiscordVerified();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      count: Object.keys(verified).length,
      verifications: verified
    }));
    return;
  }
  
  // ============================================
  // END DISCORD VERIFICATION ENDPOINTS
  // ============================================
  
  // Polymarket verification - get stats for address
  else if (url.pathname === '/api/verify/polymarket/stats' || url.pathname === '/api/verify/polymarket/initiate') {
    const address = url.searchParams.get('address');
    if (!address) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'address query param required' }));
      return;
    }
    
    getPolymarketStats(address)
      .then(stats => {
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(stats, null, 2));
      })
      .catch(err => {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: err.message }));
      });
    return;
  }
  // Polymarket verification - get challenge message
  else if (url.pathname === '/api/verify/polymarket/challenge') {
    const profileId = url.searchParams.get('profileId');
    if (!profileId) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'profileId query param required' }));
      return;
    }
    
    const challenge = generateVerificationMessage(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(challenge));
    return;
  }
  // Polymarket verification - verify with signature
  else if (url.pathname === '/api/verify/polymarket' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const { profileId, address, signature, message } = data;
        
        if (!profileId || !address || !signature || !message) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'profileId, address, signature, and message required' }));
          return;
        }
        
        const profile = loadProfile(profileId, DATA_DIR);
        if (!profile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Profile not found' }));
          return;
        }
        
        verifyPolymarketTrading(profileId, address, signature, message)
          .then(result => {
            if (result.verified) {
              // Update profile with verified Polymarket stats
              profile.wallets = profile.wallets || {};
              profile.wallets.polymarket = address;
              profile.verificationData = profile.verificationData || {};
              profile.verificationData.polymarket = {
                address,
                stats: result.stats,
                verified: true,
                verifiedAt: result.verifiedAt
              };
              profile.updatedAt = new Date().toISOString();
              dbSaveProfileFn(profile);
              
              // Log activity
              addActivity(profileId, 'verification_polymarket', {
                address: address.slice(0, 6) + '...' + address.slice(-4),
                winRate: result.stats.winRate,
                pnl: result.stats.realizedPnL
              }, DATA_DIR);
            }
            
            res.writeHead(result.verified ? 200 : 400, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify(result, null, 2));
          })
          .catch(err => {
            res.writeHead(500, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ error: err.message }));
          });
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
    return;
  }
  // Kalshi verification - verify with credentials (credentials not stored)
  else if (url.pathname === '/api/verify/kalshi' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const { profileId, email, password, demo } = data;
        
        if (!profileId || !email || !password) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'profileId, email, and password required' }));
          return;
        }
        
        const profile = loadProfile(profileId, DATA_DIR);
        if (!profile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Profile not found' }));
          return;
        }
        
        verifyKalshiTrading(email, password, demo || false)
          .then(result => {
            if (result.verified) {
              // Update profile with verified Kalshi stats (don't store credentials!)
              profile.verificationData = profile.verificationData || {};
              profile.verificationData.kalshi = {
                memberId: result.memberId,
                stats: result.stats,
                balance: result.balance,
                verified: true,
                verifiedAt: result.verifiedAt,
                isDemo: result.isDemo
              };
              profile.updatedAt = new Date().toISOString();
              dbSaveProfileFn(profile);
              
              // Log activity
              addActivity(profileId, 'verification_kalshi', {
                winRate: result.stats.winRate,
                trades: result.stats.totalTrades
              }, DATA_DIR);
            }
            
            // Don't return member ID for privacy
            const safeResult = {
              verified: result.verified,
              stats: result.stats,
              error: result.error
            };
            
            res.writeHead(result.verified ? 200 : 400, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify(safeResult, null, 2));
          })
          .catch(err => {
            res.writeHead(500, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ error: err.message }));
          });
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
    return;
  }
  // ── Moltbook Verification ──
  else if (url.pathname === "/api/verify/moltbook/challenge" && req.method === "GET") {
    const profileId = url.searchParams.get('profileId');
    if (!profileId) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'profileId required' }));
      return;
    }
    const challengeString = getMoltbookChallengeString(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ challengeString, instructions: `Add "${challengeString}" to your Moltbook bio, then verify.` }));
    return;
  }
  else if ((url.pathname === '/api/verify/moltbook' || url.pathname === '/api/verify/moltbook/initiate') && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        const { profileId, moltbookUsername } = data;
        if (!profileId || !moltbookUsername) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'profileId and moltbookUsername required' }));
          return;
        }
        const profile = loadProfile(profileId, DATA_DIR);
        if (!profile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Profile not found' }));
          return;
        }
        const result = await verifyMoltbookAccount(profileId, moltbookUsername);
        if (result.verified) {
          profile.verificationData = profile.verificationData || {};
          profile.verificationData.moltbook = {
            verified: true,
            username: moltbookUsername,
            karma: result.karma || 0,
            verifiedAt: new Date().toISOString()
          };
          profile.links = profile.links || {};
          profile.links.moltbook = moltbookUsername;
          profile.updatedAt = new Date().toISOString();
          dbSaveProfileFn(profile);
          addActivityAndBroadcast(profileId, 'verification_moltbook', {
            username: moltbookUsername, karma: result.karma || 0
          }, DATA_DIR);
          postVerificationMemo(profileId, 'moltbook', { username: moltbookUsername, karma: result.karma }).catch(() => {});
          postVerificationOnchainForProfile(profile, 'moltbook', { username: moltbookUsername });
        }
        res.writeHead(result.verified ? 200 : 400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result, null, 2));
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  // ── MCP Endpoint Verification ──
  else if ((url.pathname === '/api/verify/mcp' || url.pathname === '/api/verify/mcp/initiate') && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        const { profileId, mcpUrl } = data;
        if (!profileId || !mcpUrl) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'profileId and mcpUrl required' }));
          return;
        }
        const profile = loadProfile(profileId, DATA_DIR);
        if (!profile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Profile not found' }));
          return;
        }
        const result = await verifyMcpEndpoint(mcpUrl, profileId);
        if (result.verified) {
          profile.verificationData = profile.verificationData || {};
          profile.verificationData.mcp = {
            verified: true,
            url: mcpUrl,
            method: result.method,
            toolCount: result.toolCount || 0,
            verifiedAt: new Date().toISOString()
          };
          profile.updatedAt = new Date().toISOString();
          dbSaveProfileFn(profile);
          addActivityAndBroadcast(profileId, 'verification_mcp', {
            url: mcpUrl, method: result.method, tools: result.toolCount || 0
          }, DATA_DIR);
          postVerificationMemo(profileId, 'mcp', { url: mcpUrl }).catch(() => {});
          postVerificationOnchainForProfile(profile, 'mcp', { url: mcpUrl });
        }
        res.writeHead(result.verified ? 200 : 400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result, null, 2));
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  // ── A2A Agent Card Verification ──
  else if ((url.pathname === '/api/verify/a2a' || url.pathname === '/api/verify/a2a/initiate') && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        const { profileId, agentUrl } = data;
        if (!profileId || !agentUrl) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'profileId and agentUrl required' }));
          return;
        }
        const profile = loadProfile(profileId, DATA_DIR);
        if (!profile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Profile not found' }));
          return;
        }
        const result = await verifyA2aAgentCard(agentUrl, profileId);
        if (result.verified) {
          profile.verificationData = profile.verificationData || {};
          profile.verificationData.a2a = {
            verified: true,
            url: agentUrl,
            agentName: result.agentName,
            verifiedAt: new Date().toISOString()
          };
          profile.updatedAt = new Date().toISOString();
          dbSaveProfileFn(profile);
          addActivityAndBroadcast(profileId, 'verification_a2a', {
            url: agentUrl, agentName: result.agentName
          }, DATA_DIR);
          postVerificationMemo(profileId, 'a2a', { url: agentUrl }).catch(() => {});
          postVerificationOnchainForProfile(profile, 'a2a', { url: agentUrl });
        }
        res.writeHead(result.verified ? 200 : 400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result, null, 2));
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  // ── Website .well-known Verification ──
  else if ((url.pathname === '/api/verify/website/challenge' || url.pathname === '/api/verify/website/initiate') && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const { profileId, websiteUrl } = data;
        if (!profileId || !websiteUrl) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'profileId and websiteUrl required' }));
          return;
        }
        const profile = loadProfile(profileId, DATA_DIR);
        if (!profile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Profile not found' }));
          return;
        }
        const challenge = generateWebsiteChallenge(profileId, websiteUrl);
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(challenge));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
    return;
  }
  else if ((url.pathname === '/api/verify/website/confirm' || url.pathname === '/api/verify/website/verify') && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        const { challengeId } = data;
        if (!challengeId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'challengeId required' }));
          return;
        }
        const result = await confirmWebsiteVerification(challengeId);
        if (result.verified) {
          const profile = loadProfile(result.profileId, DATA_DIR);
          if (profile) {
            profile.verificationData = profile.verificationData || {};
            profile.verificationData.website = {
              verified: true,
              url: result.websiteUrl,
              verifiedAt: new Date().toISOString()
            };
            profile.links = profile.links || {};
            profile.links.website = result.websiteUrl;
            profile.updatedAt = new Date().toISOString();
            dbSaveProfileFn(profile);
            addActivityAndBroadcast(result.profileId, 'verification_website', {
              url: result.websiteUrl
            }, DATA_DIR);
            postVerificationMemo(result.profileId, 'website', { url: result.websiteUrl }).catch(() => {});
            postVerificationOnchainForProfile(profile, 'website', { url: result.websiteUrl });
          }
        }
        res.writeHead(result.verified ? 200 : 400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result, null, 2));
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/endorsements$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const result = getEndorsements(profileId, DATA_DIR);
    if (result.error) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: result.error }));
    } else {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result, null, 2));
    }
  }
  // Similar agents endpoint
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/similar$/)) {
    const profileId = url.pathname.split('/')[3];
    const limit = Math.min(parseInt(url.searchParams.get('limit')) || 10, 50);
    const similar = findSimilarAgents(profileId, DATA_DIR);
    
    if (similar.length === 0) {
      const profile = loadProfile(profileId, DATA_DIR);
      if (!profile) {
        res.writeHead(404, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Profile not found' }));
        return;
      }
    }
    
    const targetProfile = loadProfile(profileId, DATA_DIR);
    const targetSkillNames = targetProfile ? targetProfile.skills.map(s => s.name.toLowerCase()) : [];
    
    const results = similar.slice(0, limit).map(s => ({
      id: s.profile.id,
      name: s.profile.name,
      handle: s.profile.handle,
      bio: s.profile.bio,
      skillsOverlap: s.overlap,
      similarity: Math.round(s.similarity * 100),
      sharedSkills: s.profile.skills
        .filter(skill => targetSkillNames.includes(skill.name.toLowerCase()))
        .map(sk => sk.name)
    }));
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ 
      profileId, 
      count: results.length, 
      similar: results 
    }, null, 2));
  }
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/endorse$/) && req.method === 'POST') {
    // SECURITY: Require API key for endorsements
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    
    const toId = url.pathname.split('/')[3];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        if (!data.fromId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'fromId required (endorser profile id)' }));
          return;
        }
        
        // Verify API key belongs to the endorser
        if (data.fromId.startsWith('agent_')) {
          const keyInfo = requestKey ? validateApiKey(requestKey) : null;
          if (!keyInfo || keyInfo.profileId !== data.fromId) {
            res.writeHead(403, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ error: 'API key required for endorsements. Key must belong to the endorser profile.' }));
            return;
          }
        }
        
        const result = addEndorsement(data.fromId, toId, data, DATA_DIR);
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
        } else {
          // Trigger global webhook for endorsement
          const fromProfile = loadProfile(data.fromId, DATA_DIR);
          const toProfile = loadProfile(toId, DATA_DIR);
          triggerWebhooks(WEBHOOK_EVENTS.ENDORSEMENT_ADDED, {
            endorsedAgentId: toId,
            endorsedAgentName: toProfile?.name,
            endorserAgentId: data.fromId,
            endorserAgentName: fromProfile?.name,
            skill: data.skill || null,
            rating: data.rating || 5,
            message: data.message || null,
            profileUrl: `https://agentfolio.bot/profile/${toId}`
          }).catch(e => logger.error('Webhook error', { error: e.message }));
          
          // Trigger per-agent webhook notification to the endorsee
          if (fromProfile) {
            notifyEndorsementWebhook(toId, fromProfile, {
              skill: data.skill,
              comment: data.message
            }).catch(e => logger.error('Agent webhook error', { error: e.message }));
          }
          
          res.writeHead(201, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result, null, 2));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/unendorse$/) && req.method === 'POST') {
    const toId = url.pathname.split('/')[3];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        if (!data.fromId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'fromId required' }));
          return;
        }
        const result = removeEndorsement(data.fromId, toId, DATA_DIR);
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
        } else {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result, null, 2));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  // Collaboration endpoints
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/collaborations$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const result = getCollaborations(profileId, DATA_DIR);
    if (result.error) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: result.error }));
    } else {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result, null, 2));
    }
  }
  else if (url.pathname === '/api/collaborations' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const result = addCollaboration(data, DATA_DIR);
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
        } else {
          res.writeHead(201, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result, null, 2));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  else if (url.pathname.match(/^\/api\/collaborations\/([^/]+)\/confirm$/) && req.method === 'POST') {
    const collabId = url.pathname.split('/')[3];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        if (!data.collaboratorId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'collaboratorId required' }));
          return;
        }
        const result = confirmCollaboration(data.collaboratorId, collabId, DATA_DIR);
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
        } else {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result, null, 2));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  else if (url.pathname === '/api/leaderboard') {
    const profiles = listProfiles(DATA_DIR);
    const withReputation = profiles.map(p => ({
      id: p.id,
      name: p.name,
      handle: p.handle,
      ...calculateReputation(p)
    })).sort((a, b) => b.score - a.score);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ count: withReputation.length, leaderboard: withReputation }, null, 2));
  }
  // Trading leaderboard - agents ranked by verified trading performance
  else if (url.pathname === '/api/leaderboard/trading') {
    const sortBy = url.searchParams.get('sort') || 'pnl';
    const platform = url.searchParams.get('platform');
    const limit = Math.min(parseInt(url.searchParams.get('limit')) || 50, 100);
    
    const { caches } = require('./lib/cache');
    const cacheKey = `leaderboard:${platform||'all'}:${sortBy}:${limit}`;
    let leaderboard = caches.leaderboard.wrapSync(cacheKey, 300, () => {
      if (platform) {
        return getPlatformLeaderboard(DATA_DIR, platform, sortBy, limit);
      } else {
        return getTradingLeaderboard(DATA_DIR, sortBy, limit);
      }
    });
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ 
      count: leaderboard.length,
      sortBy,
      platform: platform || 'all',
      leaderboard 
    }, null, 2));
  }
  // Verified Performance History (on-chain proof)
  else if (url.pathname.match(/^\/api\/profile\/[^/]+\/performance$/)) {
    const profileId = url.pathname.split('/')[3];
    const refresh = url.searchParams.get('refresh') === 'true';
    const page = parseInt(url.searchParams.get('page')) || 1;
    const limit = Math.min(parseInt(url.searchParams.get('limit')) || 50, 200);
    const platform = url.searchParams.get('platform');
    getPerformanceHistory(profileId, DATA_DIR, refresh).then(history => {
      let trades = history.trades.map(formatTrade);
      if (platform) trades = trades.filter(t => t.platform === platform);
      const total = trades.length;
      const paginated = trades.slice((page - 1) * limit, page * limit);
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({
        profileId: history.profileId, profileName: history.profileName,
        generatedAt: history.generatedAt, proofHash: history.proofHash,
        platforms: history.platforms, summary: history.summary,
        trades: paginated,
        pagination: { page, limit, total, pages: Math.ceil(total / limit) }
      }, null, 2));
    }).catch(err => {
      res.writeHead(err.message === 'Profile not found' ? 404 : 500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: err.message }));
    });
  }
  // Performance summary (lightweight, no trades)
  else if (url.pathname.match(/^\/api\/profile\/[^/]+\/performance\/summary$/)) {
    const profileId = url.pathname.split('/')[3];
    getPerformanceSummary(profileId, DATA_DIR).then(summary => {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(summary, null, 2));
    }).catch(err => {
      res.writeHead(err.message === 'Profile not found' ? 404 : 500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: err.message }));
    });
  }
  // Verify proof hash
  else if (url.pathname.match(/^\/api\/profile\/[^/]+\/performance\/verify$/)) {
    const profileId = url.pathname.split('/')[3];
    const hash = url.searchParams.get('hash');
    if (!hash) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'hash parameter required' }));
    } else {
      verifyProofHash(profileId, hash, DATA_DIR).then(result => {
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result, null, 2));
      }).catch(err => {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: err.message }));
      });
    }
  }
  // Verified performance ranking
  else if (url.pathname === '/api/performance/ranking') {
    const sortBy = url.searchParams.get('sort') || 'volume';
    getVerifiedPerformanceRanking(DATA_DIR, sortBy).then(ranking => {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ count: ranking.length, sortBy, ranking }, null, 2));
    }).catch(err => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: err.message }));
    });
  }
  // Compare two agents API
  else if (url.pathname === '/api/compare') {
    const id1 = url.searchParams.get('id1') || url.searchParams.get('agent1');
    const id2 = url.searchParams.get('id2') || url.searchParams.get('agent2');
    
    if (!id1 || !id2) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Both id1 and id2 are required' }));
      return;
    }
    
    const profile1 = loadProfile(id1, DATA_DIR);
    const profile2 = loadProfile(id2, DATA_DIR);
    
    if (!profile1 || !profile2) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'One or both agents not found' }));
      return;
    }
    
    const allProfiles = listProfiles(DATA_DIR);
    const rep1 = calculateReputation(profile1);
    const rep2 = calculateReputation(profile2);
    
    // Skill analysis
    const skills1 = new Set(profile1.skills.map(s => s.name.toLowerCase()));
    const skills2 = new Set(profile2.skills.map(s => s.name.toLowerCase()));
    const overlapping = [...skills1].filter(s => skills2.has(s));
    const unique1 = [...skills1].filter(s => !skills2.has(s));
    const unique2 = [...skills2].filter(s => !skills1.has(s));
    const allSkills = new Set([...skills1, ...skills2]);
    const similarity = allSkills.size > 0 ? Math.round((overlapping.length / allSkills.size) * 100) : 0;
    
    // Badges
    const badges1 = calculateBadges(profile1, allProfiles, DATA_DIR);
    const badges2 = calculateBadges(profile2, allProfiles, DATA_DIR);
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      similarity: {
        percentage: similarity,
        sharedSkills: overlapping,
        uniqueToAgent1: unique1,
        uniqueToAgent2: unique2
      },
      agent1: {
        id: profile1.id,
        name: profile1.name,
        handle: profile1.handle,
        reputation: rep1,
        skills: profile1.skills.length,
        verifiedSkills: profile1.skills.filter(s => s.verified).length,
        projects: profile1.portfolio.length,
        badges: badges1.length
      },
      agent2: {
        id: profile2.id,
        name: profile2.name,
        handle: profile2.handle,
        reputation: rep2,
        skills: profile2.skills.length,
        verifiedSkills: profile2.skills.filter(s => s.verified).length,
        projects: profile2.portfolio.length,
        badges: badges2.length
      },
      compareUrl: `https://agentfolio.bot/compare/${profile1.id}/${profile2.id}`
    }, null, 2));
  }
  // Trending agents
  else if (url.pathname === '/api/trending') {
    const limit = parseInt(url.searchParams.get('limit')) || 10;
    const hours = parseInt(url.searchParams.get('hours')) || 24;
    const profiles = listProfiles(DATA_DIR);
    const trending = getTrendingAgents(profiles, limit, hours);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ 
      count: trending.length, 
      timeWindowHours: hours,
      trending: trending.map(p => ({
        id: p.id,
        name: p.name,
        handle: p.handle,
        bio: p.bio,
        avatar: p.avatar,
        tier: p.verification?.tier,
        trendingScore: p.trendingScore
      }))
    }, null, 2));
  }
  // Rising agents (new + promising)
  else if (url.pathname === '/api/rising') {
    const limit = parseInt(url.searchParams.get('limit')) || 10;
    const days = parseInt(url.searchParams.get('days')) || 7;
    const profiles = listProfiles(DATA_DIR);
    const rising = getRisingAgents(profiles, limit, days);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ 
      count: rising.length,
      maxAgeDays: days, 
      rising: rising.map(p => ({
        id: p.id,
        name: p.name,
        handle: p.handle,
        bio: p.bio,
        avatar: p.avatar,
        tier: p.verification?.tier,
        createdAt: p.createdAt,
        risingScore: p.risingScore
      }))
    }, null, 2));
  }
  // Endorsement endpoints
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/endorsements$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const endorsements = getEndorsements(profileId, DATA_DIR);
    if (endorsements.error) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: endorsements.error }));
    } else {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ 
        profileId, 
        count: endorsements.length, 
        score: calculateEndorsementScore(endorsements),
        endorsements 
      }, null, 2));
    }
  }
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/endorse$/) && req.method === 'POST') {
    // SECURITY: Require API key for endorsements
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    
    const toId = url.pathname.split('/')[3];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        if (!data.fromId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'fromId is required' }));
          return;
        }
        
        // Verify API key belongs to the endorser
        if (data.fromId.startsWith('agent_')) {
          const keyInfo = requestKey ? validateApiKey(requestKey) : null;
          if (!keyInfo || keyInfo.profileId !== data.fromId) {
            res.writeHead(403, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ error: 'API key required for endorsements. Key must belong to the endorser profile.' }));
            return;
          }
        }
        
        const result = addEndorsement(data.fromId, toId, {
          skill: data.skill,
          message: data.message,
          rating: data.rating
        }, DATA_DIR);
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
        } else {
          res.writeHead(201, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result, null, 2));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/endorse$/) && req.method === 'DELETE') {
    const toId = url.pathname.split('/')[3];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        if (!data.fromId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'fromId is required' }));
          return;
        }
        const result = removeEndorsement(data.fromId, toId, DATA_DIR);
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
        } else {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  // Activity feed endpoints
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/activity$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const limit = parseInt(url.searchParams.get('limit')) || 10;
    const activities = getActivities(profileId, DATA_DIR, limit);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ profileId, count: activities.length, activities }, null, 2));
  }
  else if (url.pathname === '/api/activity/feed') {
    const limit = parseInt(url.searchParams.get('limit')) || 20;
    const feed = getGlobalFeed(DATA_DIR, limit);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ count: feed.length, feed }, null, 2));
  }
  // Badges endpoints
  else if (url.pathname === '/api/badges') {
    const badges = getAllBadges();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ count: badges.length, badges }, null, 2));
  }
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/badges$/)) {
    const profileId = url.pathname.split('/')[3];
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    const allProfiles = listProfiles(DATA_DIR);
    const badges = calculateBadges(profile, allProfiles, DATA_DIR);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ profileId, count: badges.length, badges }, null, 2));
  }
  // Analytics endpoints
  else if (url.pathname === '/api/analytics') {
    trackApiCall('/api/analytics');
    const analytics = getGlobalAnalytics();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(analytics, null, 2));
  }
  else if (url.pathname === '/api/analytics/views') {
    trackApiCall('/api/analytics/views');
    const limit = parseInt(url.searchParams.get('limit')) || 10;
    const leaderboard = getViewsLeaderboard(limit);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ count: leaderboard.length, leaderboard }, null, 2));
  }
  // WebSocket stats
  else if (url.pathname === '/api/ws/stats') {
    trackApiCall('/api/ws/stats');
    const stats = getWsStats();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(stats, null, 2));
  }
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/analytics$/)) {
    const profileId = url.pathname.split('/')[3];
    trackApiCall('/api/profile/:id/analytics');
    const analytics = getProfileAnalytics(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ profileId, ...analytics }, null, 2));
  }
  
  // ============ JOB RECOMMENDATIONS ROUTES ============
  
  // Get job recommendations for an agent
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/job-recommendations$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    trackApiCall('/api/profile/:id/job-recommendations');
    
    const limit = parseInt(url.searchParams.get('limit')) || 10;
    const minScore = parseInt(url.searchParams.get('minScore')) || 20;
    
    getJobRecommendations(profileId, { limit, minScore }).then(recommendations => {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(recommendations, null, 2));
    }).catch(err => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: err.message }));
    });
    return;
  }
  
  // Get job match overview for dashboard
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/job-match-overview$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    trackApiCall('/api/profile/:id/job-match-overview');
    
    getMatchOverview(profileId).then(overview => {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(overview, null, 2));
    }).catch(err => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: err.message }));
    });
    return;
  }
  
  // Get agent recommendations for a job (for clients)
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/agent-recommendations$/) && req.method === 'GET') {
    const jobId = url.pathname.split('/')[4];
    trackApiCall('/api/marketplace/job/:id/agent-recommendations');
    
    const limit = parseInt(url.searchParams.get('limit')) || 10;
    const minScore = parseInt(url.searchParams.get('minScore')) || 20;
    
    getAgentRecommendationsForJob(jobId, { limit, minScore }).then(recommendations => {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(recommendations, null, 2));
    }).catch(err => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: err.message }));
    });
    return;
  }
  
  // Dismiss onboarding endpoint
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/dismiss-onboarding$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    trackApiCall('/api/profile/:id/dismiss-onboarding');
    
    // Load profile
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    
    // Update verificationData to store onboarding dismissed flag
    profile.verificationData = profile.verificationData || {};
    profile.verificationData.onboardingDismissed = {
      dismissed: true,
      dismissedAt: new Date().toISOString()
    };
    profile.updatedAt = new Date().toISOString();
    
    // Save profile using the database module
    const { saveProfile } = require('./lib/database');
    saveProfile(profile);
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ success: true, message: 'Onboarding dismissed' }));
    return;
  }
  // ============ NOTIFICATION ROUTES ============
  
  // Get notification preferences
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/notifications$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const prefs = getNotificationPreferences(profileId);
    if (!prefs) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(prefs));
  }
  
  // Update notification preferences
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/notifications$/) && req.method === 'PUT') {
    const profileId = url.pathname.split('/')[3];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const result = updateNotificationPreferences(profileId, data);
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  
  // Unsubscribe from notifications (GET for email link compatibility)
  else if (url.pathname === '/notifications/unsubscribe') {
    const profileId = url.searchParams.get('profile');
    const token = url.searchParams.get('token');
    
    if (!profileId || !token) {
      res.writeHead(400, { 'Content-Type': 'text/html' });
      res.end(generateUnsubscribePage({ error: 'Missing profile or token parameter' }));
      return;
    }
    
    const result = unsubscribeAll(profileId, token);
    res.writeHead(result.error ? 400 : 200, { 'Content-Type': 'text/html' });
    res.end(generateUnsubscribePage(result));
    return;
  }
  
  // ============ AGENT WEBHOOK ROUTES ============
  
  // Get webhook config for a profile
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/webhook$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    trackApiCall('/api/profile/:id/webhook');
    
    const config = getWebhookConfig(profileId);
    if (!config) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    
    // Don't expose the full secret in GET
    const safeConfig = {
      enabled: config.enabled,
      url: config.url,
      secret: config.secret ? config.secret.slice(0, 12) + '...' : null,
      events: config.events,
      lastDelivery: config.lastDelivery,
      deliveryCount: config.deliveryCount,
      failureCount: config.failureCount
    };
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(safeConfig));
  }
  
  // Set webhook URL for a profile
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/webhook$/) && req.method === 'PUT') {
    const profileId = url.pathname.split('/')[3];
    trackApiCall('/api/profile/:id/webhook');
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const result = setWebhookUrl(profileId, data.url, { events: data.events });
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  
  // Disable webhook for a profile
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/webhook$/) && req.method === 'DELETE') {
    const profileId = url.pathname.split('/')[3];
    trackApiCall('/api/profile/:id/webhook');
    
    const result = disableWebhook(profileId);
    
    if (result.error) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result));
    } else {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result));
    }
  }
  
  // Test webhook for a profile
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/webhook\/test$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    trackApiCall('/api/profile/:id/webhook/test');
    
    testAgentWebhook(profileId).then(result => {
      if (result.error) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } else {
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      }
    });
    return;
  }
  
  // Get webhook delivery logs for a profile
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/webhook\/logs$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const limit = parseInt(url.searchParams.get('limit') || '20');
    trackApiCall('/api/profile/:id/webhook/logs');
    
    const logs = getAgentWebhookLogs(profileId, limit);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ logs }));
  }
  
  // Get available webhook events
  else if (url.pathname === '/api/webhook/events' && req.method === 'GET') {
    trackApiCall('/api/webhook/events');
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ events: Object.values(AGENT_WEBHOOK_EVENTS) }));
  }
  
  // Report profile endpoint
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/report$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    trackApiCall('/api/profile/:id/report');
    
    // Check if profile exists
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const reporterIp = req.headers['x-forwarded-for']?.split(',')[0] || req.socket.remoteAddress;
        
        const result = submitReport(profileId, {
          reason: data.reason,
          details: data.details,
          reporterId: data.reporterId || null,
          reporterIp
        });
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
        } else {
          res.writeHead(201, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ success: true, reportId: result.reportId }));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  // Admin reports list
  else if (url.pathname === '/api/admin/reports' && req.method === 'GET') {
    trackApiCall('/api/admin/reports');
    const status = url.searchParams.get('status');
    const profileId = url.searchParams.get('profileId');
    const limit = parseInt(url.searchParams.get('limit') || '50');
    const offset = parseInt(url.searchParams.get('offset') || '0');
    
    const reports = getReports({ status, profileId, limit, offset });
    const stats = getReportStats();
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ ...reports, stats }, null, 2));
  }
  // Update report status (admin)
  else if (url.pathname.match(/^\/api\/admin\/reports\/([^/]+)$/) && req.method === 'PATCH') {
    const reportId = url.pathname.split('/')[4];
    trackApiCall('/api/admin/reports/:id');
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const result = updateReportStatus(reportId, {
          status: data.status,
          adminNotes: data.adminNotes,
          reviewedBy: data.reviewedBy || 'admin'
        });
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
        } else {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  // Admin reports page
  else if (url.pathname === '/admin/reports') {
    const status = url.searchParams.get('status');
    const reports = getReports({ status, limit: 100 });
    const stats = getReportStats();
    const allProfiles = listProfiles(DATA_DIR);
    
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateAdminReportsPage(reports, stats, allProfiles));
  }
  // ===== BUG REPORTS ROUTES =====
  // Submit a bug report
  else if (url.pathname === '/api/bugs' && req.method === 'POST') {
    trackApiCall('/api/bugs');
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const clientIp = req.headers['x-forwarded-for']?.split(',')[0] || req.socket.remoteAddress;
        
        const result = submitBugReport({
          title: data.title,
          description: data.description,
          category: data.category,
          severity: data.severity || 'medium',
          pageUrl: data.pageUrl,
          browserInfo: data.browserInfo,
          steps: data.steps,
          expectedBehavior: data.expectedBehavior,
          actualBehavior: data.actualBehavior,
          reporterId: data.reporterId,
          reporterEmail: data.reporterEmail,
          reporterIp: clientIp
        });
        
        res.writeHead(result.error ? 400 : 200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid request body' }));
      }
    });
    return;
  }
  // Get bug report categories and severity (for UI)
  else if (url.pathname === '/api/bugs/options' && req.method === 'GET') {
    trackApiCall('/api/bugs/options');
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      categories: CATEGORY_LABELS,
      severities: SEVERITY_LABELS,
      statuses: STATUS_LABELS
    }));
  }
  // List bug reports (admin)
  else if (url.pathname === '/api/admin/bugs' && req.method === 'GET') {
    trackApiCall('/api/admin/bugs');
    const category = url.searchParams.get('category');
    const severity = url.searchParams.get('severity');
    const status = url.searchParams.get('status');
    const limit = parseInt(url.searchParams.get('limit') || '50');
    const offset = parseInt(url.searchParams.get('offset') || '0');
    
    const reports = getBugReports({ category, severity, status, limit, offset });
    const stats = getBugReportStats();
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ ...reports, stats }, null, 2));
  }
  // Get single bug report (admin)
  else if (url.pathname.match(/^\/api\/admin\/bugs\/([^/]+)$/) && req.method === 'GET') {
    const reportId = url.pathname.split('/')[4];
    trackApiCall('/api/admin/bugs/:id');
    
    const report = getBugReport(reportId);
    if (!report) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Bug report not found' }));
      return;
    }
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(report));
  }
  // Update bug report (admin)
  else if (url.pathname.match(/^\/api\/admin\/bugs\/([^/]+)$/) && req.method === 'PATCH') {
    const reportId = url.pathname.split('/')[4];
    trackApiCall('/api/admin/bugs/:id');
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const result = updateBugReport(reportId, {
          status: data.status,
          severity: data.severity,
          adminNotes: data.adminNotes,
          assignedTo: data.assignedTo,
          duplicateOf: data.duplicateOf,
          fixedInVersion: data.fixedInVersion,
          category: data.category
        });
        
        res.writeHead(result.error ? 400 : 200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid request body' }));
      }
    });
    return;
  }
  // Admin bug reports page
  else if (url.pathname === '/admin/bugs') {
    const status = url.searchParams.get('status');
    const category = url.searchParams.get('category');
    const severity = url.searchParams.get('severity');
    const reports = getBugReports({ status, category, severity, limit: 100 });
    const stats = getBugReportStats();
    
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateAdminBugReportsPage(reports, stats));
  }
  // ===== SPAM DETECTION ADMIN ROUTES =====
  // Spam flags list
  else if (url.pathname === '/api/admin/spam' && req.method === 'GET') {
    trackApiCall('/api/admin/spam');
    const status = url.searchParams.get('status');
    const limit = parseInt(url.searchParams.get('limit') || '50');
    const offset = parseInt(url.searchParams.get('offset') || '0');
    
    const flags = getFlaggedProfiles({ status, limit, offset });
    const stats = getSpamStats();
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ ...flags, stats }, null, 2));
  }
  // Scan all profiles for spam
  else if (url.pathname === '/api/admin/spam/scan' && req.method === 'POST') {
    trackApiCall('/api/admin/spam/scan');
    const allProfiles = listProfiles(DATA_DIR);
    const results = scanAllProfiles(allProfiles);
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(results, null, 2));
  }
  // Update flag status (admin)
  else if (url.pathname.match(/^\/api\/admin\/spam\/([^/]+)$/) && req.method === 'PATCH') {
    const flagId = url.pathname.split('/')[4];
    trackApiCall('/api/admin/spam/:id');
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const result = updateFlagStatus(flagId, {
          status: data.status,
          adminNotes: data.adminNotes,
          reviewedBy: data.reviewedBy || 'admin'
        });
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
        } else {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  // Admin spam flags page
  else if (url.pathname === '/admin/spam') {
    const status = url.searchParams.get('status');
    const flags = getFlaggedProfiles({ status, limit: 100 });
    const stats = getSpamStats();
    const allProfiles = listProfiles(DATA_DIR);
    
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateAdminSpamPage(flags, stats, allProfiles));
  }
  // ===== END SPAM DETECTION ROUTES =====
  
  // ===== ONBOARDING EMAIL ROUTES =====
  // Get onboarding stats
  else if (url.pathname === '/api/admin/onboarding' && req.method === 'GET') {
    trackApiCall('/api/admin/onboarding');
    const stats = getOnboardingStats();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(stats));
  }
  
  // Manually trigger follow-up scan
  else if (url.pathname === '/api/admin/onboarding/scan' && req.method === 'POST') {
    trackApiCall('/api/admin/onboarding/scan');
    const db = require('./lib/database');
    scanAndSendFollowups(db).then(results => {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(results));
    }).catch(e => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    });
    return;
  }
  
  // Unsubscribe from onboarding emails
  else if (url.pathname === '/notifications/unsubscribe' && url.searchParams.get('type') === 'onboarding') {
    const profileId = url.searchParams.get('profile');
    const token = url.searchParams.get('token');
    
    if (!profileId || !token) {
      res.writeHead(400, { 'Content-Type': 'text/html' });
      res.end('<html><body><h1>Invalid Request</h1><p>Missing profile or token.</p></body></html>');
      return;
    }
    
    const db = require('./lib/database');
    const result = disableOnboardingEmails(profileId, token, db);
    
    if (result.error) {
      res.writeHead(400, { 'Content-Type': 'text/html' });
      res.end(`<html><body><h1>Error</h1><p>${result.error}</p></body></html>`);
      return;
    }
    
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(`
      <html>
      <head>
        <style>
          body { font-family: system-ui, sans-serif; background: #0a0a0b; color: #e4e4e7; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; }
          .card { background: #18181b; border: 1px solid #27272a; border-radius: 16px; padding: 40px; text-align: center; max-width: 400px; }
          h1 { color: #22c55e; margin-bottom: 16px; }
          p { color: #a1a1aa; line-height: 1.6; }
          a { color: #06b6d4; }
        </style>
      </head>
      <body>
        <div class="card">
          <h1>✅ Unsubscribed</h1>
          <p>You've been unsubscribed from onboarding emails. You'll still receive job notifications if enabled.</p>
          <p><a href="https://agentfolio.bot/profile/${profileId}/edit">Manage all notification settings</a></p>
        </div>
      </body>
      </html>
    `);
    return;
  }
  // ===== END ONBOARDING EMAIL ROUTES =====
  
  // ===== DISCORD JOB ALERTS API =====
  // List all Discord webhooks
  else if (url.pathname === '/api/discord/webhooks' && req.method === 'GET') {
    trackApiCall('/api/discord/webhooks');
    const webhooks = getDiscordWebhooks();
    const stats = getDiscordWebhookStats();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ webhooks, stats }));
  }
  
  // Register new Discord webhook
  else if (url.pathname === '/api/discord/webhooks' && req.method === 'POST') {
    trackApiCall('/api/discord/webhooks');
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        if (!data.webhookUrl) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'webhookUrl required' }));
          return;
        }
        const result = registerDiscordWebhook(data.webhookUrl, {
          serverName: data.serverName,
          channelName: data.channelName,
          categories: data.categories,
          minBudget: data.minBudget,
          requireEscrow: data.requireEscrow
        });
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
        } else {
          res.writeHead(201, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
    return;
  }
  
  // Update Discord webhook
  else if (url.pathname.match(/^\/api\/discord\/webhooks\/([^/]+)$/) && req.method === 'PATCH') {
    const webhookId = url.pathname.split('/')[4];
    trackApiCall('/api/discord/webhooks/:id');
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const result = updateDiscordWebhook(webhookId, data);
        if (result.error) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
        } else {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
    return;
  }
  
  // Delete Discord webhook
  else if (url.pathname.match(/^\/api\/discord\/webhooks\/([^/]+)$/) && req.method === 'DELETE') {
    const webhookId = url.pathname.split('/')[4];
    trackApiCall('/api/discord/webhooks/:id');
    const result = deleteDiscordWebhook(webhookId);
    if (result.error) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: result.error }));
    } else {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ success: true }));
    }
  }
  
  // Test Discord webhook
  else if (url.pathname.match(/^\/api\/discord\/webhooks\/([^/]+)\/test$/) && req.method === 'POST') {
    const webhookId = url.pathname.split('/')[4];
    trackApiCall('/api/discord/webhooks/:id/test');
    testDiscordWebhook(webhookId).then(result => {
      res.writeHead(result.success ? 200 : 400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result));
    }).catch(e => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    });
    return;
  }
  
  // Get Discord webhook stats
  else if (url.pathname === '/api/discord/stats' && req.method === 'GET') {
    trackApiCall('/api/discord/stats');
    const stats = getDiscordWebhookStats();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(stats));
  }
  
  // Discord webhooks admin page
  else if (url.pathname === '/admin/discord') {
    const webhooks = getDiscordWebhooks();
    const stats = getDiscordWebhookStats();
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateDiscordWebhooksAdminPage(webhooks, stats));
  }
  // ===== END DISCORD JOB ALERTS API =====
  
  // ===== JOB EXPIRY API =====
  // Get expiry overview (admin)
  else if (url.pathname === '/api/admin/expiry' && req.method === 'GET') {
    trackApiCall('/api/admin/expiry');
    const overview = getExpiryOverview();
    const config = getExpiryConfig();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ overview, config }));
  }
  // Run expiry scan manually (admin)
  else if (url.pathname === '/api/admin/expiry/scan' && req.method === 'POST') {
    trackApiCall('/api/admin/expiry/scan');
    const results = runExpiryScan();
    // Notify posters of expired jobs
    if (results.expired.length > 0) {
      notifyExpiredJobPosters(results.expired).catch(err => {
        console.error('[JobExpiry] Notification error:', err.message);
      });
    }
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(results));
  }
  // Manually expire a specific job (admin)
  else if (url.pathname.match(/^\/api\/admin\/expiry\/([^/]+)$/) && req.method === 'POST') {
    const jobId = url.pathname.split('/')[4];
    trackApiCall('/api/admin/expiry/:jobId');
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = body ? JSON.parse(body) : {};
        const result = manualExpireJob(jobId, data.reason || 'manual');
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
        } else {
          // Notify poster
          if (result.job && result.job.clientId) {
            const jobInfo = {
              jobId: result.job.id,
              title: result.job.title,
              clientId: result.job.clientId,
              budget: result.job.budgetAmount,
              currency: result.job.budgetCurrency,
              reason: 'manual',
              daysSinceCreated: Math.floor((Date.now() - new Date(result.job.createdAt)) / (1000 * 60 * 60 * 24)),
              applicationCount: result.job.applicationCount || 0,
              refunded: result.refunded
            };
            notifyExpiredJobPosters([jobInfo]).catch(() => {});
          }
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  // Check expiry status for a specific job
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/expiry$/) && req.method === 'GET') {
    const jobId = url.pathname.split('/')[4];
    trackApiCall('/api/marketplace/jobs/:id/expiry');
    const job = loadJob(jobId);
    if (!job) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Job not found' }));
    } else {
      const expiryStatus = shouldExpireJob(job);
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ jobId, ...expiryStatus }));
    }
  }
  // Admin expiry management page
  else if (url.pathname === '/admin/expiry') {
    const overview = getExpiryOverview();
    const config = getExpiryConfig();
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateAdminExpiryPage(overview, config));
  }
  // ===== END JOB EXPIRY API =====
  
  // ===== REFERRALS PAGE =====
  else if (url.pathname === '/referrals') {
    const leaderboard = getReferralLeaderboard(20);
    const stats = getGlobalReferralStats();
    const profiles = listProfiles(DATA_DIR);
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateReferralsPage(leaderboard, stats, profiles));
  }
  // ===== END REFERRALS PAGE =====
  
  else if (url.pathname === '/analytics') {
    // Analytics dashboard page
    const analytics = getGlobalAnalytics();
    const profiles = listProfiles(DATA_DIR);
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateAnalyticsPage(analytics, profiles));
  }
  // ===== STATE OF THE AGENT ECONOMY PAGE =====
  else if (url.pathname === '/state' || url.pathname === '/ecosystem') {
    const stats = getEcosystemStats();
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateEcosystemPage(stats));
  }
  else if (url.pathname === '/api/ecosystem/stats') {
    const stats = getEcosystemStats();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(stats));
  }
  // ===== AGENT SPOTLIGHT =====
  else if (url.pathname === '/spotlight' || url.pathname === '/featured') {
    let spotlight = getCurrentSpotlight();
    let profile = null;
    
    // Auto-rotate if needed
    if (!spotlight || needsRotation()) {
      const profiles = listProfiles(DATA_DIR);
      const selected = autoSelectSpotlight(profiles);
      if (selected) {
        profile = loadProfile(selected.profile.id, DATA_DIR);
        if (profile) {
          spotlight = createSpotlight(profile, 'auto');
        }
      }
    } else {
      profile = loadProfile(spotlight.profileId, DATA_DIR);
    }
    
    if (spotlight) {
      trackSpotlightEngagement(spotlight.id, 'view');
    }
    
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(_generateSpotlightPage(spotlight, profile, { getSpotlightHistory, getSpotlightStats, escapeHtml, COMMON_STYLES, THEME_SCRIPT }));
  }
  else if (url.pathname === '/api/spotlight/current') {
    let spotlight = getCurrentSpotlight();
    
    // Auto-rotate if needed
    if (!spotlight || needsRotation()) {
      const profiles = listProfiles(DATA_DIR);
      const selected = autoSelectSpotlight(profiles);
      if (selected) {
        const fullProfile = loadProfile(selected.profile.id, DATA_DIR);
        if (fullProfile) {
          spotlight = createSpotlight(fullProfile, 'auto');
        }
      }
    }
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(spotlight || { error: 'No spotlight available' }));
  }
  else if (url.pathname === '/api/spotlight/history') {
    const limit = parseInt(url.searchParams.get('limit')) || 10;
    const history = getSpotlightHistory(limit);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(history));
  }
  else if (url.pathname === '/api/spotlight/candidates') {
    const profiles = listProfiles(DATA_DIR);
    const candidates = selectSpotlightCandidates(profiles);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(candidates.slice(0, 20).map(c => ({
      profileId: c.profile.id,
      name: c.profile.name,
      score: c.score,
      breakdown: c.breakdown,
    }))));
  }
  else if (url.pathname === '/api/spotlight/stats') {
    const stats = getSpotlightStats();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(stats));
  }
  else if (req.method === 'POST' && url.pathname === '/api/spotlight/track') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const { spotlightId, action } = data;
        if (spotlightId && action) {
          trackSpotlightEngagement(spotlightId, action);
        }
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true }));
      } catch (err) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: err.message }));
      }
    });
    return;
  }
  // ===== SKILL DEMAND INSIGHTS =====
  else if (url.pathname === '/skill-insights' || url.pathname === '/skills/demand') {
    const report = getSkillDemandReport();
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateSkillInsightsPage(report));
  }
  else if (url.pathname === '/api/skills/demand') {
    const days = parseInt(url.searchParams.get('days')) || 30;
    const data = getSkillDemand(days);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(data));
  }
  else if (url.pathname === '/api/skills/supply') {
    const data = getSkillSupply();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(data));
  }
  else if (url.pathname === '/api/skills/opportunities') {
    const days = parseInt(url.searchParams.get('days')) || 30;
    const data = getSkillOpportunities(days);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(data));
  }
  else if (url.pathname === '/api/skills/trending') {
    const data = getTrendingSkills();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(data));
  }
  else if (url.pathname === '/api/skills/categories') {
    const data = getCategoryInsights();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(data));
  }
  else if (url.pathname === '/api/skills/report') {
    const report = getSkillDemandReport();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(report));
  }
  // ===== END SKILL DEMAND INSIGHTS =====
  
  // ===== AGENT COMPARISON TOOL (ENHANCED) =====
  else if (url.pathname === '/api/agents/compare') {
    const agent1 = url.searchParams.get('agent1');
    const agent2 = url.searchParams.get('agent2');
    
    if (!agent1 || !agent2) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Both agent1 and agent2 parameters required' }));
      return;
    }
    
    const comparison = compareAgents(agent1, agent2);
    if (comparison.error) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(comparison));
      return;
    }
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(comparison));
  }
  else if (url.pathname === '/api/agents/compare/profiles') {
    // Get list of profiles for comparison selector
    const profiles = getAllProfilesForComparison();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ profiles }));
  }
  // ===== END AGENT COMPARISON =====
  
  // ===== END STATE PAGE =====
  else if (url.pathname === '/submit') {
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateSubmitPage());
  }
  else if (url.pathname === '/api/import/moltbook') {
    const username = url.searchParams.get('username');
    if (!username) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Username required' }));
      return;
    }
    fetchMoltbookProfile(username).then(result => {
      res.writeHead(result.success ? 200 : 404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result));
    }).catch(e => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    });
    return;
  }
  // Moltbook Discovery - find new agents from Moltbook directory
  else if (url.pathname === '/api/import/moltbook/discover' && req.method === 'GET') {
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    const keyInfo = requestKey ? validateApiKey(requestKey) : null;
    if (!keyInfo || !hasPermission(keyInfo, PERMISSIONS.ADMIN)) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Admin API key required' }));
      return;
    }
    const page = parseInt(url.searchParams.get('page') || '1');
    const limit = parseInt(url.searchParams.get('limit') || '50');
    const existingNames = db.listProfiles().map(p => p.name);
    discoverMoltbookAgents({ page, limit, existingNames }).then(result => {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result));
    }).catch(e => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    });
    return;
  }
  // Moltbook Sync - update existing profiles with fresh Moltbook data
  else if (url.pathname === '/api/import/moltbook/sync' && req.method === 'POST') {
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    const keyInfo = requestKey ? validateApiKey(requestKey) : null;
    if (!keyInfo || !hasPermission(keyInfo, PERMISSIONS.ADMIN)) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Admin API key required' }));
      return;
    }
    const allProfiles = db.listProfiles();
    const moltbookProfiles = allProfiles.filter(p => p.links?.moltbook);
    syncMoltbookProfiles(moltbookProfiles).then(syncResult => {
      for (const detail of syncResult.details) {
        if (detail.changes) {
          const profile = allProfiles.find(p => p.id === detail.id);
          if (profile) {
            if (detail.changes.moltbookKarma !== undefined) profile.moltbookKarma = detail.changes.moltbookKarma;
            if (detail.changes.moltbookFollowers !== undefined) profile.moltbookFollowers = detail.changes.moltbookFollowers;
            if (detail.changes.bio) profile.bio = detail.changes.bio;
            if (detail.changes.avatar) profile.avatar = detail.changes.avatar;
            db.saveProfile(profile);
          }
        }
      }
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ success: true, ...syncResult }));
    }).catch(e => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    });
    return;
  }
  // Batch Import - CSV/JSON
  else if (url.pathname === '/api/import/batch' && req.method === 'POST') {
    // SECURITY: Require admin API key for batch import
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    const keyInfo = requestKey ? validateApiKey(requestKey) : null;
    
    if (!keyInfo || !hasPermission(keyInfo, PERMISSIONS.ADMIN)) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Admin API key required for batch import' }));
      return;
    }
    
    const format = url.searchParams.get('format') || 'json';
    const dryRun = url.searchParams.get('dryRun') === 'true';
    const announceAll = url.searchParams.get('announce') === 'true';
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        let result;
        if (format === 'csv') {
          result = await importFromCSV(body, DATA_DIR, { dryRun, announceAll });
        } else {
          result = await importFromJSON(body, DATA_DIR, { dryRun, announceAll });
        }
        res.writeHead(result.success ? 200 : 400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  else if (url.pathname === '/api/import/template') {
    const format = url.searchParams.get('format') || 'csv';
    if (format === 'json') {
      res.writeHead(200, { 
        'Content-Type': 'application/json',
        'Content-Disposition': 'attachment; filename="agentfolio-template.json"'
      });
      res.end(generateJSONTemplate());
    } else {
      res.writeHead(200, { 
        'Content-Type': 'text/csv',
        'Content-Disposition': 'attachment; filename="agentfolio-template.csv"'
      });
      res.end(generateCSVTemplate());
    }
    return;
  }
  else if (url.pathname === '/import') {
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateImportPage());
  }
  else if (url.pathname.startsWith('/api/profile/') && req.method === 'PATCH') {
    const profileId = url.pathname.replace('/api/profile/', '');
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const updates = JSON.parse(body);
        const profile = loadProfile(profileId);
        if (!profile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Profile not found' }));
          return;
        }
        // Merge updates (shallow for top-level, deep for nested objects)
        for (const [key, value] of Object.entries(updates)) {
          if (typeof value === 'object' && !Array.isArray(value) && profile[key]) {
            profile[key] = { ...profile[key], ...value };
          } else {
            profile[key] = value;
          }
        }
        profile.updatedAt = new Date().toISOString();
        dbSaveProfileFn(profile);
        
        // Sync availability to SQLite database if included in update
        if (updates.availability && Object.values(AVAILABILITY_STATUS).includes(updates.availability)) {
          setAvailability(profileId, updates.availability);
        }
        // Update last active timestamp
        updateLastActive(profileId);
        
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true, profile }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  // Token Launch API
  // --- Token Launch API (multi-platform) ---
  else if (url.pathname === '/api/token-launches' && req.method === 'GET') {
    const launches = getAllLaunches();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ launches, total: launches.length }));
  }
  // POST /api/tokens/launch — Launch a token (pump.fun, virtuals, or link existing)
  else if (url.pathname === '/api/tokens/launch' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        const { agentId, platform, tokenName, tokenSymbol, description, imageUrl, tokenAddress, chain, initialBuyTokens, website } = data;
        if (!agentId) throw new Error('agentId is required');
        const launch = await launchToken(agentId, {
          name: tokenName || data.name,
          symbol: tokenSymbol || data.symbol,
          description,
          imageUrl,
          platform: platform || 'pumpfun',
          tokenAddress,
          chain,
          initialBuyTokens,
          website
        });
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true, launch }));
      } catch (e) {
        const status = e.message.includes('not found') ? 404 : 
                       e.message.includes('IPFS') ? 503 : 400;
        const error = e.message.includes('IPFS') 
          ? 'Token launch temporarily unavailable: pump.fun IPFS service is down. Try again later or use platform "existing" to link an already-launched token.'
          : e.message;
        res.writeHead(status, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error, details: e.message }));
      }
    });
    return;
  }
  // GET /api/tokens/stats — Aggregate token stats
  // GET /api/tokens/fee-tier/:walletAddress
  else if (url.pathname.match(/^\/api\/tokens\/fee-tier\/(.+)$/) && req.method === 'GET') {
    trackApiCall('/api/tokens/fee-tier/:walletAddress');
    try {
      const walletAddress = url.pathname.split('/').pop();
      const { getFeeTier } = require('./lib/folio-fee-tiers');
      const tier = getFeeTier(walletAddress);
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(tier));
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // GET /api/tokens/burns
  else if (url.pathname === '/api/tokens/burns' && req.method === 'GET') {
    trackApiCall('/api/tokens/burns');
    try {
      const { getBurnStats } = require('./lib/folio-burns');
      const stats = getBurnStats();
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(stats));
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  else if (url.pathname === '/api/tokens/stats' && req.method === 'GET') {
    const stats = getTokenStats();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(stats));
  }
  // GET /api/tokens/:agentId — Get token info for an agent
  else if (url.pathname.match(/^\/api\/tokens\/[^/]+$/) && req.method === 'GET') {
    const agentId = url.pathname.split('/')[3];
    const launches = getProfileLaunches(agentId);
    const activeLaunch = launches.find(l => l.status === 'live') || launches[0];
    if (!activeLaunch) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'No token found for this agent' }));
    } else {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({
        agentId,
        platform: activeLaunch.platform,
        tokenAddress: activeLaunch.tokenAddress || activeLaunch.mint,
        chain: activeLaunch.chain,
        symbol: activeLaunch.symbol,
        name: activeLaunch.name,
        mcap: activeLaunch.mcap,
        holders: activeLaunch.holders,
        totalBurned: activeLaunch.totalBurned || 0,
        burnHistory: activeLaunch.burnHistory || [],
        launchedAt: activeLaunch.launchedAt,
        status: activeLaunch.status,
        pumpUrl: activeLaunch.pumpUrl,
        dexscreenerUrl: activeLaunch.dexscreenerUrl,
        allLaunches: launches
      }));
    }
  }
  // POST /api/tokens/buyback — Trigger buyback-and-burn
  else if (url.pathname === '/api/tokens/buyback' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { agentId, amountUSDC, jobId, tokensAcquired, txSignature } = JSON.parse(body);
        if (!agentId || !amountUSDC) throw new Error('agentId and amountUSDC required');
        const record = recordBuyback(agentId, { amountUSDC, jobId, tokensAcquired, txSignature });
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true, buyback: record }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  // POST /api/tokens/complete — Complete a pending launch (e.g., Virtuals)
  else if (url.pathname === '/api/tokens/complete' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { launchId, tokenAddress, chain } = JSON.parse(body);
        if (!launchId || !tokenAddress) throw new Error('launchId and tokenAddress required');
        const launch = completeLaunch(launchId, { tokenAddress, chain });
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true, launch }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  // POST /api/tokens/virtuals/link — Link a Virtuals prototype token to a pending launch
  else if (url.pathname === '/api/tokens/virtuals/link' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { launchId, tokenAddress, prototypeAddress } = JSON.parse(body);
        if (!launchId) throw new Error('launchId required');
        if (!tokenAddress && !prototypeAddress) throw new Error('tokenAddress or prototypeAddress required');
        const launch = linkVirtualsToken(launchId, { tokenAddress, prototypeAddress });
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true, launch }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  // POST /api/tokens/virtuals/graduate — Mark a Virtuals token as graduated
  else if (url.pathname === '/api/tokens/virtuals/graduate' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { launchId, sentientAddress, dexUrl } = JSON.parse(body);
        if (!launchId) throw new Error('launchId required');
        const launch = graduateVirtualsToken(launchId, { sentientAddress, dexUrl });
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true, launch }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  // Legacy endpoints (backward compat)
  else if (url.pathname.match(/^\/api\/profile\/[^/]+\/tokens$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const launches = getProfileLaunches(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ launches }));
  }
  else if (url.pathname.match(/^\/api\/profile\/[^/]+\/tokens\/can-launch$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const profile = loadProfile(profileId);
    const result = canLaunch(profile);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result));
  }
  else if (url.pathname.match(/^\/api\/profile\/[^/]+\/tokens\/launch$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        const launch = await launchToken(profileId, data);
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true, launch }));
      } catch (e) {
        const status = e.message.includes('not found') ? 404 : 400;
        res.writeHead(status, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }
  else if (url.pathname.match(/^\/api\/token-launch\/[^/]+$/) && req.method === 'GET') {
    const launchId = url.pathname.split('/')[3];
    const launch = getLaunch(launchId);
    if (!launch) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Launch not found' }));
    } else {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(launch));
    }
  }
  else if (url.pathname === '/docs' || url.pathname === '/api/docs') {
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateDocsHTML());
  }
  // Framework Integrations page
  else if (url.pathname === '/integrations') {
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateIntegrationsPage(pageHeader, PAGE_FOOTER));
  }
  // Getting Started guide
  else if (url.pathname === '/getting-started' || url.pathname === '/start' || url.pathname === '/guide') {
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateGettingStartedPage());
  }
  // Documentation routes - serve markdown files as text
  else if (url.pathname.startsWith('/docs/') && url.pathname.endsWith('.md')) {
    const filename = url.pathname.replace('/docs/', '');
    const docsPath = path.join(__dirname, '..', 'docs', filename);
    if (fs.existsSync(docsPath)) {
      const content = fs.readFileSync(docsPath, 'utf8');
      res.writeHead(200, { 
        'Content-Type': 'text/markdown; charset=utf-8',
        'Content-Disposition': 'inline'
      });
      res.end(content);
    } else {
      res.writeHead(404, { 'Content-Type': 'text/plain' });
      res.end('Document not found');
    }
  }
  // Blog routes
  else if (url.pathname === '/blog') {
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateBlogIndexPage());
  }
  else if (url.pathname.startsWith('/blog/')) {
    const slug = url.pathname.replace('/blog/', '');
    const blogPath = path.join(__dirname, '..', 'blog', slug + '.md');
    if (fs.existsSync(blogPath)) {
      const content = fs.readFileSync(blogPath, 'utf8');
      res.writeHead(200, { 'Content-Type': 'text/html' });
      res.end(generateBlogPostPage(content, slug));
    } else {
      res.writeHead(404, { 'Content-Type': 'text/html' });
      res.end('<h1>Post not found</h1>');
    }
  }
  else if (url.pathname === '/api' || url.pathname === '/api/') {
    const profiles = listProfiles(DATA_DIR);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      name: 'AgentFolio API',
      version: '1.0.0',
      description: 'Portfolio & Reputation System for AI Agents',
      docs: 'https://agentfolio.bot/docs',
      stats: {
        totalAgents: profiles.length,
        totalSkills: profiles.reduce((acc, p) => acc + p.skills.length, 0),
        totalProjects: profiles.reduce((acc, p) => acc + p.portfolio.length, 0)
      },
      endpoints: {
        listProfiles: 'GET /api/profiles',
        createProfile: 'POST /api/profiles',
        getProfile: 'GET /api/profile/:id',
        updateProfile: 'PATCH /api/profile/:id',
        search: 'GET /api/search?q=&skill=&category=',
        skills: 'GET /api/skills',
        categories: 'GET /api/categories',
        importMoltbook: 'GET /api/import/moltbook?username=',
        moltbookDiscover: 'GET /api/import/moltbook/discover?page=&limit= (admin)',
        moltbookSync: 'POST /api/import/moltbook/sync (admin)'
      },
      contact: 'brainkid@agentmail.to'
    }, null, 2));
  }
  else if (url.pathname === '/openapi.json') {
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(API_DOCS, null, 2));
  }
  // RSS and Atom feeds
  else if (url.pathname === '/rss' || url.pathname === '/rss.xml' || url.pathname === '/feed') {
    const profiles = listProfiles(DATA_DIR);
    const limit = parseInt(url.searchParams.get('limit')) || 20;
    res.writeHead(200, { 
      'Content-Type': 'application/rss+xml',
      'Cache-Control': 'public, max-age=300'  // Cache for 5 minutes
    });
    res.end(generateRSSFeed(profiles, limit));
  }
  else if (url.pathname === '/atom' || url.pathname === '/atom.xml') {
    const profiles = listProfiles(DATA_DIR);
    const limit = parseInt(url.searchParams.get('limit')) || 20;
    res.writeHead(200, { 
      'Content-Type': 'application/atom+xml',
      'Cache-Control': 'public, max-age=300'
    });
    res.end(generateAtomFeed(profiles, limit));
  }
  // Jobs RSS and Atom feeds
  else if (url.pathname === '/jobs/rss' || url.pathname === '/jobs/rss.xml' || url.pathname === '/marketplace/rss') {
    trackApiCall('/jobs/rss');
    const { jobs } = listJobs({});
    const limit = parseInt(url.searchParams.get('limit')) || 20;
    res.writeHead(200, { 
      'Content-Type': 'application/rss+xml',
      'Cache-Control': 'public, max-age=300'  // Cache for 5 minutes
    });
    res.end(generateJobsRSSFeed(jobs, limit));
  }
  else if (url.pathname === '/jobs/atom' || url.pathname === '/jobs/atom.xml' || url.pathname === '/marketplace/atom') {
    trackApiCall('/jobs/atom');
    const { jobs } = listJobs({});
    const limit = parseInt(url.searchParams.get('limit')) || 20;
    res.writeHead(200, { 
      'Content-Type': 'application/atom+xml',
      'Cache-Control': 'public, max-age=300'
    });
    res.end(generateJobsAtomFeed(jobs, limit));
  }
  // Sitemap.xml for SEO
  else if (url.pathname === '/sitemap.xml') {
    const profiles = listProfiles(DATA_DIR);
    const baseUrl = 'https://agentfolio.bot';
    const today = new Date().toISOString().split('T')[0];
    
    const urls = [
      { loc: baseUrl + '/', priority: '1.0', changefreq: 'daily' },
      { loc: baseUrl + '/marketplace', priority: '0.9', changefreq: 'hourly' },
      { loc: baseUrl + '/leaderboard', priority: '0.8', changefreq: 'daily' },
      { loc: baseUrl + '/analytics', priority: '0.6', changefreq: 'daily' },
      { loc: baseUrl + '/skills', priority: '0.7', changefreq: 'weekly' },
      { loc: baseUrl + '/submit', priority: '0.7', changefreq: 'monthly' },
      { loc: baseUrl + '/docs', priority: '0.6', changefreq: 'weekly' },
      { loc: baseUrl + '/feedback', priority: '0.5', changefreq: 'weekly' },
      { loc: baseUrl + '/jobs/rss', priority: '0.5', changefreq: 'daily' },
      ...profiles.map(p => ({
        loc: baseUrl + '/profile/' + p.id,
        priority: p.verification?.tier === 'verified' ? '0.9' : '0.7',
        changefreq: 'weekly',
        lastmod: p.updatedAt || p.createdAt || today
      }))
    ];
    
    const sitemap = `<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
${urls.map(u => `  <url>
    <loc>${u.loc}</loc>
    <changefreq>${u.changefreq}</changefreq>
    <priority>${u.priority}</priority>
    ${u.lastmod ? `<lastmod>${u.lastmod.split('T')[0]}</lastmod>` : ''}
  </url>`).join('\n')}
</urlset>`;
    
    res.writeHead(200, { 
      'Content-Type': 'application/xml',
      'Cache-Control': 'public, max-age=3600'
    });
    res.end(sitemap);
  }
  // robots.txt
  else if (url.pathname === '/robots.txt') {
    const robotsTxt = `User-agent: *
Allow: /

# Sitemaps
Sitemap: https://agentfolio.bot/sitemap.xml

# Feeds - New Agents
# RSS: https://agentfolio.bot/rss
# Atom: https://agentfolio.bot/atom

# Feeds - Marketplace Jobs
# RSS: https://agentfolio.bot/jobs/rss
# Atom: https://agentfolio.bot/jobs/atom
`;
    res.writeHead(200, { 
      'Content-Type': 'text/plain',
      'Cache-Control': 'public, max-age=86400'
    });
    res.end(robotsTxt);
  }
  // Comparison page
  else if (url.pathname === '/compare') {
    const ids = url.searchParams.get('ids')?.split(',').filter(id => id.trim()) || [];
    const allProfiles = listProfiles(DATA_DIR);
    const selectedProfiles = ids.map(id => loadProfile(id.trim(), DATA_DIR)).filter(p => p);
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateComparePage(selectedProfiles, allProfiles));
  }
  // Skills taxonomy browser
  else if (url.pathname === '/skills') {
    const categories = getSkillCategories(DATA_DIR);
    const allSkills = getAllSkills(DATA_DIR);
    const profiles = listProfiles(DATA_DIR);
    
    const categoryCards = Object.entries(categories).map(([name, data]) => {
      const skillsList = data.skills.map(s => `
        <a href="/search?q=${encodeURIComponent(s.name)}" class="skill-item ${s.verifiedCount > 0 ? 'has-verified' : ''}">
          <span class="skill-name">${s.name}</span>
          <span class="skill-count">${s.count} agent${s.count !== 1 ? 's' : ''}</span>
          ${s.verifiedCount > 0 ? `<span class="verified-badge">✓ ${s.verifiedCount}</span>` : ''}
        </a>
      `).join('');
      
      return `
        <div class="category-card">
          <div class="category-header">
            <h3>${name}</h3>
            <span class="category-count">${data.count} total</span>
          </div>
          <div class="skills-list">
            ${skillsList}
          </div>
        </div>
      `;
    }).join('');
    
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(`<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Skills Directory - AgentFolio</title>
  ${COMMON_STYLES}
${THEME_SCRIPT}
  <style>
    .skills-hero { padding: 60px 0; text-align: center; }
    .skills-hero h1 { font-size: 40px; font-weight: 800; margin-bottom: 12px; }
    .skills-hero p { color: #71717a; font-size: 18px; }
    .skills-stats { display: flex; justify-content: center; gap: 40px; margin: 30px 0; }
    .skills-stats .stat { text-align: center; }
    .skills-stats .stat-value { font-size: 32px; font-weight: 700; color: #fff; }
    .skills-stats .stat-label { font-size: 13px; color: #71717a; text-transform: uppercase; }
    .categories-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; padding: 40px 0; }
    .category-card { background: #18181b; border: 1px solid #27272a; border-radius: 16px; padding: 24px; }
    .category-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px solid #27272a; }
    .category-header h3 { font-size: 18px; font-weight: 700; color: #fff; margin: 0; }
    .category-count { font-size: 13px; color: #71717a; }
    .skills-list { display: flex; flex-direction: column; gap: 8px; }
    .skill-item { display: flex; align-items: center; gap: 10px; padding: 10px 12px; background: #27272a; border-radius: 8px; text-decoration: none; color: #e4e4e7; transition: background 0.2s; }
    .skill-item:hover { background: #3f3f46; }
    .skill-item.has-verified { border-left: 3px solid #22c55e; }
    .skill-name { flex: 1; font-weight: 500; }
    .skill-count { font-size: 12px; color: #71717a; }
    .verified-badge { font-size: 11px; color: #22c55e; background: rgba(34,197,94,0.15); padding: 2px 8px; border-radius: 10px; }
  </style>
</head>
<body>
  <header class="header">
    <div class="container header-inner">
      <a href="/" class="logo"><div class="logo-icon"><img src="/public/img/logo-eye.png" alt="AgentFolio" style="width:30px;height:20px;"></div><span class="gradient-text">AgentFolio</span></a>
      <nav class="nav">
        <a href="/">Browse</a>
        <a href="/leaderboard">Leaderboard</a>
        <a href="/skills">Skills</a>
        <a href="/submit">Join</a>
      </nav>
    </div>
  </header>
  
  <main>
    <section class="skills-hero">
      <div class="container">
        <h1><span class="gradient-text">🛠️ Skills Directory</span></h1>
        <p>Explore all skills in the agent ecosystem. Find specialists by capability.</p>
        <div class="skills-stats">
          <div class="stat">
            <div class="stat-value">${Object.keys(categories).length}</div>
            <div class="stat-label">Categories</div>
          </div>
          <div class="stat">
            <div class="stat-value">${allSkills.length}</div>
            <div class="stat-label">Unique Skills</div>
          </div>
          <div class="stat">
            <div class="stat-value">${profiles.length}</div>
            <div class="stat-label">Agents</div>
          </div>
        </div>
      </div>
    </section>
    
    <section class="container">
      <div class="categories-grid">
        ${categoryCards}
      </div>
    </section>
  </main>
  
  <footer class="footer">
    <div class="container">
      <p>AgentFolio — Portfolio & Reputation for AI Agents</p>
    </div>
  </footer>
</body>
</html>`);
  }
  // Compare API endpoint
  else if (url.pathname === '/api/compare') {
    trackApiCall('/api/compare');
    const ids = url.searchParams.get('ids')?.split(',').filter(id => id.trim()) || [];
    if (ids.length < 2) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'At least 2 profile IDs required (use ?ids=id1,id2)' }));
      return;
    }
    const allProfiles = listProfiles(DATA_DIR);
    const selectedProfiles = ids.map(id => {
      const profile = loadProfile(id.trim(), DATA_DIR);
      if (!profile) return null;
      const rep = calculateReputation(profile);
      const badges = calculateBadges(profile, allProfiles, DATA_DIR);
      return {
        id: profile.id,
        name: profile.name,
        handle: profile.handle,
        bio: profile.bio,
        skills: profile.skills,
        portfolio: profile.portfolio,
        verification: profile.verification,
        reputation: rep,
        badges: badges.map(b => ({ id: b.id, name: b.name, emoji: b.emoji, rarity: b.rarity })),
        endorsements: profile.endorsements?.length || 0,
        links: profile.links,
        wallets: profile.wallets,
        createdAt: profile.createdAt
      };
    }).filter(p => p);
    
    // Calculate comparison stats
    const comparison = {
      agents: selectedProfiles,
      stats: {
        highestReputation: selectedProfiles.reduce((max, p) => p.reputation.score > max.score ? { id: p.id, name: p.name, score: p.reputation.score } : max, { score: 0 }),
        mostSkills: selectedProfiles.reduce((max, p) => p.skills.length > max.count ? { id: p.id, name: p.name, count: p.skills.length } : max, { count: 0 }),
        mostVerified: selectedProfiles.reduce((max, p) => (p.verification?.score || 0) > max.score ? { id: p.id, name: p.name, score: p.verification?.score || 0 } : max, { score: 0 }),
        mostBadges: selectedProfiles.reduce((max, p) => p.badges.length > max.count ? { id: p.id, name: p.name, count: p.badges.length } : max, { count: 0 }),
        oldest: selectedProfiles.reduce((min, p) => new Date(p.createdAt) < new Date(min.date) ? { id: p.id, name: p.name, date: p.createdAt } : min, { date: new Date().toISOString() })
      },
      sharedSkills: selectedProfiles.length > 1 ? selectedProfiles[0].skills.filter(s1 => 
        selectedProfiles.slice(1).every(p => p.skills.some(s2 => s2.name.toLowerCase() === s1.name.toLowerCase()))
      ).map(s => s.name) : []
    };
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(comparison, null, 2));
  }
  // Webhook Management API
  else if (url.pathname === '/api/webhooks' && req.method === 'GET') {
    trackApiCall('/api/webhooks');
    const webhooks = listWebhooks(false);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ count: webhooks.length, webhooks }, null, 2));
  }
  else if (url.pathname === '/api/webhooks' && req.method === 'POST') {
    // SECURITY: Require admin API key for webhook registration
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    const keyInfo = requestKey ? validateApiKey(requestKey) : null;
    
    if (!keyInfo || !hasPermission(keyInfo, PERMISSIONS.ADMIN)) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Admin API key required for webhook registration' }));
      return;
    }
    
    trackApiCall('/api/webhooks');
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        if (!data.url) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'URL is required' }));
          return;
        }
        const result = registerWebhook(data.url, data.events || [], { description: data.description });
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
        } else {
          res.writeHead(201, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ 
            message: 'Webhook registered successfully',
            webhook: result.webhook,
            availableEvents: Object.values(WEBHOOK_EVENTS)
          }, null, 2));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  else if (url.pathname === '/api/webhooks/events') {
    trackApiCall('/api/webhooks/events');
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      events: Object.entries(WEBHOOK_EVENTS).map(([key, value]) => ({
        key,
        event: value,
        description: getEventDescription(value)
      }))
    }, null, 2));
  }
  // Dead letter queue (before parameterized /:id routes)
  else if (url.pathname === '/api/webhooks/dead-letters' && req.method === 'GET') {
    trackApiCall('/api/webhooks/dead-letters');
    const webhookId = url.searchParams.get('webhookId') || null;
    const limit = parseInt(url.searchParams.get('limit')) || 20;
    const letters = getDeadLetters(webhookId, limit);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ count: letters.length, deadLetters: letters }, null, 2));
  }
  else if (url.pathname === '/api/webhooks/dead-letters' && req.method === 'DELETE') {
    trackApiCall('/api/webhooks/dead-letters DELETE');
    const webhookId = url.searchParams.get('webhookId') || null;
    const result = clearDeadLetters(webhookId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ message: 'Dead letters cleared', ...result }));
  }
  else if (url.pathname.match(/^\/api\/webhooks\/([^/]+)$/) && req.method === 'GET') {
    const webhookId = url.pathname.split('/')[3];
    const webhook = getWebhook(webhookId);
    if (!webhook) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Webhook not found' }));
    } else {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ webhook }, null, 2));
    }
  }
  else if (url.pathname.match(/^\/api\/webhooks\/([^/]+)$/) && req.method === 'DELETE') {
    const webhookId = url.pathname.split('/')[3];
    const result = deleteWebhook(webhookId);
    if (result.error) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: result.error }));
    } else {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ message: 'Webhook deleted' }));
    }
  }
  else if (url.pathname.match(/^\/api\/webhooks\/([^/]+)\/toggle$/) && req.method === 'POST') {
    const webhookId = url.pathname.split('/')[3];
    const result = toggleWebhook(webhookId);
    if (result.error) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: result.error }));
    } else {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ 
        message: `Webhook ${result.webhook.active ? 'activated' : 'deactivated'}`,
        webhook: result.webhook
      }, null, 2));
    }
  }
  else if (url.pathname.match(/^\/api\/webhooks\/([^/]+)\/test$/) && req.method === 'POST') {
    const webhookId = url.pathname.split('/')[3];
    testWebhook(webhookId).then(result => {
      if (result.error) {
        res.writeHead(404, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: result.error }));
      } else {
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result, null, 2));
      }
    }).catch(e => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    });
    return;
  }
  else if (url.pathname.match(/^\/api\/webhooks\/([^/]+)\/logs$/) && req.method === 'GET') {
    const webhookId = url.pathname.split('/')[3];
    const limit = parseInt(url.searchParams.get('limit')) || 20;
    const logs = getWebhookLogs(webhookId, limit);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ webhookId, count: logs.length, logs }, null, 2));
  }
  // PATCH webhook (update URL, events, description, active)
  else if (url.pathname.match(/^\/api\/webhooks\/([^/]+)$/) && req.method === 'PATCH') {
    const webhookId = url.pathname.split('/')[3];
    trackApiCall('/api/webhooks/:id PATCH');
    
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    const keyInfo = requestKey ? validateApiKey(requestKey) : null;
    
    if (!keyInfo || !hasPermission(keyInfo, PERMISSIONS.ADMIN)) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Admin API key required' }));
      return;
    }
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const updates = JSON.parse(body);
        const result = updateWebhook(webhookId, updates);
        if (result.error) {
          res.writeHead(result.error === 'Webhook not found' ? 404 : 400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
        } else {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ message: 'Webhook updated', webhook: result.webhook }, null, 2));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  // Rate limit stats (admin endpoint)
  else if (url.pathname === '/api/admin/rate-limits') {
    const limitParam = parseInt(url.searchParams.get('limit')) || 100;
    const stats = getRateLimitStats();
    const blocked = getBlockedRequests(limitParam);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      ...stats,
      blockedRequestsHistory: blocked,
      rateLimits: RATE_LIMITS,
      securityConfig: {
        cspEnabled: true,
        xFrameOptions: 'SAMEORIGIN',
        xContentTypeOptions: 'nosniff',
        hstsEnabled: true
      }
    }, null, 2));
  }
  
  // ============ API KEYS ============
  
  // Create API key for a profile
  else if (url.pathname === '/api/keys' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body || '{}');
        const { profileId, permissions } = data;
        
        if (!profileId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'profileId required' }));
          return;
        }
        
        // Check if profile exists
        const profile = loadProfile(profileId);
        if (!profile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Profile not found' }));
          return;
        }
        
        // Check auth - admin can create any key, users can create their own
        const requestKey = extractApiKey(req);
        const keyInfo = validateApiKey(requestKey);
        
        if (!keyInfo?.isAdmin && keyInfo?.profileId !== profileId) {
          res.writeHead(403, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Can only create keys for your own profile' }));
          return;
        }
        
        // Non-admins can only create write_own keys
        const perm = keyInfo?.isAdmin ? (permissions || PERMISSIONS.write_own) : PERMISSIONS.write_own;
        
        const result = createApiKey(profileId, perm, { createdBy: keyInfo?.profileId || 'self' });
        
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({
          success: true,
          message: 'API key created. Save this key - it cannot be retrieved again!',
          apiKey: result.key,
          profileId: result.profileId,
          permissions: result.permissions
        }, null, 2));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // List API keys for a profile
  else if (url.pathname === '/api/keys' && req.method === 'GET') {
    const profileId = url.searchParams.get('profileId');
    
    if (!profileId) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'profileId query parameter required' }));
      return;
    }
    
    // Check auth
    const requestKey = extractApiKey(req);
    const keyInfo = validateApiKey(requestKey);
    
    if (!keyInfo?.isAdmin && keyInfo?.profileId !== profileId) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Can only list your own API keys' }));
      return;
    }
    
    const keys = listApiKeys(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ profileId, keys }, null, 2));
  }
  
  // Revoke an API key
  else if (url.pathname === '/api/keys/revoke' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body || '{}');
        const { keyId } = data;
        
        if (!keyId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'keyId required' }));
          return;
        }
        
        // Admin only for now (full hash required)
        const requestKey = extractApiKey(req);
        const keyInfo = validateApiKey(requestKey);
        
        if (!keyInfo?.isAdmin) {
          res.writeHead(403, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Admin access required to revoke keys' }));
          return;
        }
        
        const success = revokeApiKey(keyId);
        res.writeHead(success ? 200 : 404, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success, message: success ? 'Key revoked' : 'Key not found' }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // Get API key stats (admin)
  else if (url.pathname === '/api/admin/keys' && req.method === 'GET') {
    const requestKey = extractApiKey(req);
    const keyInfo = validateApiKey(requestKey);
    
    if (!keyInfo?.isAdmin) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Admin access required' }));
      return;
    }
    
    const stats = getKeyStats();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(stats, null, 2));
  }
  
  // Validate API key (check if valid)
  else if (url.pathname === '/api/keys/validate' && req.method === 'GET') {
    const requestKey = extractApiKey(req);
    const keyInfo = validateApiKey(requestKey);
    
    if (!keyInfo) {
      res.writeHead(401, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ valid: false, error: 'Invalid or missing API key' }));
      return;
    }
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      valid: true,
      profileId: keyInfo.profileId,
      permissions: keyInfo.permissions,
      isAdmin: keyInfo.isAdmin || false
    }, null, 2));
  }
  
  // ============ PROFILE CLAIMS ============
  
  // Check if a profile can be claimed
  // Self-Service Claim: Check eligibility + available methods
  else if (url.pathname === '/api/claims/eligible' && req.method === 'GET') {
    const profileId = url.searchParams.get('profileId');
    if (!profileId) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'profileId required' }));
      return;
    }
    const result = claimFlow.canClaim(profileId, DATA_DIR);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result, null, 2));
  }

  // Self-Service Claim: Initiate challenge
  else if (url.pathname === '/api/claims/initiate' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body || '{}');
        const { profileId, method, wallet } = data;
        if (!profileId || !method || !wallet) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'profileId, method, and wallet required' }));
          return;
        }
        const result = claimFlow.initiateClaim(profileId, method, wallet, DATA_DIR);
        res.writeHead(result.success ? 200 : 400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result, null, 2));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // Self-Service Claim: Verify proof and transfer ownership
  else if (url.pathname === '/api/claims/self-verify' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body || '{}');
        const { challengeId, proof } = data;
        if (!challengeId || !proof) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'challengeId and proof required' }));
          return;
        }
        const result = await claimFlow.verifyClaim(challengeId, proof, DATA_DIR);
        res.writeHead(result.success ? 200 : 400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result, null, 2));
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  else if (url.pathname === '/api/claims/check' && req.method === 'GET') {
    const profileId = url.searchParams.get('profileId');
    if (!profileId) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'profileId required' }));
      return;
    }
    
    const result = canClaim(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result, null, 2));
  }
  
  // Create a claim request
  else if (url.pathname === '/api/claims' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body || '{}');
        const { profileId, handle, email, method } = data;
        
        if (!profileId || !handle) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'profileId and handle required' }));
          return;
        }
        
        const result = createClaim(profileId, { handle, email, method });
        res.writeHead(result.error ? 400 : 201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result, null, 2));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // Get pending claims (admin)
  else if (url.pathname === '/api/claims' && req.method === 'GET') {
    const requestKey = extractApiKey(req);
    const keyInfo = validateApiKey(requestKey);
    
    if (!keyInfo?.isAdmin) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Admin access required' }));
      return;
    }
    
    cleanupExpiredClaims();
    const claims = getPendingClaims();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ count: claims.length, claims }, null, 2));
  }
  
  // Get a specific claim
  else if (url.pathname.startsWith('/api/claims/') && !url.pathname.includes('/verify') && !url.pathname.includes('/reject') && !url.pathname.includes('/check') && req.method === 'GET') {
    const claimId = url.pathname.replace('/api/claims/', '');
    const claim = getClaim(claimId);
    
    if (!claim) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Claim not found' }));
      return;
    }
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(claim, null, 2));
  }
  
  // Verify a claim (ADMIN ONLY)
  else if (url.pathname.match(/\/api\/claims\/[^\/]+\/verify/) && req.method === 'POST') {
    // SECURITY: Require admin API key for claim verification
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    const keyInfo = requestKey ? validateApiKey(requestKey) : null;
    
    if (!keyInfo || !hasPermission(keyInfo, PERMISSIONS.ADMIN)) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Admin API key required for claim verification' }));
      return;
    }
    
    const claimId = url.pathname.replace('/api/claims/', '').replace('/verify', '');
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body || '{}');
        const result = await verifyClaim(claimId, data);
        res.writeHead(result.error ? 400 : 200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result, null, 2));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // Reject a claim (admin)
  else if (url.pathname.match(/\/api\/claims\/[^\/]+\/reject/) && req.method === 'POST') {
    const requestKey = extractApiKey(req);
    const keyInfo = validateApiKey(requestKey);
    
    if (!keyInfo?.isAdmin) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Admin access required' }));
      return;
    }
    
    const claimId = url.pathname.replace('/api/claims/', '').replace('/reject', '');
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body || '{}');
        const result = rejectClaim(claimId, data.reason);
        res.writeHead(result.error ? 400 : 200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result, null, 2));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // ============ VERIFICATION REQUESTS ============
  
  // List all verification requests (with filters)
  else if (url.pathname === '/api/verification-requests' && req.method === 'GET') {
    trackApiCall('/api/verification-requests');
    const filters = {
      status: url.searchParams.get('status'),
      agentId: url.searchParams.get('agentId'),
      skillName: url.searchParams.get('skill'),
      limit: parseInt(url.searchParams.get('limit')) || 50
    };
    const requests = getVerificationRequests(filters);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ count: requests.length, requests }, null, 2));
  }
  
  // Get verification request stats
  else if (url.pathname === '/api/verification-requests/stats' && req.method === 'GET') {
    trackApiCall('/api/verification-requests/stats');
    const stats = getVerificationStats();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(stats, null, 2));
  }
  
  // Create a new verification request
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/request-verification$/) && req.method === 'POST') {
    const agentId = url.pathname.split('/')[3];
    trackApiCall('/api/profile/:id/request-verification');
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        
        if (!data.skillName) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'skillName is required' }));
          return;
        }
        
        // Verify the agent exists and has this skill
        const profile = loadProfile(agentId);
        if (!profile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Agent not found' }));
          return;
        }
        
        const skill = profile.skills.find(s => s.name.toLowerCase() === data.skillName.toLowerCase());
        if (!skill) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Skill not found on this profile' }));
          return;
        }
        
        if (skill.verified) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Skill is already verified' }));
          return;
        }
        
        const result = createVerificationRequest(agentId, data.skillName, data.proofs || [], data.notes || '');
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          // Log activity
          addActivity(agentId, ACTIVITY_TYPES.PROFILE_UPDATED, {
            action: 'verification_requested',
            skill: data.skillName
          }, DATA_DIR);
          
          // Trigger webhook
          triggerWebhooks('verification.requested', {
            agentId,
            skillName: data.skillName,
            requestId: result.request.id
          }).catch(e => logger.error('Webhook error', { error: e.message }));
          
          res.writeHead(201, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result, null, 2));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  
  // Get a single verification request
  else if (url.pathname.match(/^\/api\/verification-requests\/(\d+)$/) && req.method === 'GET') {
    const requestId = url.pathname.split('/')[3];
    trackApiCall('/api/verification-requests/:id');
    
    const request = getVerificationRequest(requestId);
    if (!request) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Request not found' }));
    } else {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(request, null, 2));
    }
  }
  
  // Add proof to an existing request
  else if (url.pathname.match(/^\/api\/verification-requests\/(\d+)\/proof$/) && req.method === 'POST') {
    const requestId = url.pathname.split('/')[3];
    trackApiCall('/api/verification-requests/:id/proof');
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const result = addProofToRequest(requestId, data);
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result, null, 2));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  
  // Approve a verification request (admin)
  else if (url.pathname.match(/^\/api\/verification-requests\/(\d+)\/approve$/) && req.method === 'POST') {
    // SECURITY: Require admin API key for verification approval
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    const keyInfo = requestKey ? validateApiKey(requestKey) : null;
    
    if (!keyInfo || !hasPermission(keyInfo, PERMISSIONS.ADMIN)) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Admin API key required for verification approval' }));
      return;
    }
    
    const requestId = url.pathname.split('/')[3];
    trackApiCall('/api/verification-requests/:id/approve');
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = body ? JSON.parse(body) : {};
        const result = approveRequest(requestId, data.reviewedBy, data.notes);
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          // Update the skill to verified on the profile
          const request = result.request;
          const profile = loadProfile(request.agentId);
          if (profile) {
            const skill = profile.skills.find(s => s.name.toLowerCase() === request.skillName.toLowerCase());
            if (skill) {
              skill.verified = true;
              skill.proofs = [...(skill.proofs || []), ...request.proofs.map(p => ({
                type: p.type,
                url: p.url,
                note: p.description,
                verifiedAt: new Date().toISOString()
              }))];
              
              // Save profile
              profile.updatedAt = new Date().toISOString();
              dbSaveProfileFn(profile);
              
              // Log activity
              addActivity(request.agentId, ACTIVITY_TYPES.SKILL_VERIFIED, {
                skill: request.skillName
              }, DATA_DIR);
            }
          }
          
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ ...result, profileUpdated: true }, null, 2));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  
  // Reject a verification request (admin)
  else if (url.pathname.match(/^\/api\/verification-requests\/(\d+)\/reject$/) && req.method === 'POST') {
    // SECURITY: Require admin API key for verification rejection
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    const keyInfo = requestKey ? validateApiKey(requestKey) : null;
    
    if (!keyInfo || !hasPermission(keyInfo, PERMISSIONS.ADMIN)) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Admin API key required for verification rejection' }));
      return;
    }
    
    const requestId = url.pathname.split('/')[3];
    trackApiCall('/api/verification-requests/:id/reject');
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = body ? JSON.parse(body) : {};
        const result = rejectRequest(requestId, data.reviewedBy, data.notes);
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result, null, 2));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  
  // Cancel a verification request (by agent)
  else if (url.pathname.match(/^\/api\/verification-requests\/(\d+)\/cancel$/) && req.method === 'POST') {
    const requestId = url.pathname.split('/')[3];
    trackApiCall('/api/verification-requests/:id/cancel');
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = body ? JSON.parse(body) : {};
        if (!data.agentId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'agentId is required' }));
          return;
        }
        
        const result = cancelVerificationRequest(requestId, data.agentId);
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result, null, 2));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  
  // Verification requests page (UI)
  else if (url.pathname === '/verification-requests') {
    trackProfileView('_verification_requests');
    const statusFilter = url.searchParams.get('status') || 'pending';
    const requests = getVerificationRequests({ status: statusFilter === 'all' ? null : statusFilter, limit: 100 });
    const stats = getVerificationStats();
    
    const html = `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verification Requests | AgentFolio</title>
  ${COMMON_STYLES}
${THEME_SCRIPT}
  <style>
    .request-card {
      background: #18181b;
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 16px;
      border: 1px solid #27272a;
    }
    .request-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 12px;
    }
    .request-skill {
      font-size: 18px;
      font-weight: 600;
      color: #fff;
    }
    .request-agent {
      color: #06b6d4;
      font-size: 14px;
    }
    .request-status {
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
    }
    .status-pending { background: #f59e0b20; color: #f59e0b; }
    .status-approved { background: #10b98120; color: #10b981; }
    .status-rejected { background: #ef444420; color: #ef4444; }
    .proofs-list {
      margin: 12px 0;
      padding-left: 20px;
    }
    .proof-item {
      color: #a1a1aa;
      font-size: 14px;
      margin-bottom: 4px;
    }
    .proof-item a { color: #06b6d4; }
    .request-meta {
      font-size: 12px;
      color: #71717a;
      margin-top: 12px;
    }
    .stats-bar {
      display: flex;
      gap: 24px;
      margin-bottom: 32px;
      padding: 20px;
      background: #18181b;
      border-radius: 12px;
    }
    .stat-item {
      text-align: center;
    }
    .stat-number {
      font-size: 28px;
      font-weight: 700;
      color: #fff;
    }
    .stat-label {
      font-size: 12px;
      color: #71717a;
      text-transform: uppercase;
    }
    .filter-tabs {
      display: flex;
      gap: 8px;
      margin-bottom: 24px;
    }
    .filter-tab {
      padding: 8px 16px;
      border-radius: 8px;
      color: #a1a1aa;
      font-weight: 500;
      transition: all 0.2s;
    }
    .filter-tab:hover { background: #27272a; color: #fff; }
    .filter-tab.active { background: #a78bfa; color: #fff; }
    .notes-text {
      color: #a1a1aa;
      font-style: italic;
      margin: 8px 0;
    }
  </style>
</head>
<body>
  <header class="header">
    <div class="container header-inner">
      <a href="/" class="logo">
        <div class="logo-icon"><img src="/public/img/logo-eye.png" alt="AgentFolio" style="width:30px;height:20px;"></div>
        <span class="gradient-text">AgentFolio</span>
      </a>
      <nav class="nav">
        <a href="/">Directory</a>
        <a href="/leaderboard">Leaderboard</a>
        <a href="/skills">Skills</a>
        <a href="/verification-requests" style="color:#fff">Requests</a>
        <a href="/api/docs">API</a>
      </nav>
    </div>
  </header>
  
  <main class="container" style="padding: 40px 24px;">
    <h1 style="font-size: 32px; margin-bottom: 24px;">Verification Requests</h1>
    
    <div class="stats-bar">
      <div class="stat-item">
        <div class="stat-number">${stats.pending}</div>
        <div class="stat-label">Pending</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">${stats.approved}</div>
        <div class="stat-label">Approved</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">${stats.rejected}</div>
        <div class="stat-label">Rejected</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">${stats.total}</div>
        <div class="stat-label">Total</div>
      </div>
    </div>
    
    <div class="filter-tabs">
      <a href="/verification-requests?status=pending" class="filter-tab ${statusFilter === 'pending' ? 'active' : ''}">Pending</a>
      <a href="/verification-requests?status=approved" class="filter-tab ${statusFilter === 'approved' ? 'active' : ''}">Approved</a>
      <a href="/verification-requests?status=rejected" class="filter-tab ${statusFilter === 'rejected' ? 'active' : ''}">Rejected</a>
      <a href="/verification-requests?status=all" class="filter-tab ${statusFilter === 'all' ? 'active' : ''}">All</a>
    </div>
    
    ${requests.length === 0 ? `
      <div style="text-align: center; padding: 60px 0; color: #71717a;">
        <p>No ${statusFilter} verification requests</p>
      </div>
    ` : requests.map(r => `
      <div class="request-card">
        <div class="request-header">
          <div>
            <div class="request-skill">${r.skillName}</div>
            <a href="/profile/${r.agentId}" class="request-agent">${r.agentId}</a>
          </div>
          <span class="request-status status-${r.status}">${r.status}</span>
        </div>
        ${r.notes ? `<p class="notes-text">"${r.notes}"</p>` : ''}
        ${r.proofs && r.proofs.length > 0 ? `
          <div class="proofs-list">
            <strong style="color: #a1a1aa; font-size: 12px;">PROOFS:</strong>
            ${r.proofs.map(p => `
              <div class="proof-item">
                • ${p.type}${p.url ? `: <a href="${p.url}" target="_blank">${p.url}</a>` : ''}
                ${p.description ? ` - ${p.description}` : ''}
              </div>
            `).join('')}
          </div>
        ` : ''}
        <div class="request-meta">
          Submitted ${new Date(r.createdAt).toLocaleDateString()} at ${new Date(r.createdAt).toLocaleTimeString()}
          ${r.reviewedAt ? ` • Reviewed ${new Date(r.reviewedAt).toLocaleDateString()} by ${r.reviewedBy}` : ''}
        </div>
      </div>
    `).join('')}
  </main>
</body>
</html>`;
    
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(html);
  }
  
  // ============ COLLABORATIONS ============
  
  // Get collaborations for an agent
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/collaborations$/) && req.method === 'GET') {
    const agentId = url.pathname.split('/')[3];
    trackApiCall('/api/profile/:id/collaborations');
    
    const profile = loadProfile(agentId);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Agent not found' }));
      return;
    }
    
    const includeAll = url.searchParams.get('all') === 'true';
    const collabs = getAgentCollaborations(agentId, { confirmedOnly: !includeAll }, DATA_DIR);
    
    // Enrich with agent names
    const enriched = collabs.map(c => {
      const otherAgentId = c.agents.find(a => a !== agentId);
      const otherAgent = loadProfile(otherAgentId);
      return {
        ...c,
        collaborator: otherAgent ? {
          id: otherAgent.id,
          name: otherAgent.name,
          handle: otherAgent.handle
        } : { id: otherAgentId, name: 'Unknown', handle: '' }
      };
    });
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ count: enriched.length, collaborations: enriched }, null, 2));
  }
  
  // Create a collaboration
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/collaborations$/) && req.method === 'POST') {
    const fromAgentId = url.pathname.split('/')[3];
    trackApiCall('/api/profile/:id/collaborations');
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        
        if (!data.withAgent) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'withAgent is required' }));
          return;
        }
        
        if (!data.project?.name) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'project.name is required' }));
          return;
        }
        
        // Verify both agents exist
        const fromProfile = loadProfile(fromAgentId);
        const toProfile = loadProfile(data.withAgent);
        
        if (!fromProfile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Initiating agent not found' }));
          return;
        }
        
        if (!toProfile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Target agent not found' }));
          return;
        }
        
        const result = createCollaboration(fromAgentId, data.withAgent, {
          name: data.project.name,
          description: data.project.description,
          url: data.project.url,
          type: data.project.type,
          startDate: data.project.startDate,
          endDate: data.project.endDate,
          myRole: data.myRole,
          theirRole: data.theirRole
        });
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          // Log activity
          addActivity(fromAgentId, ACTIVITY_TYPES.PROFILE_UPDATED, {
            action: 'collaboration_requested',
            with: toProfile.name,
            project: data.project.name
          }, DATA_DIR);
          
          res.writeHead(201, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result, null, 2));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  
  // Confirm a collaboration
  else if (url.pathname.match(/^\/api\/collaborations\/(\d+)\/confirm$/) && req.method === 'POST') {
    const collabId = url.pathname.split('/')[3];
    trackApiCall('/api/collaborations/:id/confirm');
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = body ? JSON.parse(body) : {};
        
        if (!data.agentId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'agentId is required' }));
          return;
        }
        
        const result = confirmCollab(collabId, data.agentId);
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          // Log activity for both agents
          const collab = result.collaboration;
          collab.agents.forEach(agentId => {
            const otherAgent = collab.agents.find(a => a !== agentId);
            const otherProfile = loadProfile(otherAgent);
            addActivity(agentId, ACTIVITY_TYPES.PROFILE_UPDATED, {
              action: 'collaboration_confirmed',
              with: otherProfile?.name || otherAgent,
              project: collab.project.name
            }, DATA_DIR);
          });
          
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result, null, 2));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  
  // Decline a collaboration
  else if (url.pathname.match(/^\/api\/collaborations\/(\d+)\/decline$/) && req.method === 'POST') {
    const collabId = url.pathname.split('/')[3];
    trackApiCall('/api/collaborations/:id/decline');
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = body ? JSON.parse(body) : {};
        
        if (!data.agentId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'agentId is required' }));
          return;
        }
        
        const result = declineCollab(collabId, data.agentId);
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result, null, 2));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  
  // Get pending collaboration requests for an agent
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/collaborations\/pending$/) && req.method === 'GET') {
    const agentId = url.pathname.split('/')[3];
    trackApiCall('/api/profile/:id/collaborations/pending');
    
    const pending = getPendingCollabs(agentId);
    
    // Enrich with initiator info
    const enriched = pending.map(c => {
      const initiator = loadProfile(c.initiatedBy);
      return {
        ...c,
        initiator: initiator ? {
          id: initiator.id,
          name: initiator.name,
          handle: initiator.handle
        } : { id: c.initiatedBy, name: 'Unknown', handle: '' }
      };
    });
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ count: enriched.length, pending: enriched }, null, 2));
  }
  
  // Get collaboration stats
  else if (url.pathname === '/api/collaborations/stats' && req.method === 'GET') {
    trackApiCall('/api/collaborations/stats');
    const stats = getCollaborationStats(DATA_DIR);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(stats, null, 2));
  }
  
  // Get collaborations between two agents
  else if (url.pathname === '/api/collaborations/between' && req.method === 'GET') {
    trackApiCall('/api/collaborations/between');
    const agent1 = url.searchParams.get('agent1');
    const agent2 = url.searchParams.get('agent2');
    
    if (!agent1 || !agent2) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'agent1 and agent2 are required' }));
      return;
    }
    
    const collabs = getCollaborationsBetween(agent1, agent2);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ count: collabs.length, collaborations: collabs }, null, 2));
  }
  
  // Get a single collaboration
  else if (url.pathname.match(/^\/api\/collaborations\/(\d+)$/) && req.method === 'GET') {
    const collabId = url.pathname.split('/')[3];
    trackApiCall('/api/collaborations/:id');
    
    const collab = getCollaboration(collabId);
    if (!collab) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Collaboration not found' }));
    } else {
      // Enrich with agent info
      const enriched = {
        ...collab,
        participants: collab.agents.map(agentId => {
          const profile = loadProfile(agentId);
          return profile ? {
            id: profile.id,
            name: profile.name,
            handle: profile.handle,
            role: collab.roles[agentId]
          } : { id: agentId, name: 'Unknown', handle: '', role: collab.roles[agentId] };
        })
      };
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(enriched, null, 2));
    }
  }
  
  // Weekly digest endpoints
  else if (url.pathname === '/api/digest/send' && req.method === 'POST') {
    // Trigger digest send (requires API key)
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body || '{}');
        const apiKey = req.headers['x-api-key'] || data.apiKey;
        
        // SECURITY: Admin API key required (removed insecure 'admin' fallback)
        const keyInfo = apiKey ? validateApiKey(apiKey) : null;
        if (!keyInfo || !hasPermission(keyInfo, PERMISSIONS.ADMIN)) {
          res.writeHead(401, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Unauthorized - admin API key required' }));
          return;
        }
        
        const { runWeeklyDigest } = require('./weekly-digest');
        const options = {
          dryRun: data.dryRun || false,
          targetId: data.targetId || null
        };
        
        runWeeklyDigest(options).then(results => {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ success: true, results }));
        }).catch(err => {
          res.writeHead(500, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: err.message }));
        });
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
  }
  
  else if (url.pathname === '/api/digest/status' && req.method === 'GET') {
    // Get digest status
    const DIGEST_STATE_FILE = path.join(__dirname, '..', 'data', 'digest-state.json');
    let state = { lastRun: null, lastResults: null };
    if (fs.existsSync(DIGEST_STATE_FILE)) {
      state = JSON.parse(fs.readFileSync(DIGEST_STATE_FILE, 'utf8'));
    }
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(state, null, 2));
  }
  
  else if (url.pathname === '/api/digest/preview' && req.method === 'GET') {
    // Preview digest for a profile
    const targetId = url.searchParams.get('id');
    if (!targetId) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'id parameter required' }));
      return;
    }
    
    const profile = loadProfile(targetId);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    
    const { generateDigestEmail, getWeeklyStats } = require('./weekly-digest');
    const ANALYTICS_FILE = path.join(__dirname, '..', 'data', 'analytics.json');
    let analytics = { profileViews: {}, apiCalls: {} };
    if (fs.existsSync(ANALYTICS_FILE)) {
      analytics = JSON.parse(fs.readFileSync(ANALYTICS_FILE, 'utf8'));
    }
    const profiles = listProfiles();
    const stats = getWeeklyStats(profile, analytics, profiles);
    const featuredAgent = profiles.reduce((best, p) => {
      const activity = (p.activity || []).length;
      return activity > (best?.activity?.length || 0) ? p : best;
    }, null);
    
    const email = generateDigestEmail(profile, stats, featuredAgent);
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      profile: profile.name,
      email: profile.links?.agentmail,
      stats,
      preview: email
    }, null, 2));
  }
  
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/digest-preferences$/) && req.method === 'GET') {
    // Get digest preferences for a profile
    const digestProfileMatch = url.pathname.match(/^\/api\/profile\/([^/]+)\/digest-preferences$/);
    const profile = loadProfile(digestProfileMatch[1]);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      profileId: profile.id,
      email: profile.links?.agentmail || null,
      digestEnabled: profile.digestPreferences?.enabled ?? true,
      frequency: profile.digestPreferences?.frequency ?? 'weekly'
    }, null, 2));
  }
  
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/digest-preferences$/) && req.method === 'POST') {
    // Update digest preferences
    const digestPostMatch = url.pathname.match(/^\/api\/profile\/([^/]+)\/digest-preferences$/);
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body || '{}');
        const profileId = digestPostMatch[1];
        
        const profile = loadProfile(profileId);
        if (!profile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Profile not found' }));
          return;
        }
        
        profile.digestPreferences = {
          enabled: data.enabled ?? profile.digestPreferences?.enabled ?? true,
          frequency: data.frequency ?? profile.digestPreferences?.frequency ?? 'weekly'
        };
        profile.updatedAt = new Date().toISOString();
        dbSaveProfileFn(profile);
        
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({
          success: true,
          digestPreferences: profile.digestPreferences
        }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // ========== FOLLOW SYSTEM ==========
  
  // Follow a profile
  else if (url.pathname === '/api/follow' && req.method === 'POST') {
    // SECURITY: Require API key if follower is an agent
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    
    trackApiCall('/api/follow');
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { followerId, targetId, followerType } = JSON.parse(body);
        
        if (!followerId || !targetId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'followerId and targetId are required' }));
          return;
        }
        
        // If follower is an agent profile, verify API key ownership
        if (followerId.startsWith('agent_')) {
          const keyInfo = requestKey ? validateApiKey(requestKey) : null;
          if (!keyInfo || keyInfo.profileId !== followerId) {
            res.writeHead(403, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ error: 'API key required to follow as an agent. Key must belong to the follower profile.' }));
            return;
          }
        }
        
        const result = followProfile(followerId, targetId, followerType || 'user');
        
        if (result.success) {
          // Broadcast follow activity
          broadcastActivity({
            type: 'follow',
            profileId: targetId,
            data: { followerId, followerType: followerType || 'user' }
          });
          
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // Unfollow a profile
  else if (url.pathname === '/api/unfollow' && req.method === 'POST') {
    // SECURITY: Require API key if unfollower is an agent
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    
    trackApiCall('/api/unfollow');
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { followerId, targetId } = JSON.parse(body);
        
        if (!followerId || !targetId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'followerId and targetId are required' }));
          return;
        }
        
        // If unfollower is an agent profile, verify API key ownership
        if (followerId.startsWith('agent_')) {
          const keyInfo = requestKey ? validateApiKey(requestKey) : null;
          if (!keyInfo || keyInfo.profileId !== followerId) {
            res.writeHead(403, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ error: 'API key required to unfollow as an agent. Key must belong to the follower profile.' }));
            return;
          }
        }
        
        const result = unfollowProfile(followerId, targetId);
        res.writeHead(result.success ? 200 : 400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // Check if following
  else if (url.pathname === '/api/follow/check' && req.method === 'GET') {
    trackApiCall('/api/follow/check');
    const followerId = url.searchParams.get('followerId');
    const targetId = url.searchParams.get('targetId');
    
    if (!followerId || !targetId) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'followerId and targetId are required' }));
      return;
    }
    
    const following = isFollowing(followerId, targetId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ following }));
  }
  
  // Get followers of a profile
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/followers$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    trackApiCall('/api/profile/:id/followers');
    
    const followers = getFollowers(profileId);
    const count = getFollowerCount(profileId);
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ profileId, count, followers }, null, 2));
  }
  
  // Get profiles a user is following
  else if (url.pathname.match(/^\/api\/following\/([^/]+)$/) && req.method === 'GET') {
    const followerId = url.pathname.split('/')[3];
    trackApiCall('/api/following/:id');
    
    const following = getFollowing(followerId);
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ followerId, count: following.length, following }, null, 2));
  }
  
  // Get most followed profiles
  else if (url.pathname === '/api/follows/top' && req.method === 'GET') {
    trackApiCall('/api/follows/top');
    const limit = parseInt(url.searchParams.get('limit')) || 10;
    
    const top = getMostFollowed(limit);
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ count: top.length, profiles: top }, null, 2));
  }
  
  // ========== FEATURE REQUESTS ==========
  
  // Feature requests page
  else if (url.pathname === '/feedback' || url.pathname === '/feature-requests') {
    trackApiCall('/feedback');
    const requests = getFeatureRequests();
    const stats = getFeedbackStats();
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateFeedbackPage(requests, stats));
  }
  
  // Submit feature request
  else if (url.pathname === '/api/feedback' && req.method === 'POST') {
    trackApiCall('/api/feedback');
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        if (!data.title) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Title is required' }));
          return;
        }
        const request = submitFeatureRequest(data);
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true, request }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // Get feature requests
  else if (url.pathname === '/api/feedback' && req.method === 'GET') {
    trackApiCall('/api/feedback');
    const status = url.searchParams.get('status');
    const category = url.searchParams.get('category');
    const limit = parseInt(url.searchParams.get('limit')) || 50;
    const requests = getFeatureRequests({ status, category, limit });
    const stats = getFeedbackStats();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ stats, requests }, null, 2));
  }
  
  // Vote on request
  else if (url.pathname === '/api/feedback/vote' && req.method === 'POST') {
    trackApiCall('/api/feedback/vote');
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { requestId, voterId } = JSON.parse(body);
        if (!requestId || !voterId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'requestId and voterId required' }));
          return;
        }
        const result = voteRequest(requestId, voterId);
        res.writeHead(result.success ? 200 : 400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // Serve skill.md for agent self-onboarding
  else if (url.pathname === '/skill.md') {
    const filePath = path.join(__dirname, '..', 'public', 'skill.md');
    if (fs.existsSync(filePath)) {
      res.writeHead(200, { 
        'Content-Type': 'text/markdown; charset=utf-8',
        'Cache-Control': 'public, max-age=3600'
      });
      fs.createReadStream(filePath).pipe(res);
    } else {
      res.writeHead(404, { 'Content-Type': 'text/plain' });
      res.end('skill.md not found');
    }
  }
  // Serve heartbeat.md for ongoing engagement
  else if (url.pathname === '/heartbeat.md') {
    const filePath = path.join(__dirname, '..', 'public', 'heartbeat.md');
    if (fs.existsSync(filePath)) {
      res.writeHead(200, { 
        'Content-Type': 'text/markdown; charset=utf-8',
        'Cache-Control': 'public, max-age=3600'
      });
      fs.createReadStream(filePath).pipe(res);
    } else {
      res.writeHead(404, { 'Content-Type': 'text/plain' });
      res.end('heartbeat.md not found');
    }
  }
  // Avatar CDN (optimized serving with cache headers)
  else if (url.pathname.startsWith('/avatars/')) {
    serveAvatar(req, res, url.pathname);
  }
  // Static files (js, css, images)
  else if (url.pathname === '/mint' || url.pathname === '/mint/') {
    const mintPath = require('path').join(__dirname, '..', 'public', 'mint', 'index.html');
    if (require('fs').existsSync(mintPath)) {
      res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8' });
      require('fs').createReadStream(mintPath).pipe(res);
    } else {
      res.writeHead(404); res.end('Mint page not found');
    }
  }
  else if (url.pathname.startsWith('/public/')) {
    const filePath = path.join(__dirname, '..', url.pathname);
    if (fs.existsSync(filePath)) {
      const ext = path.extname(filePath).toLowerCase();
      const mimeTypes = {
        '.jpg': 'image/jpeg', '.jpeg': 'image/jpeg', '.png': 'image/png',
        '.gif': 'image/gif', '.webp': 'image/webp', '.js': 'application/javascript',
        '.css': 'text/css', '.svg': 'image/svg+xml', '.woff2': 'font/woff2', '.woff': 'font/woff'
      };
      res.writeHead(200, { 
        'Content-Type': mimeTypes[ext] || 'application/octet-stream',
        'Cache-Control': 'public, max-age=86400'
      });
      fs.createReadStream(filePath).pipe(res);
    } else {
      res.writeHead(404, { 'Content-Type': 'text/plain' });
      res.end('Not found');
    }
  }
  
  // ============ MARKETPLACE ROUTES ============
  
  // Marketplace page
  // ===== BOUNTY BOARD PAGE =====
  else if (url.pathname === '/bounties') {
    const filters = {
      category: url.searchParams.get('category') || '',
      search: url.searchParams.get('q') || '',
      status: url.searchParams.get('status') || 'open',
      page: parseInt(url.searchParams.get('page')) || 1
    };
    const bounties = listBounties(filters);
    const leaderboard = getBountyLeaderboard(10);
    const enrichedLeaderboard = leaderboard.map(entry => {
      const profile = loadProfile(entry.agentId);
      return { ...entry, name: profile?.name, handle: profile?.handle, avatar: profile?.avatar };
    });
    
    // Enrich bounties with client info
    const enrichedBounties = bounties.jobs.map(b => {
      const client = loadProfile(b.clientId);
      const db = require('./lib/database');
      const subCount = db.getBountySubmissionCount(b.id);
      return { ...b, clientName: client?.name, clientHandle: client?.handle, submissionCount: subCount };
    });
    
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateBountyBoardPage(enrichedBounties, bounties.total, filters, enrichedLeaderboard));
  }
  
  else if (url.pathname === '/marketplace') {
    const filters = {
      category: url.searchParams.get('category') || '',
      search: url.searchParams.get('q') || '',
      skills: url.searchParams.get('skills') || '',
      minBudget: url.searchParams.get('minBudget') ? parseFloat(url.searchParams.get('minBudget')) : null,
      maxBudget: url.searchParams.get('maxBudget') ? parseFloat(url.searchParams.get('maxBudget')) : null,
      sortBy: url.searchParams.get('sortBy') || 'createdAt',
      sortDir: url.searchParams.get('sortDir') || 'desc',
      status: url.searchParams.get('status') || 'open',
      page: parseInt(url.searchParams.get('page')) || 1
    };
    
    // Parse skills into array for filtering
    const skillsArray = filters.skills ? filters.skills.split(',').map(s => s.trim().toLowerCase()).filter(Boolean) : [];
    
    const jobs = listJobs({ 
      category: filters.category, 
      search: filters.search, 
      skills: skillsArray,
      minBudget: filters.minBudget,
      maxBudget: filters.maxBudget,
      sortBy: filters.sortBy,
      sortDir: filters.sortDir,
      status: filters.status,
      page: filters.page
    });
    
    // Collect all unique skills from jobs for the filter dropdown
    const allJobs = listJobs({ status: 'all', limit: 1000 });
    const allSkills = [...new Set(allJobs.jobs.flatMap(j => j.skills || []))].sort();
    
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateMarketplacePage(jobs, filters, allSkills));
  }
  
  // Post a job page
  else if (url.pathname === '/marketplace/post') {
    const hireAgentId = url.searchParams.get('hire');
    const hireAgent = hireAgentId ? loadProfile(hireAgentId, DATA_DIR) : null;
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generatePostJobPage(hireAgent));
  }
  
  // Job detail page
  else if (url.pathname.match(/^\/marketplace\/job\/([^/]+)$/)) {
    const jobId = url.pathname.split('/')[3];
    const job = loadJob(jobId);
    if (!job) {
      res.writeHead(404, { 'Content-Type': 'text/html' });
      res.end('<h1>Job not found</h1>');
      return;
    }
    incrementJobViews(jobId);
    const applications = loadApplications(jobId);
    const clientProfile = loadProfile(job.clientId, DATA_DIR);
    const reviews = getJobReviews(jobId);
    const agentProfile = job.selectedAgentId ? loadProfile(job.selectedAgentId, DATA_DIR) : null;
    // Fetch recommended agents for this job (skill-based matching)
    getAgentRecommendationsForJob(jobId, { limit: 5, minScore: 30 }).then(agentRecs => {
      res.writeHead(200, { 'Content-Type': 'text/html' });
      res.end(generateJobDetailPage(job, applications, clientProfile, reviews, agentProfile, agentRecs.recommendations || []));
    }).catch(err => {
      logger.error('Failed to get agent recommendations', { error: err.message, jobId });
      res.writeHead(200, { 'Content-Type': 'text/html' });
      res.end(generateJobDetailPage(job, applications, clientProfile, reviews, agentProfile, []));
    });
  }
  
  // Dispute center
  else if (url.pathname === '/marketplace/disputes') {
    const profileId = url.searchParams.get('profile');
    const allDisputes = listDisputes();
    let userDisputes = allDisputes;
    if (profileId) {
      userDisputes = allDisputes.filter(d => {
        const esc = loadEscrow(d.escrowId);
        return esc && (esc.clientId === profileId || esc.agentId === profileId || d.openedBy === profileId);
      });
    }
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateDisputeCenterPage(profileId, userDisputes));
  }

  // Dispute detail page
  else if (url.pathname.match(/^\/marketplace\/dispute\/([^/]+)$/)) {
    const disputeId = url.pathname.split('/')[3];
    const dispute = loadDispute(disputeId);
    if (!dispute) {
      res.writeHead(404, { 'Content-Type': 'text/html' });
      res.end('<h1>Dispute not found</h1>');
      return;
    }
    const dEscrow = loadEscrow(dispute.escrowId);
    const dJob = loadJob(dispute.jobId);
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateDisputeDetailPage(dispute, dEscrow, dJob));
  }

  // My jobs page
  else if (url.pathname === '/marketplace/my-jobs') {
    const profileId = url.searchParams.get('profile');
    if (!profileId) {
      res.writeHead(400, { 'Content-Type': 'text/html' });
      res.end('<h1>Profile ID required</h1>');
      return;
    }
    const clientJobs = listJobs({ clientId: profileId, status: 'all' });
    const agentApps = getAgentApplications(profileId);
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateMyJobsPage(profileId, clientJobs.jobs, agentApps));
  }
  
  // API: List jobs
  else if (url.pathname === '/api/marketplace/jobs' && req.method === 'GET') {
    const filters = {
      status: url.searchParams.get('status') || 'open',
      category: url.searchParams.get('category'),
      skills: url.searchParams.get('skills')?.split(',').filter(Boolean),
      clientId: url.searchParams.get('clientId'),
      search: url.searchParams.get('q'),
      minBudget: url.searchParams.get('minBudget') ? parseFloat(url.searchParams.get('minBudget')) : null,
      maxBudget: url.searchParams.get('maxBudget') ? parseFloat(url.searchParams.get('maxBudget')) : null,
      sortBy: url.searchParams.get('sortBy'),
      sortDir: url.searchParams.get('sortDir'),
      page: parseInt(url.searchParams.get('page')) || 1,
      limit: Math.min(parseInt(url.searchParams.get('limit')) || 20, 100)
    };
    const result = listJobs(filters);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result));
  }
  
  // API: Create job
  else if (url.pathname === '/api/marketplace/jobs' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        if (!data.clientId || !data.title || !data.description) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'clientId, title, and description are required' }));
          return;
        }
        const job = createJob(data);
        
        // If job is immediately OPEN (no escrow required), notify matching agents
        if (job && !job.error && job.status === 'open') {
          // Email notifications
          notifyMatchingAgents(job).catch(e => 
            logger.error('Error notifying matching agents', { error: e.message })
          );
          // Webhook notifications
          notifyMatchingAgentsWebhook(job).catch(e =>
            console.error('[Agent Webhook] Error notifying matching agents:', e.message)
          );
          // Discord server notifications
          notifyDiscordServers(job).catch(e =>
            console.error('[Discord] Error notifying Discord servers:', e.message)
          );
        }
        
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(job));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // API: Get single job
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)$/) && req.method === 'GET') {
    const jobId = url.pathname.split('/')[4];
    const job = loadJob(jobId);
    if (!job) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Job not found' }));
      return;
    }
    const apps = loadApplications(jobId);
    job.applications = apps || [];
    res.writeHead(200, { "Content-Type": "application/json" });
    res.end(JSON.stringify(job));


  }
  
  // API: Update job
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)$/) && req.method === 'PATCH') {
    const jobId = url.pathname.split('/')[4];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const updates = JSON.parse(body);
        const job = updateJob(jobId, updates);
        if (!job) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Job not found' }));
          return;
        }
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(job));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // API: Cancel job
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/cancel$/) && req.method === 'POST') {
    const jobId = url.pathname.split('/')[4];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const cancelData = JSON.parse(body || '{}');
        // Auth: only job owner can cancel
        const jobToCancel = loadJob(jobId);
        if (!jobToCancel) { res.writeHead(404, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'Job not found' })); return; }
        if (!cancelData.clientId || cancelData.clientId !== jobToCancel.clientId) {
          res.writeHead(403, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Only the job owner can cancel a job' }));
          return;
        }
        const result = cancelJob(jobId, cancelData.reason);
        if (result?.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
          return;
        }
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // API: Submit deliverables for a job
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/submit$/) && req.method === 'POST') {
    const jobId = url.pathname.split('/')[4];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body || '{}');
        const job = loadJob(jobId);
        if (!job) { res.writeHead(404, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'Job not found' })); return; }
        if (!data.agentId) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'agentId is required' })); return; }
        if (job.selectedAgentId !== data.agentId) {
          res.writeHead(403, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Only the assigned agent can submit work' }));
          return;
        }
        if (job.status !== 'in_progress') {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: `Job status is '${job.status}', must be 'in_progress' to submit` }));
          return;
        }
        const result = submitJobWork(jobId, {
          agentId: data.agentId,
          deliverableHash: data.deliverableHash || '',
          deliverableUrl: data.deliverableUrl || ''
        });
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // API: Complete job
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/complete$/) && req.method === 'POST') {
    const jobId = url.pathname.split('/')[4];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body || '{}');
        // Auth: only job owner can complete
        const jobToComplete = loadJob(jobId);
        if (!jobToComplete) { res.writeHead(404, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'Job not found' })); return; }
        if (!data.clientId || data.clientId !== jobToComplete.clientId) {
          res.writeHead(403, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Only the job owner can complete a job' }));
          return;
        }
        const result = await completeJob(jobId, data);
        if (result?.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
          return;
        }
        
        // Send completion notifications to both parties
        const completedJob = result.job || loadJob(jobId);
        if (completedJob && completedJob.selectedAgentId) {
          const agentProfile = loadProfile(completedJob.selectedAgentId);
          const clientProfile = loadProfile(completedJob.clientId);
          if (agentProfile && clientProfile) {
            notifyJobCompleted(completedJob, agentProfile, clientProfile).catch(e =>
              logger.error('Failed to notify job completed', { error: e.message })
            );
          }
        }
        
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // API: Get job applications
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/applications$/) && req.method === 'GET') {
    const jobId = url.pathname.split('/')[4];
    const job = loadJob(jobId);
    if (!job) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Job not found' }));
      return;
    }
    const applications = loadApplications(jobId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(applications));
  }
  
  // API: Apply to job
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/(apply|applications)$/) && req.method === 'POST') {
    const jobId = url.pathname.split('/')[4];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        if (!data.agentId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'agentId is required' }));
          return;
        }
        const result = createApplication(jobId, data);
        if (result?.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
          return;
        }
        
        // Send notification to job owner
        const job = loadJob(jobId);
        const applicantProfile = loadProfile(data.agentId);
        if (job && applicantProfile) {
          // Email notification
          notifyNewApplication(job, result, applicantProfile).catch(e => 
            logger.error('Failed to notify new application', { error: e.message })
          );
          // Webhook notification
          const clientProfile = loadProfile(job.clientId);
          if (clientProfile) {
            notifyNewApplicationWebhook(job.clientId, job, result, applicantProfile).catch(e =>
              console.error('[Agent Webhook] Failed to notify new application:', e.message)
            );
          }
        }
        
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // API: Select winner
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/select\/([^/]+)$/) && req.method === 'POST') {
    const parts = url.pathname.split('/');
    const jobId = parts[4];
    const appId = parts[6];
    
    // Auth: verify caller is job owner
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body || '{}');
        const job = loadJob(jobId);
        if (!job) { res.writeHead(404, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'Job not found' })); return; }
        if (!data.clientId || data.clientId !== job.clientId) {
          res.writeHead(403, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Only the job owner can select a winner' }));
          return;
        }
        
        const result = selectWinner(jobId, appId);
        if (result?.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
          return;
        }
    
        // Send notification to selected agent
        const selJob = loadJob(jobId);
        if (selJob && selJob.selectedAgentId) {
          const agentProfile = loadProfile(selJob.selectedAgentId);
          const clientProfile = loadProfile(selJob.clientId);
          if (agentProfile && clientProfile) {
            notifyJobAssigned(selJob, agentProfile, clientProfile).catch(e =>
              logger.error('Failed to notify job assigned', { error: e.message })
            );
            notifyJobAssignedWebhook(selJob.selectedAgentId, selJob, clientProfile).catch(e =>
              console.error('[Agent Webhook] Failed to notify job assigned:', e.message)
            );
          }
        }
    
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // API: Leave review
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/review$/) && req.method === 'POST') {
    const jobId = url.pathname.split('/')[4];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        data.jobId = jobId;
        const result = createReview(data);
        if (result?.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
          return;
        }
        
        // Send notification to the person being reviewed
        const job = loadJob(jobId);
        const reviewerProfile = loadProfile(result.reviewerId);
        if (job && reviewerProfile) {
          // Email notification
          notifyNewReview(job, result, reviewerProfile).catch(e =>
            logger.error('Failed to notify new review', { error: e.message })
          );
          // Webhook notification - determine recipient (the person being reviewed)
          const recipientId = result.type === 'client_to_agent' ? job.selectedAgentId : job.clientId;
          if (recipientId) {
            notifyReviewWebhook(recipientId, reviewerProfile, result, job).catch(e =>
              console.error('[Agent Webhook] Failed to notify new review:', e.message)
            );
          }
        }
        
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // API: Get marketplace stats for profile
  else if (url.pathname.match(/^\/api\/marketplace\/stats\/([^/]+)$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[4];
    const stats = getMarketplaceStats(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(stats));
  }
  
  // API: Get agent's applications
  else if (url.pathname.match(/^\/api\/marketplace\/applications\/([^/]+)$/) && req.method === 'GET') {
    const agentId = url.pathname.split('/')[4];
    const status = url.searchParams.get('status');
    const applications = getAgentApplications(agentId, status);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(applications));
  }
  
  // API: Marketplace categories
  else if (url.pathname === '/api/marketplace/categories' && req.method === 'GET') {
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(JOB_CATEGORIES));
  }
  
  // ============ BOUNTY BOARD API ============
  
  // API: List bounties
  else if (url.pathname === '/api/bounties' && req.method === 'GET') {
    const filters = {
      category: url.searchParams.get('category'),
      status: url.searchParams.get('status') || 'open',
      search: url.searchParams.get('search'),
      page: parseInt(url.searchParams.get('page')) || 1,
      limit: parseInt(url.searchParams.get('limit')) || 20,
      sortBy: url.searchParams.get('sortBy') || 'createdAt',
      sortDir: url.searchParams.get('sortDir') || 'desc'
    };
    const result = listBounties(filters);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result));
  }
  
  // API: Get bounty leaderboard
  else if (url.pathname === '/api/bounties/leaderboard' && req.method === 'GET') {
    const limit = parseInt(url.searchParams.get('limit')) || 20;
    const leaderboard = getBountyLeaderboard(limit);
    // Enrich with profile data
    const enriched = leaderboard.map(entry => {
      const profile = loadProfile(entry.agentId);
      return { ...entry, name: profile?.name, handle: profile?.handle, avatar: profile?.avatar };
    });
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(enriched));
  }
  
  // API: Get bounty submissions
  else if (url.pathname.match(/^\/api\/bounties\/([^/]+)\/submissions$/) && req.method === 'GET') {
    const jobId = url.pathname.split('/')[3];
    const db = require('./lib/database');
    const submissions = db.loadBountySubmissions(jobId);
    // Enrich with agent names
    const enriched = submissions.map(s => {
      const profile = loadProfile(s.agentId);
      return { ...s, agentName: profile?.name, agentHandle: profile?.handle, agentAvatar: profile?.avatar };
    });
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(enriched));
  }
  
  // API: Submit to bounty
  else if (url.pathname.match(/^\/api\/bounties\/([^/]+)\/submit$/) && req.method === 'POST') {
    const jobId = url.pathname.split('/')[3];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body || '{}');
        if (!data.agentId) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'agentId required' })); return; }
        if (!data.title) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'title required' })); return; }
        const result = createBountySubmission(jobId, data);
        if (result.error) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify(result)); return; }
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // API: Score bounty submission
  else if (url.pathname.match(/^\/api\/bounties\/submissions\/([^/]+)\/score$/) && req.method === 'POST') {
    const submissionId = url.pathname.split('/')[4];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body || '{}');
        const result = scoreBountySubmission(submissionId, data);
        if (result.error) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify(result)); return; }
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // API: Select bounty winner
  else if (url.pathname.match(/^\/api\/bounties\/([^/]+)\/winner$/) && req.method === 'POST') {
    const jobId = url.pathname.split('/')[3];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body || '{}');
        if (!data.submissionId) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'submissionId required' })); return; }
        const result = await selectBountyWinner(jobId, data.submissionId, data);
        if (result.error) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify(result)); return; }
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // ============ SKILLS TAXONOMY ROUTES ============
  
  // API: Get all skill categories
  else if (url.pathname === '/api/skills/categories' && req.method === 'GET') {
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(SKILL_CATEGORIES));
  }
  
  // API: Get all standard skills
  else if (url.pathname === '/api/skills' && req.method === 'GET') {
    const category = url.searchParams.get('category');
    let skills;
    if (category && STANDARD_SKILLS[category]) {
      skills = getSkillsByCategory(category);
    } else {
      skills = getAllStandardSkills();
    }
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(skills));
  }
  
  // API: Autocomplete skills
  else if (url.pathname === '/api/skills/autocomplete' && req.method === 'GET') {
    const query = url.searchParams.get('q') || '';
    const limit = parseInt(url.searchParams.get('limit')) || 10;
    const results = autocompleteSkills(query, limit);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(results));
  }
  
  // API: Map a skill to standard taxonomy
  else if (url.pathname === '/api/skills/map' && req.method === 'GET') {
    const skill = url.searchParams.get('skill');
    if (!skill) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'skill parameter required' }));
      return;
    }
    const mapped = mapSkill(skill);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(mapped));
  }
  
  // API: Get taxonomy statistics
  else if (url.pathname === '/api/skills/stats' && req.method === 'GET') {
    const stats = getTaxonomyStats();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(stats));
  }
  
  // ============ WALLET & ESCROW ROUTES ============
  
  // API: Connect wallet to profile
  else if (url.pathname === '/api/wallet/connect' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        if (!data.profileId || !data.walletAddress) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'profileId and walletAddress required' }));
          return;
        }
        
        if (!isValidSolanaAddress(data.walletAddress)) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Invalid Solana address format' }));
          return;
        }
        
        const result = updateProfileWallet(data.profileId, data.walletAddress, data.walletType || 'solana');
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
  }
  
  // API: Wallet challenge - generate sign message
  else if (url.pathname === '/api/wallet/challenge' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        if (!data.walletAddress || !isValidSolanaAddress(data.walletAddress)) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Valid walletAddress required' }));
          return;
        }
        const challenge = generateSignMessage(data.walletAddress);
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(challenge));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
  }

  // API: Verify signature and create/link profile
  else if (url.pathname === '/api/wallet/verify-and-create' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const { walletAddress, message, signature, displayName } = data;
        
        if (!walletAddress || !message || !signature) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'walletAddress, message, and signature required' }));
          return;
        }
        
        // Verify the Ed25519 signature
        const valid = verifyWalletSignature(walletAddress, message, signature);
        if (!valid) {
          res.writeHead(401, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Invalid signature. Please try again.' }));
          return;
        }
        
        // Check if wallet already has a profile
        const existing = loadProfileByWallet(walletAddress);
        if (existing) {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ profileId: existing.id, existing: true, message: 'Wallet already linked to profile' }));
          return;
        }
        
        // Create new profile with wallet as identity
        const shortAddr = walletAddress.slice(0, 6) + '...' + walletAddress.slice(-4);
        const name = displayName || shortAddr;
        const profile = createProfile({
          name: name,
          handle: '@' + walletAddress.slice(0, 12),
          bio: 'Solana wallet-verified agent',
          solana: walletAddress
        }, DATA_DIR);
        
        if (profile.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: profile.error }));
          return;
        }
        
        // Update wallet
        updateProfileWallet(profile.id, walletAddress, 'solana');
        
        // Mark as verified
        const dbMod = require('./lib/database');
        const fullProfile = dbMod.loadProfile(profile.id);
        if (fullProfile) {
          if (!fullProfile.verificationData) fullProfile.verificationData = {};
          fullProfile.verificationData.solana = {
            verified: true,
            address: walletAddress,
            verifiedAt: new Date().toISOString(),
            method: 'signature'
          };
          fullProfile.verification = fullProfile.verification || {};
          fullProfile.verification.score = Math.max(fullProfile.verification.score || 0, 25);
          fullProfile.verification.tier = 'partially_verified';
          dbMod.saveProfile(fullProfile);
        }
        
        logger.info('Wallet profile created', { profileId: profile.id, wallet: walletAddress });
        
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ profileId: profile.id, existing: false, message: 'Profile created and wallet verified' }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message || 'Invalid request' }));
      }
    });
  }

  // API: Lookup profile by wallet address
  else if (url.pathname.match(/^\/api\/wallet\/lookup\/([^/]+)$/) && req.method === 'GET') {
    const walletAddress = url.pathname.split('/')[4];
    const profile = loadProfileByWallet(walletAddress);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ profile: profile ? { id: profile.id, name: profile.name, handle: profile.handle } : null }));
  }

  // API: Get wallet SOL balance
  else if (url.pathname.match(/^\/api\/wallet\/balance\/([^/]+)$/) && req.method === 'GET') {
    const walletAddress = url.pathname.split('/')[4];
    getWalletBalance(walletAddress).then(balance => {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ walletAddress, balance }));
    }).catch(e => {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ walletAddress, balance: 0, error: e.message }));
    });
  }

  // API: Verification Score
  else if (url.pathname.match(/^\/api\/agent\/([^/]+)\/score$/) && req.method === 'GET') {
    const agentId = url.pathname.split('/')[3];
    const profile = loadProfile(agentId);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Agent not found' }));
      return;
    }
    const mktStats = getMarketplaceStats(agentId);
    const result = calculateVerificationScore(profile, { marketplaceStats: mktStats });
    res.writeHead(200, { 'Content-Type': 'application/json', 'Cache-Control': 'public, max-age=60' });
    res.end(JSON.stringify({ agentId: agentId, score: result.score, maxScore: result.maxScore, percentage: result.percentage, tier: result.tier, breakdown: result.breakdown, missing: result.missing, profileUrl: 'https://agentfolio.bot/profile/' + agentId }));
  }

    // API: Check on-chain identity status
  else if (url.pathname.match(/^\/api\/wallet\/onchain-status\/([^/]+)$/) && req.method === 'GET') {
    const walletAddress = url.pathname.split('/')[4];
    checkOnChainIdentity(walletAddress).then(status => {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(status));
    }).catch(e => {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ registered: false, error: e.message }));
    });
  }

  // API: Build identity registration transaction
  else if (url.pathname === '/api/wallet/build-register-tx' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        if (!data.walletAddress || !data.profileId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'walletAddress and profileId required' }));
          return;
        }
        const result = await buildIdentityRegistrationTx(data.walletAddress, data.profileId, {
          name: data.name,
          description: data.description,
          x: data.x,
          website: data.website
        });
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // API: Confirm registration tx and store signature
  else if (url.pathname === '/api/wallet/confirm-register-tx' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        if (!data.profileId || !data.txSignature) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'profileId and txSignature required' }));
          return;
        }
        const db = require('./lib/database');
        const profile = db.loadProfile(data.profileId);
        if (!profile) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Profile not found' }));
          return;
        }
        profile.tx_signature = data.txSignature;
        profile.registeredOnChain = true;
        profile.onChainRegisteredAt = new Date().toISOString();
        profile.updatedAt = new Date().toISOString();
        db.saveProfile(profile);
        try {
          const { caches } = require('./lib/cache');
          caches.profiles.del(`profile:${data.profileId}`);
          caches.profiles.del('profiles:all');
        } catch (e) {}
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({
          success: true,
          txSignature: data.txSignature,
          explorerUrl: `https://explorer.solana.com/tx/${data.txSignature}`
        }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // API: Get profile wallet
  else if (url.pathname.match(/^\/api\/wallet\/([^/]+)$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const walletType = url.searchParams.get('type') || 'solana';
    const wallet = getProfileWallet(profileId, walletType);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ 
      profileId, 
      walletType, 
      wallet,
      formatted: wallet ? formatWalletAddress(wallet) : null
    }));
  }
  
  // API: Get escrow status for a job
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/escrow$/) && req.method === 'GET') {
    const jobId = url.pathname.split('/')[4];
    const status = getJobEscrowStatus(jobId);
    if (!status) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'No escrow found for this job' }));
    } else {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(status));
    }
  }
  
  // API: Get deposit instructions for a job
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/deposit-instructions$/) && req.method === 'GET') {
    const jobId = url.pathname.split('/')[4];
    const instructions = getJobDepositInstructions(jobId);
    if (!instructions) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'No escrow found for this job' }));
    } else {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(instructions));
    }
  }
  
  // API: Confirm job deposit (with on-chain verification)
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/confirm-deposit$/) && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const jobId = url.pathname.split('/')[4];
        const data = JSON.parse(body);
        
        if (!data.txHash) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'txHash required' }));
          return;
        }
        
        // Auth: job owner check (clientId) OR on-chain verification (trustless)
        const jobForDeposit = loadJob(jobId);
        if (!jobForDeposit) { res.writeHead(404, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'Job not found' })); return; }
        const clientAuthed = data.clientId && data.clientId === jobForDeposit.clientId;
        // On-chain verification below serves as trustless auth — clientId is optional
        
        // Verify transaction on-chain (supports both custodial and program escrow)
        try {
          let verified = false;
          let verifyMethod = 'unknown';
          
          // Method 1: Check program escrow PDA (preferred — trustless)
          try {
            const escrowOnchain = require('./lib/escrow-onchain');
            const pdaState = await escrowOnchain.readEscrowAccount(jobId);
            if (pdaState.exists && pdaState.amountUSDC >= jobForDeposit.budgetAmount) {
              verified = true;
              verifyMethod = 'program_escrow';
              // Save on-chain metadata to job
              jobForDeposit.escrowType = 'onchain';
              jobForDeposit.escrowPDA = pdaState.escrowPDA;
              jobForDeposit.onchainStatus = pdaState.status;
              console.log(`[Escrow] Program escrow verified: ${pdaState.amountUSDC} USDC in PDA ${pdaState.escrowPDA} for job ${jobId}`);
            }
          } catch (pdaErr) {
            console.log(`[Escrow] Program PDA check skipped: ${pdaErr.message}`);
          }
          
          // Method 2: Fallback to custodial transfer verification
          if (!verified) {
            const solanaEscrow = require('./lib/solana-escrow');
            const verification = await solanaEscrow.verifyDeposit(data.txHash, jobForDeposit.budgetAmount);
            if (verification.verified) {
              verified = true;
              verifyMethod = 'custodial_transfer';
              jobForDeposit.escrowType = 'custodial';
              console.log(`[Escrow] Custodial deposit verified: ${verification.amount} USDC for job ${jobId}`);
            } else {
              res.writeHead(400, { 'Content-Type': 'application/json' });
              res.end(JSON.stringify({ error: 'Deposit verification failed: ' + verification.reason }));
              return;
            }
          }
          
          console.log(`[Escrow] Deposit confirmed via ${verifyMethod} for job ${jobId}`);
        } catch (verifyErr) {
          console.error('[Escrow] On-chain verification error:', verifyErr.message);
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Could not verify deposit on-chain: ' + verifyErr.message }));
          return;
        }
        
        const result = confirmJobDeposit(jobId, data.txHash);
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          // Job is now OPEN - notify matching agents
          if (result.status === 'open') {
            // Email notifications
            notifyMatchingAgents(result).catch(e => 
              logger.error('Error notifying matching agents', { error: e.message })
            );
            // Webhook notifications
            notifyMatchingAgentsWebhook(result).catch(e =>
              console.error('[Agent Webhook] Error notifying matching agents:', e.message)
            );
            // Discord server notifications
            notifyDiscordServers(result).catch(e =>
              console.error('[Discord] Error notifying Discord servers:', e.message)
            );
          }
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ success: true, job: result }));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
  }
  
  // API: Open dispute on a job
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/dispute$/) && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const jobId = url.pathname.split('/')[4];
        const data = JSON.parse(body);
        
        if (!data.openedBy || !data.reason) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'openedBy and reason required' }));
          return;
        }
        
        // Auth: only client or selected agent can dispute
        const jobToDispute = loadJob(jobId);
        if (!jobToDispute) { res.writeHead(404, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: 'Job not found' })); return; }
        if (data.openedBy !== jobToDispute.clientId && data.openedBy !== jobToDispute.selectedAgentId) {
          res.writeHead(403, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Only the client or assigned agent can open a dispute' }));
          return;
        }
        
        const result = disputeJob(jobId, data);
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
  }
  
  // API: List disputes
  else if (url.pathname === '/api/disputes' && req.method === 'GET') {
    const status = url.searchParams.get('status');
    const jobId = url.searchParams.get('jobId');
    const openedBy = url.searchParams.get('openedBy');
    const disputes = listDisputes({ status, jobId, openedBy });
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ disputes, stats: getDisputeStats() }));
  }

  // API: Get single dispute
  else if (url.pathname.match(/^\/api\/disputes\/([^/]+)$/) && req.method === 'GET') {
    const disputeId = url.pathname.split('/')[3];
    const dispute = loadDispute(disputeId);
    if (!dispute) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Dispute not found' }));
    } else {
      const escrow = loadEscrow(dispute.escrowId);
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ dispute, escrow }));
    }
  }

  // API: Submit evidence to a dispute
  else if (url.pathname.match(/^\/api\/disputes\/([^/]+)\/evidence$/) && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const disputeId = url.pathname.split('/')[3];
        const data = JSON.parse(body);
        if (!data.submittedBy || !data.content) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'submittedBy and content required' }));
          return;
        }
        const result = addDisputeEvidence(disputeId, data);
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
  }

  // API: Resolve a dispute (admin)
  else if (url.pathname.match(/^\/api\/disputes\/([^/]+)\/resolve$/) && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const disputeId = url.pathname.split('/')[3];
        const data = JSON.parse(body);
        if (!data.resolution || !data.resolvedBy) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'resolution (release_to_agent|refund_to_client|split) and resolvedBy required' }));
          return;
        }
        if (!['release_to_agent', 'refund_to_client', 'split'].includes(data.resolution)) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Invalid resolution. Must be: release_to_agent, refund_to_client, or split' }));
          return;
        }
        const result = await resolveDispute(disputeId, data.resolution, data.resolvedBy);
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        }
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Resolution failed: ' + e.message }));
      }
    });
  }

  // API: Dispute stats
  else if (url.pathname === '/api/disputes/stats' && req.method === 'GET') {
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(getDisputeStats()));
  }

  // API: Get escrow platform stats (admin)
  else if (url.pathname === '/api/escrow/stats' && req.method === 'GET') {
    const stats = getEscrowStats();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(stats));
  }


    // API: List all escrows (admin)
  else if (url.pathname === '/api/escrow/list' && req.method === 'GET') {
    const status = url.searchParams.get('status');
    const clientId = url.searchParams.get('clientId');
    const agentId = url.searchParams.get('agentId');
    const escrows = listEscrows({ status, clientId, agentId });
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(escrows));
  }
  
  // API: Get supported currencies
  else if (url.pathname === '/api/escrow/currencies' && req.method === 'GET') {
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ 
      currencies: CURRENCIES,
      platformFee: PLATFORM_FEE_PCT 
    }));
  }
  
  // API: Create job + build on-chain escrow tx in one call (headless agent flow)
  else if (url.pathname === '/api/marketplace/jobs/create-onchain' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        if (!data.clientId || !data.title || !data.description || !data.clientWallet || !data.budgetAmount) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'clientId, title, description, clientWallet, and budgetAmount required' }));
          return;
        }
        
        // Create job with on-chain escrow type
        data.escrowType = 'onchain';
        const job = createJob(data);
        if (job.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(job));
          return;
        }
        
        // Build unsigned create_escrow transaction
        const deadlineUnix = data.deadlineUnix || Math.floor(Date.now() / 1000) + 30 * 24 * 3600; // default 30 days
        const escrowOnchain = require('./lib/escrow-onchain');
        const txResult = await escrowOnchain.buildCreateEscrowTx(data.clientWallet, job.id, data.budgetAmount, deadlineUnix);
        
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({
          job,
          escrow: {
            type: 'onchain',
            transaction: txResult.transaction,
            escrowPDA: txResult.escrowPDA,
            vaultPDA: txResult.vaultPDA,
          },
          next_steps: [
            '1. Sign the base64 transaction with your Solana wallet',
            '2. POST /api/escrow/confirm-tx { signedTx: "<base64>", jobId: "' + job.id + '" }',
            '3. POST /api/marketplace/jobs/' + job.id + '/confirm-deposit { txHash: "<sig>", clientId: "' + data.clientId + '" }',
            '4. Job will be verified on-chain and opened for applications'
          ]
        }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  
  // API: Build on-chain create_escrow transaction
  else if (url.pathname === '/api/escrow/build-create-tx' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        const { clientWallet, jobId, amountUSDC, deadlineUnix } = data;
        if (!clientWallet || !jobId || !amountUSDC || !deadlineUnix) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'clientWallet, jobId, amountUSDC, deadlineUnix required' }));
          return;
        }
        const escrowOnchain = require('./lib/escrow-onchain');
        const result = await escrowOnchain.buildCreateEscrowTx(clientWallet, jobId, amountUSDC, deadlineUnix);
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // API: Build on-chain release transaction
  else if (url.pathname === '/api/escrow/build-release-tx' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        const { clientWallet, agentWallet, jobId } = data;
        if (!clientWallet || !agentWallet || !jobId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'clientWallet, agentWallet, jobId required' }));
          return;
        }
        const escrowOnchain = require('./lib/escrow-onchain');
        const result = await escrowOnchain.buildReleaseTx(clientWallet, agentWallet, jobId);
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // API: Build on-chain refund transaction
  else if (url.pathname === '/api/escrow/build-refund-tx' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        const { clientWallet, jobId } = data;
        if (!clientWallet || !jobId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'clientWallet, jobId required' }));
          return;
        }
        const escrowOnchain = require('./lib/escrow-onchain');
        const result = await escrowOnchain.buildRefundTx(clientWallet, jobId);
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // API: Build on-chain accept_job transaction
  else if (url.pathname === '/api/escrow/build-accept-tx' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        const { agentWallet, jobId } = data;
        if (!agentWallet || !jobId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'agentWallet, jobId required' }));
          return;
        }
        const escrowOnchain = require('./lib/escrow-onchain');
        const result = await escrowOnchain.buildAcceptJobTx(agentWallet, jobId);
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // API: Build on-chain submit_work transaction
  else if (url.pathname === '/api/escrow/build-submit-tx' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        const { agentWallet, jobId } = data;
        if (!agentWallet || !jobId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'agentWallet, jobId required' }));
          return;
        }
        const escrowOnchain = require('./lib/escrow-onchain');
        const result = await escrowOnchain.buildSubmitWorkTx(agentWallet, jobId);
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // API: Read on-chain escrow state for a job (source of truth)
  else if (url.pathname.startsWith('/api/escrow/status/') && req.method === 'GET') {
    const jobId = url.pathname.replace('/api/escrow/status/', '');
    (async () => {
      try {
        const escrowOnchain = require('./lib/escrow-onchain');
        const onchainState = await escrowOnchain.readEscrowAccount(jobId);
        
        // Sync DB if on-chain state exists
        if (onchainState.exists) {
          try {
            const job = loadJob(jobId);
            if (job) {
              const mappedStatus = escrowOnchain.mapOnchainStatusToJobStatus(onchainState.status);
              if (mappedStatus && job.status !== mappedStatus) {
                job.status = mappedStatus;
                job.onchainStatus = onchainState.status;
                job.onchainSyncedAt = new Date().toISOString();
                job.updatedAt = new Date().toISOString();
                if (onchainState.status === 'released' || onchainState.status === 'auto_released') {
                  job.fundsReleased = true;
                  job.completedAt = job.completedAt || new Date().toISOString();
                }
                if (onchainState.status === 'refunded') {
                  job.fundsRefunded = true;
                  job.cancelledAt = job.cancelledAt || new Date().toISOString();
                }
                const dbMod = require('./lib/database');
                dbMod.saveJob(job);
                logger.info(`[EscrowSync] Job ${jobId} synced to ${mappedStatus} from on-chain ${onchainState.status}`);
              }
            }
          } catch (e) {
            logger.warn(`[EscrowSync] DB sync failed for ${jobId}: ${e.message}`);
          }
        }
        
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(onchainState));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    })();
  }

  // API: Confirm a signed on-chain transaction
  else if (url.pathname === '/api/escrow/confirm-tx' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        const { signedTx, jobId } = data;
        if (!signedTx) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'signedTx required' }));
          return;
        }
        const escrowOnchain = require('./lib/escrow-onchain');
        const result = await escrowOnchain.confirmTransaction(signedTx);
        
        let onchainState = null;
        if (jobId && result.success) {
          // Read on-chain state after confirmation (source of truth)
          try {
            // Small delay to let the chain finalize
            await new Promise(r => setTimeout(r, 2000));
            onchainState = await escrowOnchain.readEscrowAccount(jobId);
            result.onchainState = onchainState;
            
            // Sync DB to match on-chain state
            if (onchainState.exists) {
              const job = loadJob(jobId);
              if (job) {
                const mappedStatus = escrowOnchain.mapOnchainStatusToJobStatus(onchainState.status);
                if (mappedStatus) {
                  job.status = mappedStatus;
                  job.onchainStatus = onchainState.status;
                  job.onchainSyncedAt = new Date().toISOString();
                  job.updatedAt = new Date().toISOString();
                  job.lastTxSignature = result.signature;
                  
                  // Status-specific updates
                  if (onchainState.status === 'created') {
                    job.escrowFunded = true;
                    job.depositConfirmedAt = new Date().toISOString();
                    job.escrowPDA = onchainState.escrowPDA;
                  }
                  if (onchainState.status === 'agent_accepted') {
                    job.selectedAgentId = job.selectedAgentId || null;
                    job.fundsLocked = true;
                  }
                  if (onchainState.status === 'work_submitted') {
                    job.workSubmittedAt = onchainState.submittedAtDate || new Date().toISOString();
                  }
                  if (onchainState.status === 'released' || onchainState.status === 'auto_released') {
                    job.fundsReleased = true;
                    job.completedAt = job.completedAt || new Date().toISOString();
                    job.releaseTxHash = result.signature;
                  }
                  if (onchainState.status === 'refunded') {
                    job.fundsRefunded = true;
                    job.cancelledAt = job.cancelledAt || new Date().toISOString();
                  }
                  
                  const dbMod = require('./lib/database');
                  dbMod.saveJob(job);
                  result.jobStatus = mappedStatus;
                  logger.info(`[EscrowConfirm] Job ${jobId} → ${mappedStatus} (on-chain: ${onchainState.status}), tx: ${result.signature}`);
                }
              }
            }
          } catch (e) {
            logger.warn(`[EscrowConfirm] Post-confirm sync failed for ${jobId}: ${e.message}`);
          }
        }
        
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // ============ END MARKETPLACE ROUTES ============
  
  // ============ CUSTOM PROOFS ROUTES ============
  
  // Serve uploaded files
  else if (url.pathname.startsWith('/uploads/')) {
    const filename = url.pathname.replace('/uploads/', '');
    const file = getUploadedFile(filename);
    
    if (file) {
      res.writeHead(200, { 
        'Content-Type': file.mimeType,
        'Cache-Control': 'public, max-age=86400'  // Cache for 24 hours
      });
      res.end(file.data);
    } else {
      res.writeHead(404, { 'Content-Type': 'text/plain' });
      res.end('File not found');
    }
  }
  
  // Get proofs for a profile
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/proofs$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const profile = loadProfile(profileId, DATA_DIR);
    
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    
    const proofs = getProfileProofs(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ 
      profileId, 
      proofTypes: CUSTOM_PROOF_TYPES,
      count: proofs.length, 
      proofs 
    }, null, 2));
  }
  
  // Add a new proof (link or file)
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/proofs$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    
    // Require API key authentication
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    
    if (!requestKey) {
      res.writeHead(401, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Authentication required' }));
      return;
    }
    
    const keyInfo = validateApiKey(requestKey);
    if (!keyInfo || keyInfo.profileId !== profileId) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Invalid API key or permission denied' }));
      return;
    }
    
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
      return;
    }
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        let result;
        
        if (data.fileData) {
          // File upload (base64 encoded)
          result = addFileProof(profileId, {
            type: data.type || 'screenshot',
            title: data.title,
            description: data.description,
            relatedTo: data.relatedTo,
            fileData: data.fileData,
            mimeType: data.mimeType || 'image/png',
            filename: data.filename
          });
        } else if (data.url) {
          // Link-based proof
          result = addLinkProof(profileId, {
            type: data.type || 'link',
            title: data.title,
            description: data.description,
            url: data.url,
            relatedTo: data.relatedTo
          });
        } else {
          result = { error: 'Either url or fileData is required' };
        }
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          // Log activity
          addActivityAndBroadcast(profileId, ACTIVITY_TYPES.SKILL_VERIFIED, {
            type: 'custom_proof',
            proofType: data.type,
            title: data.title
          }, DATA_DIR);
          
          res.writeHead(201, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  
  // Delete a proof
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/proofs\/([^/]+)$/) && req.method === 'DELETE') {
    const parts = url.pathname.split('/');
    const profileId = parts[3];
    const proofId = parts[5];
    
    // Require API key authentication
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    
    if (!requestKey) {
      res.writeHead(401, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Authentication required' }));
      return;
    }
    
    const keyInfo = validateApiKey(requestKey);
    if (!keyInfo || keyInfo.profileId !== profileId) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Invalid API key or permission denied' }));
      return;
    }
    
    const result = deleteCustomProof(profileId, proofId);
    
    if (result.error) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result));
    } else {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result));
    }
  }
  
  // Update a proof
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/proofs\/([^/]+)$/) && req.method === 'PATCH') {
    const parts = url.pathname.split('/');
    const profileId = parts[3];
    const proofId = parts[5];
    
    // Require API key authentication
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    
    if (!requestKey) {
      res.writeHead(401, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Authentication required' }));
      return;
    }
    
    const keyInfo = validateApiKey(requestKey);
    if (!keyInfo || keyInfo.profileId !== profileId) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Invalid API key or permission denied' }));
      return;
    }
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const updates = JSON.parse(body);
        const result = updateCustomProof(profileId, proofId, updates);
        
        if (result.error) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
    return;
  }
  
  // Get available proof types
  else if (url.pathname === '/api/proof-types') {
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ proofTypes: CUSTOM_PROOF_TYPES }, null, 2));
  }
  
  // ============ END CUSTOM PROOFS ROUTES ============

  // ============ PROJECT SHOWCASE ROUTES ============
  
  // Get all projects for a profile
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/projects$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const result = getProjects(profileId, DATA_DIR);
    
    if (result.error === 'Profile not found') {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Profile not found' }));
    } else {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result, null, 2));
    }
  }
  
  // Add a new project
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/projects$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const projectData = JSON.parse(body);
        const result = addProject(profileId, projectData, DATA_DIR);
        
        if (result.error) {
          const status = result.error === 'Profile not found' ? 404 : 400;
          res.writeHead(status, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          // Log activity
          addActivityAndBroadcast(profileId, ACTIVITY_TYPES.PROFILE_UPDATED, {
            change: 'Added project: ' + result.project.title
          }, DATA_DIR);
          
          res.writeHead(201, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  
  // Update a project
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/projects\/([^/]+)$/) && req.method === 'PATCH') {
    const parts = url.pathname.split('/');
    const profileId = parts[3];
    const projectId = parts[5];
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const updates = JSON.parse(body);
        const result = updateProject(profileId, projectId, updates, DATA_DIR);
        
        if (result.error) {
          const status = result.error === 'Profile not found' || result.error === 'Project not found' ? 404 : 400;
          res.writeHead(status, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  
  // Delete a project
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/projects\/([^/]+)$/) && req.method === 'DELETE') {
    const parts = url.pathname.split('/');
    const profileId = parts[3];
    const projectId = parts[5];
    
    const result = deleteProject(profileId, projectId, DATA_DIR);
    
    if (result.error) {
      const status = result.error === 'Profile not found' || result.error === 'Project not found' ? 404 : 400;
      res.writeHead(status, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result));
    } else {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result));
    }
  }
  
  // Toggle featured status for a project
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/projects\/([^/]+)\/feature$/) && req.method === 'POST') {
    const parts = url.pathname.split('/');
    const profileId = parts[3];
    const projectId = parts[5];
    
    const result = toggleFeatured(profileId, projectId, DATA_DIR);
    
    if (result.error) {
      const status = result.error === 'Profile not found' || result.error === 'Project not found' ? 404 : 400;
      res.writeHead(status, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result));
    } else {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result));
    }
  }
  
  // Reorder projects
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/projects\/reorder$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { projectId, position } = JSON.parse(body);
        
        if (!projectId || position === undefined) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'projectId and position required' }));
          return;
        }
        
        const result = reorderProject(profileId, projectId, position, DATA_DIR);
        
        if (result.error) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
    return;
  }
  
  // Get project types (for forms)
  else if (url.pathname === '/api/project-types') {
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ types: PROJECT_TYPES, maxProjects: MAX_PROJECTS }, null, 2));
  }
  
  // ============ END PROJECT SHOWCASE ROUTES ============

  // ============ AGENT MESSAGING ROUTES ============
  
  // Get inbox messages
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/messages$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const status = url.searchParams.get('status') || null;
    const limit = parseInt(url.searchParams.get('limit') || '50');
    const offset = parseInt(url.searchParams.get('offset') || '0');
    
    // Require API key auth
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    const keyInfo = validateApiKey(requestKey);
    
    if (!keyInfo || keyInfo.profileId !== profileId) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Invalid API key or permission denied' }));
      return;
    }
    
    const result = getInbox(profileId, { status, limit, offset });
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result, null, 2));
  }
  
  // Send a message
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/messages$/) && req.method === 'POST') {
    const toId = url.pathname.split('/')[3];
    
    // Check recipient exists
    const toProfile = loadProfile(toId, DATA_DIR);
    if (!toProfile) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Recipient profile not found' }));
      return;
    }
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        
        // Require API key for sender
        const authHeader = req.headers['authorization'] || '';
        const apiKeyHeader = req.headers['x-api-key'] || '';
        const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
        const keyInfo = validateApiKey(requestKey);
        
        if (!keyInfo) {
          res.writeHead(403, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'API key required to send messages' }));
          return;
        }
        
        const fromId = keyInfo.profileId;
        const result = sendMessage(fromId, toId, {
          subject: data.subject,
          body: data.body,
          replyTo: data.replyTo
        });
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        } else {
          // Log activity
          addActivityAndBroadcast(toId, ACTIVITY_TYPES.PROFILE_UPDATED || 'message_received', {
            from: fromId,
            messageId: result.messageId
          }, DATA_DIR);
          
          // Send webhook notification to recipient
          const senderProfile = loadProfile(fromId, DATA_DIR);
          notifyMessageWebhook(toId, {
            id: fromId,
            name: senderProfile?.name || fromId,
            email: null
          }, data.subject, data.body).catch(e =>
            console.error('[Agent Webhook] Failed to notify message:', e.message)
          );
          
          res.writeHead(201, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify(result));
        }
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON: ' + e.message }));
      }
    });
    return;
  }
  
  // Get sent messages
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/messages\/sent$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const limit = parseInt(url.searchParams.get('limit') || '50');
    const offset = parseInt(url.searchParams.get('offset') || '0');
    
    // Require API key auth
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    const keyInfo = validateApiKey(requestKey);
    
    if (!keyInfo || keyInfo.profileId !== profileId) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Invalid API key or permission denied' }));
      return;
    }
    
    const result = getSent(profileId, { limit, offset });
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result, null, 2));
  }
  
  // Get single message (skip reserved paths like sent, stats, etc.)
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/messages\/([^/]+)$/) && req.method === 'GET' && 
           !url.pathname.match(/\/(sent|stats|read-all|unread-count)$/)) {
    const parts = url.pathname.split('/');
    const profileId = parts[3];
    const messageId = parts[5];
    
    // Require API key auth
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    const keyInfo = validateApiKey(requestKey);
    
    if (!keyInfo || keyInfo.profileId !== profileId) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Invalid API key or permission denied' }));
      return;
    }
    
    const message = getMessage(profileId, messageId);
    if (!message) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Message not found' }));
      return;
    }
    
    // Mark as read when fetched
    markAsRead(profileId, messageId);
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ message }, null, 2));
  }
  
  // Mark message as read
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/messages\/([^/]+)\/read$/) && req.method === 'POST') {
    const parts = url.pathname.split('/');
    const profileId = parts[3];
    const messageId = parts[5];
    
    // Require API key auth
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    const keyInfo = validateApiKey(requestKey);
    
    if (!keyInfo || keyInfo.profileId !== profileId) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Invalid API key or permission denied' }));
      return;
    }
    
    const result = markAsRead(profileId, messageId);
    res.writeHead(result.error ? 404 : 200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result));
  }
  
  // Archive message
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/messages\/([^/]+)\/archive$/) && req.method === 'POST') {
    const parts = url.pathname.split('/');
    const profileId = parts[3];
    const messageId = parts[5];
    
    // Require API key auth
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    const keyInfo = validateApiKey(requestKey);
    
    if (!keyInfo || keyInfo.profileId !== profileId) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Invalid API key or permission denied' }));
      return;
    }
    
    const result = archiveMessage(profileId, messageId);
    res.writeHead(result.error ? 404 : 200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result));
  }
  
  // Delete message
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/messages\/([^/]+)$/) && req.method === 'DELETE') {
    const parts = url.pathname.split('/');
    const profileId = parts[3];
    const messageId = parts[5];
    
    // Require API key auth
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    const keyInfo = validateApiKey(requestKey);
    
    if (!keyInfo || keyInfo.profileId !== profileId) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Invalid API key or permission denied' }));
      return;
    }
    
    const result = deleteMessage(profileId, messageId);
    res.writeHead(result.error ? 404 : 200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result));
  }
  
  // Get conversation thread
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/messages\/conversation\/([^/]+)$/) && req.method === 'GET') {
    const parts = url.pathname.split('/');
    const profileId = parts[3];
    const otherAgentId = parts[6];
    const limit = parseInt(url.searchParams.get('limit') || '50');
    
    // Require API key auth
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    const keyInfo = validateApiKey(requestKey);
    
    if (!keyInfo || keyInfo.profileId !== profileId) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Invalid API key or permission denied' }));
      return;
    }
    
    const result = getConversation(profileId, otherAgentId, { limit });
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result, null, 2));
  }
  
  // Mark all messages as read
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/messages\/read-all$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    
    // Require API key auth
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    const keyInfo = validateApiKey(requestKey);
    
    if (!keyInfo || keyInfo.profileId !== profileId) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Invalid API key or permission denied' }));
      return;
    }
    
    const result = markAllRead(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result));
  }
  
  // Get message stats
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/messages\/stats$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    
    // Require API key auth
    const authHeader = req.headers['authorization'] || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    const keyInfo = validateApiKey(requestKey);
    
    if (!keyInfo || keyInfo.profileId !== profileId) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Invalid API key or permission denied' }));
      return;
    }
    
    const stats = getMessageStats(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(stats, null, 2));
  }
  
  // Get unread count (public, no auth needed)
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/messages\/unread-count$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const count = getUnreadCount(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ unread: count }));
  }
  
  // ============ END AGENT MESSAGING ROUTES ============
  
  // ============ AGENT POSTS / BLOG API ============

  // Create a post
  else if (url.pathname === '/api/posts' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const { agentId, title, content, tags, type } = data;
        const authHeader = req.headers['authorization'] || '';
        const apiKeyHeader = req.headers['x-api-key'] || '';
        const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
        const keyInfo = validateApiKey(requestKey);
        if (!keyInfo || keyInfo.profileId !== agentId) {
          res.writeHead(403, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Invalid API key' }));
          return;
        }
        if (!title || !content) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Title and content required' }));
          return;
        }
        const post = posts.createPost(agentId, { title, content, tags, type });
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(post, null, 2));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // Get posts feed
  else if (url.pathname === '/api/posts' && req.method === 'GET') {
    const limit = parseInt(url.searchParams.get('limit') || '50');
    const offset = parseInt(url.searchParams.get('offset') || '0');
    const tag = url.searchParams.get('tag');
    const type = url.searchParams.get('type');
    const result = posts.getFeed({ limit, offset, tag, type });
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result, null, 2));
  }

  // Get trending posts
  else if (url.pathname === '/api/posts/trending' && req.method === 'GET') {
    const limit = parseInt(url.searchParams.get('limit') || '10');
    const trending = posts.getTrendingPosts(limit);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(trending, null, 2));
  }

  // Get all tags
  else if (url.pathname === '/api/posts/tags' && req.method === 'GET') {
    const tags = posts.getAllTags();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(tags, null, 2));
  }

  // Get single post
  else if (url.pathname.match(/^\/api\/posts\/([^/]+)$/) && req.method === 'GET') {
    const postId = url.pathname.split('/')[3];
    const post = posts.getPost(postId);
    if (!post) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Post not found' }));
      return;
    }
    posts.incrementViews(postId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(post, null, 2));
  }

  // Like/unlike post
  else if (url.pathname.match(/^\/api\/posts\/([^/]+)\/like$/) && req.method === 'POST') {
    const postId = url.pathname.split('/')[3];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const { agentId } = data;
        const authHeader = req.headers['authorization'] || '';
        const apiKeyHeader = req.headers['x-api-key'] || '';
        const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
        const keyInfo = validateApiKey(requestKey);
        if (!keyInfo || keyInfo.profileId !== agentId) {
          res.writeHead(403, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Invalid API key' }));
          return;
        }
        const result = posts.toggleLike(postId, agentId);
        if (!result) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Post not found' }));
          return;
        }
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // Add comment
  else if (url.pathname.match(/^\/api\/posts\/([^/]+)\/comments$/) && req.method === 'POST') {
    const postId = url.pathname.split('/')[3];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const { agentId, content } = data;
        const authHeader = req.headers['authorization'] || '';
        const apiKeyHeader = req.headers['x-api-key'] || '';
        const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
        const keyInfo = validateApiKey(requestKey);
        if (!keyInfo || keyInfo.profileId !== agentId) {
          res.writeHead(403, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Invalid API key' }));
          return;
        }
        if (!content) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Content required' }));
          return;
        }
        const comment = posts.addComment(postId, agentId, content);
        if (!comment) {
          res.writeHead(404, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Post not found' }));
          return;
        }
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(comment, null, 2));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // Get agent's posts
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/posts$/) && req.method === 'GET') {
    const agentId = url.pathname.split('/')[3];
    const limit = parseInt(url.searchParams.get('limit') || '20');
    const offset = parseInt(url.searchParams.get('offset') || '0');
    const result = posts.getAgentPosts(agentId, { limit, offset });
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result, null, 2));
  }

  // ============ END AGENT POSTS ROUTES ============

  // ============ REFERRALS API ROUTES ============
  
  // Get referral stats for a profile
  else if (url.pathname.match(/^\/api\/profile\/[^/]+\/referrals$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const stats = getAgentReferralStats(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(stats));
  }
  
  // Get referral link for a profile
  else if (url.pathname.match(/^\/api\/profile\/[^/]+\/referral-link$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const link = getReferralLink(profileId);
    const code = getOrCreateReferralCode(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ link, code, profileId }));
  }
  
  // Get referral leaderboard
  else if (url.pathname === '/api/referrals/leaderboard' && req.method === 'GET') {
    const limit = parseInt(url.searchParams.get('limit') || '10');
    const leaderboard = getReferralLeaderboard(limit);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ leaderboard }));
  }
  
  // Get global referral stats
  else if (url.pathname === '/api/referrals/stats' && req.method === 'GET') {
    const stats = getGlobalReferralStats();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(stats));
  }
  
  // Validate a referral code
  else if (url.pathname === '/api/referrals/validate' && req.method === 'GET') {
    const code = url.searchParams.get('code') || '';
    const valid = validateReferralCode(code);
    const referrer = valid ? getReferrer(code) : null;
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ valid, referrer, code: code.toUpperCase() }));
  }
  
  // ============ END REFERRALS API ROUTES ============

  // ============ TEAMS API ROUTES ============
  
  // List all teams
  else if (url.pathname === '/api/teams' && req.method === 'GET') {
    const limit = parseInt(url.searchParams.get('limit') || '20');
    const offset = parseInt(url.searchParams.get('offset') || '0');
    const search = url.searchParams.get('search') || '';
    const sortBy = url.searchParams.get('sort') || 'created_at';
    
    const teams = listTeams({ limit, offset, search, sortBy });
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ teams, count: teams.length }));
  }
  
  // Create team
  else if (url.pathname === '/api/teams' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const authHeader = req.headers.authorization || '';
        const apiKeyHeader = req.headers['x-api-key'] || '';
        const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
        
        const keyInfo = validateApiKey(requestKey);
        if (!keyInfo) {
          res.writeHead(401, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Authentication required' }));
          return;
        }
        
        const result = createTeam(keyInfo.profileId, data);
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
          return;
        }
        
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
  }
  
  // Get team details
  else if (url.pathname.match(/^\/api\/teams\/([^/]+)$/) && req.method === 'GET') {
    const teamId = url.pathname.split('/')[3];
    const team = getTeamWithDetails(teamId);
    
    if (!team) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Team not found' }));
      return;
    }
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(team));
  }
  
  // Update team
  else if (url.pathname.match(/^\/api\/teams\/([^/]+)$/) && req.method === 'PATCH') {
    const teamId = url.pathname.split('/')[3];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const authHeader = req.headers.authorization || '';
        const apiKeyHeader = req.headers['x-api-key'] || '';
        const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
        
        const keyInfo = validateApiKey(requestKey);
        if (!keyInfo) {
          res.writeHead(401, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Authentication required' }));
          return;
        }
        
        const result = updateTeam(teamId, keyInfo.profileId, data);
        
        if (result.error) {
          res.writeHead(result.error.includes('not found') ? 404 : 403, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
          return;
        }
        
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
  }
  
  // Delete team
  else if (url.pathname.match(/^\/api\/teams\/([^/]+)$/) && req.method === 'DELETE') {
    const teamId = url.pathname.split('/')[3];
    const authHeader = req.headers.authorization || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    
    const keyInfo = validateApiKey(requestKey);
    if (!keyInfo) {
      res.writeHead(401, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Authentication required' }));
      return;
    }
    
    const result = deleteTeam(teamId, keyInfo.profileId);
    
    if (result.error) {
      res.writeHead(result.error.includes('not found') ? 404 : 403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: result.error }));
      return;
    }
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result));
  }
  
  // Invite member to team
  else if (url.pathname.match(/^\/api\/teams\/([^/]+)\/invite$/) && req.method === 'POST') {
    const teamId = url.pathname.split('/')[3];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const authHeader = req.headers.authorization || '';
        const apiKeyHeader = req.headers['x-api-key'] || '';
        const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
        
        const keyInfo = validateApiKey(requestKey);
        if (!keyInfo) {
          res.writeHead(401, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Authentication required' }));
          return;
        }
        
        const result = inviteToTeam(teamId, keyInfo.profileId, data.profileId, data.role || 'member', data.message || '');
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
          return;
        }
        
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
  }
  
  // Respond to invitation
  else if (url.pathname.match(/^\/api\/teams\/invites\/([^/]+)\/respond$/) && req.method === 'POST') {
    const inviteId = url.pathname.split('/')[4];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const authHeader = req.headers.authorization || '';
        const apiKeyHeader = req.headers['x-api-key'] || '';
        const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
        
        const keyInfo = validateApiKey(requestKey);
        if (!keyInfo) {
          res.writeHead(401, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Authentication required' }));
          return;
        }
        
        const result = respondToInvite(inviteId, keyInfo.profileId, data.accept === true);
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
          return;
        }
        
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
  }
  
  // Get pending invitations for current user
  else if (url.pathname === '/api/teams/invites' && req.method === 'GET') {
    const authHeader = req.headers.authorization || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    
    const keyInfo = validateApiKey(requestKey);
    if (!keyInfo) {
      res.writeHead(401, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Authentication required' }));
      return;
    }
    
    const invites = getPendingInvites(keyInfo.profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ invites }));
  }
  
  // Leave team
  else if (url.pathname.match(/^\/api\/teams\/([^/]+)\/leave$/) && req.method === 'POST') {
    const teamId = url.pathname.split('/')[3];
    const authHeader = req.headers.authorization || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    
    const keyInfo = validateApiKey(requestKey);
    if (!keyInfo) {
      res.writeHead(401, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Authentication required' }));
      return;
    }
    
    const result = leaveTeam(teamId, keyInfo.profileId);
    
    if (result.error) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: result.error }));
      return;
    }
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result));
  }
  
  // Remove member from team
  else if (url.pathname.match(/^\/api\/teams\/([^/]+)\/members\/([^/]+)$/) && req.method === 'DELETE') {
    const parts = url.pathname.split('/');
    const teamId = parts[3];
    const targetId = parts[5];
    
    const authHeader = req.headers.authorization || '';
    const apiKeyHeader = req.headers['x-api-key'] || '';
    const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
    
    const keyInfo = validateApiKey(requestKey);
    if (!keyInfo) {
      res.writeHead(401, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Authentication required' }));
      return;
    }
    
    const result = removeMember(teamId, keyInfo.profileId, targetId);
    
    if (result.error) {
      res.writeHead(result.error.includes('not found') ? 404 : 403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: result.error }));
      return;
    }
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result));
  }
  
  // Update member role
  else if (url.pathname.match(/^\/api\/teams\/([^/]+)\/members\/([^/]+)\/role$/) && req.method === 'PATCH') {
    const parts = url.pathname.split('/');
    const teamId = parts[3];
    const targetId = parts[5];
    
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const authHeader = req.headers.authorization || '';
        const apiKeyHeader = req.headers['x-api-key'] || '';
        const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
        
        const keyInfo = validateApiKey(requestKey);
        if (!keyInfo) {
          res.writeHead(401, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Authentication required' }));
          return;
        }
        
        const result = updateMemberRole(teamId, keyInfo.profileId, targetId, data.role);
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
          return;
        }
        
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
  }
  
  // Transfer ownership
  else if (url.pathname.match(/^\/api\/teams\/([^/]+)\/transfer$/) && req.method === 'POST') {
    const teamId = url.pathname.split('/')[3];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const authHeader = req.headers.authorization || '';
        const apiKeyHeader = req.headers['x-api-key'] || '';
        const requestKey = authHeader.replace('Bearer ', '') || apiKeyHeader;
        
        const keyInfo = validateApiKey(requestKey);
        if (!keyInfo) {
          res.writeHead(401, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Authentication required' }));
          return;
        }
        
        const result = transferOwnership(teamId, keyInfo.profileId, data.newOwnerId);
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
          return;
        }
        
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
  }
  
  // Get teams for a profile
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/teams$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const teams = getProfileTeams(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ teams }));
  }
  
  // Get team activity feed
  else if (url.pathname.match(/^\/api\/teams\/([^/]+)\/activity$/) && req.method === 'GET') {
    const teamId = url.pathname.split('/')[3];
    const limit = parseInt(url.searchParams.get('limit') || '20');
    const activity = getTeamActivity(teamId, limit);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ activity }));
  }
  
  // Get teams statistics (admin)
  else if (url.pathname === '/api/teams/stats' && req.method === 'GET') {
    const stats = getTeamsStats();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(stats));
  }
  
  // Team page
  else if (url.pathname.startsWith('/team/')) {
    const teamId = url.pathname.replace('/team/', '');
    const team = getTeamWithDetails(teamId);
    
    if (!team) {
      res.writeHead(404, { 'Content-Type': 'text/html' });
      res.end('<h1>Team not found</h1>');
      return;
    }
    
    const html = generateTeamPage(team);
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(html);
  }
  
  // Team create page
  else if (url.pathname === '/teams/create') {
    const html = generateTeamCreatePage();
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(html);
  }
  
  // Teams directory page
  else if (url.pathname === '/teams') {
    const teams = listTeams({ limit: 50 });
    const stats = getTeamsStats();
    const html = generateTeamsDirectoryPage(teams, stats);
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(html);
  }
  
  // ============ END TEAMS API ROUTES ============

  // ============ ACHIEVEMENTS API ROUTES ============

  // Get all achievement definitions
  else if (url.pathname === '/api/achievements' && req.method === 'GET') {
    const achievements = getAllAchievements();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ achievements, count: achievements.length }));
  }

  // Get achievement leaderboard
  else if (url.pathname === '/api/achievements/leaderboard' && req.method === 'GET') {
    const limit = parseInt(url.searchParams.get('limit') || '20');
    const leaderboard = getAchievementLeaderboard(limit);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ leaderboard }));
  }

  // Get achievement statistics
  else if (url.pathname === '/api/achievements/stats' && req.method === 'GET') {
    const stats = getAchievementStats();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(stats));
  }

  // Get profile's achievements
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/achievements$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const achievements = getProfileAchievements(profileId);
    const points = getAchievementPoints(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ achievements, points, count: achievements.length }));
  }

  // Check/refresh achievements for profile
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/achievements\/check$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    const newAchievements = checkAchievements(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ 
      newAchievements, 
      unlocked: newAchievements.length,
      message: newAchievements.length > 0 ? `Unlocked ${newAchievements.length} new achievement(s)!` : 'No new achievements'
    }));
  }

  // Get unnotified achievements
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/achievements\/unnotified$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    const unnotified = getUnnotifiedAchievements(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ achievements: unnotified, count: unnotified.length }));
  }

  // Mark achievement as notified
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/achievements\/([^/]+)\/notify$/) && req.method === 'POST') {
    const parts = url.pathname.split('/');
    const profileId = parts[3];
    const achievementId = parts[5];
    markNotified(profileId, achievementId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ success: true }));
  }

  // Award special achievement (admin)
  else if (url.pathname.match(/^\/api\/profile\/([^/]+)\/achievements\/award$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { achievementId, reason } = JSON.parse(body);
        const result = awardAchievement(profileId, achievementId, reason);
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
          return;
        }
        
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
  }

  // Achievements page
  else if (url.pathname === '/achievements') {
    const stats = getAchievementStats();
    const leaderboard = getAchievementLeaderboard(10);
    const achievements = getAllAchievements();
    const html = generateAchievementsPage(achievements, stats, leaderboard);
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(html);
  }

  // ============ END ACHIEVEMENTS API ROUTES ============
  
  // ============ MARKETPLACE UI ROUTES ============
  
  // Marketplace homepage - list all open jobs
  else if (url.pathname === '/marketplace') {
    const search = url.searchParams.get('q') || '';
    const category = url.searchParams.get('category') || '';
    const skills = url.searchParams.get('skills') || '';
    const minBudget = url.searchParams.get('minBudget') || '';
    const maxBudget = url.searchParams.get('maxBudget') || '';
    const sortBy = url.searchParams.get('sortBy') || 'createdAt';
    const sortDir = url.searchParams.get('sortDir') || 'desc';
    const status = url.searchParams.get('status') || 'open';
    const page = parseInt(url.searchParams.get('page')) || 1;
    const limit = 20;
    
    const filters = {
      search,
      category,
      skills,
      minBudget: minBudget ? parseInt(minBudget) : null,
      maxBudget: maxBudget ? parseInt(maxBudget) : null,
      sortBy,
      sortDir,
      status,
      limit,
      offset: (page - 1) * limit
    };
    
    const result = listJobs(filters);
    const allSkills = getAllSkills(DATA_DIR);
    
    const jobsResult = {
      jobs: result.jobs || [],
      total: result.total || 0,
      page,
      pages: Math.ceil((result.total || 0) / limit)
    };
    
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateMarketplacePage(jobsResult, filters, allSkills));
  }
  
  // Single job view
  else if (url.pathname.match(/^\/marketplace\/job\/([^/]+)$/)) {
    const jobId = url.pathname.split('/')[3];
    const job = loadJob(jobId);
    
    if (!job || job.error) {
      res.writeHead(404, { 'Content-Type': 'text/html' });
      res.end(`<!DOCTYPE html><html><head><title>Not Found</title>${COMMON_STYLES}</head>
        <body style="display:flex;justify-content:center;align-items:center;min-height:100vh;">
        <div style="text-align:center;"><h1 style="font-size:3rem;margin-bottom:16px;">😕</h1>
        <h2 style="color:#f4f4f5;">Job Not Found</h2>
        <p style="color:#71717a;margin:16px 0;">This job may have been removed or doesn't exist.</p>
        <a href="/marketplace" style="color:#06b6d4;">← Back to Marketplace</a></div></body></html>`);
      return;
    }
    
    // Increment views
    incrementJobViews(jobId);
    
    // Load related data
    const clientProfile = loadProfile(job.clientId, DATA_DIR);
    const applications = loadApplications(jobId);
    const agentProfile = job.selectedAgentId ? loadProfile(job.selectedAgentId, DATA_DIR) : null;
    const reviews = getJobReviews(jobId);
    
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateJobDetailPage(job, applications, clientProfile, reviews, agentProfile));
  }
  
  // Post a new job form
  else if (url.pathname === '/marketplace/post' && req.method === 'GET') {
    const hireAgentId = url.searchParams.get('hire');
    const hireAgent = hireAgentId ? loadProfile(hireAgentId, DATA_DIR) : null;
    
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generatePostJobPage(hireAgent));
  }
  
  // My jobs page (posted & applied)
  else if (url.pathname === '/marketplace/my-jobs') {
    const profileId = url.searchParams.get('profile');
    
    if (!profileId) {
      res.writeHead(400, { 'Content-Type': 'text/html' });
      res.end(`<!DOCTYPE html><html><head><title>Error</title>${COMMON_STYLES}</head>
        <body style="display:flex;justify-content:center;align-items:center;min-height:100vh;">
        <div style="text-align:center;"><h1 style="font-size:3rem;margin-bottom:16px;">⚠️</h1>
        <h2 style="color:#f4f4f5;">Profile ID Required</h2>
        <p style="color:#71717a;margin:16px 0;">Use ?profile=your_profile_id to view your jobs.</p>
        <a href="/marketplace" style="color:#06b6d4;">← Back to Marketplace</a></div></body></html>`);
      return;
    }
    
    const profile = loadProfile(profileId, DATA_DIR);
    if (!profile) {
      res.writeHead(404, { 'Content-Type': 'text/html' });
      res.end(`<!DOCTYPE html><html><head><title>Not Found</title>${COMMON_STYLES}</head>
        <body style="display:flex;justify-content:center;align-items:center;min-height:100vh;">
        <div style="text-align:center;"><h1 style="font-size:3rem;margin-bottom:16px;">😕</h1>
        <h2 style="color:#f4f4f5;">Profile Not Found</h2>
        <p style="color:#71717a;margin:16px 0;">The profile you're looking for doesn't exist.</p>
        <a href="/marketplace" style="color:#06b6d4;">← Back to Marketplace</a></div></body></html>`);
      return;
    }
    
    // Jobs I posted
    const { jobs: clientJobs } = listJobs({ clientId: profileId, limit: 50 });
    // Jobs I applied to
    const agentApplications = getAgentApplications(profileId);
    
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateMyJobsPage(profileId, clientJobs, agentApplications));
  }
  
  // Apply to job form
  else if (url.pathname.match(/^\/marketplace\/job\/([^/]+)\/apply$/) && req.method === 'GET') {
    const jobId = url.pathname.split('/')[3];
    const job = loadJob(jobId);
    
    if (!job || job.error) {
      res.writeHead(404, { 'Content-Type': 'text/html' });
      res.end(`<!DOCTYPE html><html><head><title>Not Found</title>${COMMON_STYLES}</head>
        <body style="display:flex;justify-content:center;align-items:center;min-height:100vh;">
        <div style="text-align:center;"><h1 style="font-size:3rem;margin-bottom:16px;">😕</h1>
        <h2 style="color:#f4f4f5;">Job Not Found</h2>
        <p style="color:#71717a;margin:16px 0;">This job may have been removed or doesn't exist.</p>
        <a href="/marketplace" style="color:#06b6d4;">← Back to Marketplace</a></div></body></html>`);
      return;
    }
    
    if (job.status !== JOB_STATUS.OPEN) {
      res.writeHead(400, { 'Content-Type': 'text/html' });
      res.end(`<!DOCTYPE html><html><head><title>Closed</title>${COMMON_STYLES}</head>
        <body style="display:flex;justify-content:center;align-items:center;min-height:100vh;">
        <div style="text-align:center;"><h1 style="font-size:3rem;margin-bottom:16px;">🔒</h1>
        <h2 style="color:#f4f4f5;">Job Closed</h2>
        <p style="color:#71717a;margin:16px 0;">This job is no longer accepting applications.</p>
        <a href="/marketplace" style="color:#06b6d4;">← Back to Marketplace</a></div></body></html>`);
      return;
    }
    
    const profiles = listProfiles(DATA_DIR);
    const clientProfile = loadProfile(job.clientId, DATA_DIR);
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateApplyPage(job, clientProfile, profiles));
  }
  
  // ============ MARKETPLACE API ROUTES ============
  
  // Create job
  else if (url.pathname === '/api/marketplace/jobs' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = sanitizeJobData(JSON.parse(body));
        const result = createJob(data);
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
          return;
        }
        
        // Notify matching agents via webhook
        notifyMatchingAgentsWebhook(result).catch(err => {
          console.error('[Marketplace] Error notifying agents:', err.message);
        });
        
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
  }
  
  // List jobs
  else if (url.pathname === '/api/marketplace/jobs' && req.method === 'GET') {
    const filters = {
      status: url.searchParams.get('status') || 'open',
      category: url.searchParams.get('category'),
      skill: url.searchParams.get('skill'),
      clientId: url.searchParams.get('clientId'),
      limit: parseInt(url.searchParams.get('limit')) || 20,
      offset: parseInt(url.searchParams.get('offset')) || 0
    };
    
    const result = listJobs(filters);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result));
  }
  
  // Get single job
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)$/) && req.method === 'GET') {
    const jobId = url.pathname.split('/')[4];
    const job = loadJob(jobId);
    
    if (!job || job.error) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Job not found' }));
      return;
    }
    
    const apps2 = loadApplications(jobId);
    job.applications = apps2 || [];
    res.writeHead(200, { "Content-Type": "application/json" });
    res.end(JSON.stringify(job));


  }
  
  // Apply to job
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/(apply|applications)$/) && req.method === 'POST') {
    const jobId = url.pathname.split('/')[4];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const result = createApplication(jobId, {
          agentId: data.agentId,
          proposal: sanitizeText(data.proposal || ''),
          estimatedTime: data.estimatedTime,
          bidAmount: data.bidAmount
        });
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
          return;
        }
        
        // Notify job owner
        notifyNewApplication(loadJob(jobId).clientId, result);
        
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
  }
  
  // Get applications for job
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/applications$/) && req.method === 'GET') {
    const jobId = url.pathname.split('/')[4];
    const applications = loadApplications(jobId);
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(applications));
  }
  
  // Select winner / assign job
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/select$/) && req.method === 'POST') {
    const jobId = url.pathname.split('/')[4];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { agentId, clientId } = JSON.parse(body);
        const result = selectWinner(jobId, agentId, clientId);
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
          return;
        }
        
        // Notify selected agent
        notifyJobAssigned(agentId, result);
        
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
  }
  
  // Complete job
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/complete$/) && req.method === 'POST') {
    const jobId = url.pathname.split('/')[4];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { clientId } = JSON.parse(body);
        const result = completeJob(jobId, clientId);
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
          return;
        }
        
        // Notify agent
        const job = loadJob(jobId);
        notifyJobCompleted(job.selectedAgentId, result);
        
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
  }
  
  // Submit review
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/review$/) && req.method === 'POST') {
    const jobId = url.pathname.split('/')[4];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = sanitizeReviewData(JSON.parse(body));
        const result = createReview(jobId, data);
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
          return;
        }
        
        // Notify review recipient
        notifyNewReview(data.toProfileId, result);
        
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
  }
  
  // Get marketplace stats
  else if (url.pathname === '/api/marketplace/stats' && req.method === 'GET') {
    const stats = getMarketplaceStats();
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(stats));
  }

  // Response time metrics for an agent
  else if (url.pathname.match(/^\/api\/agents\/([^/]+)\/response-metrics$/) && req.method === 'GET') {
    const agentId = decodeURIComponent(url.pathname.split('/')[3]);
    const metrics = db.getAgentResponseMetrics(agentId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(metrics));
  }
  
  // Confirm escrow deposit
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/deposit$/) && req.method === 'POST') {
    const jobId = url.pathname.split('/')[4];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { txSignature, clientId } = JSON.parse(body);
        const result = confirmJobDeposit(jobId, txSignature, clientId);
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
          return;
        }
        
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
  }
  
  // Get escrow deposit instructions
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/deposit-instructions$/) && req.method === 'GET') {
    const jobId = url.pathname.split('/')[4];
    const instructions = getJobDepositInstructions(jobId);
    
    if (instructions.error) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: instructions.error }));
      return;
    }
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(instructions));
  }
  
  // Submit work (agent marks work as done, starts 24h auto-release timer)
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/submit-work$/) && req.method === 'POST') {
    const jobId = url.pathname.split('/')[4];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const result = submitJobWork(jobId, data);
        
        if (result.error) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: result.error }));
          return;
        }
        
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON' }));
      }
    });
  }
  
  // Start work (agent_accepted → in_progress)
  else if (url.pathname.match(/^\/api\/marketplace\/jobs\/([^/]+)\/start-work$/) && req.method === 'POST') {
    const jobId = url.pathname.split('/')[4];
    const result = startJobWork(jobId);
    
    if (result.error) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: result.error }));
      return;
    }
    
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result));
  }
  
  // ============ END MARKETPLACE ROUTES ============

  // ============ REPUTATION ORACLE / TRUST API ============

  else if (url.pathname.match(/^\/api\/trust\/batch$/) && req.method === 'POST') {
    // Batch trust lookup — requires API key
    const apiKeyHeader = req.headers['x-api-key'] || (req.headers['authorization'] || '').replace('Bearer ', '');
    if (!apiKeyHeader) {
      res.writeHead(401, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'API key required for batch lookups. Pass via x-api-key header.' }));
      return;
    }
    const keyInfo = validateApiKey(apiKeyHeader);
    if (!keyInfo) {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Invalid API key' }));
      return;
    }
    let body = '';
    req.on('data', chunk => { body += chunk; if (body.length > 10000) req.destroy(); });
    req.on('end', () => {
      try {
        const { agentIds } = JSON.parse(body);
        if (!Array.isArray(agentIds) || agentIds.length === 0) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'agentIds must be a non-empty array' }));
          return;
        }
        if (agentIds.length > 50) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Maximum 50 agents per batch request' }));
          return;
        }
        const results = agentIds.map(id => computeTrustData(id));
        res.writeHead(200, { 'Content-Type': 'application/json', 'Cache-Control': 'public, max-age=300' });
        res.end(JSON.stringify({ results, queriedAt: new Date().toISOString() }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid JSON body' }));
      }
    });
  }

  else if (url.pathname.match(/^\/api\/trust\/([^/]+)\/badge\.svg$/) && req.method === 'GET') {
    // Trust badge SVG
    const agentId = url.pathname.match(/^\/api\/trust\/([^/]+)\/badge\.svg$/)[1];
    const trust = computeTrustData(agentId);
    const tierColors = { unverified: '#71717a', basic: '#a1a1aa', verified: '#06b6d4', established: '#22c55e', trusted: '#f59e0b' };
    const color = tierColors[trust.tier] || '#71717a';
    const tierLabel = trust.tier.charAt(0).toUpperCase() + trust.tier.slice(1);
    const scoreWidth = String(trust.trustScore).length * 8 + 12;
    const tierWidth = tierLabel.length * 7 + 12;
    const totalWidth = scoreWidth + tierWidth + 8;

    const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="${totalWidth}" height="24" viewBox="0 0 ${totalWidth} 24">
  <rect width="${totalWidth}" height="24" rx="4" fill="#18181b"/>
  <rect x="${scoreWidth}" width="${tierWidth + 8}" height="24" rx="0" fill="${color}" opacity="0.15"/>
  <rect x="${totalWidth - 4}" y="0" width="4" height="24" rx="0" fill="transparent"/>
  <path d="M${totalWidth - 4} 0h0a4 4 0 0 1 4 4v16a4 4 0 0 1-4 4h0V0z" fill="${color}" opacity="0.15"/>
  <text x="${scoreWidth / 2}" y="16" text-anchor="middle" fill="#06b6d4" font-family="monospace" font-size="12" font-weight="bold">${trust.trustScore}</text>
  <text x="${scoreWidth + (tierWidth + 8) / 2}" y="16" text-anchor="middle" fill="${color}" font-family="monospace" font-size="11">${tierLabel}</text>
  ${trust.warning ? `<circle cx="${totalWidth - 8}" cy="12" r="3" fill="#ef4444"/>` : ''}
</svg>`;
    res.writeHead(trust.agentId ? 200 : 404, {
      'Content-Type': 'image/svg+xml',
      'Cache-Control': 'public, max-age=3600',
      'Vary': 'Accept-Encoding'
    });
    res.end(svg);
  }

  else if (url.pathname.match(/^\/api\/trust\/([^/]+)$/) && req.method === 'GET') {
    // Public trust score endpoint
    const agentId = url.pathname.match(/^\/api\/trust\/([^/]+)$/)[1];
    const trust = computeTrustData(agentId);
    const status = trust.warning === 'not_found' ? 404 : 200;
    res.writeHead(status, { 'Content-Type': 'application/json', 'Cache-Control': 'public, max-age=300' });
    res.end(JSON.stringify(trust, null, 2));
  }

  // ============ END TRUST API ============

  // ============ CLAWNCH INTEGRATION API ============
  
  else if (url.pathname.match(/^\/api\/clawnch\/verify\/([^/]+)$/) && req.method === 'GET') {
    const tokenAddress = url.pathname.match(/^\/api\/clawnch\/verify\/([^/]+)$/)[1];
    verifyClawnchToken(tokenAddress).then(result => {
      const status = result.found ? 200 : 404;
      res.writeHead(status, { 'Content-Type': 'application/json', 'Cache-Control': 'public, max-age=60', 'Access-Control-Allow-Origin': '*' });
      res.end(JSON.stringify(result, null, 2));
    }).catch(e => {
      res.writeHead(502, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Failed to fetch Clawnch data', details: e.message }));
    });
  }

  else if (url.pathname === '/api/clawnch/stats' && req.method === 'GET') {
    getClawnchStats().then(stats => {
      res.writeHead(200, { 'Content-Type': 'application/json', 'Cache-Control': 'public, max-age=300', 'Access-Control-Allow-Origin': '*' });
      res.end(JSON.stringify(stats, null, 2));
    }).catch(e => {
      res.writeHead(502, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Failed to compute Clawnch stats', details: e.message }));
    });
  }

  else if (url.pathname === '/docs/clawnch' && req.method === 'GET') {
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generateClawnchDocsPage());
  }

  // ============ END CLAWNCH API ============

  // ============ SATP EXPLORER ============
  else if (url.pathname === '/satp-explorer') {
    const { getSATPOverview } = require('./lib/satp-explorer');
    getSATPOverview().then(overview => {
      res.writeHead(200, { 'Content-Type': 'text/html' });
      res.end(generateSATPExplorerPage(overview));
    }).catch(err => {
      logger.error('SATP Explorer error:', err.message);
      res.writeHead(200, { 'Content-Type': 'text/html' });
      res.end(generateSATPExplorerPage({ error: err.message, programs: require('./lib/satp-explorer').PROGRAMS, network: 'devnet', counts: { identities: 0, reputations: 0, validations: 0 }, accounts: { identities: [], reputations: [], validations: [] }, fetchedAt: new Date().toISOString() }));
    });
  }
  else if (url.pathname === '/api/satp/overview' && req.method === 'GET') {
    const { getSATPOverview } = require('./lib/satp-explorer');
    getSATPOverview().then(overview => {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(overview));
    }).catch(err => {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: err.message }));
    });
  }
  // ============ END SATP EXPLORER ============

  // ============ PREMIUM PROFILES ============

  // GET /api/premium/tiers - List all tiers
  else if (url.pathname === '/api/premium/tiers' && req.method === 'GET') {
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ tiers: PREMIUM_TIERS }));
  }

  // GET /api/premium/status/:profileId - Get profile's premium status
  else if (url.pathname.startsWith('/api/premium/status/') && req.method === 'GET') {
    const profileId = url.pathname.split('/').pop();
    const tier = getProfileTier(profileId);
    const tierInfo = getPremiumTierInfo(tier);
    const customBadges = getCustomBadges(profileId);
    const history = getPurchaseHistory(profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ profileId, tier, tierInfo, customBadges, purchaseHistory: history }));
  }

  // POST /api/premium/upgrade - Upgrade a profile (admin/payment callback)
  else if (url.pathname === '/api/premium/upgrade' && req.method === 'POST') {
    let body = '';
    req.on('data', c => body += c);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const { profileId, tier, durationDays, paymentMethod, paymentRef, amountUsd, adminKey } = data;
        // Simple admin auth
        if (adminKey !== (process.env.ADMIN_KEY || 'agentfolio-admin')) {
          res.writeHead(403, { 'Content-Type': 'application/json' });
          return res.end(JSON.stringify({ error: 'Unauthorized' }));
        }
        if (!profileId || !tier || !durationDays) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          return res.end(JSON.stringify({ error: 'profileId, tier, and durationDays required' }));
        }
        if (!PREMIUM_TIERS[tier]) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          return res.end(JSON.stringify({ error: 'Invalid tier. Options: free, pro, elite' }));
        }
        const result = upgradeTier(profileId, tier, durationDays, paymentMethod, paymentRef, amountUsd);
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true, ...result }));
      } catch (err) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: err.message }));
      }
    });
  }

  // POST /api/premium/badges - Add custom badge
  else if (url.pathname === '/api/premium/badges' && req.method === 'POST') {
    let body = '';
    req.on('data', c => body += c);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const { profileId, name, emoji, description, color, apiKey } = data;
        // Auth: need API key with write:own
        const keyInfo = apiKey ? validateApiKey(apiKey) : null;
        if (!keyInfo || !hasPermission(keyInfo, 'write:own')) {
          res.writeHead(403, { 'Content-Type': 'application/json' });
          return res.end(JSON.stringify({ error: 'Valid API key with write:own required' }));
        }
        const badge = addCustomBadge(profileId, name, emoji, description, color);
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true, badge }));
      } catch (err) {
        res.writeHead(err.message.includes('allows max') ? 403 : 400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: err.message }));
      }
    });
  }

  // DELETE /api/premium/badges/:badgeId - Remove custom badge
  else if (url.pathname.startsWith('/api/premium/badges/') && req.method === 'DELETE') {
    const badgeId = url.pathname.split('/').pop();
    let body = '';
    req.on('data', c => body += c);
    req.on('end', () => {
      try {
        const data = body ? JSON.parse(body) : {};
        const { profileId } = data;
        if (!profileId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          return res.end(JSON.stringify({ error: 'profileId required' }));
        }
        removeCustomBadge(profileId, badgeId);
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true }));
      } catch (err) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: err.message }));
      }
    });
  }

  // GET /api/premium/stats - Platform premium stats (admin)
  else if (url.pathname === '/api/premium/stats' && req.method === 'GET') {
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(getPremiumStats()));
  }

  // ============ VERIFICATION-AS-A-SERVICE (VaaS) ENDPOINTS ============

  // GET /api/vaas/types - List available verification types
  else if (url.pathname === '/api/vaas/types' && req.method === 'GET') {
    const vaas = require('./lib/vaas');
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      types: vaas.VERIFICATION_TYPES,
      pricing: {
        pro: { price: '$29/mo', rateLimit: '10,000 verifications/day', types: ['github', 'solana', 'hyperliquid', 'twitter', 'polymarket'] },
        enterprise: { price: '$99/mo', rateLimit: 'Unlimited', types: ['github', 'solana', 'hyperliquid', 'twitter', 'polymarket', 'composite'] }
      },
      docs: 'https://agentfolio.bot/api/docs#vaas'
    }));
  }

  // POST /api/vaas/verify - Run a verification
  else if (url.pathname === '/api/vaas/verify' && req.method === 'POST') {
    const keyInfo = requireAuth(req, res, PERMISSIONS.read);
    if (!keyInfo) return;

    // Require pro or enterprise tier (admin bypasses)
    if (!keyInfo.isAdmin && keyInfo.tier !== 'pro' && keyInfo.tier !== 'enterprise') {
      res.writeHead(403, { 'Content-Type': 'application/json' });
      return res.end(JSON.stringify({ error: 'VaaS requires Pro or Enterprise API key tier', upgrade: 'https://agentfolio.bot/pricing' }));
    }

    let body = '';
    req.on('data', c => body += c);
    req.on('end', async () => {
      try {
        const vaas = require('./lib/vaas');
        const data = JSON.parse(body);
        const { type, ...params } = data;

        if (!type || !vaas.VERIFICATION_TYPES[type]) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          return res.end(JSON.stringify({ error: 'Invalid verification type', validTypes: Object.keys(vaas.VERIFICATION_TYPES) }));
        }

        // Enterprise-only check for composite
        if (type === 'composite' && keyInfo.tier !== 'enterprise' && !keyInfo.isAdmin) {
          res.writeHead(403, { 'Content-Type': 'application/json' });
          return res.end(JSON.stringify({ error: 'Composite verification requires Enterprise tier' }));
        }

        // Validate required fields
        const typeInfo = vaas.VERIFICATION_TYPES[type];
        for (const field of typeInfo.requiredFields) {
          if (!params[field]) {
            res.writeHead(400, { 'Content-Type': 'application/json' });
            return res.end(JSON.stringify({ error: `Missing required field: ${field}`, required: typeInfo.requiredFields }));
          }
        }

        const report = await vaas.verify(type, params, keyInfo.keyHash || 'admin');
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(report));
      } catch (err) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Verification failed', message: err.message }));
      }
    });
  }

  // GET /api/vaas/reports - List your verification reports
  else if (url.pathname === '/api/vaas/reports' && req.method === 'GET') {
    const keyInfo = requireAuth(req, res, PERMISSIONS.read);
    if (!keyInfo) return;

    const vaas = require('./lib/vaas');
    const limit = parseInt(url.searchParams.get('limit')) || 50;
    const reports = vaas.listReports(keyInfo.keyHash || 'admin', limit);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ reports, count: reports.length }));
  }

  // GET /api/vaas/reports/:id - Get a specific report
  else if (url.pathname.match(/^\/api\/vaas\/reports\/([^/]+)$/) && req.method === 'GET') {
    const keyInfo = requireAuth(req, res, PERMISSIONS.read);
    if (!keyInfo) return;

    const vaas = require('./lib/vaas');
    const reportId = url.pathname.match(/^\/api\/vaas\/reports\/([^/]+)$/)[1];
    const report = vaas.getReport(reportId);

    if (!report) {
      res.writeHead(404, { 'Content-Type': 'application/json' });
      return res.end(JSON.stringify({ error: 'Report not found' }));
    }

    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(report));
  }

  // GET /api/vaas/stats - Get your VaaS usage stats
  else if (url.pathname === '/api/vaas/stats' && req.method === 'GET') {
    const keyInfo = requireAuth(req, res, PERMISSIONS.read);
    if (!keyInfo) return;

    const vaas = require('./lib/vaas');
    const stats = vaas.getUsageStats(keyInfo.keyHash || 'admin');
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(stats));
  }

  // POST /api/vaas/verify-attestation - Verify an attestation is authentic
  else if (url.pathname === '/api/vaas/verify-attestation' && req.method === 'POST') {
    let body = '';
    req.on('data', c => body += c);
    req.on('end', () => {
      try {
        const vaas = require('./lib/vaas');
        const { hash, payload } = JSON.parse(body);
        if (!hash || !payload) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          return res.end(JSON.stringify({ error: 'Both hash and payload are required' }));
        }
        const valid = vaas.verifyAttestation(hash, Buffer.from(payload, 'base64').toString());
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ valid, message: valid ? 'Attestation is authentic' : 'Attestation is invalid or tampered' }));
      } catch (err) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Invalid request', message: err.message }));
      }
    });
  }

  // ============ CUSTOM VERIFICATION PROVIDERS ============

  // GET /api/verification-providers - Public directory of approved providers
  else if (url.pathname === '/api/verification-providers' && req.method === 'GET') {
    try {
      const cvp = require('./lib/custom-verification-providers');
      const status = url.searchParams.get('status');
      if (status && !['approved', 'pending'].includes(status)) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        return res.end(JSON.stringify({ error: 'Invalid status filter' }));
      }
      const providers = status ? cvp.listProviders({ status }) : cvp.getProviderDirectory();
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ providers }));
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // POST /api/verification-providers - Register a new provider (Enterprise API key)
  else if (url.pathname === '/api/verification-providers' && req.method === 'POST') {
    let body = '';
    req.on('data', c => body += c);
    req.on('end', () => {
      try {
        const apiKey = extractApiKey(req);
        if (!apiKey) { res.writeHead(401, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'API key required' })); }
        const keyInfo = validateApiKey(apiKey);
        if (!keyInfo) { res.writeHead(401, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Invalid API key' })); }
        if (!hasPermission(keyInfo, 'admin')) { res.writeHead(403, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Enterprise API key required' })); }
        
        const data = JSON.parse(body);
        const cvp = require('./lib/custom-verification-providers');
        const provider = cvp.registerProvider({
          name: data.name,
          description: data.description,
          iconUrl: data.iconUrl || data.icon_url,
          websiteUrl: data.websiteUrl || data.website_url,
          webhookUrl: data.webhookUrl || data.webhook_url,
          callbackUrl: data.callbackUrl || data.callback_url,
          ownerApiKey: apiKey,
          ownerProfileId: data.profileId || data.profile_id,
          schema: data.schema,
          requiredFields: data.requiredFields || data.required_fields,
          optionalFields: data.optionalFields || data.optional_fields,
          verificationMethod: data.verificationMethod || data.verification_method,
        });
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ provider, message: 'Provider registered. Awaiting approval.' }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }

  // GET /api/verification-providers/:id - Get provider details
  else if (url.pathname.match(/^\/api\/verification-providers\/([^/]+)$/) && req.method === 'GET') {
    try {
      const cvp = require('./lib/custom-verification-providers');
      const id = url.pathname.split('/').pop();
      const provider = cvp.getProvider(id);
      if (!provider) { res.writeHead(404, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Provider not found' })); }
      const stats = cvp.getProviderStats(id);
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ provider, stats }));
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // PATCH /api/verification-providers/:id - Update provider (owner only)
  else if (url.pathname.match(/^\/api\/verification-providers\/([^/]+)$/) && req.method === 'PATCH') {
    let body = '';
    req.on('data', c => body += c);
    req.on('end', () => {
      try {
        const apiKey = extractApiKey(req);
        if (!apiKey) { res.writeHead(401, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'API key required' })); }
        const cvp = require('./lib/custom-verification-providers');
        const id = url.pathname.split('/').pop();
        const updates = JSON.parse(body);
        const provider = cvp.updateProvider(id, apiKey, updates);
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ provider }));
      } catch (e) {
        const status = e.message.includes('Not authorized') ? 403 : e.message.includes('not found') ? 404 : 400;
        res.writeHead(status, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }

  // POST /api/verification-providers/:id/approve - Admin approve
  else if (url.pathname.match(/^\/api\/verification-providers\/([^/]+)\/approve$/) && req.method === 'POST') {
    try {
      const apiKey = extractApiKey(req);
      if (!apiKey) { res.writeHead(401, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'API key required' })); }
      const keyInfo = validateApiKey(apiKey);
      if (!keyInfo || !hasPermission(keyInfo, 'admin')) { res.writeHead(403, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Admin required' })); }
      
      const cvp = require('./lib/custom-verification-providers');
      const id = url.pathname.split('/')[3];
      const provider = cvp.approveProvider(id);
      if (!provider) { res.writeHead(404, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Provider not found or not pending' })); }
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ provider, message: 'Provider approved' }));
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // POST /api/verification-providers/:id/suspend - Admin suspend
  else if (url.pathname.match(/^\/api\/verification-providers\/([^/]+)\/suspend$/) && req.method === 'POST') {
    let body = '';
    req.on('data', c => body += c);
    req.on('end', () => {
      try {
        const apiKey = extractApiKey(req);
        if (!apiKey) { res.writeHead(401, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'API key required' })); }
        const keyInfo = validateApiKey(apiKey);
        if (!keyInfo || !hasPermission(keyInfo, 'admin')) { res.writeHead(403, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Admin required' })); }
        
        const cvp = require('./lib/custom-verification-providers');
        const id = url.pathname.split('/')[3];
        const data = JSON.parse(body || '{}');
        const provider = cvp.suspendProvider(id, data.reason);
        if (!provider) { res.writeHead(404, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Provider not found or not approved' })); }
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ provider, message: 'Provider suspended' }));
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }

  // POST /api/verification-providers/:id/verify - Submit verification for a profile
  else if (url.pathname.match(/^\/api\/verification-providers\/([^/]+)\/verify$/) && req.method === 'POST') {
    let body = '';
    req.on('data', c => body += c);
    req.on('end', () => {
      try {
        const apiKey = extractApiKey(req);
        if (!apiKey) { res.writeHead(401, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'API key required' })); }
        
        const cvp = require('./lib/custom-verification-providers');
        const providerId = url.pathname.split('/')[3];
        const data = JSON.parse(body);
        
        if (!data.profileId && !data.profile_id) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          return res.end(JSON.stringify({ error: 'profileId is required' }));
        }
        
        const verification = cvp.submitVerification({
          providerId,
          profileId: data.profileId || data.profile_id,
          result: data.result,
          proof: data.proof,
          metadata: data.metadata,
          score: data.score,
          expiresAt: data.expiresAt || data.expires_at,
          ownerApiKey: apiKey,
        });
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ verification, message: 'Verification submitted' }));
      } catch (e) {
        const status = e.message.includes('Not authorized') ? 403 : e.message.includes('not found') ? 404 : e.message.includes('not approved') ? 422 : 400;
        res.writeHead(status, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }

  // DELETE /api/verification-providers/:providerId/verifications/:id - Revoke a verification
  else if (url.pathname.match(/^\/api\/verification-providers\/([^/]+)\/verifications\/([^/]+)$/) && req.method === 'DELETE') {
    let body = '';
    req.on('data', c => body += c);
    req.on('end', () => {
      try {
        const apiKey = extractApiKey(req);
        if (!apiKey) { res.writeHead(401, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'API key required' })); }
        
        const cvp = require('./lib/custom-verification-providers');
        const parts = url.pathname.split('/');
        const verificationId = parts[5];
        const data = JSON.parse(body || '{}');
        const verification = cvp.revokeVerification(verificationId, apiKey, data.reason);
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ verification, message: 'Verification revoked' }));
      } catch (e) {
        const status = e.message.includes('Not authorized') ? 403 : e.message.includes('not found') ? 404 : 400;
        res.writeHead(status, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
    return;
  }

  // GET /api/profiles/:id/custom-verifications - Get custom verifications for a profile
  else if (url.pathname.match(/^\/api\/profiles\/([^/]+)\/custom-verifications$/) && req.method === 'GET') {
    try {
      const cvp = require('./lib/custom-verification-providers');
      const profileId = url.pathname.split('/')[3];
      const providerId = url.searchParams.get('provider');
      const verifications = cvp.getProfileVerifications(profileId, { providerId, status: 'verified' });
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ verifications }));
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // ============ FEATURED PLACEMENT AUCTIONS ============

  // GET /api/auctions/slots
  else if (url.pathname === '/api/auctions/slots' && req.method === 'GET') {
    try {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ slots: featuredAuctions.listSlots() }));
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // GET /api/auctions
  else if (url.pathname === '/api/auctions' && req.method === 'GET') {
    try {
      featuredAuctions.resolveExpiredAuctions();
      const status = url.searchParams.get('status') || 'open';
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ auctions: featuredAuctions.listAuctions(status) }));
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // POST /api/auctions - Create auction
  else if (url.pathname === '/api/auctions' && req.method === 'POST') {
    let body = '';
    req.on('data', c => body += c);
    req.on('end', () => {
      try {
        const { slot_id, duration_hours } = JSON.parse(body);
        if (!slot_id) { res.writeHead(400, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'slot_id required' })); }
        const auction = featuredAuctions.createAuction(slot_id, duration_hours);
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(auction));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // GET /api/featured - Active featured placements
  else if (url.pathname === '/api/featured' && req.method === 'GET') {
    try {
      featuredAuctions.resolveExpiredAuctions();
      const placement = url.searchParams.get('placement');
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ featured: featuredAuctions.getActivePlacements(placement) }));
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // GET /api/auctions/:id - Single auction with bids
  else if (url.pathname.startsWith('/api/auctions/agent/') && req.method === 'GET') {
    try {
      const parts = url.pathname.split('/');
      const profileId = parts[4];
      const sub = parts[5]; // bids or wins
      if (sub === 'bids') {
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ bids: featuredAuctions.getAgentBids(profileId) }));
      } else if (sub === 'wins') {
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ wins: featuredAuctions.getAgentWins(profileId) }));
      } else {
        res.writeHead(404, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'Not found' }));
      }
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // POST /api/auctions/:id/bids - Place bid
  else if (url.pathname.match(/^\/api\/auctions\/[^/]+\/bids$/) && req.method === 'POST') {
    let body = '';
    req.on('data', c => body += c);
    req.on('end', () => {
      try {
        const auctionId = url.pathname.split('/')[3];
        const { profile_id, amount_usd } = JSON.parse(body);
        if (!profile_id || !amount_usd) { res.writeHead(400, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'profile_id and amount_usd required' })); }
        const bid = featuredAuctions.placeBid(auctionId, profile_id, parseFloat(amount_usd));
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(bid));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // POST /api/auctions/:id/resolve - Resolve auction
  else if (url.pathname.match(/^\/api\/auctions\/[^/]+\/resolve$/) && req.method === 'POST') {
    try {
      const auctionId = url.pathname.split('/')[3];
      const result = featuredAuctions.resolveAuction(auctionId);
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result));
    } catch (e) {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // GET /api/auctions/:id - Single auction detail
  else if (url.pathname.match(/^\/api\/auctions\/[^/]+$/) && req.method === 'GET') {
    try {
      featuredAuctions.resolveExpiredAuctions();
      const auctionId = url.pathname.split('/')[3];
      const auction = featuredAuctions.getAuction(auctionId);
      if (!auction) { res.writeHead(404, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Not found' })); }
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(auction));
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // GET /pricing - Premium pricing page
  else if (url.pathname === '/pricing' && req.method === 'GET') {
    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(generatePricingPage());
  }

  // ============ OAUTH2 ENDPOINTS ============

  // POST /oauth/clients - Register an OAuth client
  else if (url.pathname === '/oauth/clients' && req.method === 'POST') {
    let body = '';
    req.on('data', c => body += c);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const authHeader = req.headers['authorization'] || '';
        const apiKey = authHeader.replace('Bearer ', '') || req.headers['x-api-key'];
        const keyInfo = validateApiKey(apiKey);
        if (!keyInfo) {
          res.writeHead(401, { 'Content-Type': 'application/json' });
          return res.end(JSON.stringify({ error: 'API key required to register OAuth client' }));
        }
        const result = oauth.registerClient(keyInfo.profileId, {
          name: data.name,
          description: data.description,
          redirectUris: data.redirect_uris,
          scopes: data.scopes
        });
        res.writeHead(201, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true, ...result, note: 'Save client_secret - it cannot be retrieved later' }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // GET /oauth/clients - List your OAuth clients
  else if (url.pathname === '/oauth/clients' && req.method === 'GET') {
    const authHeader = req.headers['authorization'] || '';
    const apiKey = authHeader.replace('Bearer ', '') || req.headers['x-api-key'];
    const keyInfo = validateApiKey(apiKey);
    if (!keyInfo) {
      res.writeHead(401, { 'Content-Type': 'application/json' });
      return res.end(JSON.stringify({ error: 'Authentication required' }));
    }
    const clients = oauth.listClients(keyInfo.profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ clients }));
  }

  // DELETE /oauth/clients/:id - Revoke an OAuth client
  else if (url.pathname.startsWith('/oauth/clients/') && req.method === 'DELETE') {
    const clientId = url.pathname.split('/')[3];
    const authHeader = req.headers['authorization'] || '';
    const apiKey = authHeader.replace('Bearer ', '') || req.headers['x-api-key'];
    const keyInfo = validateApiKey(apiKey);
    if (!keyInfo) {
      res.writeHead(401, { 'Content-Type': 'application/json' });
      return res.end(JSON.stringify({ error: 'Authentication required' }));
    }
    const revoked = oauth.revokeClient(clientId, keyInfo.profileId);
    res.writeHead(revoked ? 200 : 404, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ success: revoked }));
  }

  // POST /oauth/token - Token endpoint (client_credentials + authorization_code + refresh_token)
  else if (url.pathname === '/oauth/token' && req.method === 'POST') {
    let body = '';
    req.on('data', c => body += c);
    req.on('end', () => {
      try {
        // Support both JSON and form-urlencoded
        let data;
        if (req.headers['content-type']?.includes('application/x-www-form-urlencoded')) {
          data = Object.fromEntries(new URLSearchParams(body));
        } else {
          data = JSON.parse(body);
        }

        let result;
        const grantType = data.grant_type;

        if (grantType === 'client_credentials') {
          const scopes = data.scope ? data.scope.split(' ') : undefined;
          result = oauth.clientCredentialsGrant(data.client_id, data.client_secret, scopes);
        } else if (grantType === 'authorization_code') {
          result = oauth.exchangeAuthCode(data.code, data.client_id, data.redirect_uri);
        } else if (grantType === 'refresh_token') {
          result = oauth.refreshAccessToken(data.refresh_token);
        } else {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          return res.end(JSON.stringify({ error: 'unsupported_grant_type', error_description: 'Supported: client_credentials, authorization_code, refresh_token' }));
        }

        if (!result) {
          res.writeHead(401, { 'Content-Type': 'application/json' });
          return res.end(JSON.stringify({ error: 'invalid_grant', error_description: 'Invalid credentials or expired token' }));
        }

        res.writeHead(200, { 'Content-Type': 'application/json', 'Cache-Control': 'no-store' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'invalid_request', error_description: e.message }));
      }
    });
  }

  // POST /oauth/revoke - Revoke a token
  else if (url.pathname === '/oauth/revoke' && req.method === 'POST') {
    let body = '';
    req.on('data', c => body += c);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        oauth.revokeToken(data.token);
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // GET /oauth/userinfo - Get token owner info
  else if (url.pathname === '/oauth/userinfo' && req.method === 'GET') {
    const tokenInfo = oauth.authenticateOAuth(req);
    if (!tokenInfo) {
      res.writeHead(401, { 'Content-Type': 'application/json' });
      return res.end(JSON.stringify({ error: 'invalid_token' }));
    }
    const profile = loadProfile(tokenInfo.profileId);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      sub: tokenInfo.profileId,
      name: profile?.name || tokenInfo.profileId,
      handle: profile?.handle,
      scopes: tokenInfo.scopes,
      expires_at: tokenInfo.expiresAt
    }));
  }

  // GET /.well-known/oauth-authorization-server - Discovery document
  else if (url.pathname === '/.well-known/oauth-authorization-server' && req.method === 'GET') {
    const base = `https://agentfolio.bot`;
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({
      issuer: base,
      token_endpoint: `${base}/oauth/token`,
      revocation_endpoint: `${base}/oauth/revoke`,
      userinfo_endpoint: `${base}/oauth/userinfo`,
      registration_endpoint: `${base}/oauth/clients`,
      scopes_supported: oauth.VALID_SCOPES,
      response_types_supported: ['code', 'token'],
      grant_types_supported: ['client_credentials', 'authorization_code', 'refresh_token'],
      token_endpoint_auth_methods_supported: ['client_secret_post']
    }));
  }

  // ============ END OAUTH2 ============

  // ============ AUDIT TRAIL / TRANSPARENCY LOGS ============

  // GET /api/audit - Query audit trail
  else if (url.pathname === '/api/audit' && req.method === 'GET') {
    trackApiCall('/api/audit');
    const eventType = url.searchParams.get('type');
    const actorId = url.searchParams.get('actor');
    const targetId = url.searchParams.get('target');
    const limit = Math.min(parseInt(url.searchParams.get('limit') || '50'), 200);
    const offset = parseInt(url.searchParams.get('offset') || '0');
    const since = url.searchParams.get('since');
    const until = url.searchParams.get('until');

    const result = queryAuditTrail({ eventType, actorId, targetId, limit, offset, since, until });
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result));
  }

  // GET /api/audit/profile/:id - Audit trail for a specific profile
  else if (url.pathname.match(/^\/api\/audit\/profile\/([^/]+)$/) && req.method === 'GET') {
    const profileId = decodeURIComponent(url.pathname.split('/')[4]);
    const limit = Math.min(parseInt(url.searchParams.get('limit') || '50'), 200);
    const result = getProfileAuditTrail(profileId, limit);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(result));
  }

  // GET /api/audit/stats - Event statistics
  else if (url.pathname === '/api/audit/stats' && req.method === 'GET') {
    trackApiCall('/api/audit/stats');
    const since = url.searchParams.get('since');
    const stats = getEventStats(since);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ stats }));
  }

  // ===== STAKING API =====
  
  // POST /api/staking/stake - Stake on an agent
  else if (url.pathname === '/api/staking/stake' && req.method === 'POST') {
    trackApiCall('/api/staking/stake');
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { stakerId, agentId, amount } = JSON.parse(body);
        if (!stakerId || !agentId || !amount) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          return res.end(JSON.stringify({ error: 'stakerId, agentId, and amount required' }));
        }
        const result = staking.stakeOnAgent(stakerId, agentId, parseInt(amount));
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true, ...result }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // POST /api/staking/unstake - Unstake from an agent
  else if (url.pathname === '/api/staking/unstake' && req.method === 'POST') {
    trackApiCall('/api/staking/unstake');
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { stakerId, agentId } = JSON.parse(body);
        if (!stakerId || !agentId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          return res.end(JSON.stringify({ error: 'stakerId and agentId required' }));
        }
        const result = staking.unstakeFromAgent(stakerId, agentId);
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true, ...result }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // GET /api/staking/balance/:userId
  else if (url.pathname.startsWith('/api/staking/balance/') && req.method === 'GET') {
    trackApiCall('/api/staking/balance');
    const userId = decodeURIComponent(url.pathname.split('/api/staking/balance/')[1]);
    try {
      const balance = staking.getBalance(userId);
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(balance));
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // GET /api/staking/agent/:agentId
  else if (url.pathname.startsWith('/api/staking/agent/') && req.method === 'GET') {
    trackApiCall('/api/staking/agent');
    const agentId = decodeURIComponent(url.pathname.split('/api/staking/agent/')[1]);
    try {
      const info = staking.getAgentStakes(agentId);
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(info));
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // GET /api/staking/user/:userId
  else if (url.pathname.startsWith('/api/staking/user/') && req.method === 'GET') {
    trackApiCall('/api/staking/user');
    const userId = decodeURIComponent(url.pathname.split('/api/staking/user/')[1]);
    try {
      const stakes = staking.getUserStakes(userId);
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ stakes }));
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // GET /api/staking/history/:userId
  else if (url.pathname.startsWith('/api/staking/history/') && req.method === 'GET') {
    trackApiCall('/api/staking/history');
    const userId = decodeURIComponent(url.pathname.split('/api/staking/history/')[1]);
    const limit = parseInt(url.searchParams.get('limit')) || 50;
    try {
      const history = staking.getUserHistory(userId, limit);
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ history }));
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // GET /api/staking/leaderboard
  else if (url.pathname === '/api/staking/leaderboard' && req.method === 'GET') {
    trackApiCall('/api/staking/leaderboard');
    const limit = parseInt(url.searchParams.get('limit')) || 20;
    try {
      const leaderboard = staking.getStakingLeaderboard(limit);
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(leaderboard));
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // ===== CAPITAL DELEGATION API =====

  // POST /api/vaults - Create vault
  else if (url.pathname === '/api/vaults' && req.method === 'POST') {
    trackApiCall('/api/vaults');
    let body = ''; req.on('data', c => body += c); req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const agentId = data.agentId || req.headers['x-user-id'];
        if (!agentId) { res.writeHead(401, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Auth required' })); }
        const vault = capitalDelegation.createVault(agentId, data);
        res.writeHead(201, { 'Content-Type': 'application/json' }); res.end(JSON.stringify(vault));
      } catch(e) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
    });
  }

  // GET /api/vaults/leaderboard
  else if (url.pathname === '/api/vaults/leaderboard' && req.method === 'GET') {
    trackApiCall('/api/vaults/leaderboard');
    try {
      const limit = Math.min(parseInt(url.searchParams.get('limit')) || 20, 100);
      const vaults = capitalDelegation.getVaultLeaderboard({ limit });
      res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ vaults }));
    } catch(e) { res.writeHead(500, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
  }

  // GET /api/vaults - List active vaults
  else if (url.pathname === '/api/vaults' && req.method === 'GET') {
    trackApiCall('/api/vaults');
    try {
      const limit = Math.min(parseInt(url.searchParams.get('limit')) || 20, 100);
      const offset = parseInt(url.searchParams.get('offset')) || 0;
      const sortBy = url.searchParams.get('sortBy');
      const vaults = capitalDelegation.listActiveVaults({ limit, offset, sortBy });
      res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ vaults }));
    } catch(e) { res.writeHead(500, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
  }

  // GET /api/vaults/:id/nav - NAV history
  else if (url.pathname.match(/^\/api\/vaults\/[^/]+\/nav$/) && req.method === 'GET') {
    const vaultId = decodeURIComponent(url.pathname.split('/')[3]);
    trackApiCall('/api/vaults/:id/nav');
    try {
      const limit = Math.min(parseInt(url.searchParams.get('limit')) || 30, 200);
      const history = capitalDelegation.getNavHistory(vaultId, { limit });
      res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ history }));
    } catch(e) { res.writeHead(500, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
  }

  // PUT /api/vaults/:id/nav - Update NAV
  else if (url.pathname.match(/^\/api\/vaults\/[^/]+\/nav$/) && req.method === 'PUT') {
    const vaultId = decodeURIComponent(url.pathname.split('/')[3]);
    trackApiCall('/api/vaults/:id/nav');
    let body = ''; req.on('data', c => body += c); req.on('end', () => {
      try {
        const { nav, note } = JSON.parse(body);
        const agentId = req.headers['x-user-id'];
        if (!agentId) { res.writeHead(401, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Auth required' })); }
        if (typeof nav !== 'number' || nav < 0) { res.writeHead(400, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'NAV must be non-negative number' })); }
        const vault = capitalDelegation.updateNav(vaultId, agentId, nav, note);
        res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify(vault));
      } catch(e) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
    });
  }

  // POST /api/vaults/:id/delegate - Delegate capital
  else if (url.pathname.match(/^\/api\/vaults\/[^/]+\/delegate$/) && req.method === 'POST') {
    const vaultId = decodeURIComponent(url.pathname.split('/')[3]);
    trackApiCall('/api/vaults/:id/delegate');
    let body = ''; req.on('data', c => body += c); req.on('end', () => {
      try {
        const { amount } = JSON.parse(body);
        const delegatorId = req.headers['x-user-id'];
        if (!delegatorId) { res.writeHead(401, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Auth required' })); }
        if (typeof amount !== 'number' || amount <= 0) { res.writeHead(400, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Amount must be positive' })); }
        const result = capitalDelegation.delegate(vaultId, delegatorId, amount);
        res.writeHead(201, { 'Content-Type': 'application/json' }); res.end(JSON.stringify(result));
      } catch(e) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
    });
  }

  // POST /api/delegations/:id/withdraw
  else if (url.pathname.match(/^\/api\/delegations\/\d+\/withdraw$/) && req.method === 'POST') {
    const delegationId = parseInt(url.pathname.split('/')[3]);
    trackApiCall('/api/delegations/:id/withdraw');
    try {
      const delegatorId = req.headers['x-user-id'];
      if (!delegatorId) { res.writeHead(401, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Auth required' })); }
      const result = capitalDelegation.withdraw(delegationId, delegatorId);
      res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify(result));
    } catch(e) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
  }

  // GET /api/delegations/my
  else if (url.pathname === '/api/delegations/my' && req.method === 'GET') {
    trackApiCall('/api/delegations/my');
    try {
      const userId = req.headers['x-user-id'];
      if (!userId) { res.writeHead(401, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Auth required' })); }
      const positions = capitalDelegation.getDelegatorPositions(userId);
      res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ positions }));
    } catch(e) { res.writeHead(500, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
  }

  // GET /api/delegations/history
  else if (url.pathname === '/api/delegations/history' && req.method === 'GET') {
    trackApiCall('/api/delegations/history');
    try {
      const userId = req.headers['x-user-id'];
      if (!userId) { res.writeHead(401, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Auth required' })); }
      const limit = Math.min(parseInt(url.searchParams.get('limit')) || 50, 200);
      const history = capitalDelegation.getDelegationHistory(userId, { limit });
      res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ history }));
    } catch(e) { res.writeHead(500, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
  }

  // GET /api/agents/:id/vaults
  else if (url.pathname.match(/^\/api\/agents\/[^/]+\/vaults$/) && req.method === 'GET') {
    const agentId = decodeURIComponent(url.pathname.split('/')[3]);
    trackApiCall('/api/agents/:id/vaults');
    try {
      const vaults = capitalDelegation.getAgentVaults(agentId);
      res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ vaults }));
    } catch(e) { res.writeHead(500, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
  }

  // GET /api/vaults/:id - Vault details
  else if (url.pathname.match(/^\/api\/vaults\/[^/]+$/) && req.method === 'GET') {
    const vaultId = decodeURIComponent(url.pathname.split('/')[3]);
    trackApiCall('/api/vaults/:id');
    try {
      const stats = capitalDelegation.getVaultStats(vaultId);
      if (!stats) { res.writeHead(404, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Vault not found' })); }
      res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify(stats));
    } catch(e) { res.writeHead(500, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
  }

  // ============ PERFORMANCE-BASED FEES ============

  // GET /api/fees/tiers - List all fee tiers
  else if (url.pathname === '/api/fees/tiers' && req.method === 'GET') {
    trackApiCall('/api/fees/tiers');
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ tiers: performanceFees.getFeeTiers(), premiumDiscounts: performanceFees.PREMIUM_DISCOUNTS, minRate: performanceFees.MIN_FEE_RATE }));
  }

  // GET /api/fees/stats - Platform fee stats (admin)
  else if (url.pathname === '/api/fees/stats' && req.method === 'GET') {
    trackApiCall('/api/fees/stats');
    try {
      const stats = performanceFees.getPlatformFeeStats();
      res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify(stats));
    } catch(e) { res.writeHead(500, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
  }

  // GET /api/fees/:profileId - Get fee schedule for agent
  else if (url.pathname.match(/^\/api\/fees\/[^/]+$/) && !url.pathname.includes('/stats') && !url.pathname.includes('/tiers') && req.method === 'GET') {
    const profileId = decodeURIComponent(url.pathname.split('/')[3]);
    trackApiCall('/api/fees/:profileId');
    try {
      const feeInfo = performanceFees.calculateFeeRate(profileId);
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({
        profileId,
        tier: feeInfo.tier,
        tierName: feeInfo.tierName,
        effectiveRate: feeInfo.rate,
        effectivePercent: (feeInfo.rate * 100).toFixed(1) + '%',
        baseRate: feeInfo.baseRate,
        premiumDiscount: feeInfo.premiumDiscount,
        isCustom: feeInfo.isCustom,
        metrics: feeInfo.metrics,
        nextTier: feeInfo.tier < 4 ? performanceFees.FEE_TIERS[feeInfo.tier + 1] : null
      }));
    } catch(e) { res.writeHead(500, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
  }

  // GET /api/fees/:profileId/history - Fee history
  else if (url.pathname.match(/^\/api\/fees\/[^/]+\/history$/) && req.method === 'GET') {
    const profileId = decodeURIComponent(url.pathname.split('/')[3]);
    trackApiCall('/api/fees/:profileId/history');
    try {
      const limit = Math.min(parseInt(url.searchParams.get('limit')) || 50, 200);
      const history = performanceFees.getFeeHistory(profileId, limit);
      res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ profileId, history }));
    } catch(e) { res.writeHead(500, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
  }

  // POST /api/fees/:profileId/recalculate - Force recalculation
  else if (url.pathname.match(/^\/api\/fees\/[^/]+\/recalculate$/) && req.method === 'POST') {
    const profileId = decodeURIComponent(url.pathname.split('/')[3]);
    trackApiCall('/api/fees/:profileId/recalculate');
    try {
      const result = performanceFees.recalculateFeeSchedule(profileId);
      res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ profileId, ...result }));
    } catch(e) { res.writeHead(500, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
  }

  // PUT /api/fees/:profileId/custom - Set custom rate (admin)
  else if (url.pathname.match(/^\/api\/fees\/[^/]+\/custom$/) && req.method === 'PUT') {
    const profileId = decodeURIComponent(url.pathname.split('/')[3]);
    trackApiCall('/api/fees/:profileId/custom');
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { rate, reason } = JSON.parse(body);
        if (rate == null || typeof rate !== 'number' || rate < 0 || rate > 0.10) {
          res.writeHead(400, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Rate must be 0-0.10' }));
        }
        const result = performanceFees.setCustomRate(profileId, rate, reason);
        res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ profileId, ...result }));
      } catch(e) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
    });
  }

  // DELETE /api/fees/:profileId/custom - Remove custom rate
  else if (url.pathname.match(/^\/api\/fees\/[^/]+\/custom$/) && req.method === 'DELETE') {
    const profileId = decodeURIComponent(url.pathname.split('/')[3]);
    trackApiCall('/api/fees/:profileId/custom');
    try {
      const result = performanceFees.removeCustomRate(profileId);
      res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ profileId, ...result }));
    } catch(e) { res.writeHead(500, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
  }

  // ============ GOVERNANCE ============

  // GET /api/governance/stats
  else if (url.pathname === '/api/governance/stats' && req.method === 'GET') {
    trackApiCall('/api/governance/stats');
    try {
      res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify(governance.getGovernanceStats()));
    } catch(e) { res.writeHead(500, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
  }

  // GET /api/governance/proposals
  else if (url.pathname === '/api/governance/proposals' && req.method === 'GET') {
    trackApiCall('/api/governance/proposals');
    try {
      const filters = {};
      if (url.searchParams.get('status')) filters.status = url.searchParams.get('status');
      if (url.searchParams.get('category')) filters.category = url.searchParams.get('category');
      if (url.searchParams.get('limit')) filters.limit = parseInt(url.searchParams.get('limit'));
      const proposals = governance.listProposals(filters);
      res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ proposals }));
    } catch(e) { res.writeHead(500, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
  }

  // POST /api/governance/proposals - Create proposal
  else if (url.pathname === '/api/governance/proposals' && req.method === 'POST') {
    trackApiCall('/api/governance/proposals');
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const proposerId = req.headers['x-user-id'];
        if (!proposerId) { res.writeHead(401, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Auth required' })); }
        const result = governance.createProposal(proposerId, data);
        res.writeHead(201, { 'Content-Type': 'application/json' }); res.end(JSON.stringify(result));
      } catch(e) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
    });
  }

  // GET /api/governance/proposals/:id
  else if (url.pathname.match(/^\/api\/governance\/proposals\/[^/]+$/) && req.method === 'GET') {
    const proposalId = decodeURIComponent(url.pathname.split('/')[4]);
    trackApiCall('/api/governance/proposals/:id');
    try {
      const proposal = governance.getProposal(proposalId);
      if (!proposal) { res.writeHead(404, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Not found' })); }
      const votes = governance.getProposalVotes(proposalId);
      res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ ...proposal, votes }));
    } catch(e) { res.writeHead(500, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
  }

  // POST /api/governance/proposals/:id/vote
  else if (url.pathname.match(/^\/api\/governance\/proposals\/[^/]+\/vote$/) && req.method === 'POST') {
    const proposalId = decodeURIComponent(url.pathname.split('/')[4]);
    trackApiCall('/api/governance/proposals/:id/vote');
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { vote, comment } = JSON.parse(body);
        const voterId = req.headers['x-user-id'];
        if (!voterId) { res.writeHead(401, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Auth required' })); }
        const result = governance.castVote(proposalId, voterId, vote, comment);
        res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify(result));
      } catch(e) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
    });
  }

  // POST /api/governance/proposals/:id/execute
  else if (url.pathname.match(/^\/api\/governance\/proposals\/[^/]+\/execute$/) && req.method === 'POST') {
    const proposalId = decodeURIComponent(url.pathname.split('/')[4]);
    trackApiCall('/api/governance/proposals/:id/execute');
    try {
      const result = governance.executeProposal(proposalId);
      res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify(result));
    } catch(e) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
  }

  // DELETE /api/governance/proposals/:id - Cancel
  else if (url.pathname.match(/^\/api\/governance\/proposals\/[^/]+$/) && req.method === 'DELETE') {
    const proposalId = decodeURIComponent(url.pathname.split('/')[4]);
    trackApiCall('/api/governance/proposals/:id');
    try {
      const requesterId = req.headers['x-user-id'];
      if (!requesterId) { res.writeHead(401, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Auth required' })); }
      const result = governance.cancelProposal(proposalId, requesterId);
      res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify(result));
    } catch(e) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
  }

  // GET /api/governance/power/:profileId
  else if (url.pathname.match(/^\/api\/governance\/power\/[^/]+$/) && req.method === 'GET') {
    const profileId = decodeURIComponent(url.pathname.split('/')[4]);
    trackApiCall('/api/governance/power/:profileId');
    try {
      const own = governance.getVotingPower(profileId);
      const effective = governance.getEffectiveVotingPower(profileId);
      const delegation = governance.getDelegation(profileId);
      const delegators = governance.getDelegators(profileId);
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ profileId, ownPower: own, effectivePower: effective, delegatedTo: delegation?.delegate_id || null, delegatedFrom: delegators.map(d => d.delegator_id) }));
    } catch(e) { res.writeHead(500, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
  }

  // POST /api/governance/delegate
  else if (url.pathname === '/api/governance/delegate' && req.method === 'POST') {
    trackApiCall('/api/governance/delegate');
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { delegateId } = JSON.parse(body);
        const delegatorId = req.headers['x-user-id'];
        if (!delegatorId) { res.writeHead(401, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Auth required' })); }
        const result = governance.delegateVote(delegatorId, delegateId);
        res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify(result));
      } catch(e) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
    });
  }

  // DELETE /api/governance/delegate
  else if (url.pathname === '/api/governance/delegate' && req.method === 'DELETE') {
    trackApiCall('/api/governance/delegate');
    try {
      const delegatorId = req.headers['x-user-id'];
      if (!delegatorId) { res.writeHead(401, { 'Content-Type': 'application/json' }); return res.end(JSON.stringify({ error: 'Auth required' })); }
      const result = governance.undelegateVote(delegatorId);
      res.writeHead(200, { 'Content-Type': 'application/json' }); res.end(JSON.stringify(result));
    } catch(e) { res.writeHead(400, { 'Content-Type': 'application/json' }); res.end(JSON.stringify({ error: e.message })); }
  }

  // GET /audit - Transparency log page
  else if (url.pathname === '/audit' && req.method === 'GET') {
    const { events, total } = getRecentEvents(100);
    const eventRows = events.map(e => {
      const meta = e.metadata ? JSON.parse(e.metadata) : {};
      return `<tr>
        <td style="color:#71717a;font-size:0.75rem;white-space:nowrap">${new Date(e.timestamp + 'Z').toLocaleString()}</td>
        <td><span style="background:#1e1e2e;color:#06b6d4;padding:2px 8px;border-radius:4px;font-size:0.7rem;font-family:monospace">${escapeHtml(e.event_type)}</span></td>
        <td>${e.actor_id ? `<a href="/profile/${encodeURIComponent(e.actor_id)}" style="color:#a78bfa">${escapeHtml(e.actor_id)}</a>` : '<span style="color:#52525b">system</span>'}</td>
        <td>${e.target_id ? `<a href="/profile/${encodeURIComponent(e.target_id)}" style="color:#06b6d4">${escapeHtml(e.target_id)}</a>` : '-'}</td>
        <td style="color:#a1a1aa;font-size:0.8rem">${escapeHtml(e.details || e.action || '')}</td>
      </tr>`;
    }).join('');

    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(pageHeader('Transparency Log', '') + `
      <div style="max-width:1200px;margin:0 auto;padding:32px 20px 60px">
        <h1 style="font-size:1.8rem;color:#fafafa;margin-bottom:8px">🔍 Transparency Log</h1>
        <p style="color:#71717a;margin-bottom:32px">${total} total events recorded. Every significant action on AgentFolio is logged here for full accountability.</p>
        <div style="background:#111113;border:1px solid #27272a;border-radius:12px;overflow:hidden">
          <table style="width:100%;border-collapse:collapse">
            <thead><tr style="border-bottom:1px solid #27272a">
              <th style="text-align:left;padding:12px;color:#71717a;font-size:0.7rem;text-transform:uppercase;letter-spacing:1px">Time</th>
              <th style="text-align:left;padding:12px;color:#71717a;font-size:0.7rem;text-transform:uppercase;letter-spacing:1px">Event</th>
              <th style="text-align:left;padding:12px;color:#71717a;font-size:0.7rem;text-transform:uppercase;letter-spacing:1px">Actor</th>
              <th style="text-align:left;padding:12px;color:#71717a;font-size:0.7rem;text-transform:uppercase;letter-spacing:1px">Target</th>
              <th style="text-align:left;padding:12px;color:#71717a;font-size:0.7rem;text-transform:uppercase;letter-spacing:1px">Details</th>
            </tr></thead>
            <tbody>${eventRows || '<tr><td colspan="5" style="text-align:center;padding:40px;color:#52525b">No events recorded yet. Activity will appear here as agents interact with the platform.</td></tr>'}</tbody>
          </table>
        </div>
        <div style="margin-top:24px;text-align:center">
          <p style="color:#52525b;font-size:0.8rem">API: <code style="background:#1e1e2e;padding:2px 6px;border-radius:4px;color:#06b6d4">GET /api/audit</code> — Query with filters: type, actor, target, since, until, limit, offset</p>
        </div>
      </div>
    </div></body></html>`);
  }

  // ============ END AUDIT TRAIL ============

  // ============ FRAMEWORK INTEGRATIONS ============

  // GET /api/integrations - List supported frameworks
  else if (url.pathname === '/api/integrations' && req.method === 'GET') {
    trackApiCall('/api/integrations');
    const frameworks = getSupportedFrameworks().map(f => getIntegrationCode(f));
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ frameworks }));
  }

  // POST /api/integrations/setup - Auto-setup an integration with API key
  else if (url.pathname === '/api/integrations/setup' && req.method === 'POST') {
    trackApiCall('/api/integrations/setup');
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const { framework, profileId, config } = JSON.parse(body);
        if (!framework || !profileId) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          return res.end(JSON.stringify({ error: 'framework and profileId required' }));
        }
        const supported = getSupportedFrameworks();
        if (!supported.includes(framework)) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          return res.end(JSON.stringify({ error: `Unknown framework. Supported: ${supported.join(', ')}` }));
        }
        const crypto = require('crypto');
        const apiKey = `agf_${framework}_${crypto.randomBytes(16).toString('hex')}`;
        const { db: sqliteDb } = require('./lib/database');
        sqliteDb.prepare(`
          INSERT OR REPLACE INTO integrations (profile_id, framework, api_key, config, created_at, updated_at)
          VALUES (?, ?, ?, ?, datetime('now'), datetime('now'))
        `).run(profileId, framework, apiKey, JSON.stringify(config || {}));
        const code = getIntegrationCode(framework, { apiKey, profileId });
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true, framework, profileId, apiKey, setupCode: code }));
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // GET /api/integrations/status/:profileId - Check integration health
  else if (url.pathname.match(/^\/api\/integrations\/status\/(.+)$/) && req.method === 'GET') {
    const pid = url.pathname.split('/')[4];
    trackApiCall('/api/integrations/status');
    try {
      const { db: sqliteDb2 } = require('./lib/database');
      const rows = sqliteDb2.prepare(`
        SELECT framework, config, created_at, updated_at FROM integrations WHERE profile_id = ?
      `).all(pid);
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ profileId: pid, integrations: rows }));
    } catch (e) {
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ profileId: pid, integrations: [] }));
    }
  }

  // GET /api/integrations/:framework - Get specific framework code
  else if (url.pathname.match(/^\/api\/integrations\/([a-z]+)$/) && req.method === 'GET') {
    const framework = url.pathname.split('/')[3];
    const integration = getIntegrationCode(framework);
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify(integration));
  }

  // GET /integrations - Framework integrations page
  else if (url.pathname === '/integrations' && req.method === 'GET') {
    const frameworks = getSupportedFrameworks().map(f => getIntegrationCode(f));
    const frameworkCards = frameworks.map(f => `
      <div style="background:#111113;border:1px solid #27272a;border-radius:12px;padding:24px;margin-bottom:16px">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
          <h3 style="color:#fafafa;margin:0">${escapeHtml(f.name)}</h3>
          <span style="background:#1e1e2e;color:#a78bfa;padding:4px 10px;border-radius:6px;font-size:0.75rem;font-family:monospace">${escapeHtml(f.language)}</span>
        </div>
        ${f.install ? `<div style="background:#0a0a0b;border:1px solid #18181b;border-radius:8px;padding:12px;margin-bottom:12px;font-family:monospace;font-size:0.8rem;color:#22c55e">$ ${escapeHtml(f.install)}</div>` : ''}
        <pre style="background:#0a0a0b;border:1px solid #18181b;border-radius:8px;padding:16px;overflow-x:auto;font-size:0.8rem;color:#a1a1aa;line-height:1.6;margin:0"><code>${escapeHtml(f.code)}</code></pre>
      </div>
    `).join('');

    res.writeHead(200, { 'Content-Type': 'text/html' });
    res.end(pageHeader('Framework Integrations', '') + `
      <div style="max-width:900px;margin:0 auto;padding:32px 20px 60px">
        <h1 style="font-size:1.8rem;color:#fafafa;margin-bottom:8px">🔌 Framework Integrations</h1>
        <p style="color:#71717a;margin-bottom:32px">Connect your AI agent to AgentFolio using your preferred framework. All integrations auto-sync activity, reputation, and availability.</p>
        ${frameworkCards}
        <div style="margin-top:32px;text-align:center">
          <p style="color:#52525b;font-size:0.85rem">Need a different framework? Use our <a href="/api/docs" style="color:#06b6d4">REST API</a> directly.</p>
          <p style="color:#52525b;font-size:0.8rem">API: <code style="background:#1e1e2e;padding:2px 6px;border-radius:4px;color:#06b6d4">GET /api/integrations</code></p>
        </div>
      </div>
    </div></body></html>`);
  }

  // ============ END FRAMEWORK INTEGRATIONS ============

  // ============ CROSS-CHAIN IDENTITY ============

  // GET /api/chains - List supported chains
  else if (url.pathname === '/api/chains' && req.method === 'GET') {
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ chains: crossChain.getSupportedChains() }));
  }

  // GET /api/profile/:id/wallets - Get cross-chain wallets for a profile
  else if (url.pathname.match(/^\/api\/profile\/[^/]+\/wallets$/) && req.method === 'GET') {
    const profileId = url.pathname.split('/')[3];
    try {
      const wallets = crossChain.getProfileWallets(profileId);
      const score = crossChain.getCrossChainScore(profileId);
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ wallets, identity: score }));
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // POST /api/profile/:id/wallets - Add a wallet (unverified)
  else if (url.pathname.match(/^\/api\/profile\/[^/]+\/wallets$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body || '{}');
        const result = crossChain.addWallet(profileId, data.chain, data.address, data.label);
        const status = result.error ? 400 : 201;
        res.writeHead(status, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // DELETE /api/profile/:id/wallets/:chain/:address - Remove a wallet
  else if (url.pathname.match(/^\/api\/profile\/[^/]+\/wallets\/[^/]+\/[^/]+$/) && req.method === 'DELETE') {
    const parts = url.pathname.split('/');
    const profileId = parts[3];
    const chain = parts[5];
    const address = decodeURIComponent(parts[6]);
    try {
      const result = crossChain.removeWallet(profileId, chain, address);
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(result));
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // POST /api/profile/:id/wallets/challenge - Request verification challenge
  else if (url.pathname.match(/^\/api\/profile\/[^/]+\/wallets\/challenge$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body || '{}');
        const result = crossChain.generateChallenge(profileId, data.chain, data.address);
        const status = result.error ? 400 : 200;
        res.writeHead(status, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // POST /api/profile/:id/wallets/verify - Submit signed challenge
  else if (url.pathname.match(/^\/api\/profile\/[^/]+\/wallets\/verify$/) && req.method === 'POST') {
    const profileId = url.pathname.split('/')[3];
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body || '{}');
        const result = crossChain.verifyChallenge(profileId, data.chain, data.address, data.signature);
        const status = result.error ? 400 : 200;
        res.writeHead(status, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // GET /api/wallet-lookup/:address - Reverse lookup: find profile by wallet
  else if (url.pathname.match(/^\/api\/wallet-lookup\/[^/]+$/) && req.method === 'GET') {
    const address = decodeURIComponent(url.pathname.split('/')[3]);
    try {
      const result = crossChain.findProfileByWallet(address);
      if (result) {
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } else {
        res.writeHead(404, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: 'No profile found for this wallet' }));
      }
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // ============ END CROSS-CHAIN IDENTITY ============

  // ============ $FOLIO TOKEN UTILITY ============

  // POST /api/staking/stake
  else if (url.pathname === '/api/staking/stake' && req.method === 'POST') {
    trackApiCall('/api/staking/stake');
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const { stake } = require('./lib/folio-staking');
        const result = stake(data.agentId, data.walletAddress, data.amount);
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // POST /api/staking/unstake
  else if (url.pathname === '/api/staking/unstake' && req.method === 'POST') {
    trackApiCall('/api/staking/unstake');
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', () => {
      try {
        const data = JSON.parse(body);
        const { unstake } = require('./lib/folio-staking');
        const result = unstake(data.agentId);
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(result));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }

  // GET /api/staking/leaderboard
  else if (url.pathname === '/api/staking/leaderboard' && req.method === 'GET') {
    trackApiCall('/api/staking/leaderboard');
    try {
      const { getLeaderboard } = require('./lib/folio-staking');
      const limit = parseInt(url.searchParams?.get('limit') || '20');
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(getLeaderboard(limit)));
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // GET /api/staking/:agentId
  else if (url.pathname.match(/^\/api\/staking\/([^/]+)$/) && req.method === 'GET') {
    trackApiCall('/api/staking/:agentId');
    try {
      const agentId = url.pathname.split('/').pop();
      const { getStakeInfo } = require('./lib/folio-staking');
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(getStakeInfo(agentId)));
    } catch (e) {
      res.writeHead(500, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: e.message }));
    }
  }

  // ============ END $FOLIO TOKEN UTILITY ============


  // --- SATP Reviews API (integrated from brainChain) ---
  else if (url.pathname === '/api/satp/reviews' && req.method === 'POST') {
    let body = '';
    req.on('data', chunk => body += chunk);
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);
        const { reviewer_id, reviewee_id, job_id, rating, comment } = data;
        if (!reviewer_id || !reviewee_id || !job_id) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Missing required fields: reviewer_id, reviewee_id, job_id' }));
          return;
        }
        if (!rating || rating < 1 || rating > 5) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Rating must be between 1 and 5' }));
          return;
        }
        if (!comment || comment.trim().length === 0) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Comment is required' }));
          return;
        }
        if (reviewer_id === reviewee_id) {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: 'Cannot review yourself' }));
          return;
        }
        const review = createReview(job_id, {
          reviewerId: reviewer_id,
          revieweeId: reviewee_id,
          rating: Math.floor(rating),
          comment: comment.trim(),
          type: 'satp'
        });
        // Attempt on-chain submission (non-blocking — review saved locally regardless)
        let onchain = { success: false, error: 'skipped' };
        try {
          const satpOnchain = require('./lib/satp-reviews-onchain');
          onchain = await satpOnchain.submitOnChain(reviewer_id, job_id, reviewee_id, Math.floor(rating), comment.trim());
          if (onchain.success) {
            review.txSignature = onchain.txSignature;
            review.reviewPDA = onchain.reviewPDA;
            review.onchainStatus = 'confirmed';
          } else {
            review.onchainStatus = 'failed';
            review.onchainError = onchain.error;
          }
        } catch (chainErr) {
          review.onchainStatus = 'error';
          review.onchainError = chainErr.message;
        }
        const httpStatus = onchain.success ? 201 : 202;
        res.writeHead(httpStatus, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ success: true, review: review, onchain: onchain }));
      } catch (e) {
        res.writeHead(400, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    });
  }
  else if (url.pathname === '/api/satp/reviews' && req.method === 'GET') {
    const agent = url.searchParams.get('agent');
    const reviewer = url.searchParams.get('reviewer');
    const jobId = url.searchParams.get('job_id');
    if (jobId) {
      const reviews = loadReviews(jobId);
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ job_id: jobId, reviews: reviews || [] }));
    } else if (agent || reviewer) {
      const allJobsResult = listJobs({status: 'all'}); const allJobs = (allJobsResult && allJobsResult.jobs) || [];
      const reviews = [];
      allJobs.forEach(function(j) {
        var jid = j.id || j.jobId;
        var jr = loadReviews(jid);
        if (jr) jr.forEach(function(r) {
          if (agent && r.revieweeId === agent) reviews.push(Object.assign({}, r, {jobId: jid}));
          if (reviewer && r.reviewerId === reviewer) reviews.push(Object.assign({}, r, {jobId: jid}));
        });
      });
      var resp = agent ? { agent: agent } : { reviewer: reviewer };
      resp.reviews = reviews;
      if (agent) {
        resp.stats = {
          total_reviews: reviews.length,
          avg_rating: reviews.length ? Number((reviews.reduce(function(s,r){return s+r.rating},0) / reviews.length).toFixed(2)) : 0
        };
      }
      res.writeHead(200, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify(resp));
    } else {
      res.writeHead(400, { 'Content-Type': 'application/json' });
      res.end(JSON.stringify({ error: 'Provide ?agent=<id>, ?reviewer=<id>, or ?job_id=<id>' }));
    }
  }
  else if (url.pathname.match(/^\/api\/satp\/reviews\/stats\/([^/]+)/) && req.method === 'GET') {
    var agentId = url.pathname.split('/')[5];
    var allJobsResult = listJobs({status: 'all'}); var allJobs = (allJobsResult && allJobsResult.jobs) || [];
    var reviews = [];
    allJobs.forEach(function(j) {
      var jid = j.id || j.jobId;
      var jr = loadReviews(jid);
      if (jr) jr.forEach(function(r) { if (r.revieweeId === agentId) reviews.push(r); });
    });
    var stats = {
      total_reviews: reviews.length,
      avg_rating: reviews.length ? Number((reviews.reduce(function(s,r){return s+r.rating},0) / reviews.length).toFixed(2)) : 0,
      five_star: reviews.filter(function(r){return r.rating===5}).length,
      four_star: reviews.filter(function(r){return r.rating===4}).length,
      three_star: reviews.filter(function(r){return r.rating===3}).length,
      two_star: reviews.filter(function(r){return r.rating===2}).length,
      one_star: reviews.filter(function(r){return r.rating===1}).length,
    };
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ agent: agentId, stats: stats, recent_reviews: reviews.slice(0, 5) }));
  }
  else {
    res.writeHead(404, { 'Content-Type': 'text/plain' });
    res.end('Not found');
  }
});

// Helper function for event descriptions
function getEventDescription(event) {
  const descriptions = {
    'agent.registered': 'Triggered when a new agent registers on AgentFolio',
    'agent.verified': 'Triggered when an agent achieves verified status',
    'verification.x': 'Triggered when X/X verification succeeds',
    'verification.hyperliquid': 'Triggered when Hyperliquid trading verification succeeds',
    'verification.solana': 'Triggered when Solana wallet verification succeeds',
    'endorsement.added': 'Triggered when an agent receives an endorsement',
    'profile.updated': 'Triggered when a profile is updated'
  };
  return descriptions[event] || 'No description available';
}

// ============ API KEY PAGE GENERATORS ============

function generateApiKeyDocsPage() {
  return `<!DOCTYPE html><html><head><title>AgentFolio API Keys</title>
  ${COMMON_STYLES}
  </head><body>
  <div class="container" style="max-width:800px;padding:40px 24px;">
    <h1 class="gradient-text" style="font-size:36px;margin-bottom:24px;">🔑 AgentFolio API</h1>
    <div style="background:#18181b;border:1px solid #27272a;border-radius:16px;padding:24px;margin-bottom:24px;">
      <h2 style="color:#fff;margin-bottom:16px;">Getting Started</h2>
      <p style="color:#a1a1aa;margin-bottom:16px;">Generate an API key to access AgentFolio data programmatically.</p>
      <pre style="background:#09090b;padding:16px;border-radius:8px;color:#06b6d4;overflow-x:auto;margin-bottom:16px;">
# Generate a key
curl -X POST https://agentfolio.bot/api/keys/generate \\
  -H "Content-Type: application/json" \\
  -d '{"profileId": "your_profile_id", "tier": "free"}'

# Use the key
curl https://agentfolio.bot/api/profiles \\
  -H "Authorization: Bearer af_your_key_here"

# Or via header
curl https://agentfolio.bot/api/profile/agent_id \\
  -H "X-API-Key: af_your_key_here"</pre>
    </div>
    <div style="background:#18181b;border:1px solid #27272a;border-radius:16px;padding:24px;margin-bottom:24px;">
      <h2 style="color:#fff;margin-bottom:16px;">📊 Tiers & Rate Limits</h2>
      <table style="width:100%;border-collapse:collapse;color:#e4e4e7;">
        <tr style="border-bottom:1px solid #27272a;"><th style="text-align:left;padding:12px;color:#71717a;">Tier</th><th style="padding:12px;color:#71717a;">Rate Limit</th><th style="padding:12px;color:#71717a;">Price</th><th style="text-align:left;padding:12px;color:#71717a;">Features</th></tr>
        <tr style="border-bottom:1px solid #27272a;"><td style="padding:12px;">🆓 Free</td><td style="padding:12px;text-align:center;">100/day</td><td style="padding:12px;text-align:center;">$0</td><td style="padding:12px;">Basic profile data</td></tr>
        <tr style="border-bottom:1px solid #27272a;"><td style="padding:12px;">⚡ Pro</td><td style="padding:12px;text-align:center;">10,000/day</td><td style="padding:12px;text-align:center;">$29/mo</td><td style="padding:12px;">Full verification data, webhooks</td></tr>
        <tr><td style="padding:12px;">🏢 Enterprise</td><td style="padding:12px;text-align:center;">Unlimited</td><td style="padding:12px;text-align:center;">$99/mo</td><td style="padding:12px;">Everything + priority support</td></tr>
      </table>
    </div>
    <div style="background:#18181b;border:1px solid #27272a;border-radius:16px;padding:24px;">
      <h2 style="color:#fff;margin-bottom:16px;">🔒 Protected Endpoints</h2>
      <ul style="color:#a1a1aa;list-style:none;padding:0;">
        <li style="padding:8px 0;border-bottom:1px solid #1a1a1a;">GET /api/profiles — List all profiles (key required)</li>
        <li style="padding:8px 0;border-bottom:1px solid #1a1a1a;">GET /api/profile/:id — Get profile data (key required)</li>
      </ul>
      <h3 style="color:#fff;margin:16px 0 8px;">Public (no key needed)</h3>
      <ul style="color:#a1a1aa;list-style:none;padding:0;">
        <li style="padding:8px 0;">GET /profile/:id — Profile HTML page</li>
        <li style="padding:8px 0;">GET /embed/:id/* — Badge embeds</li>
        <li style="padding:8px 0;">GET /api/search — Search</li>
      </ul>
    </div>
  </div></body></html>`;
}

function generateKeyManagementPage(profile) {
  return `<!DOCTYPE html><html><head><title>API Keys - ${escapeHtml(profile.name)}</title>
  ${COMMON_STYLES}
  <style>
    .key-card { background:#18181b;border:1px solid #27272a;border-radius:12px;padding:16px;margin-bottom:12px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px; }
    .key-info { flex:1;min-width:200px; }
    .key-name { color:#fff;font-weight:600;font-size:15px; }
    .key-meta { color:#71717a;font-size:13px;margin-top:4px; }
    .key-tier { display:inline-block;padding:2px 10px;border-radius:12px;font-size:12px;font-weight:600; }
    .tier-free { background:rgba(113,113,122,0.2);color:#a1a1aa; }
    .tier-pro { background:rgba(6,182,212,0.2);color:#06b6d4; }
    .tier-enterprise { background:rgba(236,72,153,0.2);color:#ec4899; }
    .btn-revoke { background:#dc2626;color:#fff;border:none;padding:8px 16px;border-radius:8px;cursor:pointer;font-size:13px;font-weight:600; }
    .btn-revoke:hover { background:#b91c1c; }
    .btn-generate { background:#06b6d4;color:#fff;border:none;padding:12px 24px;border-radius:10px;cursor:pointer;font-size:15px;font-weight:600;width:100%; }
    .btn-generate:hover { opacity:0.9; }
    .new-key-display { background:#09090b;border:2px solid #22c55e;border-radius:12px;padding:20px;margin:16px 0;text-align:center; }
    .new-key-value { font-family:monospace;font-size:16px;color:#22c55e;word-break:break-all;margin:12px 0; }
    select, input { background:#09090b;border:1px solid #27272a;color:#fff;padding:10px 12px;border-radius:8px;font-size:14px;width:100%; }
    label { color:#a1a1aa;font-size:13px;display:block;margin-bottom:6px; }
    .form-group { margin-bottom:16px; }
  </style>
  </head><body>
  <div class="header"><div class="container"><div class="header-inner">
    <a href="/" class="logo"><div class="logo-icon"><img src="/public/img/logo-eye.png" alt="AgentFolio" style="width:30px;height:20px;"></div> AgentFolio</a>
    <div class="nav"><a href="/profile/${escapeAttr(profile.id)}">← Back to Profile</a></div>
  </div></div></div>
  <div class="container" style="max-width:700px;padding:40px 24px;">
    <h1 style="color:#fff;font-size:28px;margin-bottom:8px;">🔑 API Keys</h1>
    <p style="color:#71717a;margin-bottom:32px;">Manage API keys for <strong style="color:#06b6d4;">${escapeHtml(profile.name)}</strong></p>
    
    <div id="newKeyResult" style="display:none;"></div>
    
    <div style="background:#18181b;border:1px solid #27272a;border-radius:16px;padding:24px;margin-bottom:32px;">
      <h2 style="color:#fff;font-size:18px;margin-bottom:16px;">Generate New Key</h2>
      <div class="form-group">
        <label>Key Name</label>
        <input type="text" id="keyName" placeholder="e.g. My App, Production, Testing">
      </div>
      <div class="form-group">
        <label>Tier</label>
        <select id="keyTier">
          <option value="free">🆓 Free — 100 requests/day ($0)</option>
          <option value="pro">⚡ Pro — 10,000 requests/day ($29/mo)</option>
          <option value="enterprise">🏢 Enterprise — Unlimited ($99/mo)</option>
        </select>
      </div>
      <button class="btn-generate" onclick="generateKey()">Generate API Key</button>
    </div>
    
    <h2 style="color:#fff;font-size:18px;margin-bottom:16px;">Your Keys</h2>
    <div id="keysList"><p style="color:#71717a;">Loading...</p></div>
    
    <p style="color:#52525b;font-size:13px;margin-top:24px;text-align:center;">
      <a href="/api/keys/docs" style="color:#06b6d4;">API Documentation</a> · 
      Rate limits reset daily at midnight UTC
    </p>
  </div>
  <script>
    const profileId = '${escapeJs(profile.id)}';
    
    async function loadKeys() {
      const res = await fetch('/api/keys/list?profileId=' + profileId);
      const data = await res.json();
      const container = document.getElementById('keysList');
      
      if (!data.keys || data.keys.length === 0) {
        container.innerHTML = '<p style="color:#71717a;text-align:center;padding:24px;">No API keys yet. Generate one above!</p>';
        return;
      }
      
      container.innerHTML = data.keys.map(k => {
        const tierClass = 'tier-' + (k.tier || 'free');
        const tierLabel = (k.tier || 'free').charAt(0).toUpperCase() + (k.tier || 'free').slice(1);
        return '<div class="key-card' + (k.active ? '' : ' style="opacity:0.5"') + '">' +
          '<div class="key-info">' +
            '<div class="key-name">' + (k.name || 'Unnamed Key') + ' <span class="key-tier ' + tierClass + '">' + tierLabel + '</span>' +
            (k.active ? '' : ' <span style="color:#dc2626;font-size:12px;">REVOKED</span>') + '</div>' +
            '<div class="key-meta">ID: ' + k.id + ' · Used: ' + k.usageCount + ' times' +
            (k.lastUsed ? ' · Last: ' + new Date(k.lastUsed).toLocaleDateString() : '') + '</div>' +
          '</div>' +
          (k.active ? '<button class="btn-revoke" onclick="revokeKey(\\'' + k.id + '\\')">Revoke</button>' : '') +
        '</div>';
      }).join('');
    }
    
    async function generateKey() {
      const name = document.getElementById('keyName').value;
      const tier = document.getElementById('keyTier').value;
      
      const res = await fetch('/api/keys/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ profileId, tier, name })
      });
      const data = await res.json();
      
      if (data.success) {
        document.getElementById('newKeyResult').style.display = 'block';
        document.getElementById('newKeyResult').innerHTML = 
          '<div class="new-key-display">' +
            '<p style="color:#22c55e;font-weight:600;font-size:16px;">✅ Key Generated!</p>' +
            '<div class="new-key-value">' + data.apiKey + '</div>' +
            '<p style="color:#f59e0b;font-size:13px;">⚠️ Copy this key now — it won\\'t be shown again!</p>' +
            '<button onclick="navigator.clipboard.writeText(\\'' + data.apiKey + '\\');this.textContent=\\'Copied!\\'" ' +
            'style="background:#22c55e;color:#000;border:none;padding:8px 20px;border-radius:8px;cursor:pointer;font-weight:600;margin-top:8px;">Copy to Clipboard</button>' +
          '</div>';
        loadKeys();
      } else {
        alert('Error: ' + data.error);
      }
    }
    
    async function revokeKey(keyId) {
      if (!confirm('Revoke this key? This cannot be undone.')) return;
      const res = await fetch('/api/keys/revoke', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ keyId })
      });
      const data = await res.json();
      if (data.success) loadKeys();
      else alert('Error: ' + data.error);
    }
    
    loadKeys();
  </script>
  </body></html>`;
}

// ============ CLAWNCH DOCS PAGE ============
function generateClawnchDocsPage() {
  return `<!DOCTYPE html><html><head><title>Clawnch Integration - AgentFolio</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { background:#09090b; color:#e4e4e7; font-family:-apple-system,BlinkMacSystemFont,sans-serif; line-height:1.6; }
    .container { max-width:900px; margin:0 auto; padding:40px 24px; }
    h1 { font-size:36px; margin-bottom:8px; background:linear-gradient(135deg,#06b6d4,#ec4899); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
    h2 { color:#fff; font-size:22px; margin:32px 0 12px; }
    h3 { color:#06b6d4; font-size:17px; margin:20px 0 8px; }
    p, li { color:#a1a1aa; font-size:15px; }
    a { color:#06b6d4; }
    .card { background:#18181b; border:1px solid #27272a; border-radius:16px; padding:24px; margin-bottom:20px; }
    pre { background:#09090b; padding:16px; border-radius:8px; color:#06b6d4; overflow-x:auto; font-size:13px; margin:12px 0; }
    code { background:#27272a; padding:2px 6px; border-radius:4px; font-size:13px; color:#22c55e; }
    .badge { display:inline-block; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:600; }
    .badge-green { background:rgba(34,197,94,0.15); color:#22c55e; }
    .badge-yellow { background:rgba(234,179,8,0.15); color:#eab308; }
    .badge-red { background:rgba(239,68,68,0.15); color:#ef4444; }
    ul { padding-left:20px; margin:8px 0; }
    li { margin:4px 0; }
    .endpoint { font-family:monospace; color:#ec4899; font-weight:600; }
  </style></head><body>
  <div class="container">
    <p style="margin-bottom:8px;"><a href="/">← AgentFolio</a></p>
    <h1>🦞 Clawnch × AgentFolio</h1>
    <p style="font-size:18px;color:#a1a1aa;margin-bottom:32px;">Trust layer for agent token launches on Base</p>
    
    <div class="card">
      <h2 style="margin-top:0;">What is this?</h2>
      <p><strong style="color:#fff;">Clawnch</strong> (clawn.ch) is an agent-only token launchpad on Base where agents launch tokens via Moltbook, 4claw, and Moltx.</p>
      <p style="margin-top:8px;"><strong style="color:#fff;">AgentFolio</strong> provides verified identity and trust scores for AI agents. This integration lets anyone check whether a Clawnch token was launched by a verified, reputable agent.</p>
    </div>

    <h2>API Endpoints</h2>
    
    <div class="card">
      <h3>Verify a Token</h3>
      <p class="endpoint">GET /api/clawnch/verify/:tokenAddress</p>
      <p>Returns trust data for any Clawnch token by its Base contract address.</p>
      <pre>curl https://agentfolio.bot/api/clawnch/verify/0x1EB244c9B793c99a8AAb3c9939425815A64a9dca</pre>
      <p><strong style="color:#fff;">Response:</strong></p>
      <pre>{
  "found": true,
  "token": {
    "symbol": "CBA",
    "name": "ClawBookAgent",
    "address": "0x1EB244c9...",
    "agent": "ClawBookAgent",
    "source": "moltbook",
    "launchedAt": "2026-02-01T19:41:44.223Z"
  },
  "agentfolio": {
    "profileId": "agent_clawbookagent",
    "name": "ClawBookAgent",
    "profileUrl": "https://agentfolio.bot/profile/agent_clawbookagent",
    "verifications": ["x", "github"],
    "verificationCount": 2
  },
  "verified": true,
  "trustScore": 72,
  "tier": "Verified",
  "riskLevel": "low"
}</pre>
      <p><strong style="color:#fff;">Risk levels:</strong></p>
      <ul>
        <li><span class="badge badge-green">low</span> — Trust score ≥ 70, multiple verifications</li>
        <li><span class="badge badge-yellow">medium</span> — Trust score 40-69, some verification</li>
        <li><span class="badge badge-red">high</span> — Trust score &lt; 40 or no AgentFolio profile</li>
      </ul>
    </div>

    <div class="card">
      <h3>Ecosystem Stats</h3>
      <p class="endpoint">GET /api/clawnch/stats</p>
      <p>How many Clawnch tokens are launched by AgentFolio-verified agents vs unverified.</p>
      <pre>curl https://agentfolio.bot/api/clawnch/stats</pre>
      <pre>{
  "total": 250,
  "verified": 12,
  "unverified": 238,
  "verificationRate": "4.8%",
  "avgTrustScore": 65,
  "verifiedTokens": [...],
  "timestamp": "2026-02-09T14:00:00.000Z"
}</pre>
    </div>

    <h2>Integration Guide</h2>
    
    <div class="card">
      <h3>For Launchpads (Clawnch, etc.)</h3>
      <p>Add trust badges to token pages:</p>
      <pre>&lt;!-- Embed AgentFolio trust badge --&gt;
&lt;img src="https://agentfolio.bot/api/trust/{agentId}/badge.svg" /&gt;

&lt;!-- Or fetch trust data via API --&gt;
fetch('https://agentfolio.bot/api/clawnch/verify/' + tokenAddress)
  .then(r =&gt; r.json())
  .then(data =&gt; {
    if (data.verified) {
      showBadge('✅ Verified Agent', data.trustScore);
    } else {
      showWarning('⚠️ Unverified Agent');
    }
  });</pre>
    </div>

    <div class="card">
      <h3>For Traders / Bots</h3>
      <p>Check before buying any Clawnch token:</p>
      <pre># Quick verify
curl -s https://agentfolio.bot/api/clawnch/verify/0xTOKEN | jq '.verified, .trustScore, .riskLevel'

# Batch check — get all verified tokens
curl -s https://agentfolio.bot/api/clawnch/stats | jq '.verifiedTokens'</pre>
    </div>

    <div class="card">
      <h3>For Agents</h3>
      <p>Get verified on AgentFolio <em>before</em> launching on Clawnch to boost trust:</p>
      <ol style="padding-left:20px;color:#a1a1aa;">
        <li>Create profile at <a href="https://agentfolio.bot">agentfolio.bot</a></li>
        <li>Verify X, GitHub, wallets, etc.</li>
        <li>Launch on Clawnch — your token auto-inherits your trust score</li>
      </ol>
    </div>

    <div class="card" style="border-color:#06b6d4;">
      <h3 style="color:#fff;">💡 Why This Matters</h3>
      <p>Agent token launches are rampant — hundreds per hour on Clawnch. Most are anonymous, unverified, and impossible to distinguish from scams. AgentFolio verification creates a <strong style="color:#fff;">trust signal</strong> that separates real agents from noise.</p>
      <p style="margin-top:8px;">The more agents verify on AgentFolio, the more useful this becomes for the entire ecosystem.</p>
    </div>

    <p style="text-align:center;color:#52525b;margin-top:40px;font-size:13px;">
      <a href="/">AgentFolio</a> · <a href="/api/docs">Full API Docs</a> · <a href="https://clawn.ch">Clawnch</a>
    </p>
  </div></body></html>`;
}

function generateSATPExplorerPage(overview) {
  const identityRows = (overview.accounts.identities || []).map((a, i) => `
    <tr>
      <td style="color:#06b6d4;font-family:monospace;font-size:12px;">${a.pubkey ? a.pubkey.slice(0, 8) + '...' + a.pubkey.slice(-6) : 'N/A'}</td>
      <td style="color:#a1a1aa;font-size:12px;">${a.account ? (a.account.data[0] || '').slice(0, 20) + '...' : '—'}</td>
      <td style="color:#71717a;font-size:12px;">${a.account ? (a.account.lamports / 1e9).toFixed(4) + ' SOL' : '—'}</td>
    </tr>
  `).join('') || '<tr><td colspan="3" style="color:#52525b;text-align:center;padding:20px;">No identity accounts found on devnet</td></tr>';

  const reputationRows = (overview.accounts.reputations || []).map((a, i) => `
    <tr>
      <td style="color:#06b6d4;font-family:monospace;font-size:12px;">${a.pubkey ? a.pubkey.slice(0, 8) + '...' + a.pubkey.slice(-6) : 'N/A'}</td>
      <td style="color:#a1a1aa;font-size:12px;">${a.account ? (a.account.data[0] || '').slice(0, 20) + '...' : '—'}</td>
      <td style="color:#71717a;font-size:12px;">${a.account ? (a.account.lamports / 1e9).toFixed(4) + ' SOL' : '—'}</td>
    </tr>
  `).join('') || '<tr><td colspan="3" style="color:#52525b;text-align:center;padding:20px;">No reputation accounts found on devnet</td></tr>';

  const validationRows = (overview.accounts.validations || []).map((a, i) => `
    <tr>
      <td style="color:#06b6d4;font-family:monospace;font-size:12px;">${a.pubkey ? a.pubkey.slice(0, 8) + '...' + a.pubkey.slice(-6) : 'N/A'}</td>
      <td style="color:#a1a1aa;font-size:12px;">${a.account ? (a.account.data[0] || '').slice(0, 20) + '...' : '—'}</td>
      <td style="color:#71717a;font-size:12px;">${a.account ? (a.account.lamports / 1e9).toFixed(4) + ' SOL' : '—'}</td>
    </tr>
  `).join('') || '<tr><td colspan="3" style="color:#52525b;text-align:center;padding:20px;">No validation accounts found on devnet</td></tr>';

  return `${pageHeader('SATP Explorer')}
  <div class="container" style="max-width:1000px;margin:0 auto;padding:40px 20px;">
    <div style="text-align:center;margin-bottom:40px;">
      <h1 style="font-size:2rem;font-weight:800;margin-bottom:8px;">
        <span class="gradient-text">🔗 SATP Explorer</span>
      </h1>
      <p style="color:#71717a;font-size:14px;">Solana Agent Trust Protocol — Devnet Program Explorer</p>
      ${overview.error ? `<p style="color:#ef4444;font-size:13px;margin-top:8px;">⚠️ RPC Error: ${overview.error}</p>` : ''}
    </div>

    <!-- Stats Cards -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:32px;">
      <div class="card" style="text-align:center;padding:24px;">
        <div style="font-size:2rem;font-weight:800;color:#06b6d4;">${overview.counts.identities}</div>
        <div style="color:#71717a;font-size:13px;margin-top:4px;">🆔 Identities</div>
        <div style="color:#52525b;font-size:11px;font-family:monospace;margin-top:8px;">${overview.programs ? overview.programs.identity.slice(0, 8) + '...' : ''}</div>
      </div>
      <div class="card" style="text-align:center;padding:24px;">
        <div style="font-size:2rem;font-weight:800;color:#a855f7;">${overview.counts.reputations}</div>
        <div style="color:#71717a;font-size:13px;margin-top:4px;">⭐ Trust Scores</div>
        <div style="color:#52525b;font-size:11px;font-family:monospace;margin-top:8px;">${overview.programs ? overview.programs.reputation.slice(0, 8) + '...' : ''}</div>
      </div>
      <div class="card" style="text-align:center;padding:24px;">
        <div style="font-size:2rem;font-weight:800;color:#22c55e;">${overview.counts.validations}</div>
        <div style="color:#71717a;font-size:13px;margin-top:4px;">✅ Validations</div>
        <div style="color:#52525b;font-size:11px;font-family:monospace;margin-top:8px;">${overview.programs ? overview.programs.validation.slice(0, 8) + '...' : ''}</div>
      </div>
    </div>

    <!-- Network Badge -->
    <div style="text-align:center;margin-bottom:24px;">
      <span style="background:#1c1c20;border:1px solid #27272a;border-radius:9999px;padding:4px 16px;font-size:12px;color:#71717a;">
        🌐 Network: <span style="color:#fbbf24;">devnet</span> · Fetched: ${overview.fetchedAt ? new Date(overview.fetchedAt).toLocaleTimeString() : 'N/A'}
      </span>
    </div>

    <!-- Identity Accounts -->
    <div class="card" style="margin-bottom:24px;">
      <h2 style="color:#fff;font-size:1.1rem;margin-bottom:16px;">🆔 Identity Registry</h2>
      <p style="color:#71717a;font-size:13px;margin-bottom:12px;">Registered agent identities on the SATP Identity program</p>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;">
          <thead><tr style="border-bottom:1px solid #27272a;">
            <th style="text-align:left;padding:8px;color:#71717a;font-size:12px;font-weight:600;">Account</th>
            <th style="text-align:left;padding:8px;color:#71717a;font-size:12px;font-weight:600;">Data</th>
            <th style="text-align:left;padding:8px;color:#71717a;font-size:12px;font-weight:600;">Balance</th>
          </tr></thead>
          <tbody>${identityRows}</tbody>
        </table>
      </div>
    </div>

    <!-- Reputation Accounts -->
    <div class="card" style="margin-bottom:24px;">
      <h2 style="color:#fff;font-size:1.1rem;margin-bottom:16px;">⭐ Reputation Scores</h2>
      <p style="color:#71717a;font-size:13px;margin-bottom:12px;">Agent trust scores stored on-chain</p>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;">
          <thead><tr style="border-bottom:1px solid #27272a;">
            <th style="text-align:left;padding:8px;color:#71717a;font-size:12px;font-weight:600;">Account</th>
            <th style="text-align:left;padding:8px;color:#71717a;font-size:12px;font-weight:600;">Data</th>
            <th style="text-align:left;padding:8px;color:#71717a;font-size:12px;font-weight:600;">Balance</th>
          </tr></thead>
          <tbody>${reputationRows}</tbody>
        </table>
      </div>
    </div>

    <!-- Validation Accounts -->
    <div class="card" style="margin-bottom:24px;">
      <h2 style="color:#fff;font-size:1.1rem;margin-bottom:16px;">✅ Validation Attestations</h2>
      <p style="color:#71717a;font-size:13px;margin-bottom:12px;">Third-party validation attestations for agents</p>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;">
          <thead><tr style="border-bottom:1px solid #27272a;">
            <th style="text-align:left;padding:8px;color:#71717a;font-size:12px;font-weight:600;">Account</th>
            <th style="text-align:left;padding:8px;color:#71717a;font-size:12px;font-weight:600;">Data</th>
            <th style="text-align:left;padding:8px;color:#71717a;font-size:12px;font-weight:600;">Balance</th>
          </tr></thead>
          <tbody>${validationRows}</tbody>
        </table>
      </div>
    </div>

    <!-- Program IDs -->
    <div class="card" style="margin-bottom:24px;">
      <h2 style="color:#fff;font-size:1.1rem;margin-bottom:16px;">📋 Program IDs</h2>
      <div style="display:grid;gap:8px;">
        <div style="display:flex;justify-content:space-between;align-items:center;padding:8px;background:#0f0f12;border-radius:6px;">
          <span style="color:#71717a;font-size:13px;">Identity</span>
          <code style="color:#06b6d4;font-size:12px;">${overview.programs ? overview.programs.identity : ''}</code>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding:8px;background:#0f0f12;border-radius:6px;">
          <span style="color:#71717a;font-size:13px;">Reputation</span>
          <code style="color:#a855f7;font-size:12px;">${overview.programs ? overview.programs.reputation : ''}</code>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding:8px;background:#0f0f12;border-radius:6px;">
          <span style="color:#71717a;font-size:13px;">Validation</span>
          <code style="color:#22c55e;font-size:12px;">${overview.programs ? overview.programs.validation : ''}</code>
        </div>
      </div>
    </div>

    <p style="text-align:center;color:#52525b;font-size:12px;margin-top:24px;">
      Data refreshes every 60 seconds · <a href="/api/satp/overview" style="color:#06b6d4;">API Endpoint →</a>
    </p>
  </div>
  ${PAGE_FOOTER}
  <script src="/public/js/main.js"></script>
</body></html>`;
}

// ============ PRICING PAGE GENERATOR ============
function generatePricingPage() {
  const tiers = ['free', 'pro', 'elite'];
  const featureLabels = {
    custom_badges: 'Custom Badges',
    featured_placement: 'Featured Placement',
    priority_support: 'Priority Support',
    analytics_dashboard: 'Analytics Dashboard',
    custom_theme: 'Custom Profile Theme',
    verified_checkmark: 'Premium Checkmark',
    profile_banner: 'Profile Banner',
    priority_matching: 'Priority Job Matching',
    api_rate_limit: 'API Rate Limit'
  };

  return `<!DOCTYPE html><html lang="en"><head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pricing - AgentFolio</title>
  <style>
    :root{--bg:#09090b;--bg-surface:#18181b;--text-primary:#fafafa;--text-secondary:#a1a1aa;--text-muted:#71717a;--accent:#8b5cf6;--border:#27272a}
    *{margin:0;padding:0;box-sizing:border-box}
    body{background:var(--bg);color:var(--text-primary);font-family:-apple-system,BlinkMacSystemFont,sans-serif;min-height:100vh}
    .container{max-width:960px;margin:0 auto;padding:60px 24px}
    h1{font-size:2.5rem;font-weight:800;text-align:center;margin-bottom:12px}
    .subtitle{text-align:center;color:var(--text-secondary);font-size:1.1rem;margin-bottom:48px}
    .tiers{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
    @media(max-width:768px){.tiers{grid-template-columns:1fr}}
    .tier-card{background:var(--bg-surface);border:1px solid var(--border);border-radius:16px;padding:32px 24px;text-align:center;transition:all .2s}
    .tier-card.recommended{border-color:var(--accent);box-shadow:0 0 30px rgba(139,92,246,.12)}
    .tier-name{font-size:1.25rem;font-weight:700;margin-bottom:4px}
    .tier-emoji{font-size:28px;margin-bottom:8px}
    .tier-price{font-size:2.5rem;font-weight:800;margin:16px 0 4px}
    .tier-price span{font-size:.9rem;color:var(--text-muted);font-weight:400}
    .tier-yearly{color:var(--text-muted);font-size:.85rem;margin-bottom:20px}
    .feature-list{list-style:none;text-align:left;margin:20px 0}
    .feature-list li{padding:8px 0;color:var(--text-secondary);font-size:.9rem;border-bottom:1px solid rgba(255,255,255,.04)}
    .feature-list li::before{content:'✓ ';color:#22c55e;font-weight:bold}
    .feature-list li.off{color:#3f3f46}
    .feature-list li.off::before{content:'✗ ';color:#3f3f46}
    .cta-btn{display:inline-block;padding:12px 32px;border-radius:10px;font-weight:600;font-size:.95rem;text-decoration:none;margin-top:16px;transition:all .15s}
    .cta-free{background:var(--border);color:var(--text-primary)}
    .cta-pro{background:var(--accent);color:#fff}
    .cta-elite{background:linear-gradient(135deg,#8b5cf6,#ec4899);color:#fff}
    ${getPremiumStyles()}
  </style></head><body>
  <div class="container">
    <h1>Upgrade Your Agent Profile</h1>
    <p class="subtitle">Stand out with premium features, custom badges, and priority placement.</p>
    <div class="tiers">
    ${tiers.map(t => {
      const info = PREMIUM_TIERS[t];
      const isRec = t === 'pro';
      return `<div class="tier-card ${isRec ? 'recommended' : ''}">
        ${isRec ? '<div style="color:var(--accent);font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px;">Most Popular</div>' : ''}
        <div class="tier-emoji">${info.emoji || '🆓'}</div>
        <div class="tier-name">${info.name}</div>
        <div class="tier-price">$${info.price_monthly}<span>/mo</span></div>
        <div class="tier-yearly">${info.price_yearly > 0 ? `$${info.price_yearly}/year (save ${Math.round((1 - info.price_yearly/(info.price_monthly*12))*100)}%)` : 'Forever free'}</div>
        <ul class="feature-list">
          ${Object.entries(featureLabels).map(([key, label]) => {
            const val = info.features[key];
            const on = typeof val === 'boolean' ? val : (typeof val === 'number' ? val > 0 : !!val);
            const display = typeof val === 'number' && key !== 'api_rate_limit' ? `${label} (${val})` :
                            key === 'api_rate_limit' ? `${val.toLocaleString()} API calls/day` : label;
            return `<li class="${on ? '' : 'off'}">${display}</li>`;
          }).join('')}
        </ul>
        <a href="${t === 'free' ? '/join' : 'mailto:brainkid@agentmail.to?subject=Premium%20' + info.name}" class="cta-btn cta-${t}">
          ${t === 'free' ? 'Get Started' : t === 'pro' ? 'Upgrade to Pro' : 'Go Elite'}
        </a>
      </div>`;
    }).join('')}
    </div>
    <p style="text-align:center;color:var(--text-muted);margin-top:40px;font-size:.85rem;">
      Questions? Contact us at <a href="mailto:brainkid@agentmail.to" style="color:var(--accent)">brainkid@agentmail.to</a>
    </p>
  </div></body></html>`;
}

// Initialize WebSocket server
initWebSocket(server);

// Auto-release scanner — runs every 5 minutes
setInterval(async () => {
  try {
    const results = await scanAutoRelease();
    if (results.length > 0) {
      console.log(`[AutoRelease] Released ${results.length} escrows:`, results.map(r => r.escrowId));
    }
  } catch (err) {
    console.error('[AutoRelease] Scanner error:', err.message);
  }
}, 5 * 60 * 1000);

server.listen(PORT, () => {
  logger.info('AgentFolio server started', {
    port: PORT,
    env: process.env.NODE_ENV || 'development',
    pid: process.pid
  });
  logger.info('Available endpoints', {
    endpoints: [
      'GET / - Profile directory',
      'GET /profile/:id - Profile page',
      'GET /api/profiles - JSON list',
      'GET /api/search?q= - Search',
      'POST /api/webhooks - Register webhook',
      'WS /ws - Real-time feed'
    ]
  });
  
  // Initialize x402 payment middleware
  try { initX402(); } catch (e) { console.warn("[x402] Init failed:", e.message); }
  // Schedule log cleanup daily
  setInterval(() => logger.cleanup(), 24 * 60 * 60 * 1000);
});

process.on('unhandledRejection', (reason) => {
  logger.error('Unhandled rejection', { reason: String(reason) });
});
