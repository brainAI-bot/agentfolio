app.get('/api/jobs/:id/applications', (req, res) => {
  const jobId = req.params.id;
  const fs = require('fs');
  const path = require('path');
  const jobPath = path.join(__dirname, '..', 'data', 'marketplace', 'jobs', jobId + '.json');
  if (!fs.existsSync(jobPath)) return res.status(404).json({ error: 'Job not found' });
  const appDir = path.join(__dirname, '..', 'data', 'marketplace', 'applications');
  let apps = [];
  try {
    // Check for old-format array file (job_xxx.json in applications dir)
    const legacyFile = path.join(appDir, jobId + '.json');
    if (fs.existsSync(legacyFile)) {
      const legacy = JSON.parse(fs.readFileSync(legacyFile, 'utf8'));
      if (Array.isArray(legacy)) apps = legacy;
    }
    // Scan individual app files (new format)
    for (const f of fs.readdirSync(appDir)) {
      if (!f.startsWith('app_') || !f.endsWith('.json')) continue;
      try {
        const app = JSON.parse(fs.readFileSync(path.join(appDir, f), 'utf8'));
        if (app.jobId === jobId) apps.push(app);
      } catch(e) {}
    }
  } catch(e) {}
  res.json({ jobId, total: apps.length, applications: apps });
});

