// Basic API routes
app.get('/api/profiles', (req, res) => {
  try {
    const Database = require('better-sqlite3');
    const pathMod = require('path');
    const { calculateLevel, calculateReputation } = require('./sprint3-scoring');
    const db = new Database(pathMod.join(__dirname, '..', 'data', 'agentfolio.db'), { readonly: true });
    const page = parseInt(req.query.page) || 1;
    const limit = Math.min(parseInt(req.query.limit) || 20, 100);
    const offset = (page - 1) * limit;
    const total = db.prepare('SELECT COUNT(*) as c FROM profiles').get().c;
    const profiles = db.prepare('SELECT * FROM profiles ORDER BY created_at DESC LIMIT ? OFFSET ?').all(limit, offset);
    const LEVEL_NAMES = ['Unregistered','Registered','Verified','On-Chain','Trusted','Sovereign'];
    const enriched = profiles.map(p => {
      const level = calculateLevel(p, db);
      const rep = calculateReputation(p, db);
      const repScore = typeof rep === 'number' ? rep : (rep?.score || 0);
      return {
        id: p.id, name: p.name, handle: p.handle, bio: p.bio, avatar: p.avatar,
        skills: JSON.parse(p.skills || '[]'),
        verification: p.verification,
        created_at: p.created_at,
        level, levelName: LEVEL_NAMES[level] || 'Unknown',
        reputationScore: repScore,
        reputationRank: repScore >= 800 ? 'Elite' : repScore >= 600 ? 'Expert' : repScore >= 400 ? 'Skilled' : repScore >= 200 ? 'Competent' : repScore >= 100 ? 'Developing' : 'Newcomer'
      };
    });
    db.close();
    res.json({ profiles: enriched, total, page });
  } catch(e) { console.error('Profile scoring error:', e); res.status(500).json({ error: e.message }); }
});

// Individual profile endpoint
app.get('/api/profile/:id', async (req, res) => {
  const { getCompleteScore } = require("./lib/scoring-engine-v2");
  const profileId = req.params.id;
  try {
    const Database = require('better-sqlite3');
    const path = require('path');
    const db = new Database(path.join(__dirname, '..', 'data', 'agentfolio.db'), { readonly: true });
    const row = db.prepare('SELECT * FROM profiles WHERE id = ?').get(profileId);
    db.close();
    if (!row) return res.status(404).json({ error: 'Profile not found', id: profileId });

    // Compute 2D scoring
    let verificationLevel = 0, verificationLevelName = 'Unregistered', reputationScore = 0, reputationRank = 'Newcomer';
    try {
      const profileObj = {
        id: row.id, name: row.name, handle: row.handle, bio: row.bio, avatar: row.avatar,
        skills: JSON.parse(row.skills || '[]'),
        verification: JSON.parse(row.verification || '{}'),
        endorsements: JSON.parse(row.endorsements || '[]'),
        portfolio: JSON.parse(row.portfolio || '[]'),
        track_record: JSON.parse(row.track_record || '{}'),
      };
      // Also load JSON profile for verificationData
      try {
        const pPath = require('path').join(__dirname, '..', 'data', 'profiles', row.id + '.json');
        if (fs.existsSync(pPath)) {
          const pf = JSON.parse(fs.readFileSync(pPath, 'utf8'));
          profileObj.verificationData = pf.verificationData || {};
          profileObj.moltbookStats = pf.moltbookStats || {};
        }
      } catch {}
      const scoreResult = getCompleteScore(profileObj);
      verificationLevel = scoreResult.verificationLevel?.level || 0;
      verificationLevelName = scoreResult.verificationLevel?.name || 'Unregistered';
      reputationScore = scoreResult.reputationScore?.score || 0;
      reputationRank = scoreResult.reputationScore?.rank || 'Newcomer';
    } catch (scoreErr) { console.error('[PROFILE API] Scoring error:', scoreErr.message); }


    // Compute jobsCompleted from marketplace data
    let jobsCompleted = 0;
    try {
      const jobsDir = require('path').join(__dirname, '..', 'data', 'marketplace', 'jobs');
      if (fs.existsSync(jobsDir)) {
        fs.readdirSync(jobsDir).filter(f => f.endsWith('.json')).forEach(f => {
          try {
            const job = JSON.parse(fs.readFileSync(require('path').join(jobsDir, f), 'utf-8'));
            if (job.status === 'completed' && job.acceptedApplicant === profileId) jobsCompleted++;
          } catch {}
        });
      }
    } catch {}
    // Compute rating from reviews
    let avgRating = 0;
    let reviewsCount = 0;
    try {
      const rDb = new Database(require('path').join(__dirname, '..', 'data', 'agentfolio.db'), { readonly: true });
      const revs = rDb.prepare('SELECT rating FROM reviews WHERE reviewee_id = ?').all(profileId);
      rDb.close();
      reviewsCount = revs.length;
      if (reviewsCount > 0) avgRating = revs.reduce((s, r) => s + r.rating, 0) / reviewsCount;
    } catch {}


    // Fetch SATP on-chain data if wallet exists (cached 5min)
    let satpOnChain = null;
    try {
      const wallets = JSON.parse(row.wallets || '{}');
      let solWallet = wallets.solana || (JSON.parse(row.verification || '{}').solana || {}).address;
      if (!solWallet) {
        try {
          const profilePath = require('path').join(__dirname, '..', 'data', 'profiles', row.id + '.json');
          if (fs.existsSync(profilePath)) {
            const pf = JSON.parse(fs.readFileSync(profilePath, 'utf8'));
            solWallet = pf.wallets?.solana || (pf.verificationData?.solana || {}).address;
          }
        } catch {}
      }
      if (solWallet) {
        const satpIdentity = require('./satp-identity-client');
        // Cache SATP registry for 5 minutes to avoid RPC spam
        if (!global._satpRegistryCache || Date.now() - global._satpRegistryCacheTime > 300000) {
          global._satpRegistryCache = await satpIdentity.listRegisteredAgents().catch(() => ({ agents: [] }));
          global._satpRegistryCacheTime = Date.now();
        }
        const regResult = global._satpRegistryCache;
        const agentEntry = (regResult?.agents || []).find(a => a.authority === solWallet);
        if (agentEntry) {
          satpOnChain = {
            identity: { name: agentEntry.name, description: agentEntry.description, authority: agentEntry.authority, version: agentEntry.version },
            scores: { verificationLevel: agentEntry.verificationLevel, verificationLabel: agentEntry.verificationLabel, reputationScore: agentEntry.reputationScore, reputationRank: agentEntry.reputationRank },
            wallet: solWallet
          };
        }
      }
    } catch {}

    res.json({
      id: row.id,
      name: row.name,
      handle: row.handle,
      bio: row.bio,
      avatar: row.avatar,
      skills: JSON.parse(row.skills || '[]'),
      links: JSON.parse(row.links || '{}'),
      wallets: JSON.parse(row.wallets || '{}'),
      verification: JSON.parse(row.verification || '{}'),
      endorsements: JSON.parse(row.endorsements || '[]'),
      portfolio: JSON.parse(row.portfolio || '[]'),
      track_record: JSON.parse(row.track_record || '{}'),
      created_at: row.created_at,
      updated_at: row.updated_at,
      availability: row.availability,
      last_active_at: row.last_active_at,
      nftAvatar: row.nft_avatar ? JSON.parse(row.nft_avatar) : null,
      metadata: row.metadata ? JSON.parse(row.metadata) : {},
      jobsCompleted,
      rating: Math.round(avgRating * 10) / 10,
      reviews_count: reviewsCount,
      verificationLevel,
      verificationLevelName,
      reputationScore,
      reputationRank,
      satp: satpOnChain,
    });
  } catch(e) { console.error("[PROFILE API] Error:", e.message, e.stack?.split("\n")[1]); res.status(500).json({ error: e.message }); }
});

