      const conn = satpV3Leaderboard.connection;
      const accts = await conn.getMultipleAccountsInfo(pdas.map(p => p.pda));
      const v3Scores = [];
      for (let i = 0; i < pdas.length; i++) {
        if (accts[i] && accts[i].data) {
          const record = await satpV3Leaderboard.getGenesisRecord(pdas[i].agentId);
          if (record && !record.error) {
            v3Scores.push({ agentId: pdas[i].agentId, ...record });
          }
        }
      }
      v3Scores.sort((a, b) => b.reputationScore - a.reputationScore);
      const leaderboard = v3Scores.slice(0, limit).map((s, i) => ({
        rank: i + 1,
        agentId: s.agentId,
        agentName: s.agentName,
        reputationScore: s.reputationScore,
        reputationPct: s.reputationPct,
        verificationLevel: s.verificationLevel,
        verificationLabel: s.verificationLabel,
        isBorn: s.isBorn,
        source: 'v3-onchain',
      }));
      return res.json({ leaderboard, total: leaderboard.length, limit, source: 'v3-onchain', computedAt: new Date().toISOString(), payment: { protocol: 'x402', network: X402_NETWORK, price: '$0.05' } });
    } catch (e) {
      console.error('[Leaderboard] V3 failed, falling back:', e.message);
    }
  }
  // Fallback to old scoring
  const leaderboard = computeLeaderboard([], limit);
  res.json({ leaderboard, total: leaderboard.length, limit, source: 'scoring-v2', computedAt: new Date().toISOString(), payment: { protocol: 'x402', network: X402_NETWORK, price: '$0.05' } });
});

