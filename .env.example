# AgentMail
AGENTMAIL_API_KEY=your_agentmail_api_key_here
AGENTMAIL_INBOX=notifications@example.com

# App runtime
NODE_ENV=production
PORT=3000

# Solana RPC endpoints
# Use HELIUS_RPC_URL for Helius DAS calls used by burn-to-become wallet/asset lookups.
# SOLANA_RPC_URL must be a managed mainnet provider endpoint for SATP V3/escrow.
# Keep credentials in environment variables; do not hardcode API keys in source.
SOLANA_RPC_URL=
HELIUS_RPC_URL=
