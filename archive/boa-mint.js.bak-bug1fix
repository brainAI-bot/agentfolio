/**
 * BOA Mint API endpoint — server-side authority co-signing
 * 
 * POST /api/boa/mint
 * Body: { wallet: "<minter_pubkey>" }
 * Returns: { transaction: "<base64 serialized tx>", mint_number: N, price: 0|1000000000 }
 * 
 * The server checks eligibility from DB, builds the transaction, and co-signs
 * with the authority keypair. The minter's wallet must sign the returned transaction.
 */

const { Connection, PublicKey, Transaction, TransactionInstruction, SystemProgram, Keypair } = require('@solana/web3.js');
const crypto = require('crypto');
const fs = require('fs');
const path = require('path');
const Database = require('better-sqlite3');

const PROGRAM_ID = new PublicKey('4JUGpKNdhAbQPQc9EG1q25NyaJidziszMMQ4phtg5S4o');
const TREASURY = new PublicKey('FriU1FEpWbdgVrTcS49YV5mVv2oqN6poaVQjzq2BS5be');
const RPC_URL = process.env.SOLANA_RPC_URL || 'https://api.mainnet-beta.solana.com';

// Rate limiting: 1 mint per minute per IP
const mintRateLimit = new Map(); // ip -> timestamp

function getDb() {
  return new Database(path.join(__dirname, '..', '..', 'data', 'agentfolio.db'), { readonly: true });
}

function loadAuthorityKeypair() {
  const keypairPath = process.env.BOA_AUTHORITY_KEYPAIR || path.join(process.env.HOME, '.config/solana/mainnet-deployer.json');
  const secretKey = JSON.parse(fs.readFileSync(keypairPath, 'utf-8'));
  return Keypair.fromSecretKey(Uint8Array.from(secretKey));
}

// Anchor instruction discriminator: sha256("global:mint_nft")[0..8]
function getInstructionDiscriminator(name) {
  const hash = crypto.createHash('sha256').update(`global:${name}`).digest();
  return hash.slice(0, 8);
}

function findPDA(seeds, programId) {
  return PublicKey.findProgramAddressSync(seeds, programId);
}

function registerBoaMintRoutes(app) {
  const { getCompleteScore, calculateVerificationLevel, calculateReputationScore } = require('../lib/scoring-engine-v2');
  
  // POST /api/boa/mint — Build and authority-sign a mint transaction
  app.post('/api/boa/mint', async (req, res) => {
    const ip = req.headers['x-forwarded-for'] || req.socket.remoteAddress;
    
    // Rate limit
    const lastMint = mintRateLimit.get(ip);
    if (lastMint && Date.now() - lastMint < 60000) {
      return res.status(429).json({ error: 'Rate limited — 1 mint per minute. Try again later.' });
    }
    
    // DISABLED: Minting pipeline incomplete — no actual NFT created yet
    // ENABLED for walkthrough test — was: return res.status(503)
    const { wallet } = req.body;
    if (!wallet) return res.status(400).json({ error: 'Missing wallet address' });
    
    let minterPubkey;
    try {
      minterPubkey = new PublicKey(wallet);
    } catch {
      return res.status(400).json({ error: 'Invalid wallet address' });
    }
    
    try {
      // Check eligibility from DB
      const db = getDb();
      
      // Find profile linked to this wallet
      const profiles = db.prepare('SELECT * FROM profiles').all();
      let matchedProfile = null;
      for (const p of profiles) {
        try {
          const vd = JSON.parse(p.verification_data || '{}');
          if (vd.solana?.address === wallet && vd.solana?.verified) {
            matchedProfile = p;
            break;
          }
        } catch {}
      }
      
      if (!matchedProfile) {
        db.close();
        return res.status(403).json({ error: 'No verified AgentFolio profile linked to this wallet. Verify your Solana wallet on agentfolio.bot/verify first.' });
      }
      
      // Build profile object for scoring-engine-v2
      let profileObj = {
        id: matchedProfile.id, name: matchedProfile.name, handle: matchedProfile.handle,
        bio: matchedProfile.bio, avatar: matchedProfile.avatar,
        skills: JSON.parse(matchedProfile.skills || '[]'),
        verification: JSON.parse(matchedProfile.verification || '{}'),
        endorsements: JSON.parse(matchedProfile.endorsements || '[]'),
        portfolio: JSON.parse(matchedProfile.portfolio || '[]'),
        track_record: JSON.parse(matchedProfile.track_record || '{}'),
      };
      try {
        const pPath = require('path').join(__dirname, '..', '..', 'data', 'profiles', matchedProfile.id + '.json');
        if (require('fs').existsSync(pPath)) {
          const pf = JSON.parse(require('fs').readFileSync(pPath, 'utf8'));
          profileObj.verificationData = pf.verificationData || {};
            profileObj.stats = pf.stats || {};
            profileObj.endorsements = pf.endorsements || profileObj.endorsements || [];
          profileObj.moltbookStats = pf.moltbookStats || {};
        }
      } catch {}
      const level = calculateVerificationLevel(profileObj);
      const reputation = calculateReputationScore(profileObj);
      db.close();
      
      if (level < 3) {
        return res.status(403).json({ error: `Verification level ${level} insufficient. Need Level 3+.`, level, reputation });
      }
      if (reputation < 50) {
        return res.status(403).json({ error: `Reputation ${reputation} insufficient. Need 50+.`, level, reputation });
      }
      
      // Build transaction
      const connection = new Connection(RPC_URL, 'confirmed');
      const authority = loadAuthorityKeypair();
      
      // PDAs
      const [collectionPda] = findPDA([Buffer.from('collection')], PROGRAM_ID);
      const [mintTrackerPda] = findPDA([Buffer.from('tracker'), minterPubkey.toBuffer()], PROGRAM_ID);
      
      // Check current collection state
      const collectionAcct = await connection.getAccountInfo(collectionPda);
      if (!collectionAcct) {
        return res.status(500).json({ error: 'Collection not initialized' });
      }
      const totalMinted = collectionAcct.data.readBigUInt64LE(40);
      const softCap = collectionAcct.data.readBigUInt64LE(80);
      
      if (softCap > 0n && totalMinted >= softCap) {
        return res.status(403).json({ error: 'Soft launch cap reached. Stay tuned for full launch!', totalMinted: Number(totalMinted), softCap: Number(softCap) });
      }
      
      // Check mint tracker
      let currentMints = 0;
      const trackerAcct = await connection.getAccountInfo(mintTrackerPda);
      if (trackerAcct && trackerAcct.data.length >= 42) {
        // 8 disc + 32 wallet + 1 mints + 1 initialized
        currentMints = trackerAcct.data[40]; // mints field
        const initialized = trackerAcct.data[41];
        if (initialized && currentMints >= 3) {
          return res.status(403).json({ error: 'Maximum 3 mints per wallet reached', mints: currentMints });
        }
      }
      
      const price = currentMints === 0 ? 0 : 1_000_000_000; // 1st free, 2nd-3rd = 1 SOL
      
      // Build the mint_nft instruction
      const discriminator = getInstructionDiscriminator('mint_nft');
      
      const keys = [
        { pubkey: collectionPda, isSigner: false, isWritable: true },
        { pubkey: mintTrackerPda, isSigner: false, isWritable: true },
        { pubkey: minterPubkey, isSigner: true, isWritable: true },
        { pubkey: authority.publicKey, isSigner: true, isWritable: false },
        { pubkey: TREASURY, isSigner: false, isWritable: true },
        { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },
      ];
      
      const instruction = new TransactionInstruction({
        keys,
        programId: PROGRAM_ID,
        data: discriminator, // no additional args needed
      });
      
      // Build transaction
      const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash('confirmed');
      const tx = new Transaction({
        blockhash,
        lastValidBlockHeight,
        feePayer: minterPubkey, // minter pays gas
      });
      tx.add(instruction);
      
      // Authority co-signs
      tx.partialSign(authority);
      
      // Serialize (minter still needs to sign)
      const serializedTx = tx.serialize({ requireAllSignatures: false }).toString('base64');
      
      // Update rate limit
      mintRateLimit.set(ip, Date.now());
      
      // Log the mint attempt
      console.log(`[BOA MINT] wallet=${wallet} agent=${matchedProfile.id} level=${level} rep=${reputation} price=${price} mint#=${Number(totalMinted)+1}`);
      
      res.json({
        transaction: serializedTx,
        mint_number: Number(totalMinted) + 1,
        price,
        price_sol: price / 1_000_000_000,
        agent: matchedProfile.id,
        level,
        reputation,
        current_mints: currentMints,
        soft_cap: Number(softCap),
        total_minted: Number(totalMinted),
      });
      
    } catch (e) {
      console.error('[BOA MINT ERROR]', e);
      res.status(500).json({ error: e.message });
    }
  });
  
  // GET /api/boa/status — Collection status (Metaplex pipeline)
  app.get('/api/boa/status', async (req, res) => {
    try {
      const pipelineDir = '/home/ubuntu/agentfolio/boa-pipeline';
      const assetsDir = process.env.HOME + '/boa-assets';
      
      // Load collection info
      const collectionFile = require('path').join(pipelineDir, 'collection-mainnet.json');
      let collection = {};
      try { collection = JSON.parse(fs.readFileSync(collectionFile, 'utf-8')); } catch {}
      
      // Count minted from mint-records
      const recordsDir = require('path').join(pipelineDir, 'mint-records');
      let totalMinted = 0;
      try { totalMinted = fs.readdirSync(recordsDir).filter(f => f.endsWith('.json')).length; } catch {}
      
      // Count available assets
      const metadataDir = require('path').join(assetsDir, 'metadata');
      let totalAssets = 0;
      try { totalAssets = fs.readdirSync(metadataDir).filter(f => f.endsWith('.json')).length; } catch {}
      
      res.json({
        initialized: true,
        pipeline: 'metaplex',
        collection_mint: collection.collectionMint || 'xNQmPj1Tcx3PyNNN1RLPeNkaMsZMRthAgWZ7Tbn6RHY',
        authority: collection.authority || 'Bq1niVKyTECn4HDxAJWiHZvRMCZndZtC113yj3Rkbroc',
        treasury: collection.treasury || 'FriU1FEpWbdgVrTcS49YV5mVv2oqN6poaVQjzq2BS5be',
        total_minted: totalMinted,
        total_assets: totalAssets,
        max_supply: 100,
        minting_enabled: totalMinted < 100,
      });
    } catch (e) {
      res.status(500).json({ error: e.message });
    }
  });
}

module.exports = { registerBoaMintRoutes };

// POST /api/boa/mint/complete — Called after payment TX confirms, creates the actual NFT
// Body: { wallet: "<minter_pubkey>", txSignature: "<payment_tx_sig>" }
function registerBoaMintCompleteRoute(app) {
  app.post('/api/boa/mint/complete', async (req, res) => {
    const { wallet, txSignature } = req.body;
    if (!wallet || !txSignature) {
      return res.status(400).json({ error: 'wallet and txSignature required' });
    }
    
    // Validate signature format (base58, 64-88 chars) before any RPC calls
    if (!/^[1-9A-HJ-NP-Za-km-z]{64,88}$/.test(txSignature)) {
      return res.status(400).json({ error: 'Invalid transaction signature format' });
    }
    
    try {
      console.log('[BOA MINT COMPLETE] Request received:', { wallet, txSignature, txSigLength: txSignature.length });
      const connection = new Connection(RPC_URL, 'confirmed');
      
      // Idempotency: verify cached mint exists on-chain before returning
      const boaRecordsDir = "/home/ubuntu/agentfolio/data/boa-mints";
      if (fs.existsSync(boaRecordsDir)) {
        const files = fs.readdirSync(boaRecordsDir).filter(f => f.endsWith('.json'));
        for (const file of files) {
          try {
            const rec = JSON.parse(fs.readFileSync(require('path').join(boaRecordsDir, file), 'utf-8'));
            if (rec.paymentTx === txSignature && rec.wallet === wallet && rec.mint) {
              const mintPk = new PublicKey(rec.mint);
              const mintAcct = await connection.getAccountInfo(mintPk);
              if (mintAcct && mintAcct.data.length > 0) {
                console.log(`[BOA MINT COMPLETE] Verified cached mint on-chain tx=${txSignature}`);
                return res.json({
                  success: true,
                  nft_number: parseInt(file.replace('.json', '')),
                  mint: rec.mint, name: rec.name,
                  metadata_uri: rec.metadataUri, image_uri: rec.imageUri,
                  collection: rec.collection, collection_verified: rec.collectionVerified,
                  traits: rec.traits, retried: true,
                });
              } else {
                console.log(`[BOA MINT COMPLETE] STALE cache tx=${txSignature}, mint ${rec.mint} not on-chain. Re-minting.`);
                fs.unlinkSync(require('path').join(boaRecordsDir, file));
              }
            }
          } catch (cacheErr) {
            console.log('[BOA MINT COMPLETE] Cache check error:', cacheErr.message);
          }
        }
      }
      
      // Verify TX is confirmed (retry-friendly: 404 means "try again later")
      let txInfo;
      try {
        txInfo = await connection.getTransaction(txSignature, { commitment: 'confirmed', maxSupportedTransactionVersion: 0 });
      } catch (txErr) {
        console.error('[BOA MINT COMPLETE] getTransaction error:', txErr.message);
        return res.status(400).json({ error: 'Invalid transaction signature', detail: txErr.message });
      }
      if (!txInfo) {
        return res.status(404).json({ error: 'Transaction not found or not confirmed yet. Try again in a few seconds.', retryable: true });
      }
      if (txInfo.meta?.err) {
        return res.status(400).json({ error: 'Transaction failed on-chain', txErr: txInfo.meta.err });
      }
      
      // Get current mint count from collection state
      const [collectionPda] = findPDA([Buffer.from('collection')], PROGRAM_ID);
      const acct = await connection.getAccountInfo(collectionPda);
      const totalMinted = Number(acct.data.readBigUInt64LE(40));
      
      // NFT number = totalMinted (the counter was already incremented by the on-chain program)
      const nftNumber = totalMinted;
      
      console.log(`[BOA MINT COMPLETE] wallet=${wallet} tx=${txSignature} nft=#${nftNumber}`);
      
      // Check if assets exist for this number
      // fs already at top level // const fs = require('fs');
      const assetsDir = '/home/ubuntu/boa-assets';
      const metadataPath = `${assetsDir}/metadata/${nftNumber}.json`;
      const imagePath = `${assetsDir}/images/${nftNumber}.jpg`;
      
      if (!fs.existsSync(metadataPath) || !fs.existsSync(imagePath)) {
        return res.status(500).json({ error: `Assets not found for NFT #${nftNumber}. Contact support.` });
      }
      
      // Mint the actual Metaplex NFT (ESM dynamic import)
      const { mintBoaNft } = await import('./boa-nft-minter.mjs');
      
      const CLUSTER = process.env.SOLANA_CLUSTER || 'mainnet';
      const collectionFile = CLUSTER === 'mainnet' 
        ? '/home/ubuntu/agentfolio/src/boa-collection-mainnet.json'
        : '/home/ubuntu/agentfolio/src/boa-collection-devnet.json';
      
      const collectionInfo = JSON.parse(fs.readFileSync(collectionFile, 'utf-8'));
      
      const result = await mintBoaNft({
        recipient: wallet,
        nftNumber,
        cluster: CLUSTER,
        deployerKeypath: process.env.HOME + '/.config/solana/mainnet-deployer.json',
        assetsDir,
        collectionMint: collectionInfo.collectionMint,
      });
      
      console.log(`[BOA MINT COMPLETE] NFT #${nftNumber} minted: ${result.mint}`);
      
      // Save mint record
      const mintRecordsDir = '/home/ubuntu/agentfolio/data/boa-mints';
      if (!fs.existsSync(mintRecordsDir)) fs.mkdirSync(mintRecordsDir, { recursive: true });
      fs.writeFileSync(`${mintRecordsDir}/${nftNumber}.json`, JSON.stringify({
        ...result,
        wallet,
        paymentTx: txSignature,
        mintedAt: new Date().toISOString(),
      }, null, 2));
      
      res.json({
        success: true,
        nft_number: nftNumber,
        mint: result.mint,
        name: result.name,
        metadata_uri: result.metadataUri,
        image_uri: result.imageUri,
        collection: result.collection,
        collection_verified: result.collectionVerified,
        traits: result.traits,
      });
      
    } catch (e) {
      console.error('[BOA MINT COMPLETE ERROR]', e);
      res.status(500).json({ error: e.message });
    }
  });
}

module.exports.registerBoaMintCompleteRoute = registerBoaMintCompleteRoute;
